<%
  layout = 'main';
  title = 'Inbox & Chat';
  subtitle = 'Exchange personal queries, guidance notes, and alerts with other academy members';
  page = 'inbox';
%>

<div class="inbox-container <%= selectedContact ? 'has-selection' : '' %>" id="inboxContainer">
  <!-- Contacts Panel (Left) -->
  <div class="inbox-contacts-panel">
    <div class="contacts-search-box">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" id="contactSearchInput" placeholder="Search contacts by name or role...">
    </div>
    <!-- Filter Tabs for Segregation -->
    <div class="contacts-filter-tabs" style="display: flex; gap: 4px; padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border); overflow-x: auto; background: rgba(0,0,0,0.15); scrollbar-width: none;">
      <button class="filter-tab active" data-filter="all" style="background: none; border: none; color: var(--text-muted); font-size: 0.75rem; padding: 4px 10px; border-radius: 4px; cursor: pointer; white-space: nowrap; transition: all 0.2s; font-weight: 600;">All</button>
      <button class="filter-tab" data-filter="unread" style="background: none; border: none; color: var(--text-muted); font-size: 0.75rem; padding: 4px 10px; border-radius: 4px; cursor: pointer; white-space: nowrap; transition: all 0.2s; font-weight: 600; display: flex; align-items: center; gap: 4px;">
        Unread
        <span class="tab-unread-dot" style="display: none; width: 6px; height: 6px; background: var(--error, #ef4444); border-radius: 50%;"></span>
      </button>
      <button class="filter-tab" data-filter="admin" style="background: none; border: none; color: var(--text-muted); font-size: 0.75rem; padding: 4px 10px; border-radius: 4px; cursor: pointer; white-space: nowrap; transition: all 0.2s; font-weight: 600;">Admins</button>
      <button class="filter-tab" data-filter="teacher" style="background: none; border: none; color: var(--text-muted); font-size: 0.75rem; padding: 4px 10px; border-radius: 4px; cursor: pointer; white-space: nowrap; transition: all 0.2s; font-weight: 600;">Teachers</button>
      <button class="filter-tab" data-filter="counsellor" style="background: none; border: none; color: var(--text-muted); font-size: 0.75rem; padding: 4px 10px; border-radius: 4px; cursor: pointer; white-space: nowrap; transition: all 0.2s; font-weight: 600;">Counsellors</button>
      <% if (user.role !== 'student') { %>
        <button class="filter-tab" data-filter="student" style="background: none; border: none; color: var(--text-muted); font-size: 0.75rem; padding: 4px 10px; border-radius: 4px; cursor: pointer; white-space: nowrap; transition: all 0.2s; font-weight: 600;">Students</button>
      <% } %>
    </div>
    <div class="contacts-list" id="contactsList">
      <% if (contacts.length === 0) { %>
        <div class="empty-contacts">
          <p>No contacts available.</p>
        </div>
      <% } else { %>
        <% contacts.forEach(c => { %>
          <% 
            const isSelected = selectedContact && selectedContact._id.toString() === c._id.toString(); 
            const unreadCount = unreadMap[c._id.toString()] || 0;
            const lastMsg = lastMessageMap[c._id.toString()];
            
            // Format time dynamically: e.g. "10:30 AM" or "Yesterday" or date
            let lastMsgTime = '';
            if (lastMsg) {
              const msgDate = new Date(lastMsg.createdAt);
              const today = new Date();
              if (msgDate.toDateString() === today.toDateString()) {
                lastMsgTime = msgDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
              } else {
                lastMsgTime = msgDate.toLocaleDateString([], { day: 'numeric', month: 'short' });
              }
            }

            let roleColor = 'var(--gold)';
            if (c.role === 'admin') roleColor = '#3b82f6';
            else if (c.role === 'teacher') roleColor = '#10b981';
            else if (c.role === 'counsellor') roleColor = '#f59e0b';
            else if (c.role === 'student') roleColor = '#8b5cf6';
          %>
          <a href="/auth/inbox?chat=<%= c._id %>" class="contact-item <%= isSelected ? 'active' : '' %>" data-name="<%= c.name.toLowerCase() %>" data-role="<%= c.role.toLowerCase() %>" data-unread="<%= unreadCount > 0 ? 'true' : 'false' %>">
            <div class="contact-avatar-wrapper">
              <% if (c.profilePic) { %>
                <img src="<%= c.profilePic %>" alt="<%= c.name %>" class="contact-avatar">
              <% } else { %>
                <%
                  const initials = c.name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
                %>
                <div class="contact-avatar-fallback" <%= `style="background-color: ${roleColor}15; color: ${roleColor};"` %>>
                  <%= initials %>
                </div>
              <% } %>
              <% if (unreadCount > 0) { %>
                <span class="unread-dot"></span>
              <% } %>
            </div>
            <div class="contact-info">
              <div class="contact-header">
                <span class="contact-name"><%= c.name %></span>
                <% if (lastMsg) { %>
                  <span class="contact-time"><%= lastMsgTime %></span>
                <% } %>
              </div>
              <div class="contact-meta-row">
                <div class="contact-last-preview">
                  <% if (lastMsg) { %>
                    <%= lastMsg.senderMe ? 'You: ' : '' %><%= lastMsg.content %>
                  <% } else { %>
                    <span style="opacity: 0.5; font-style: italic;">No messages exchanged</span>
                  <% } %>
                </div>
                <% if (unreadCount > 0) { %>
                  <span class="unread-badge"><%= unreadCount %></span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- Chat History Panel (Right) -->
  <div class="inbox-chat-panel">
    <% if (!selectedContact) { %>
      <div class="chat-empty-state">
        <div class="empty-icon">💬</div>
        <h3>Select a conversation</h3>
        <p>Choose a contact from the list on the left to start exchanging messages.</p>
      </div>
    <% } else { %>
      <!-- Chat Header -->
      <div class="chat-header-bar">
        <div class="chat-header-info">
          <button type="button" class="inbox-back-btn" onclick="document.getElementById('inboxContainer').classList.remove('has-selection')" aria-label="Back to contacts" title="Back to contacts">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          </button>
          <% 
            let roleColor = 'var(--gold)';
            if (selectedContact.role === 'admin') roleColor = '#3b82f6';
            else if (selectedContact.role === 'teacher') roleColor = '#10b981';
            else if (selectedContact.role === 'counsellor') roleColor = '#f59e0b';
            else if (selectedContact.role === 'student') roleColor = '#8b5cf6';
          %>
          <% if (selectedContact.profilePic) { %>
            <img src="<%= selectedContact.profilePic %>" alt="<%= selectedContact.name %>" class="chat-header-avatar">
          <% } else { %>
            <%
              const initials = selectedContact.name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
            %>
            <div class="chat-header-avatar-fallback" <%= `style="background-color: ${roleColor}15; color: ${roleColor};"` %>>
              <%= initials %>
            </div>
          <% } %>
          <div>
            <div class="chat-header-name"><%= selectedContact.name %></div>
            <div class="chat-header-meta">
              <span class="contact-role-badge" <%= `style="border-color: ${roleColor}20; color: ${roleColor}; background-color: ${roleColor}08; font-size: 10px; padding: 1px 6px;"` %>>
                <%= selectedContact.role %></span>
            </div>
          </div>
        </div>

        <!-- Go to Profile Redirection Button / Details Modal Trigger -->
        <%
          let profileUrl = null;
          if (user.role === 'admin') {
            if (selectedContact.role === 'student') profileUrl = `/admin/students/${selectedContact._id}`;
            else if (selectedContact.role === 'teacher') profileUrl = `/admin/teachers/${selectedContact._id}`;
            else if (selectedContact.role === 'counsellor') profileUrl = `/admin/counsellors/${selectedContact._id}`;
          } else if (user.role === 'teacher' && selectedContact.role === 'student') {
            profileUrl = `/teacher/students?search=${encodeURIComponent(selectedContact.name)}`;
          } else if (user.role === 'counsellor' && selectedContact.role === 'student') {
            profileUrl = `/counsellor/admissions?search=${encodeURIComponent(selectedContact.name)}`;
          }
        %>
        <% if (profileUrl) { %>
          <a href="<%= profileUrl %>" class="btn btn-ghost btn-sm header-profile-link" style="display: flex; align-items: center; gap: 6px; padding: 5px 12px; border: 1px solid var(--border); border-radius: 6px; text-decoration: none; font-size: 0.78rem; font-weight: 600; color: var(--text-sub); transition: background 0.2s;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>View Profile</span>
          </a>
        <% } else { %>
          <button type="button" onclick="window.openContactDetailModal(<%= JSON.stringify(selectedContact.name) %>, <%= JSON.stringify(selectedContact.role) %>, <%= JSON.stringify(selectedContact.profilePic || '') %>)" class="btn btn-ghost btn-sm header-profile-link" style="display: flex; align-items: center; gap: 6px; padding: 5px 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 0.78rem; font-weight: 600; color: var(--text-sub); transition: background 0.2s; background: none; cursor: pointer;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            <span>Contact Details</span>
          </button>
        <% } %>
      </div>

      <!-- Messages Window -->
      <div class="chat-messages-window" id="chatMessagesWindow">
        <% if (chatHistory.length === 0) { %>
          <div class="chat-history-empty">
            <p>No messages exchanged yet. Send a message to start the conversation!</p>
          </div>
        <% } else { %>
          <% 
            let lastDividerDate = null;
            chatHistory.forEach(msg => { 
              const msgDate = new Date(msg.createdAt);
              const isMe = msg.sender._id.toString() === user._id.toString();
              const formattedTime = msgDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
              
              // Determine Divider Title
              const today = new Date();
              const yesterday = new Date();
              yesterday.setDate(yesterday.getDate() - 1);
              
              let dividerText = '';
              if (msgDate.toDateString() === today.toDateString()) {
                dividerText = 'Today';
              } else if (msgDate.toDateString() === yesterday.toDateString()) {
                dividerText = 'Yesterday';
              } else {
                dividerText = msgDate.toLocaleDateString([], { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
              }
              
              const showDivider = lastDividerDate !== msgDate.toDateString();
              if (showDivider) {
                lastDividerDate = msgDate.toDateString();
              }
          %>
            <% if (showDivider) { %>
              <div class="chat-date-divider" style="display: flex; align-items: center; justify-content: center; margin: 16px 0; position: relative; width: 100%;">
                <div style="position: absolute; left: 0; right: 0; top: 50%; border-top: 1px solid var(--border); opacity: 0.4; z-index: 1;"></div>
                <span style="position: relative; z-index: 2; background: var(--bg-card); padding: 4px 12px; border-radius: 20px; font-size: 0.68rem; font-weight: 600; color: var(--text-muted); border: 1px solid var(--border); letter-spacing: 0.5px;"><%= dividerText %></span>
              </div>
            <% } %>
            <div class="message-row <%= isMe ? 'me' : 'them' %>" data-message-id="<%= msg._id %>">
              <div class="message-bubble" style="box-shadow: 0 2px 8px rgba(0,0,0,0.12); margin-top: 2px; position: relative;">
                <!-- Reply Context Quote -->
                <% if (msg.replyTo) { %>
                  <div class="reply-quote-preview" data-parent-id="<%= msg.replyTo._id %>" style="background: rgba(0,0,0,0.15); border-left: 3px solid var(--gold); padding: 4px 8px; border-radius: 4px; margin-bottom: 6px; font-size: 0.75rem; color: var(--text-sub); display: flex; flex-direction: column; cursor: pointer;">
                    <span style="font-weight: 700; font-size: 0.7rem; color: var(--gold); margin-bottom: 2px;">
                      <%= msg.replyTo.sender.toString() === user._id.toString() ? 'You' : (msg.replyTo.sender.toString() === selectedContact._id.toString() ? selectedContact.name : 'User') %>
                    </span>
                    <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;">
                      <%= msg.replyTo.content %>
                    </span>
                  </div>
                <% } %>

                <!-- Message Content -->
                <div class="message-content" id="msg-content-<%= msg._id %>"><%= msg.content %></div>

                <!-- Render Attachments -->
                <% if (msg.attachments && msg.attachments.length > 0) { %>
                  <div class="message-attachments" style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px;">
                    <% msg.attachments.forEach(att => { %>
                      <% if (att.fileType.startsWith('image/')) { %>
                        <div class="attachment-image-wrapper" onclick="openDocPreviewModal('<%= att.url %>', '<%= att.fileName %>')" style="max-width: 280px; border-radius: 8px; overflow: hidden; border: 1px solid var(--border); cursor: pointer;">
                          <img src="<%= att.url %>" style="width: 100%; height: auto; display: block;" alt="Uploaded Image">
                        </div>
                      <% } else { %>
                        <div class="attachment-file-wrapper" onclick="openDocPreviewModal('<%= att.url %>', '<%= att.fileName %>')" style="display: flex; align-items: center; gap: 8px; background: rgba(0,0,0,0.1); border: 1px solid var(--border); border-radius: 6px; padding: 6px 12px; font-size: 0.8rem; cursor: pointer; transition: background 0.2s;">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--gold);"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                          <span style="color: var(--text); font-weight: 600; text-decoration: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 180px;">
                            <%= att.fileName || 'Attachment' %>
                          </span>
                        </div>
                      <% } %>
                    <% }) %>
                  </div>
                <% } %>

                <!-- Hover actions drawer -->
                <div class="message-hover-actions">
                  <!-- Emoji list drawer -->
                  <div class="reaction-emoji-selector">
                    <button class="emoji-btn" data-emoji="👍" title="Like">👍</button>
                    <button class="emoji-btn" data-emoji="❤️" title="Love">❤️</button>
                    <button class="emoji-btn" data-emoji="😂" title="Laugh">😂</button>
                    <button class="emoji-btn" data-emoji="😮" title="Wow">😮</button>
                    <button class="emoji-btn" data-emoji="😢" title="Sad">😢</button>
                    <button class="emoji-btn" data-emoji="🙏" title="Pray/Thanks">🙏</button>
                  </div>
                  <button class="btn-msg-action reply-btn-trigger" data-message-id="<%= msg._id %>" data-sender-name="<%= isMe ? 'You' : selectedContact.name %>" data-snippet="<%= msg.content.substring(0, 60) + (msg.content.length > 60 ? '...' : '') %>" title="Reply">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 17 4 12 9 7"></polyline><path d="M20 18v-2a4 4 0 0 0-4-4H4"></path></svg>
                  </button>
                  <% 
                    const isEditable = isMe;
                  %>
                  <% if (isEditable) { %>
                    <button class="btn-msg-action edit-btn-trigger" data-message-id="<%= msg._id %>" title="Edit Message">
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                    </button>
                  <% } %>
                </div>

                <!-- Rendered Reactions -->
                <% if (msg.reactions && msg.reactions.length > 0) { %>
                  <div class="message-reactions-container" style="display: flex; gap: 4px; flex-wrap: wrap; margin-top: 4px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 4px;">
                    <% 
                      // Group by emoji to show count, or list them out cleanly
                      const reactionCounts = {};
                      msg.reactions.forEach(r => {
                        reactionCounts[r.emoji] = (reactionCounts[r.emoji] || 0) + 1;
                      });
                    %>
                    <% Object.entries(reactionCounts).forEach(([emoji, count]) => { %>
                      <span class="reaction-badge" data-emoji="<%= emoji %>" style="display: inline-flex; align-items: center; background: rgba(255,255,255,0.08); border: 1px solid var(--border); border-radius: 12px; padding: 2px 6px; font-size: 0.75rem; cursor: pointer; user-select: none;">
                        <%= emoji %> <span style="opacity: 0.8; margin-left: 2px; font-size: 0.65rem;"><%= count %></span>
                      </span>
                    <% }) %>
                  </div>
                <% } %>

                <div class="message-time" style="opacity: 0.75; display: flex; align-items: center; justify-content: flex-end; gap: 4px;">
                  <%= formattedTime %>
                  <% if (isMe) { %>
                    <span class="read-status-text" style="font-size: 0.65rem; opacity: 0.85; margin-left: 4px;">
                      <% if (msg.readAt) { %>
                        Seen (<%= new Date(msg.readAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>)
                      <% } else { %>
                        Sent
                      <% } %>
                    </span>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- Selected Files Preview Bar -->
      <div id="filePreviewContainer" style="display: none; background: rgba(0,0,0,0.2); border-top: 1px solid var(--border); padding: 8px 1.25rem; align-items: center; justify-content: space-between;">
        <span id="filePreviewText" style="font-size: 0.8rem; color: var(--text-sub); overflow: hidden; text-overflow: ellipsis;">No files selected</span>
        <button type="button" id="clearFilesBtn" style="background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 4px;" title="Clear files">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>

      <!-- Reply Preview Bar (Top of Chat Input Bar) -->
      <div id="replyPreviewContainer" style="display: none; background: rgba(0,0,0,0.25); border-top: 1px solid var(--border); padding: 8px 1.25rem; align-items: center; justify-content: space-between; gap: 12px;">
        <div style="border-left: 3px solid var(--gold); padding-left: 8px; font-size: 0.8rem; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; flex: 1;">
          <div style="font-weight: 700; color: var(--gold); font-size: 0.72rem; margin-bottom: 2px;">Replying to <span id="replyPreviewUser">User</span></div>
          <div id="replyPreviewText" style="color: var(--text-muted); font-size: 0.78rem; overflow: hidden; text-overflow: ellipsis;">Message snippet...</div>
        </div>
        <button type="button" id="cancelReplyBtn" style="background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 4px; display: flex; align-items: center; justify-content: center; transition: color 0.2s;" title="Cancel Reply">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>

      <!-- Edit Preview Bar (Top of Chat Input Bar) -->
      <div id="editPreviewContainer" style="display: none; background: rgba(0,0,0,0.25); border-top: 1px solid var(--border); padding: 8px 1.25rem; align-items: center; justify-content: space-between; gap: 12px;">
        <div style="border-left: 3px solid var(--gold); padding-left: 8px; font-size: 0.8rem; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; flex: 1;">
          <div style="font-weight: 700; color: var(--gold); font-size: 0.72rem; margin-bottom: 2px;">Editing Message</div>
          <div id="editPreviewText" style="color: var(--text-muted); font-size: 0.78rem; overflow: hidden; text-overflow: ellipsis;">Original text...</div>
        </div>
        <button type="button" id="cancelEditBtn" style="background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 4px; display: flex; align-items: center; justify-content: center; transition: color 0.2s;" title="Cancel Edit">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>

      <!-- Message Form -->
      <form action="/auth/inbox/send" method="POST" enctype="multipart/form-data" class="chat-input-bar">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="recipientId" value="<%= selectedContact._id %>">
        <input type="hidden" name="replyTo" id="replyToInput" value="">
        <input type="hidden" name="editMessageId" id="editMessageIdInput" value="">
        
        <!-- File Input with Attachment Icon -->
        <label for="chatAttachmentInput" class="btn btn-ghost" style="padding: 8px; margin: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; border-radius: 50%; width: 38px; height: 38px;" title="Attach JPEG, PNG, or PDF">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
        </label>
        <input type="file" name="attachments" id="chatAttachmentInput" multiple style="display: none;">

        <textarea name="content" id="chatMessageInput" placeholder="Type a message here... (Press Enter to send)"></textarea>
        <button type="submit" class="btn btn-primary send-btn" aria-label="Send Message">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
          <span>Send</span>
        </button>
      </form>
    <% } %>
</div>

<!-- Edit Message Modal -->
<div id="editMessageModal" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 1000; align-items: center; justify-content: center; transition: opacity 0.3s ease;">
  <div class="modal-content" style="background: var(--bg-card, #121212); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; width: 90%; max-width: 500px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); position: relative;">
    <h3 style="margin-top: 0; margin-bottom: 1rem; color: var(--text);">Edit Message</h3>
    <form id="editMessageForm" method="POST">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <textarea id="editMessageTextarea" name="content" style="width: 100%; min-height: 100px; padding: 0.75rem; border: 1px solid var(--border); border-radius: 6px; background: var(--bg-input); color: var(--text); font-family: inherit; font-size: 0.9rem; resize: vertical; margin-bottom: 1rem; outline: none; transition: border-color 0.2s;" required></textarea>
