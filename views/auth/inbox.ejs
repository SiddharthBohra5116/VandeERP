<script>
// Global Error Handler for Diagnostics
window.onerror = function (message, source, lineno, colno, error) {
  alert("🚨 JS Error detected:\nMessage: " + message + "\nSource: " + source + "\nLine: " + lineno + ":" + colno);
  return false;
};

// Expose Edit Modal Functions Globally
window.openEditModal = (messageId) => {
  console.log("✏️ openEditModal inline called with messageId:", messageId);
  const chatInput = document.getElementById('chatMessageInput');
  const editIdInput = document.getElementById('editMessageIdInput');
  const editPreviewText = document.getElementById('editPreviewText');
  const editPreviewContainer = document.getElementById('editPreviewContainer');
  
  // Close reply preview if open, to avoid layout clutter
  const replyToInput = document.getElementById('replyToInput');
  const replyPreviewContainer = document.getElementById('replyPreviewContainer');
  if (replyToInput) replyToInput.value = '';
  if (replyPreviewContainer) replyPreviewContainer.style.display = 'none';

  let contentDiv = document.getElementById('msg-content-' + messageId);
  if (!contentDiv) {
    const messageRow = document.querySelector(`.message-row[data-message-id="${messageId}"]`);
    if (messageRow) {
      contentDiv = messageRow.querySelector('.message-content');
    }
  }

  if (chatInput && editIdInput && editPreviewText && editPreviewContainer && contentDiv) {
    const text = contentDiv.textContent.trim();
    editIdInput.value = messageId;
    editPreviewText.textContent = text;
    editPreviewContainer.style.display = 'flex';
    chatInput.value = text;
    chatInput.focus();
    console.log("✅ Loaded message into input bar for inline editing.");
  } else {
    console.error("❌ Failed to load edit. Elements missing:", {
      chatInput: !!chatInput,
      editIdInput: !!editIdInput,
      editPreviewText: !!editPreviewText,
      editPreviewContainer: !!editPreviewContainer,
      contentDiv: !!contentDiv
    });
  }
};

window.closeEditModal = () => {
  const modal = document.getElementById('editMessageModal');
  if (modal) {
    modal.style.display = 'none';
  }
};

// Global click delegation for edit buttons to run independently of DOMContentLoaded scripts
document.addEventListener('click', (e) => {
  const editBtn = e.target.closest('.edit-btn-trigger');
  if (editBtn) {
    const msgId = editBtn.getAttribute('data-message-id');
    console.log("Global edit-btn-trigger click detected for messageId:", msgId);
    window.openEditModal(msgId);
  }
});

// Expose secure document preview functions
window.openDocPreviewModal = (url, fileName) => {
  const modal = document.getElementById('documentPreviewModal');
  const title = document.getElementById('previewDocTitle');
  const downloadBtn = document.getElementById('previewDocDownloadBtn');
  const frameContainer = document.getElementById('previewDocFrameContainer');
  
  if (modal && title && downloadBtn && frameContainer) {
    title.textContent = `Preview: ${fileName}`;
    downloadBtn.href = url;
    downloadBtn.setAttribute('download', fileName);
    
    // Inject sandboxed iframe to securely render PDF/document isolation
    frameContainer.innerHTML = '';
    const iframe = document.createElement('iframe');
    iframe.src = url;
    iframe.style.width = '100%';
    iframe.style.height = '100%';
    iframe.style.border = 'none';
    
    // sandbox attributes restrict javascript execution, popups, form submissions inside the document
    iframe.setAttribute('sandbox', 'allow-scripts allow-same-origin');
    
    frameContainer.appendChild(iframe);
    modal.style.display = 'flex';
  }
};

window.closeDocPreviewModal = () => {
  const modal = document.getElementById('documentPreviewModal');
  const frameContainer = document.getElementById('previewDocFrameContainer');
  if (modal) {
    modal.style.display = 'none';
  }
  if (frameContainer) {
    frameContainer.innerHTML = ''; // tear down iframe immediately to free memory
  }
};

window.openContactDetailModal = (name, role, profilePic) => {
  const modal = document.getElementById('contactDetailModal');
  const titleName = document.getElementById('contactDetailName');
  const titleRole = document.getElementById('contactDetailRole');
  const avatarWrapper = document.getElementById('contactDetailAvatarWrapper');
  const deptEl = document.getElementById('contactDetailDept');
  
  if (modal && titleName && titleRole && avatarWrapper) {
    titleName.textContent = name;
    titleRole.textContent = role;
    
    if (deptEl) {
      deptEl.textContent = role.charAt(0).toUpperCase() + role.slice(1) + ' Services';
    }

    let roleColor = 'var(--gold)';
    if (role === 'admin') roleColor = '#3b82f6';
    else if (role === 'teacher') roleColor = '#10b981';
    else if (role === 'counsellor') roleColor = '#f59e0b';
    else if (role === 'student') roleColor = '#8b5cf6';

    if (profilePic) {
      avatarWrapper.innerHTML = `<img src="${profilePic}" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 2px solid ${roleColor};" alt="${name}">`;
    } else {
      const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
      avatarWrapper.innerHTML = `
        <div style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.6rem; background-color: ${roleColor}15; color: ${roleColor}; border: 2px solid ${roleColor}30;">
          ${initials}
        </div>
      `;
    }
    modal.style.display = 'flex';
  }
};

window.closeContactDetailModal = () => {
  const modal = document.getElementById('contactDetailModal');
  if (modal) {
    modal.style.display = 'none';
  }
};

document.addEventListener('DOMContentLoaded', () => {
  // 1. Search & Filter Tab Logic
  const searchInput = document.getElementById('contactSearchInput');
  const filterTabs = document.querySelectorAll('.filter-tab');
  const contactItems = document.querySelectorAll('.contact-item');
  let currentFilter = 'all';

  const filterContacts = () => {
    const term = searchInput ? searchInput.value.toLowerCase().trim() : '';
    let hasUnreadInList = false;

    contactItems.forEach(item => {
      const name = item.getAttribute('data-name');
      const role = item.getAttribute('data-role');
      const isUnread = item.getAttribute('data-unread') === 'true';

      if (isUnread) hasUnreadInList = true;

      // Filter by tab
      let matchesTab = true;
      if (currentFilter === 'unread') {
        matchesTab = isUnread;
      } else if (currentFilter !== 'all') {
        matchesTab = (role === currentFilter);
      }

      // Filter by search term
      const matchesSearch = name.includes(term) || role.includes(term);

      if (matchesTab && matchesSearch) {
        item.style.display = 'flex';
      } else {
        item.style.display = 'none';
      }
    });

    // Update unread tab dot indicator if there are unread messages
    const unreadDot = document.querySelector('.tab-unread-dot');
    if (unreadDot) {
      unreadDot.style.display = hasUnreadInList ? 'inline-block' : 'none';
    }
  };

  if (searchInput) {
    searchInput.addEventListener('input', filterContacts);
  }

  filterTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      filterTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentFilter = tab.getAttribute('data-filter');
      filterContacts();
    });
  });

  // Call filterContacts initially to set up unread dots
  filterContacts();

  // 2. Scroll Chat Window to Bottom
  const chatWindow = document.getElementById('chatMessagesWindow');
  if (chatWindow) {
    chatWindow.scrollTop = chatWindow.scrollHeight;
  }

  // 3. Submit Textarea on Enter Key (Shift+Enter for new line)
  const chatInput = document.getElementById('chatMessageInput');
  if (chatInput) {
    chatInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        if (chatInput.value.trim()) {
          chatInput.form.requestSubmit();
        }
      }
    });
  }

  // 4. Edit Modal Logic
  const editModalOverlay = document.getElementById('editMessageModal');
  if (editModalOverlay) {
    editModalOverlay.addEventListener('click', (e) => {
      if (e.target === editModalOverlay) {
        window.closeEditModal();
      }
    });
  }

  const docModalOverlay = document.getElementById('documentPreviewModal');
  if (docModalOverlay) {
    docModalOverlay.addEventListener('click', (e) => {
      if (e.target === docModalOverlay) {
        window.closeDocPreviewModal();
      }
    });
  }

  const detailModalOverlay = document.getElementById('contactDetailModal');
  if (detailModalOverlay) {
    detailModalOverlay.addEventListener('click', (e) => {
      if (e.target === detailModalOverlay) {
        window.closeContactDetailModal();
      }
    });
  }

  // 5. Reply Handler Logic
  const replyToInput = document.getElementById('replyToInput');
  const replyPreviewContainer = document.getElementById('replyPreviewContainer');
  const replyPreviewUser = document.getElementById('replyPreviewUser');
  const replyPreviewText = document.getElementById('replyPreviewText');
  const cancelReplyBtn = document.getElementById('cancelReplyBtn');

  // Trigger reply action
  document.addEventListener('click', (e) => {
    const replyBtn = e.target.closest('.reply-btn-trigger');
    if (replyBtn) {
      const msgId = replyBtn.getAttribute('data-message-id');
      const senderName = replyBtn.getAttribute('data-sender-name');
      const snippet = replyBtn.getAttribute('data-snippet');

      if (replyToInput && replyPreviewContainer && replyPreviewUser && replyPreviewText) {
        replyToInput.value = msgId;
        replyPreviewUser.textContent = senderName;
        replyPreviewText.textContent = snippet;
        replyPreviewContainer.style.display = 'flex';
        if (chatInput) chatInput.focus();
      }
    }


    // Scroll to & highlight replied-to parent message
    const quotePreview = e.target.closest('.reply-quote-preview');
    if (quotePreview) {
      const parentId = quotePreview.getAttribute('data-parent-id');
      if (parentId) {
        const parentRow = document.querySelector(`.message-row[data-message-id="${parentId}"]`);
        if (parentRow) {
          parentRow.scrollIntoView({ behavior: 'smooth', block: 'center' });
          const bubble = parentRow.querySelector('.message-bubble');
          if (bubble) {
            bubble.classList.remove('pulse-highlight');
            // Trigger reflow to restart CSS animation cleanly
            void bubble.offsetWidth;
            bubble.classList.add('pulse-highlight');
            setTimeout(() => {
              bubble.classList.remove('pulse-highlight');
            }, 1500);
          }
        }
      }
    }
  });

  // Cancel reply action
  if (cancelReplyBtn) {
    cancelReplyBtn.addEventListener('click', () => {
      if (replyToInput && replyPreviewContainer) {
        replyToInput.value = '';
        replyPreviewContainer.style.display = 'none';
      }
    });
  }

  // 6. Reaction handler via Event Delegation (fetch POST request to /auth/inbox/react)
  const getCsrfToken = () => {
    const csrfInput = document.querySelector('input[name="_csrf"]');
    return csrfInput ? csrfInput.value : '';
  };

  document.addEventListener('click', async (e) => {
    const emojiBtn = e.target.closest('.emoji-btn');
    const badgeBtn = e.target.closest('.reaction-badge');

    let messageId = null;
    let emoji = null;

    if (emojiBtn) {
      const msgRow = emojiBtn.closest('.message-row');
      if (msgRow) {
        messageId = msgRow.getAttribute('data-message-id');
        emoji = emojiBtn.getAttribute('data-emoji');
      }
    } else if (badgeBtn) {
      const msgRow = badgeBtn.closest('.message-row');
      if (msgRow) {
        messageId = msgRow.getAttribute('data-message-id');
        emoji = badgeBtn.getAttribute('data-emoji');
      }
    }

    if (messageId && emoji) {
      try {
        const response = await fetch('/auth/inbox/react', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            messageId,
            emoji,
            _csrf: getCsrfToken()
          })
        });
        
        if (response.ok) {
          // Real-time UI refresh simple version: reload page to match exact backend state cleanly
          window.location.reload();
        } else {
          const resData = await response.json();
          alert(resData.error || 'Failed to add reaction');
        }
      } catch (err) {
        console.error('Error adding reaction:', err);
      }
    }
  });

  // 7. File Upload Selection & Drag and Drop Handling
  const fileInput = document.getElementById('chatAttachmentInput');
  const filePreviewContainer = document.getElementById('filePreviewContainer');
  const filePreviewText = document.getElementById('filePreviewText');
  const clearFilesBtn = document.getElementById('clearFilesBtn');
  const chatMessagesWindow = document.getElementById('chatMessagesWindow');

  const updateFilePreview = () => {
    if (fileInput && fileInput.files && fileInput.files.length > 0) {
      const maxSizeBytes = 25 * 1024 * 1024; // 25 MB
      const oversizedFiles = Array.from(fileInput.files).filter(f => f.size > maxSizeBytes);
      
      if (oversizedFiles.length > 0) {
        alert(`File size exceeds limit: ${oversizedFiles.map(f => f.name).join(', ')}. Maximum allowed size is 25MB.`);
        fileInput.value = '';
        if (filePreviewContainer) filePreviewContainer.style.display = 'none';
        return;
      }

      const names = Array.from(fileInput.files).map(f => f.name).join(', ');
      if (filePreviewText && filePreviewContainer) {
        filePreviewText.textContent = `Selected files: ${names}`;
        filePreviewContainer.style.display = 'flex';
      }
    } else {
      if (filePreviewContainer) {
        filePreviewContainer.style.display = 'none';
      }
    }
  };

  if (fileInput) {
    fileInput.addEventListener('change', updateFilePreview);
  }

  if (clearFilesBtn) {
    clearFilesBtn.addEventListener('click', () => {
      if (fileInput) {
        fileInput.value = '';
        updateFilePreview();
      }
    });
  }

  // Drag and Drop Logic
  if (chatMessagesWindow && fileInput) {
    ['dragenter', 'dragover'].forEach(eventName => {
      chatMessagesWindow.addEventListener(eventName, (e) => {
        e.preventDefault();
        chatMessagesWindow.style.background = 'rgba(212, 175, 55, 0.05)';
        chatMessagesWindow.style.border = '2px dashed var(--gold)';
      }, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
      chatMessagesWindow.addEventListener(eventName, (e) => {
        e.preventDefault();
        chatMessagesWindow.style.background = 'rgba(0, 0, 0, 0.015)';
        chatMessagesWindow.style.border = 'none';
      }, false);
    });

    chatMessagesWindow.addEventListener('drop', (e) => {
      const dt = e.dataTransfer;
      const files = dt.files;
      if (files && files.length > 0) {
        fileInput.files = files;
        updateFilePreview();
      }
    }, false);
  }

  // 8. Dynamic Polling and AJAX Submission for Live Chat (no reloads)
  const messageForm = document.querySelector('.chat-input-bar');
  const activeChatContactId = '<%= selectedContact ? selectedContact._id : "" %>';
  const currentUserId = '<%= user._id %>';
  const selectedContactName = '<%= selectedContact ? selectedContact.name : "" %>';

  const clearActiveChatUnreadBadge = () => {
    if (!activeChatContactId) return;
    const activeContactItem = document.querySelector(`a.contact-item[href*="chat=${activeChatContactId}"]`);
    if (activeContactItem) {
      activeContactItem.setAttribute('data-unread', 'false');
      const dot = activeContactItem.querySelector('.unread-dot');
      if (dot) dot.remove();
      const badge = activeContactItem.querySelector('.unread-badge');
      if (badge) badge.remove();
    }
  };

  const escapeHtmlAttr = (str) => {
    if (!str) return '';
    return str
      .replace(/&/g, '&amp;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  };

  const renderChatHistory = (messages) => {
    if (!chatMessagesWindow) return;
    
    // Calculate scroll state to stay down if already scrolled down
    const isScrolledToBottom = chatMessagesWindow.scrollHeight - chatMessagesWindow.clientHeight <= chatMessagesWindow.scrollTop + 50;

    let html = '';
    let lastDividerDate = null;

    if (messages.length === 0) {
      html = '<div class="chat-history-empty"><p>No messages exchanged yet. Send a message to start the conversation!</p></div>';
    } else {
      messages.forEach(msg => {
        const msgDate = new Date(msg.createdAt);
        const isMe = msg.sender._id.toString() === currentUserId;
        const formattedTime = msgDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        
        // Determine Divider Title
        const today = new Date();
        const yesterday = new Date();
        yesterday.setDate(yesterday.getDate() - 1);
        
        let dividerText = '';
        if (msgDate.toDateString() === today.toDateString()) {
          dividerText = 'Today';
        } else if (msgDate.toDateString() === yesterday.toDateString()) {
          dividerText = 'Yesterday';
        } else {
          dividerText = msgDate.toLocaleDateString([], { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
        }
        
        const showDivider = lastDividerDate !== msgDate.toDateString();
        if (showDivider) {
          lastDividerDate = msgDate.toDateString();
          html += `
            <div class="chat-date-divider" style="display: flex; align-items: center; justify-content: center; margin: 16px 0; position: relative; width: 100%;">
              <div style="position: absolute; left: 0; right: 0; top: 50%; border-top: 1px solid var(--border); opacity: 0.4; z-index: 1;"></div>
              <span style="position: relative; z-index: 2; background: var(--bg-card); padding: 4px 12px; border-radius: 20px; font-size: 0.68rem; font-weight: 600; color: var(--text-muted); border: 1px solid var(--border); letter-spacing: 0.5px;">${dividerText}</span>
            </div>
          `;
        }

        let replyQuoteHtml = '';
        if (msg.replyTo) {
          const replySenderName = msg.replyTo.sender.toString() === currentUserId ? 'You' : (msg.replyTo.sender.toString() === activeChatContactId ? selectedContactName : 'User');
          replyQuoteHtml = `
            <div class="reply-quote-preview" data-parent-id="${msg.replyTo._id}" style="background: rgba(0,0,0,0.15); border-left: 3px solid var(--gold); padding: 4px 8px; border-radius: 4px; margin-bottom: 6px; font-size: 0.75rem; color: var(--text-sub); display: flex; flex-direction: column; cursor: pointer;">
              <span style="font-weight: 700; font-size: 0.7rem; color: var(--gold); margin-bottom: 2px;">${replySenderName}</span>
              <span style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;">${msg.replyTo.content}</span>
            </div>
          `;
        }

        let attachmentsHtml = '';
        if (msg.attachments && msg.attachments.length > 0) {
          attachmentsHtml += '<div class="message-attachments" style="display: flex; flex-direction: column; gap: 8px; margin-top: 8px;">';
          msg.attachments.forEach(att => {
            if (att.fileType.startsWith('image/')) {
              attachmentsHtml += `
                <div class="attachment-image-wrapper" onclick="openDocPreviewModal('${att.url}', '${att.fileName}')" style="max-width: 280px; border-radius: 8px; overflow: hidden; border: 1px solid var(--border); cursor: pointer;">
                  <img src="${att.url}" style="width: 100%; height: auto; display: block;" alt="Uploaded Image">
                </div>
              `;
            } else {
              attachmentsHtml += `
                <div class="attachment-file-wrapper" onclick="openDocPreviewModal('${att.url}', '${att.fileName}')" style="display: flex; align-items: center; gap: 8px; background: rgba(0,0,0,0.1); border: 1px solid var(--border); border-radius: 6px; padding: 6px 12px; font-size: 0.8rem; cursor: pointer; transition: background 0.2s;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--gold);"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                  <span style="color: var(--text); font-weight: 600; text-decoration: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 180px;">${att.fileName || 'Attachment'}</span>
                </div>
              `;
            }
          });
          attachmentsHtml += '</div>';
        }
        let editBtnHtml = '';
        if (isMe) {
          editBtnHtml = `
            <button class="btn-msg-action edit-btn-trigger" data-message-id="${msg._id}" title="Edit Message">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            </button>
          `;
        }

        let reactionsHtml = '';
        if (msg.reactions && msg.reactions.length > 0) {
          reactionsHtml += '<div class="message-reactions-container" style="display: flex; gap: 4px; flex-wrap: wrap; margin-top: 4px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 4px;">';
          const reactionCounts = {};
          msg.reactions.forEach(r => {
            reactionCounts[r.emoji] = (reactionCounts[r.emoji] || 0) + 1;
          });
          Object.entries(reactionCounts).forEach(([emoji, count]) => {
            reactionsHtml += `
              <span class="reaction-badge" data-emoji="${emoji}" style="display: inline-flex; align-items: center; background: rgba(255,255,255,0.08); border: 1px solid var(--border); border-radius: 12px; padding: 2px 6px; font-size: 0.75rem; cursor: pointer; user-select: none;">
                ${emoji} <span style="opacity: 0.8; margin-left: 2px; font-size: 0.65rem;">${count}</span>
              </span>
            `;
          });
          reactionsHtml += '</div>';
        }

        const seenHtml = isMe ? `<span class="read-status-text" style="font-size: 0.65rem; opacity: 0.85; margin-left: 4px;">${msg.readAt ? 'Seen (' + new Date(msg.readAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) + ')' : 'Sent'}</span>` : '';

        html += `
          <div class="message-row ${isMe ? 'me' : 'them'}" data-message-id="${msg._id}">
            <div class="message-bubble" style="box-shadow: 0 2px 8px rgba(0,0,0,0.12); margin-top: 2px; position: relative;">
              ${replyQuoteHtml}
              <div class="message-content" id="msg-content-${msg._id}">${msg.content}</div>
              ${attachmentsHtml}
              <div class="message-hover-actions">
                <div class="reaction-emoji-selector">
                  <button class="emoji-btn" data-emoji="👍" title="Like">👍</button>
                  <button class="emoji-btn" data-emoji="❤️" title="Love">❤️</button>
                  <button class="emoji-btn" data-emoji="😂" title="Laugh">😂</button>
                  <button class="emoji-btn" data-emoji="😮" title="Wow">😮</button>
                  <button class="emoji-btn" data-emoji="😢" title="Sad">😢</button>
                  <button class="emoji-btn" data-emoji="🙏" title="Pray/Thanks">🙏</button>
                </div>
                <button class="btn-msg-action reply-btn-trigger" data-message-id="${msg._id}" data-sender-name="${isMe ? 'You' : escapeHtmlAttr(selectedContactName)}" data-snippet="${escapeHtmlAttr(msg.content.substring(0, 60))}" title="Reply">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 17 4 12 9 7"></polyline><path d="M20 18v-2a4 4 0 0 0-4-4H4"></path></svg>
                </button>
                ${editBtnHtml}
              </div>
              ${reactionsHtml}
              <div class="message-time" style="opacity: 0.75; display: flex; align-items: center; justify-content: flex-end; gap: 4px;">
                ${formattedTime}
                ${seenHtml}
              </div>
            </div>
          </div>
        `;
      });
    }

    chatMessagesWindow.innerHTML = html;
    clearActiveChatUnreadBadge();
    
    if (isScrolledToBottom) {
      chatMessagesWindow.scrollTop = chatMessagesWindow.scrollHeight;
    }
  };

  const pollMessages = async () => {
    if (!activeChatContactId) return;
    try {
      const response = await fetch(`/auth/inbox/messages?chat=${activeChatContactId}`);
      if (response.ok) {
        const data = await response.json();
        if (data.ok && data.messages) {
          renderChatHistory(data.messages);
        }
      }
    } catch (err) {
      console.error('Polling error:', err);
    }
  };

  // Poll for new messages every 3 seconds to keep chat live
  if (activeChatContactId) {
    setInterval(pollMessages, 3000);
  }

  // Cancel Edit Action Handler
  const cancelEditBtn = document.getElementById('cancelEditBtn');
  const editMessageIdInput = document.getElementById('editMessageIdInput');
  const editPreviewContainer = document.getElementById('editPreviewContainer');

  if (cancelEditBtn) {
    cancelEditBtn.addEventListener('click', () => {
      if (editMessageIdInput) editMessageIdInput.value = '';
      if (editPreviewContainer) editPreviewContainer.style.display = 'none';
      if (chatInput) chatInput.value = '';
    });
  }

  // Handle AJAX message submission (no page reloads on send or edit)
  if (messageForm) {
    messageForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const restoreSubmitBtn = () => {
        const submitBtn = messageForm.querySelector('button[type="submit"]');
        if (submitBtn) {
          submitBtn.disabled = false;
          const origText = submitBtn.getAttribute('data-original-text');
          if (origText) {
            submitBtn.innerHTML = origText;
          }
        }
      };

      const editMessageId = editMessageIdInput ? editMessageIdInput.value : '';

      if (editMessageId) {
        // Handle Inline Message Edit via AJAX
        const content = chatInput ? chatInput.value.trim() : '';
        if (!content) {
          restoreSubmitBtn();
          return;
        }

        const actionUrl = `/auth/messages/${editMessageId}/edit`;

        const params = new URLSearchParams();
        params.append('content', content);
        params.append('_csrf', getCsrfToken());

        try {
          const response = await fetch(actionUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded',
              'Accept': 'application/json'
            },
            body: params.toString()
          });

          if (response.ok) {
            // Reset Edit State
            if (editMessageIdInput) editMessageIdInput.value = '';
            if (editPreviewContainer) editPreviewContainer.style.display = 'none';
            if (chatInput) chatInput.value = '';
            
            // Poll immediately to show edited content
            pollMessages();
          } else {
            const errData = await response.json().catch(() => ({ error: 'Failed to update message.' }));
            alert(errData.error || 'Failed to update message.');
          }
        } catch (err) {
          console.error('AJAX edit error:', err);
          alert('An error occurred while editing the message.');
        } finally {
          restoreSubmitBtn();
        }
        return;
      }

      // Otherwise: Standard Send Message
      const formData = new FormData(messageForm);
      if (!chatInput.value.trim() && (!fileInput || fileInput.files.length === 0)) {
        restoreSubmitBtn();
        return; // do not send empty
      }

      try {
        const response = await fetch('/auth/inbox/send', {
          method: 'POST',
          body: formData
        });

        if (response.ok) {
          // Clear inputs
          chatInput.value = '';
          if (fileInput) fileInput.value = '';
          if (replyToInput) replyToInput.value = '';
          if (replyPreviewContainer) replyPreviewContainer.style.display = 'none';
          if (filePreviewContainer) filePreviewContainer.style.display = 'none';
          
          // Poll immediately to show new message
          pollMessages();
        } else {
          console.error('Failed to send message via AJAX');
        }
      } catch (err) {
        console.error('AJAX send error:', err);
      } finally {
        restoreSubmitBtn();
      }
    });
  }
  
  // Clear unread badge for the active chat immediately on page load
  clearActiveChatUnreadBadge();
});
</script>
