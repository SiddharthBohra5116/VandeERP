<%
  layout = 'main';
  title = 'My Profile';
  page = 'profile';

  const profile = typeof roleProfile !== 'undefined' ? roleProfile : null;
  const initials = (user.name || 'User').split(' ').filter(Boolean).map(n => n[0]).join('').toUpperCase().slice(0, 2);
  const roleLabel = (user.role || 'user').charAt(0).toUpperCase() + (user.role || 'user').slice(1);
  const formatDate = (value) => value ? new Date(value).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'Not added';
  const showValue = (value) => value || 'Not added';
  const currentPic = user.profilePic || (profile && profile.documents && profile.documents.profilePic) || '';
  const isCurrentPicImage = currentPic && /\.(jpe?g|png|webp)($|\?)/i.test(currentPic);
  const localSuccessList = Array.isArray(success) ? success.filter(msg => String(msg || '').trim()) : (success ? [success] : []);
  const localErrorList = Array.isArray(error) ? error.filter(msg => String(msg || '').trim() && String(msg).trim() !== '1') : (error && String(error).trim() !== '1' ? [error] : []);

  const studentFamily = profile && profile.family ? profile.family : {};
  const fatherName = user.fatherName || (studentFamily.father && studentFamily.father.name) || '';
  const fatherPhone = user.fatherPhone || (studentFamily.father && studentFamily.father.phone) || '';
  const motherName = user.motherName || (studentFamily.mother && studentFamily.mother.name) || '';
  const motherPhone = user.motherPhone || (studentFamily.mother && studentFamily.mother.phone) || '';
  const guardianName = user.guardianName || (studentFamily.guardian && studentFamily.guardian.name) || '';
  const guardianRelation = user.guardianRelation || (studentFamily.guardian && studentFamily.guardian.relation) || '';
  const guardianPhone = user.guardianPhone || (studentFamily.guardian && studentFamily.guardian.phone) || '';
%>

<div class="profile-shell">
  <section class="profile-hero">
    <div class="profile-avatar-wrap">
      <div class="avatar-lg profile-avatar <%= isCurrentPicImage ? '' : 'avatar-fallback-visible' %>">
        <% if (isCurrentPicImage) { %>
          <img src="<%= currentPic %>" alt="<%= user.name %>" onerror="this.hidden=true; this.parentElement.classList.add('avatar-fallback-visible');">
        <% } %>
        <span class="avatar-fallback"><%= initials %></span>
      </div>
      <span class="profile-role-pill"><%= roleLabel %></span>
    </div>
    <div class="profile-hero-main">
      <div class="profile-eyebrow">Account profile</div>
      <h1 class="profile-name"><%= user.name %></h1>
      <div class="profile-meta">
        <span><%= user.email %></span>
        <span><%= showValue(user.phone) %></span>
      </div>
    </div>
    <div class="profile-status-card">
      <div class="profile-status-label">Status</div>
      <div class="profile-status-value"><%= user.status || 'active' %></div>
      <div class="profile-status-sub">Joined <%= formatDate(user.createdAt) %></div>
    </div>
  </section>

  <% if (localErrorList.length) { %>
    <div class="alert alert-error profile-alert"><span><%= localErrorList[0] %></span></div>
  <% } %>
  <% if (localSuccessList.length && !(typeof query !== 'undefined' && (query.updated || query.saved || query.request_submitted))) { %>
    <div class="alert alert-success profile-alert"><span><%= localSuccessList[0] %></span></div>
  <% } %>
  <% if (typeof query !== 'undefined' && query.updated) { %>
    <div class="alert alert-success profile-alert"><span>Your profile was updated successfully.</span></div>
  <% } %>
  <% if (typeof query !== 'undefined' && query.saved) { %>
    <div class="alert alert-success profile-alert"><span>Your document was uploaded and is ready for review.</span></div>
  <% } %>
  <% if (typeof query !== 'undefined' && query.error) { %>
    <div class="alert alert-error profile-alert"><span>Something went wrong. Please check the details and try again.</span></div>
  <% } %>
  <% if (user.role === 'student') { %>
    <% if (typeof request_submitted !== 'undefined' || (typeof query !== 'undefined' && query.request_submitted)) { %>
      <div class="alert alert-success profile-alert"><span>Your profile update request was submitted for admin approval.</span></div>
    <% } %>
  <% } %>

  <div class="profile-summary-grid">
    <% if (user.role === 'student') { %>
      <div class="profile-info-tile">
        <span>Roll number</span>
        <strong><%= showValue(profile && profile.rollNumber) %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Course</span>
        <strong><%= showValue(profile && profile.course && profile.course.name) %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Batch</span>
        <strong><%= showValue(profile && profile.batch && profile.batch.name) %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Fees due</span>
        <strong>Rs. <%= profile ? (profile.fees_due || 0).toLocaleString('en-IN') : '0' %></strong>
      </div>
    <% } else if (user.role === 'teacher') { %>
      <div class="profile-info-tile">
        <span>Teacher ID</span>
        <strong><%= showValue(profile && profile.rollNumber) %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Qualification</span>
        <strong><%= showValue(profile && profile.qualification) %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Experience</span>
        <strong><%= profile ? `${profile.experienceYears || 0} yrs` : 'Not added' %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Courses</span>
        <strong><%= profile && profile.courses && profile.courses.length ? profile.courses.map(c => c.name).join(', ') : 'Not assigned' %></strong>
      </div>
    <% } else if (user.role === 'counsellor') { %>
      <div class="profile-info-tile">
        <span>Counsellor ID</span>
        <strong><%= showValue(profile && profile.rollNumber) %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Email</span>
        <strong><%= user.email %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Phone</span>
        <strong><%= showValue(user.phone) %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Location</span>
        <strong><%= [user.city, user.address].filter(Boolean).join(', ') || 'Not added' %></strong>
      </div>
    <% } else { %>
      <div class="profile-info-tile">
        <span>Email</span>
        <strong><%= user.email %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Phone</span>
        <strong><%= showValue(user.phone) %></strong>
      </div>
      <div class="profile-info-tile">
        <span>City</span>
        <strong><%= showValue(user.city) %></strong>
      </div>
      <div class="profile-info-tile">
        <span>Date of birth</span>
        <strong><%= formatDate(user.dob) %></strong>
      </div>
    <% } %>
  </div>

  <div class="profile-layout">
    <div class="profile-main-col">
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Profile Details</div>
            <div class="profile-card-subtitle">
              <% if (user.role === 'student') { %>
                Student edits are sent to admin for verification.
              <% } else { %>
                Keep your academy contact details current.
              <% } %>
            </div>
          </div>
        </div>

        <% if (user.role === 'student' && user.pendingProfileUpdate && user.pendingProfileUpdate.requestedAt) { %>
          <div class="profile-pending-box">
            <div class="profile-pending-title">Pending approval</div>
            <div class="profile-pending-grid">
              <span>Name: <strong><%= user.pendingProfileUpdate.name || 'Not added' %></strong></span>
              <span>Phone: <strong><%= user.pendingProfileUpdate.phone || 'Not added' %></strong></span>
              <span>Father: <strong><%= user.pendingProfileUpdate.fatherName || 'Not added' %></strong></span>
              <span>Father phone: <strong><%= user.pendingProfileUpdate.fatherPhone || 'Not added' %></strong></span>
              <span>Mother: <strong><%= user.pendingProfileUpdate.motherName || 'Not added' %></strong></span>
              <span>Mother phone: <strong><%= user.pendingProfileUpdate.motherPhone || 'Not added' %></strong></span>
              <span>Guardian: <strong><%= user.pendingProfileUpdate.guardianName || 'Not added' %></strong></span>
              <span>Guardian phone: <strong><%= user.pendingProfileUpdate.guardianPhone || 'Not added' %></strong></span>
            </div>
          </div>
        <% } %>

        <form action="/auth/profile" method="POST" enctype="multipart/form-data" class="profile-form">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

          <div class="profile-form-section">
            <div class="profile-section-heading">Personal Information</div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="name">Full Name</label>
                <input type="text" id="name" name="name" class="form-control" value="<%= user.name %>" required>
              </div>
              <div class="form-group">
                <label class="form-label" for="phone">Phone Number</label>
                <input type="tel" id="phone" name="phone" class="form-control js-phone-input" value="<%= user.phone || '' %>" maxlength="10" pattern="[0-9]{10}" inputmode="numeric">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="dob">Date of Birth</label>
                <input type="date" id="dob" name="dob" class="form-control" value="<%= user.dob ? new Date(user.dob).toISOString().split('T')[0] : '' %>">
              </div>
              <div class="form-group">
                <label class="form-label" for="city">City</label>
                <input type="text" id="city" name="city" class="form-control" value="<%= user.city || '' %>">
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="address">Address</label>
              <input type="text" id="address" name="address" class="form-control" value="<%= user.address || '' %>">
            </div>
          </div>

          <% if (user.role === 'student') { %>
            <div class="profile-form-section">
              <div class="profile-section-heading">Parent / Guardian Information</div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="fatherName">Father's Name</label>
                  <input type="text" id="fatherName" name="fatherName" class="form-control" value="<%= fatherName %>">
                </div>
                <div class="form-group">
                  <label class="form-label" for="fatherPhone">Father's Phone</label>
                  <input type="tel" id="fatherPhone" name="fatherPhone" class="form-control js-phone-input" value="<%= fatherPhone %>" maxlength="10" pattern="[0-9]{10}" inputmode="numeric">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="motherName">Mother's Name</label>
                  <input type="text" id="motherName" name="motherName" class="form-control" value="<%= motherName %>">
                </div>
                <div class="form-group">
                  <label class="form-label" for="motherPhone">Mother's Phone</label>
                  <input type="tel" id="motherPhone" name="motherPhone" class="form-control js-phone-input" value="<%= motherPhone %>" maxlength="10" pattern="[0-9]{10}" inputmode="numeric">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="guardianName">Guardian Name</label>
                  <input type="text" id="guardianName" name="guardianName" class="form-control" value="<%= guardianName %>">
                </div>
                <div class="form-group">
                  <label class="form-label" for="guardianRelation">Relationship</label>
                  <input type="text" id="guardianRelation" name="guardianRelation" class="form-control" value="<%= guardianRelation %>">
                </div>
              </div>
              <div class="form-group">
                <label class="form-label" for="guardianPhone">Guardian Phone Number</label>
                <input type="tel" id="guardianPhone" name="guardianPhone" class="form-control js-phone-input" value="<%= guardianPhone %>" maxlength="10" pattern="[0-9]{10}" inputmode="numeric">
              </div>
            </div>
          <% } %>

          <div class="profile-form-section">
            <div class="profile-section-heading">Profile Photo</div>
            <div class="profile-photo-control">
              <div class="profile-photo-preview <%= isCurrentPicImage ? '' : 'is-empty' %>" id="profilePhotoPreview">
                <% if (isCurrentPicImage) { %>
                  <img src="<%= currentPic %>" alt="Current profile photo" onerror="this.hidden=true; this.parentElement.classList.add('is-empty');">
                <% } %>
                <span><%= initials %></span>
              </div>
              <div class="profile-photo-input">
                <label class="form-label" for="profilePic">Upload New Picture</label>
                <input type="file" id="profilePic" name="profilePic" class="form-control" accept="image/jpeg,image/png,image/webp">
                <div class="form-hint">Use a clear JPG, PNG, or WebP image. Square photos look best.</div>
                <% if (currentPic) { %>
                  <label class="profile-remove-photo">
                    <input type="checkbox" name="removeProfilePic" value="1">
                    <span>Remove current photo and use initials</span>
                  </label>
                <% } %>
              </div>
            </div>
          </div>

          <button type="submit" class="btn btn-primary mt-2"><%= user.role === 'student' ? 'Submit for Approval' : 'Save Changes' %></button>
        </form>
      </div>
    </div>

    <aside class="profile-side-col">
      <% if (user.role === 'teacher') { %>
        <div class="card profile-side-card">
          <div class="card-header"><div class="card-title">Teaching Profile</div></div>
          <div class="profile-detail-list">
            <div><span>ID</span><strong><%= showValue(profile && profile.rollNumber) %></strong></div>
            <div><span>Qualification</span><strong><%= showValue(profile && profile.qualification) %></strong></div>
            <div><span>Experience</span><strong><%= profile ? `${profile.experienceYears || 0} years` : 'Not added' %></strong></div>
            <div><span>Joining date</span><strong><%= formatDate(profile && profile.joiningDate) %></strong></div>
          </div>
        </div>
      <% } else if (user.role === 'counsellor') { %>
        <div class="card profile-side-card">
          <div class="card-header"><div class="card-title">Counsellor Profile</div></div>
          <div class="profile-detail-list">
            <div><span>ID</span><strong><%= showValue(profile && profile.rollNumber) %></strong></div>
            <div><span>Email</span><strong><%= user.email %></strong></div>
            <div><span>Phone</span><strong><%= showValue(user.phone) %></strong></div>
            <div><span>Joined</span><strong><%= formatDate(user.createdAt) %></strong></div>
          </div>
        </div>
      <% } else if (user.role === 'student') { %>
        <div class="card profile-side-card">
          <div class="card-header"><div class="card-title">Assigned Team</div></div>
          <div class="profile-detail-list">
            <div><span>Teacher</span><strong><%= profile && profile.teacher && profile.teacher.user ? profile.teacher.user.name : 'Not assigned' %></strong></div>
            <div><span>Counsellor</span><strong><%= profile && profile.counsellor && profile.counsellor.user ? profile.counsellor.user.name : 'Not assigned' %></strong></div>
            <div><span>Enrollment</span><strong><%= formatDate(profile && profile.enrollmentDate) %></strong></div>
          </div>
        </div>
      <% } %>

      <div class="card profile-side-card">
        <div class="card-header"><div class="card-title">Change Password</div></div>
        <form action="/auth/change-password" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <div class="form-group">
            <label class="form-label" for="currentPassword">Current Password</label>
            <input type="password" id="currentPassword" name="currentPassword" class="form-control" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="newPassword">New Password</label>
            <input type="password" id="newPassword" name="newPassword" class="form-control" minlength="8" required>
            <div class="form-hint">Minimum 8 characters.</div>
          </div>
          <button type="submit" class="btn btn-ghost mt-2">Change Password</button>
        </form>
      </div>
    </aside>
  </div>

  <% if (user.role === 'student') { %>
    <section id="document-verification" class="card profile-document-card">
      <div class="card-header">
        <div>
          <div class="card-title">Document Verification</div>
          <div class="profile-card-subtitle">
            <% if (user.idProof && user.idVerified) { %>
              Verified by the academy.
            <% } else if (user.idProof) { %>
              Submitted and waiting for admin review.
            <% } else { %>
              Upload one identity document to complete verification.
            <% } %>
          </div>
        </div>
        <span class="profile-doc-status <%= user.idProof && user.idVerified ? 'is-verified' : user.idProof ? 'is-review' : 'is-missing' %>">
          <%= user.idProof && user.idVerified ? 'Verified' : user.idProof ? 'Under review' : 'Required' %>
        </span>
      </div>

      <% if (user.idProof) { %>
        <div class="profile-current-document">
          <a href="<%= user.idProof %>" target="_blank">View uploaded document</a>
          <% if (user.idProof.match(/\.(jpeg|jpg|png|gif|webp)($|\?)/i)) { %>
            <img src="<%= user.idProof %>" alt="ID proof preview">
          <% } else { %>
            <div class="profile-pdf-chip">PDF document uploaded</div>
          <% } %>
        </div>
      <% } %>

      <form action="/student/profile/upload-id" method="POST" enctype="multipart/form-data" class="profile-document-form">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="form-group">
          <label class="form-label" for="idProof"><%= user.idProof ? 'Replace document' : 'Upload ID document' %></label>
          <input type="file" id="idProof" name="idProof" class="form-control" accept="image/jpeg,image/png,application/pdf" required>
          <div class="form-hint">Accepted formats: JPG, PNG, or PDF. Maximum file size: 5 MB.</div>
        </div>
        <div id="local-preview-container" class="profile-local-preview" hidden>
          <img id="local-preview-img" src="" alt="Selected document preview" hidden>
          <div id="local-preview-pdf" hidden>Selected PDF document</div>
        </div>
        <button type="submit" class="btn btn-primary"><%= user.idProof ? 'Re-upload Document' : 'Submit for Verification' %></button>
      </form>
    </section>
  <% } %>
</div>

<script>
  document.querySelectorAll('.js-phone-input').forEach((input) => {
    input.addEventListener('input', () => {
      input.value = input.value.replace(/[^0-9]/g, '').slice(0, 10);
    });
  });

  document.getElementById('profilePic')?.addEventListener('change', (event) => {
    const file = event.target.files && event.target.files[0];
    const preview = document.getElementById('profilePhotoPreview');
    if (!file || !preview || !file.type.startsWith('image/')) return;

    let image = preview.querySelector('img');
    if (!image) {
      image = document.createElement('img');
      image.alt = 'Selected profile photo';
      preview.prepend(image);
    }
    image.hidden = false;
    preview.classList.remove('is-empty');
    image.src = URL.createObjectURL(file);
  });

  document.getElementById('idProof')?.addEventListener('change', (event) => {
    const file = event.target.files && event.target.files[0];
    const previewContainer = document.getElementById('local-preview-container');
    const previewImg = document.getElementById('local-preview-img');
    const previewPdf = document.getElementById('local-preview-pdf');
    if (!file || !previewContainer) return;

    previewContainer.hidden = false;
    if (file.type.startsWith('image/')) {
      previewImg.hidden = false;
      previewPdf.hidden = true;
      previewImg.src = URL.createObjectURL(file);
    } else if (file.type === 'application/pdf') {
      previewImg.hidden = true;
      previewPdf.hidden = false;
    } else {
      previewContainer.hidden = true;
    }
  });
</script>
