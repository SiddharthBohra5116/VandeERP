<%
  layout = 'auth';
  title = 'Set New Password';
%>

<div>
  <div style="margin-bottom: 1.25rem;">
    <h2 style="margin: 0 0 0.35rem; font-size: 1.25rem;">Set New Password</h2>
    <div style="font-size: 0.82rem; color: var(--text-sub); line-height: 1.5;">
      <% if (user.passwordSetByAdmin) { %>
        You are using a temporary password. Create your own password to continue.
      <% } else { %>
        This is your first login. Create your own password to continue.
      <% } %>
    </div>
  </div>

  <form action="/auth/force-change-password" method="POST" data-no-soft-nav="true">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <div class="form-group">
      <label class="form-label" for="newPassword">New Password</label>
      <input type="password" id="newPassword" name="newPassword" class="form-control" minlength="8" placeholder="Minimum 8 characters" autocomplete="new-password" required>
    </div>
    <div class="form-group">
      <label class="form-label" for="confirmPassword">Confirm New Password</label>
      <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" minlength="8" placeholder="Repeat new password" autocomplete="new-password" required>
    </div>
    <button type="submit" class="btn btn-primary btn-block">Save Password & Continue</button>
  </form>

  <div style="margin-top: 1rem; text-align: center;">
    <a href="/auth/logout" style="font-size: 0.78rem; color: var(--text-sub);">Sign out</a>
  </div>
</div>
