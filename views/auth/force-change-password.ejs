<%
  layout = 'main';
  title = 'Set New Password';
  page = 'profile';
%>

<div class="card" style="max-width: 560px; margin: 0 auto;">
  <div class="card-header">
    <div>
      <div class="card-title">Set New Password</div>
      <div style="font-size: 0.82rem; color: var(--text-sub); margin-top: 4px;">
        <% if (user.passwordSetByAdmin) { %>
          You are using a temporary password. Create your own password to continue.
        <% } else { %>
          This is your first login. Create your own password to continue.
        <% } %>
      </div>
    </div>
  </div>

  <form action="/auth/force-change-password" method="POST">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <div class="form-group">
      <label class="form-label" for="newPassword">New Password</label>
      <input type="password" id="newPassword" name="newPassword" class="form-control" minlength="8" placeholder="Minimum 8 characters" required autofocus>
    </div>
    <div class="form-group">
      <label class="form-label" for="confirmPassword">Confirm New Password</label>
      <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" minlength="8" placeholder="Repeat new password" required>
    </div>
    <button type="submit" class="btn btn-primary btn-block">Save Password & Continue</button>
  </form>
</div>
