<%
  layout = 'main';
  title = 'System Guide';
  subtitle = 'Replayable guided tours on the real system screens';
  page = 'guide';
  const activeRole = user && user.role ? user.role : 'student';
%>

<style>
  .guide-launch-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    gap: 18px;
    margin-bottom: 18px;
  }

  .guide-launch-card,
  .guide-tour-tile {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px;
  }

  .guide-launch-card h2 {
    margin: 0 0 8px;
    color: var(--text);
    font-size: 24px;
  }

  .guide-launch-copy {
    color: var(--text-sub);
    font-size: 13px;
    line-height: 1.65;
    margin: 0;
  }

  .guide-launch-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  .guide-kicker {
    color: var(--gold);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .guide-tour-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 12px;
  }

  .guide-tour-tile {
    display: grid;
    gap: 10px;
  }

  .guide-tour-tile h3 {
    margin: 0;
    color: var(--text);
    font-size: 16px;
  }

  .guide-tour-tile p {
    margin: 0;
    color: var(--text-sub);
    font-size: 12px;
    line-height: 1.55;
  }

  .guide-section-heading {
    margin: 20px 0 10px;
    color: var(--gold);
    font-size: 15px;
  }

  .guide-flow-list {
    display: grid;
    gap: 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .guide-flow-list li {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 9px;
    align-items: start;
    color: var(--text-sub);
    font-size: 12px;
    line-height: 1.45;
  }

  .guide-flow-list span {
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--gold-dim);
    color: var(--gold);
    border: 1px solid var(--gold-border);
    font-weight: 900;
    font-size: 11px;
  }

  @media (max-width: 800px) {
    .guide-launch-hero {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="guide-launch-hero">
  <section class="guide-launch-card">
    <div class="guide-kicker">Real screen walkthrough</div>
    <h2>Start a tour and the system will guide you on the actual pages.</h2>
    <p class="guide-launch-copy">
      This guide is not a static manual. It navigates to real routes, highlights the real buttons,
      explains what each control does, and lets the user stop anytime. Users can come back here
      and replay the full tour or only one feature whenever they want.
    </p>
    <div class="guide-launch-actions">
      <button type="button" class="btn btn-primary btn-sm" data-start-tour="<%= activeRole %>">Start My Full Tour</button>
      <a href="<%= activeRole === 'admin' ? '/admin/dashboard' : activeRole === 'teacher' ? '/teacher/dashboard' : activeRole === 'counsellor' ? '/counsellor/dashboard' : '/student/dashboard' %>" class="btn btn-ghost btn-sm">Go To My Dashboard</a>
    </div>
  </section>

  <aside class="guide-launch-card">
    <div class="guide-kicker">How it works</div>
    <ul class="guide-flow-list">
      <li><span>1</span><div>Choose a full tour or a specific feature tour.</div></li>
      <li><span>2</span><div>The app opens the real page for that step.</div></li>
      <li><span>3</span><div>The exact button, card, form, or section is highlighted.</div></li>
      <li><span>4</span><div>User clicks Next, Back, Stop, or repeats the tour later.</div></li>
    </ul>
  </aside>
</div>

<h3 class="guide-section-heading">Full Role Tours</h3>
<div class="guide-tour-grid">
  <% if (activeRole === 'admin') { %>
    <article class="guide-tour-tile">
      <div class="guide-kicker">Admin</div>
      <h3>Admin Full Tour</h3>
      <p>Dashboard, reset requests, users, fees, leads, schedules, reports, holidays, leaves, and security.</p>
      <button type="button" class="btn btn-primary btn-sm" data-start-tour="admin">Start Admin Tour</button>
    </article>

    <article class="guide-tour-tile">
      <div class="guide-kicker">Teacher</div>
      <h3>Teacher Portal Preview</h3>
      <p>Dashboard, class completion, attendance, assignments, progress, curriculum, updates, and leaves.</p>
      <button type="button" class="btn btn-primary btn-sm" data-start-tour="teacher">Start Teacher Tour</button>
    </article>

    <article class="guide-tour-tile">
      <div class="guide-kicker">Counsellor</div>
      <h3>Counsellor Portal Preview</h3>
      <p>Dashboard, leads, lead creation, follow-ups, admissions, leave requests, and reports.</p>
      <button type="button" class="btn btn-primary btn-sm" data-start-tour="counsellor">Start Counsellor Tour</button>
    </article>

    <article class="guide-tour-tile">
      <div class="guide-kicker">Student</div>
      <h3>Student Portal Preview</h3>
      <p>Dashboard, KYC, assignments, attendance, updates, reports, fees, and inbox.</p>
      <button type="button" class="btn btn-primary btn-sm" data-start-tour="student">Start Student Tour</button>
    </article>
  <% } else if (activeRole === 'teacher') { %>
    <article class="guide-tour-tile">
      <div class="guide-kicker">Teacher</div>
      <h3>Teacher Full Tour</h3>
      <p>Dashboard, class completion, attendance, assignments, progress, curriculum, updates, and leaves.</p>
      <button type="button" class="btn btn-primary btn-sm" data-start-tour="teacher">Start Teacher Tour</button>
    </article>
  <% } else if (activeRole === 'counsellor') { %>
    <article class="guide-tour-tile">
      <div class="guide-kicker">Counsellor</div>
      <h3>Counsellor Full Tour</h3>
      <p>Dashboard, leads, lead creation, follow-ups, admissions, leave requests, and reports.</p>
      <button type="button" class="btn btn-primary btn-sm" data-start-tour="counsellor">Start Counsellor Tour</button>
    </article>
  <% } else { %>
    <article class="guide-tour-tile">
      <div class="guide-kicker">Student</div>
      <h3>Student Full Tour</h3>
      <p>Dashboard, KYC, assignments, attendance, updates, reports, fees, and inbox.</p>
      <button type="button" class="btn btn-primary btn-sm" data-start-tour="student">Start Student Tour</button>
    </article>
  <% } %>
</div>

<h3 class="guide-section-heading">Specific Feature Tours</h3>
<div class="guide-tour-grid">
  <% if (activeRole === 'admin') { %>
    <article class="guide-tour-tile">
      <h3>Dashboard Alerts</h3>
      <p>Learn admin dashboard cards and password reset request handling.</p>
      <button type="button" class="btn btn-ghost btn-sm" data-start-tour="admin_dashboard">Start Tour</button>
    </article>
    <article class="guide-tour-tile">
      <h3>Fees</h3>
      <p>Open fee ledgers and understand payment/balance controls.</p>
      <button type="button" class="btn btn-ghost btn-sm" data-start-tour="admin_fees">Start Tour</button>
    </article>
    <article class="guide-tour-tile">
      <h3>Leads</h3>
      <p>Understand lead list, detail, assignment, notes, and conversion entry points.</p>
      <button type="button" class="btn btn-ghost btn-sm" data-start-tour="admin_leads">Start Tour</button>
    </article>
  <% } else if (activeRole === 'teacher') { %>
    <article class="guide-tour-tile">
      <h3>Attendance</h3>
      <p>Learn filters, roster visibility, marking statuses, and saving attendance.</p>
      <button type="button" class="btn btn-ghost btn-sm" data-start-tour="teacher_attendance">Start Tour</button>
    </article>
    <article class="guide-tour-tile">
      <h3>Assignments</h3>
      <p>Learn assignment creation and submission/grading workflow entry points.</p>
      <button type="button" class="btn btn-ghost btn-sm" data-start-tour="teacher_assignments">Start Tour</button>
    </article>
  <% } else if (activeRole === 'counsellor') { %>
    <article class="guide-tour-tile">
      <h3>Leads</h3>
      <p>Learn lead list, add lead, and follow-up screens.</p>
      <button type="button" class="btn btn-ghost btn-sm" data-start-tour="counsellor_leads">Start Tour</button>
    </article>
  <% } else { %>
    <article class="guide-tour-tile">
      <h3>Dashboard And KYC</h3>
      <p>Learn warnings, KYC/document verification, and dashboard shortcuts.</p>
      <button type="button" class="btn btn-ghost btn-sm" data-start-tour="student_dashboard">Start Tour</button>
    </article>
    <article class="guide-tour-tile">
      <h3>Fee Ledger</h3>
      <p>Learn where to see total fees, paid amount, balance, and installments.</p>
      <button type="button" class="btn btn-ghost btn-sm" data-start-tour="student_fees">Start Tour</button>
    </article>
  <% } %>
</div>
