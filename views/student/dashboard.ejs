<%
  layout = 'main';
  title = 'My Dashboard';
  subtitle = `Welcome, ${user.name}! Track your learning stats`;
  page = 'dashboard';

  const netDue = fee ? Math.max(0, fee.totalAmount - (fee.discount || 0) - fee.paidAmount) : 0;
  const pendingUpdate = user.pendingProfileUpdate || {};
  const effectiveFatherName = user.fatherName || pendingUpdate.fatherName;
  const effectiveGuardianPhone = user.guardianPhone || pendingUpdate.guardianPhone;
  const hasNoIdProof = !user.idProof;
  const isIdNotVerified = user.idProof && !user.idVerified;
  const isKycIncomplete = hasNoIdProof || !effectiveFatherName || !effectiveGuardianPhone;
  const isNotEnrolled = typeof notEnrolled !== 'undefined' && notEnrolled;
  const todaySchedules = isNotEnrolled ? [] : (schedules || []).filter(s => s.date === today);
  const nextClass = isNotEnrolled ? null : ((schedules || []).find(s => s.status === 'scheduled') || (schedules || [])[0] || null);
  const nextUpdate = (updates || [])[0] || null;
  const nextMessage = (messages || [])[0] || null;
  const latestRemarks = user.remarks && user.remarks.length ? user.remarks.slice().reverse().slice(0, 2) : [];
  const assignmentSummary = assignmentStats || { pending: (pendingAssignments || []).length, submitted: 0, graded: 0, closed: 0 };
  const assignmentResults = recentAssignmentResults || [];
  const weekClasses = [];
  const weekdayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

  if (!isNotEnrolled && daysTimetable) {
    weekdayNames.forEach((day, index) => {
      const classes = daysTimetable[day] || [];
      if (classes.length) {
        weekClasses.push({ day, date: weekDates[index], classes });
      }
    });
  }

  let primaryAction = {
    label: 'Open assignments',
    href: '/student/assignments',
    title: 'You are all caught up',
    body: 'No urgent task is waiting right now. Keep an eye on class updates and upcoming sessions.',
    tone: 'calm'
  };

  if (isKycIncomplete) {
    primaryAction = {
      label: 'Complete verification',
      href: '/auth/profile#document-verification',
      title: 'Complete verification first',
      body: 'Upload your ID and parent/guardian details to keep your account fully active.',
      tone: 'danger'
    };
  } else if (isIdNotVerified) {
    primaryAction = {
      label: 'View profile',
      href: '/auth/profile#document-verification',
      title: 'Verification is under review',
      body: 'Your ID document is uploaded. The academy team will approve it soon.',
      tone: 'warn'
    };
  } else if ((pendingAssignments || []).length > 0) {
    primaryAction = {
      label: 'Submit homework',
      href: '/student/assignments',
      title: `${pendingAssignments.length} homework task${pendingAssignments.length > 1 ? 's' : ''} pending`,
      body: 'Open assignments and submit the pending work before the due date.',
      tone: 'warn'
    };
  } else if (netDue > 0) {
    primaryAction = {
      label: 'Review fee ledger',
      href: '/student/fees',
      title: `Rs. ${netDue.toLocaleString('en-IN')} fee balance`,
      body: fee && fee.dueDate ? `Next due date: ${new Date(fee.dueDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })}.` : 'Check your fee ledger for details.',
      tone: 'danger'
    };
  } else if (nextClass) {
    primaryAction = {
      label: 'See schedule',
      href: '#today-classes',
      title: 'Next class is ready',
      body: `${nextClass.course && nextClass.course.name ? nextClass.course.name : 'Class'} at ${nextClass.startTime || 'scheduled time'}.`,
      tone: 'calm'
    };
  }
%>

<div class="student-dashboard">
  <section class="student-hero">
    <div>
      <p class="student-kicker">Today at a glance</p>
      <h2 id="dashboardGreeting" class="dashboard-greeting">Welcome back!</h2>
      <p class="student-hero-sub">
        <%= isNotEnrolled ? 'Your batch assignment is pending. Contact the academy team to activate your class schedule.' : 'Everything important is grouped here. Use the buttons when you need the full page.' %>
      </p>
    </div>

    <div class="next-action-card <%= primaryAction.tone %>">
      <span class="next-action-label">Next step</span>
      <strong><%= primaryAction.title %></strong>
      <p><%= primaryAction.body %></p>
      <a href="<%= primaryAction.href %>" class="btn btn-primary btn-sm"><%= primaryAction.label %></a>
    </div>
  </section>

  <% if (user.status === 'complete' && user.feedback && user.feedback.submitted) { %>
    <section class="student-complete-card">
      <div>
        <span class="student-kicker">Course complete</span>
        <h3>Congratulations on your graduation</h3>
        <p>Your completion certificate is unlocked and ready.</p>
      </div>
      <a href="/student/certificate" target="_blank" class="btn btn-primary">Download Certificate</a>
    </section>
  <% } %>

  <section class="student-metric-grid">
    <a href="/student/attendance" class="student-metric-card">
      <span>Attendance</span>
      <strong><%= (attendancePct !== null && attendancePct !== undefined) ? attendancePct + '%' : '-' %></strong>
      <small><%= presentCount %> of <%= totalClasses %> sessions attended</small>
    </a>
    <a href="/student/assignments" class="student-metric-card">
      <span>Homework</span>
      <strong><%= assignmentSummary.pending %></strong>
      <small><%= assignmentSummary.graded %> graded, <%= assignmentSummary.submitted %> submitted</small>
    </a>
    <a href="/student/fees" class="student-metric-card">
      <span>Fees</span>
      <strong>Rs. <%= netDue.toLocaleString('en-IN') %></strong>
      <small><%= netDue > 0 && fee && fee.dueDate ? `Due ${new Date(fee.dueDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })}` : 'No outstanding invoice' %></small>
    </a>
    <a href="/auth/profile#document-verification" class="student-metric-card">
      <span>Verification</span>
      <strong><%= user.idVerified ? 'Done' : user.idProof ? 'Review' : 'Missing' %></strong>
      <small><%= user.idVerified ? 'ID approved' : user.idProof ? 'Waiting for approval' : 'Upload ID proof' %></small>
    </a>
  </section>

  <% if (fee && fee.installments && fee.installments.length > 0) { %>
    <details class="student-details-card">
      <summary>
        <span>Fee installment plan</span>
        <strong><%= fee.installments.filter(inst => inst.paidAmount >= inst.amount).length %>/<%= fee.installments.length %> paid</strong>
      </summary>
      <div class="student-installments">
        <% fee.installments.forEach(inst => { %>
          <%
            const isPaid = inst.paidAmount >= inst.amount;
            const pct = inst.amount > 0 ? Math.min(100, Math.round((inst.paidAmount / inst.amount) * 100)) : 0;
          %>
          <div class="student-installment <%= isPaid ? 'paid' : '' %>">
            <div>
              <strong><%= inst.name %></strong>
              <span>Due <%= new Date(inst.dueDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
            </div>
            <div class="student-installment-amount">Rs. <%= inst.amount.toLocaleString('en-IN') %></div>
            <div class="student-mini-progress"><span style="width: <%= pct %>%"></span></div>
          </div>
        <% }) %>
      </div>
    </details>
  <% } %>

  <section class="student-dashboard-grid">
    <div class="card student-panel" id="today-classes">
      <div class="student-panel-head">
        <div>
          <span class="student-kicker">Classes</span>
          <h3>Today</h3>
        </div>
        <a href="/student/attendance" class="btn btn-ghost btn-sm">Attendance</a>
      </div>

      <% if (isNotEnrolled) { %>
        <div class="student-empty">Batch is not assigned yet.</div>
      <% } else if (todaySchedules.length === 0) { %>
        <div class="student-empty">No classes scheduled for today.</div>
      <% } else { %>
        <div class="student-class-list">
          <% todaySchedules.forEach(sched => { %>
            <div class="student-class-item">
              <div>
                <strong><%= (sched.course && sched.course.name) || sched.note || 'Class' %></strong>
                <span><%= sched.teacher && sched.teacher.user ? sched.teacher.user.name : sched.teacher ? sched.teacher.name : 'Teacher' %></span>
              </div>
              <time><%= sched.startTime %> - <%= sched.endTime %></time>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="card student-panel">
      <div class="student-panel-head">
        <div>
          <span class="student-kicker">Homework</span>
          <h3>Pending deadlines</h3>
        </div>
        <a href="/student/assignments" class="btn btn-ghost btn-sm">All</a>
      </div>

      <% if ((pendingAssignments || []).length === 0) { %>
        <% if (assignmentResults.length === 0) { %>
          <div class="student-empty">You are all caught up.</div>
        <% } else { %>
          <div class="assignment-status-strip" aria-label="Assignment status summary">
            <span><strong><%= assignmentSummary.pending %></strong> pending</span>
            <span><strong><%= assignmentSummary.submitted %></strong> submitted</span>
            <span><strong><%= assignmentSummary.graded %></strong> graded</span>
          </div>
          <div class="student-task-list">
            <% assignmentResults.forEach(item => { %>
              <% const sub = item.submission; const assign = item.assignment; %>
              <a href="/student/assignments#assignment-<%= assign._id %>" class="student-task-item">
                <strong><%= assign.title %></strong>
                <span>
                  <%= sub.status === 'graded' || sub.marks !== null ? `Graded${sub.marks !== null ? `: ${sub.marks}/${assign.totalMarks}` : ''}` : 'Submitted for review' %>
                </span>
              </a>
            <% }) %>
          </div>
        <% } %>
      <% } else { %>
        <div class="assignment-status-strip" aria-label="Assignment status summary">
          <span><strong><%= assignmentSummary.pending %></strong> pending</span>
          <span><strong><%= assignmentSummary.submitted %></strong> submitted</span>
          <span><strong><%= assignmentSummary.graded %></strong> graded</span>
        </div>
        <div class="student-task-list">
          <% pendingAssignments.slice(0, 3).forEach(assign => { %>
            <a href="/student/assignments" class="student-task-item">
              <strong><%= assign.title %></strong>
              <span><%= assign.course && assign.course.name ? assign.course.name : 'Assignment' %> · Due <%= new Date(assign.dueDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></span>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="card student-panel student-panel-wide">
      <div class="student-panel-head">
        <div>
          <span class="student-kicker">Weekly timetable</span>
          <h3><%= weekDates && weekDates.length ? `${weekDates[0].toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })} - ${weekDates[6].toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })}` : 'This week' %></h3>
        </div>
        <div class="student-week-actions">
          <a href="?weekOffset=<%= weekOffset - 1 %>" class="btn btn-ghost btn-sm">Previous</a>
          <% if (weekOffset !== 0) { %><a href="?weekOffset=0" class="btn btn-ghost btn-sm">Current</a><% } %>
          <a href="?weekOffset=<%= weekOffset + 1 %>" class="btn btn-ghost btn-sm">Next</a>
        </div>
      </div>

      <% if (isNotEnrolled) { %>
        <div class="student-empty">Timetable will appear after batch assignment.</div>
      <% } else if (weekClasses.length === 0) { %>
        <div class="student-empty">No classes scheduled this week.</div>
      <% } else { %>
        <div class="student-week-strip">
          <% weekClasses.forEach(dayBlock => { %>
            <div class="student-week-day">
              <span><%= dayBlock.day.slice(0, 3) %> · <%= dayBlock.date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></span>
              <% dayBlock.classes.slice(0, 2).forEach(sched => { %>
                <div>
                  <strong><%= sched.startTime %></strong>
                  <small><%= sched.course && sched.course.name ? sched.course.name : 'Class' %></small>
                </div>
              <% }) %>
              <% if (dayBlock.classes.length > 2) { %>
                <em>+<%= dayBlock.classes.length - 2 %> more</em>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="card student-panel">
      <div class="student-panel-head">
        <div>
          <span class="student-kicker">Messages</span>
          <h3>Academy notes</h3>
        </div>
        <a href="/auth/inbox" class="btn btn-ghost btn-sm">Inbox</a>
      </div>

      <% if (!nextMessage) { %>
        <div class="student-empty">No new academy messages.</div>
      <% } else { %>
        <div class="student-message-list">
          <% (messages || []).slice(0, 2).forEach(msg => { %>
            <div class="student-message-item">
              <strong><%= msg.content %></strong>
              <span><%= msg.sender ? msg.sender.name : 'System' %> · <%= new Date(msg.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></span>
              <% if (msg.attachments && msg.attachments.length) { %>
                <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:8px;">
                  <% msg.attachments.forEach(file => { %>
                    <a href="<%= file.url %>" target="_blank" rel="noopener" class="btn btn-ghost btn-xs"><%= file.fileName || 'Open material' %></a>
                  <% }) %>
                </div>
              <% } else { %>
                <a href="/auth/inbox" class="btn btn-ghost btn-xs" style="margin-top:8px;">Open inbox</a>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="card student-panel">
      <div class="student-panel-head">
        <div>
          <span class="student-kicker">Class updates</span>
          <h3>Latest from teacher</h3>
        </div>
        <a href="/student/updates" class="btn btn-ghost btn-sm">All</a>
      </div>

      <% if (!nextUpdate) { %>
        <div class="student-empty">No class updates published yet.</div>
      <% } else { %>
        <div class="student-update-list">
          <% (updates || []).slice(0, 3).forEach(up => { %>
            <%
              const updateTopics = (up.coveredTopics || []).map(t => t.title).filter(Boolean);
              if (updateTopics.length === 0 && up.topics && up.topics.length) {
                updateTopics.push(...up.topics);
              }
              if (updateTopics.length === 0 && up.content) {
                updateTopics.push(...String(up.content).split(',').map(t => t.trim()).filter(Boolean));
              }
            %>
            <a href="/student/updates" class="student-update-item">
              <strong><%= up.subject || (up.course && up.course.name) || 'Class update' %></strong>
              <span><%= up.homework ? up.homework : (updateTopics.length ? updateTopics.join(', ') : 'Update posted') %></span>
              <small><%= new Date(up.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></small>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>

    <% if (latestRemarks.length) { %>
      <div class="card student-panel student-panel-wide">
        <div class="student-panel-head">
          <div>
            <span class="student-kicker">Staff remarks</span>
            <h3>Recent notes</h3>
          </div>
        </div>
        <div class="student-remark-list">
          <% latestRemarks.forEach(rem => { %>
            <div class="student-remark-item">
              <strong><%= rem.note %></strong>
              <span><%= rem.role ? rem.role.toUpperCase() : 'STAFF' %> · <%= new Date(rem.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </section>
</div>
