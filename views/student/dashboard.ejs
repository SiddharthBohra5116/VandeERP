<%
  layout = 'main';
  title = 'My Dashboard';
  subtitle = `Welcome, ${user.name}! Track your learning stats`;
  page = 'dashboard';
%>

<!-- Stats Calculation -->
<% 
  const netDue = fee ? Math.max(0, fee.totalAmount - (fee.discount || 0) - fee.paidAmount) : 0;
  
  const missingFields = [];
  if (!user.phone) missingFields.push('Phone Number');
  if (!user.dob) missingFields.push('Date of Birth');
  if (!user.address || !user.city) missingFields.push('Address & City');
  if (!user.fatherName) missingFields.push('Father\'s Name');
  if (!user.guardianPhone) missingFields.push('Guardian\'s Phone');
  
  const hasMissingFields = missingFields.length > 0;
  const hasNoIdProof = !user.idProof;
  const isIdNotVerified = user.idProof && !user.idVerified;
  const isKycIncomplete = hasNoIdProof || !user.fatherName || !user.guardianPhone;
%>

<!-- Greeting Header -->
<h2 id="dashboardGreeting" style="font-family: var(--font-display); font-weight: 800; font-size: 1.6rem; color: var(--gold); margin-bottom: 1.5rem;">Welcome back!</h2>

<!-- Document Verification Banner -->
<% if (isKycIncomplete) { %>
  <div class="card" style="border: 2px solid var(--red); background: rgba(239, 68, 68, 0.06); margin-bottom: 1.5rem; padding: 1.25rem 1.5rem;">
    <div style="display: flex; align-items: flex-start; gap: 1rem;">
      <div style="background: rgba(239, 68, 68, 0.12); border: 1px solid rgba(239, 68, 68, 0.25); border-radius: var(--radius); padding: 0.55rem; flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: var(--red);">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="7" y1="9" x2="17" y2="9"/><line x1="7" y1="13" x2="13" y2="13"/></svg>
      </div>
      <div style="flex: 1;">
        <h3 style="font-size: 1rem; font-weight: 700; color: var(--red); margin-bottom: 0.4rem;">
          Document Verification Pending
        </h3>
        <p style="font-size: 0.85rem; color: var(--text-sub); margin-bottom: 0.85rem; line-height: 1.5;">
          Please complete the following to activate your full account. This is required for attendance, assignments, and your completion certificate.
        </p>
        <ul style="margin: 0 0 1rem 0; padding-left: 1.2rem; font-size: 0.84rem; color: var(--text); line-height: 1.7;">
          <% if (hasNoIdProof) { %>
            <li><strong>Upload your ID document</strong> — a government-issued photo ID (e.g. Aadhaar, passport, or school ID).</li>
          <% } %>
          <% if (!user.fatherName) { %>
            <li><strong>Add your parent / guardian name</strong> — required for enrollment records.</li>
          <% } %>
          <% if (!user.guardianPhone) { %>
            <li><strong>Add a guardian contact number</strong> — required for emergency contact.</li>
          <% } %>
        </ul>
        <a href="/auth/profile#document-verification" class="btn btn-red btn-sm" style="font-weight: 600;">Complete Document Verification &rarr;</a>
      </div>
    </div>
  </div>
<% } else if (isIdNotVerified) { %>
  <div class="card" style="border: 1px solid rgba(195,155,52,0.5); background: rgba(195,155,52,0.05); margin-bottom: 1.5rem; padding: 1rem 1.25rem;">
    <div style="display: flex; align-items: center; gap: 0.85rem;">
      <div style="color: var(--gold); flex-shrink: 0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <div>
        <span style="font-size: 0.87rem; font-weight: 600; color: var(--gold);">Document Verification in progress</span>
        <span style="font-size: 0.82rem; color: var(--text-sub); margin-left: 0.5rem;">— Your document has been uploaded and is being reviewed by the academy. No further action needed.</span>
      </div>
    </div>
  </div>
<% } else if (hasMissingFields) { %>
  <div class="card" style="border: 1px solid rgba(239, 68, 68, 0.3); background: rgba(239, 68, 68, 0.04); margin-bottom: 1.5rem; padding: 1rem 1.25rem;">
    <div style="display: flex; align-items: flex-start; gap: 0.85rem;">
      <div style="color: var(--red); flex-shrink: 0; margin-top: 2px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <div>
        <span style="font-size: 0.87rem; font-weight: 600; color: var(--red);">Profile incomplete</span>
        <span style="font-size: 0.82rem; color: var(--text-sub); margin-left: 0.4rem;">— Missing: <strong><%= missingFields.join(', ') %></strong>.</span>
        <a href="/auth/profile" style="font-size: 0.82rem; color: var(--gold); text-decoration: underline; margin-left: 0.5rem;">Update profile &rarr;</a>
      </div>
    </div>
  </div>
<% } %>

<% if (user.status === 'complete' && user.feedback && user.feedback.submitted) { %>
  <div class="card" style="border: 2px solid var(--gold); background: linear-gradient(135deg, rgba(195,155,52,0.1) 0%, rgba(0,0,0,0) 100%); margin-bottom: 1.5rem; text-align: center; padding: 2rem 1.5rem;">
    <div style="font-size: 2.5rem; margin-bottom: 0.5rem;">🎓</div>
    <h3 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 800; color: var(--gold); margin-bottom: 0.5rem;">Congratulations on Your Graduation!</h3>
    <p style="color: var(--text-sub); font-size: 0.9rem; max-width: 600px; margin: 0 auto 1.25rem auto;">You have successfully completed all syllabus goals, assignments, and curriculum projects. Your formal certificate of completion is now unlocked and available.</p>
    <a href="/student/certificate" target="_blank" class="btn" style="background: var(--gold); color: black; font-weight: 700; border-color: var(--gold); padding: 0.6rem 1.5rem;">Download Completion Certificate</a>
  </div>
<% } %>

<% if (typeof notEnrolled === 'undefined' || !notEnrolled) { %>
<div class="stats-grid">
  <a href="/student/attendance" class="stat-card green" style="display: block; text-decoration: none; transition: transform 0.2s;">
    <div class="stat-label">Attendance Rate</div>
    <div class="stat-value"><%= (attendancePct !== null && attendancePct !== undefined) ? attendancePct + '%' : '—' %></div>
    <div class="stat-sub">Attended: <%= presentCount %> / <%= totalClasses %> sessions</div>
  </a>
  <a href="/student/assignments" class="stat-card gold" style="display: block; text-decoration: none; transition: transform 0.2s;">
    <div class="stat-label">Pending Homework</div>
    <div class="stat-value"><%= pendingAssignments.length %></div>
    <div class="stat-sub">Assignments requiring submission</div>
  </a>
  <a href="/student/fees" class="stat-card red" style="display: block; text-decoration: none; transition: transform 0.2s;">
    <div class="stat-label">Outstanding Fees Due</div>
    <div class="stat-value">₹<%= netDue.toLocaleString('en-IN') %></div>
    <div class="stat-sub">
      <%= fee && fee.dueDate ? 'Next due on: ' + new Date(fee.dueDate).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) : 'No outstanding invoice' %>
      <% if (fee && fee.totalFine > 0) { %> (Includes ₹<%= fee.totalFine %> fines)<% } %>
    </div>
  </a>
</div>
<% } else { %>
  <div class="card" style="border: 1px solid var(--gold); background: linear-gradient(135deg, rgba(255, 204, 0, 0.05) 0%, rgba(0, 0, 0, 0) 100%); margin-bottom: 1.5rem; text-align: center; padding: 2.5rem 1.5rem;">
    <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">🗓️</div>
    <h3 style="font-family: var(--font-display); font-size: 1.3rem; font-weight: 800; color: var(--gold); margin-bottom: 0.5rem;">Batch Assignment Pending</h3>
    <p style="color: var(--text-sub); font-size: 0.9rem; max-width: 600px; margin: 0 auto;">You have not been assigned to a batch yet. Please contact the admin.</p>
  </div>
<% } %>

<!-- Tuition Installments Schedule (Student View) -->
<% if (fee && fee.installments && fee.installments.length > 0) { %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
      <div class="card-title" style="display:flex; align-items:center; gap:0.4rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--gold);">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"/><line x1="12" y1="10" x2="12" y2="14"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        Tuition Fee Installment Schedule
      </div>
      <% if (fee.totalFine > 0) { %>
        <span class="badge badge-red" style="font-size: 10px;">⚠️ Late Fines Accrued: +₹<%= fee.totalFine.toLocaleString('en-IN') %></span>
      <% } %>
    </div>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; padding-top: 0.5rem;">
      <% fee.installments.forEach(inst => { %>
        <% 
          const isPaid = inst.paidAmount >= inst.amount;
          const isLate = !isPaid && inst.dueDate && new Date(inst.dueDate) < new Date();
          
          let fine = 0;
          if (isLate) {
            const diffDays = Math.ceil(Math.abs(new Date() - new Date(inst.dueDate)) / (1000 * 60 * 60 * 24));
            if (diffDays > 60) fine = 1000;
            else if (diffDays > 30) fine = 500;
            else fine = 250;
          }

          const statusLabel = isPaid ? 'Paid' : isLate ? 'Overdue' : 'Pending';
          const statusBadgeClass = isPaid ? 'badge-green' : isLate ? 'badge-red' : 'badge-orange';
          const instPct = inst.amount > 0 ? Math.round((inst.paidAmount / inst.amount) * 100) : 0;
        %>
        <div <%= isLate ? 'style="background:var(--bg-input); border: 1px solid rgba(239,68,68,0.2); border-radius:var(--radius); padding: 12px 14px; display:flex; flex-direction:column; gap:4px;"' : 'style="background:var(--bg-input); border: 1px solid var(--border); border-radius:var(--radius); padding: 12px 14px; display:flex; flex-direction:column; gap:4px;"' %>>
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span style="font-size:12px; font-weight:700; color:var(--text);"><%= inst.name %></span>
            <span class="badge <%= statusBadgeClass %>" style="font-size:8px; padding:1px 4px;"><%= statusLabel %></span>
          </div>
          <div style="font-size:16px; font-weight:800; color:var(--gold); font-family:var(--mono);">
            ₹<%= inst.amount.toLocaleString('en-IN') %>
          </div>
          <div style="font-size:10px; color:var(--text-muted);">
            Due Date: <span class="mono"><%= new Date(inst.dueDate).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></span>
          </div>
          <% if (fine > 0) { %>
            <div style="font-size:10px; color:var(--red); font-weight:700; margin-top:2px;">
              ⚠️ Penalty: +₹<%= fine %>
            </div>
          <% } %>
          <div style="margin-top:auto; padding-top:4px;">
            <div style="display:flex; justify-content:space-between; font-size:9px; color:var(--text-muted); margin-bottom:2px;">
              <span>Paid: ₹<%= inst.paidAmount.toLocaleString('en-IN') %></span>
              <span><%= instPct %>%</span>
            </div>
            <div class="progress-bar" style="height:3px; background:rgba(255,255,255,0.05); border-radius:4px;">
              <div class="progress-fill <%= isPaid ? 'green' : instPct > 0 ? 'orange' : 'red' %>" <%= `style="width: ${instPct}%"` %>></div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
<% } %>

<!-- Admin & Faculty Alerts -->
<div class="card" style="margin-bottom: 1.5rem; border-color: var(--gold-border); background: linear-gradient(180deg, rgba(255,204,0,0.02) 0%, rgba(0,0,0,0) 100%);">
  <div class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">
    <div class="card-title" style="color:var(--gold); font-size:0.75rem; letter-spacing:0.05em; display:flex; align-items:center; gap:0.4rem; text-transform: uppercase;">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      Direct Messages & Notifications
    </div>
  </div>
  <% if (typeof messages === 'undefined' || !messages || messages.length === 0) { %>
    <div class="empty-state" style="padding: 1.5rem 1rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.2; margin-bottom:0.5rem;"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <p style="font-size:0.78rem;">No personal messages or notifications from the academy staff.</p>
    </div>
  <% } else { %>
    <div style="display:flex; flex-direction:column; gap:0.6rem; padding: 0.25rem 0.5rem;">
      <% messages.forEach(msg => { %>
        <div style="background:var(--bg-input); padding:0.65rem 0.85rem; border-radius:var(--radius); border-left: 2px solid var(--gold); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); border-right: 1px solid var(--border);">
          <p style="font-size:0.85rem; color:var(--text); line-height:1.4; margin: 0;"><%= msg.content %></p>
          <div style="display:flex; justify-content:space-between; font-size:0.7rem; color:var(--text-muted); margin-top:0.35rem;">
            <span>From: <%= msg.sender ? msg.sender.name : 'System' %> (<%= msg.sender ? msg.sender.role : 'Staff' %>)</span>
            <span><%= new Date(msg.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %> · <%= new Date(msg.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- Identity Verification Status -->
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">
    <div class="card-title" style="display:flex; align-items:center; gap:0.4rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      Identity Verification Document (Aadhaar / PAN Card)
    </div>
    <span class="badge <%= user.idVerified ? 'badge-green' : (user.idProof ? 'badge-orange' : 'badge-red') %>" style="font-size: 0.65rem; padding: 2px 6px;">
      <%= user.idVerified ? 'Verified' : (user.idProof ? 'Verification Pending' : 'Missing ID Proof') %>
    </span>
  </div>

  <% if (user.idVerified) { %>
    <div style="display: flex; align-items: center; gap: 10px; color: var(--green); font-size: 0.85rem; padding: 0.5rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <span>Your identity document has been verified and approved by the academy administration.</span>
    </div>
  <% } else if (user.idProof) { %>
    <div style="display: flex; flex-direction: column; gap: 10px; font-size: 0.85rem; padding: 0.5rem;">
      <div style="display: flex; align-items: center; gap: 10px; color: var(--gold);">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>Your ID proof document has been uploaded. Waiting for admin approval and verification.</span>
      </div>
      <div style="max-width: 150px; border: 1px solid var(--border); border-radius: 4px; overflow: hidden; background: var(--bg-input);">
        <img src="<%= user.idProof %>" alt="ID Proof Preview" style="width: 100%; height: auto; display: block; max-height: 80px; object-fit: contain;">
      </div>
    </div>
  <% } else { %>
    <form action="/student/profile/upload-id" method="POST" enctype="multipart/form-data" style="margin: 0; padding: 0.5rem;">
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;">Please upload a scanned image or photo of your Aadhaar card or PAN card to complete your enrollment verification.</p>
        <div style="display: flex; gap: 10px; align-items: center; margin-top: 4px;">
          <input type="file" name="idProof" accept="image/*" class="form-control" required style="max-width: 300px; padding: 3px 10px; height: auto; font-size: 12px;">
          <button type="submit" class="btn btn-primary btn-xs">Upload ID Proof</button>
        </div>
      </div>
    </form>
  <% } %>
</div>

<div class="grid-2">
  <% if (typeof notEnrolled === 'undefined' || !notEnrolled) { %>
  <% 
    const todaySchedules = schedules.filter(s => s.date === today);
  %>
  <!-- Today's Schedule Card -->
  <div style="grid-column: span 2; margin-bottom: 1rem;" class="card">
    <div class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">
      <div class="card-title" style="display:flex; align-items:center; gap:0.4rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Today's Schedule & Classes
      </div>
    </div>
    <% if (todaySchedules.length === 0) { %>
      <div class="empty-state" style="padding: 1rem;">
        <p style="font-size:0.78rem; color: var(--text-muted);">No classes scheduled for today.</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Subject</th>
              <th>Classroom</th>
              <th>Time Slot</th>
              <th>Instructor</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% todaySchedules.forEach(sched => { %>
              <tr>
                <td><strong><%= sched.note || '—' %></strong></td>
                <td><%= sched.classroom ? sched.classroom.name : '—' %></td>
                <td class="mono text-xs"><%= sched.startTime %> - <%= sched.endTime %></td>
                <td><%= sched.teacher ? sched.teacher.name : '—' %></td>
                <td>
                  <span class="badge <%= sched.status === 'scheduled' ? 'badge-green' : (sched.status === 'completed' ? 'badge-blue' : 'badge-red') %>">
                    <%= sched.status %>
                  </span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Class Schedules / Batch Timetable (Weekly Grid) -->
  <div style="grid-column: span 2; margin-bottom: 0.5rem;">
    <%- include('../partials/_weekly_timetable', { daysTimetable, weekDates, weekOffset, viewType: 'student' }) %>
  </div>

  <!-- Homework Tasks due -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">Pending Deadlines</div>
      <a href="/student/assignments" class="btn btn-ghost btn-sm">All Assignments</a>
    </div>
    
    <% if (pendingAssignments.length === 0) { %>
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <p>You're all caught up! No pending homework tasks found.</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Title</th>
              <th>Subject</th>
              <th>Due Date</th>
            </tr>
          </thead>
          <tbody>
            <% pendingAssignments.forEach(assign => { %>
              <tr>
                <td class="td-name"><a href="/student/assignments" style="color:var(--gold);"><%= assign.title %></a></td>
                <td><%= assign.course && assign.course.name ? assign.course.name : '—' %></td>
                <td class="mono text-sm text-red fw-600">
                  <%= new Date(assign.dueDate).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Recent Class Updates Feed -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">Recent Class Updates</div>
      <a href="/student/updates" class="btn btn-ghost btn-sm">All Updates</a>
    </div>
    
    <% if (updates.length === 0) { %>
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        <p>No class updates published yet.</p>
      </div>
    <% } else { %>
      <div class="timeline" style="margin-top: 0.5rem; padding-left: 0.5rem;">
        <% updates.forEach((up, index) => { %>
          <div class="timeline-item">
            <div class="timeline-dot <%= index === 0 ? 'active' : '' %>"></div>
            <div class="timeline-body">
              <div style="font-size:13px; font-weight:600;"><%= up.subject %> &nbsp;·&nbsp; <span class="td-muted text-xs">By <%= up.teacher ? up.teacher.name : 'Teacher' %></span></div>
              <div class="timeline-meta"><%= new Date(up.date).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %></div>
              <div class="mt-1 text-sm text-sub" style="line-height:1.4;"><%= up.homework ? 'Homework: ' + up.homework : 'Topics: ' + (up.topics ? up.topics.join(', ') : '') %></div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
  <% } %>

  <!-- Staff Remarks Timeline -->
  <% if (user.remarks && user.remarks.length > 0) { %>
    <div class="card" style="margin-top: 1rem; grid-column: span 2;">
      <div class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">
        <div class="card-title" style="display:flex; align-items:center; gap:0.4rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Academy Faculty & Staff Remarks
        </div>
      </div>
      <div class="timeline" style="padding-left: 0.5rem;">
        <% user.remarks.slice().reverse().forEach(rem => { %>
          <div class="timeline-item">
            <div class="timeline-dot active" style="background: var(--gold);"></div>
            <div class="timeline-body">
              <div style="font-size:13px; font-weight:600; color: var(--text);"><%= rem.note %></div>
              <div style="font-size:10px; color:var(--text-muted); margin-top: 4px;">
                Posted by: <span style="color: var(--gold);"><%= rem.role ? rem.role.toUpperCase() : 'STAFF' %></span> &nbsp;·&nbsp; 
                <%= new Date(rem.date).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- Send Message Note to Staff -->
  <div class="card" style="margin-top: 1rem; grid-column: span 2;">
    <div class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">
      <div class="card-title" style="display:flex; align-items:center; gap:0.4rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Send Query / Message Note to Staff
      </div>
    </div>
    <form action="/student/messages/send" method="POST" style="margin: 0; padding: 0;">
      <input type="hidden" name="redirect" value="/student/dashboard">
      <div class="form-row">
        <div class="form-group" style="flex: 1;">
          <label class="form-label" style="font-size: 10px;">Select Recipient *</label>
          <select name="recipientId" class="form-control" required>
            <% if (typeof admin !== 'undefined' && admin) { %>
              <option value="<%= admin._id %>">Vande Academy Admin (Office)</option>
            <% } %>
            <% if (user.teacher) { %>
              <option value="<%= user.teacher._id %>">Primary Instructor: <%= user.teacher.name %></option>
            <% } %>
            <% if (user.counsellor) { %>
              <option value="<%= user.counsellor._id %>">Assigned Counsellor: <%= user.counsellor.name %></option>
            <% } %>
          </select>
        </div>
      </div>
      <div class="form-group" style="margin-top: 0.75rem;">
        <label class="form-label" style="font-size: 10px;">Message Content *</label>
        <textarea name="content" class="form-control" placeholder="Type message note to send..." required style="min-height: 80px;"></textarea>
      </div>
      <div style="display: flex; justify-content: flex-end; margin-top: 0.75rem;">
        <button type="submit" class="btn btn-primary btn-sm">Send Message</button>
      </div>
    </form>
  </div>
</div>
