<%
  layout = 'main';
  title = 'Class Updates';
  subtitle = 'Daily log of topics taught and assigned home tasks';
  page = 'updates';
%>

<div class="card" style="padding: 1rem 1.25rem; margin-bottom: 1.25rem;">
  <form method="GET" action="/student/updates" class="filter-bar form-inline">
    <div class="form-group">
      <label class="form-label" for="subjectFilter" style="margin-bottom:0.25rem;">Subject</label>
      <input type="text" id="subjectFilter" name="subject" class="form-control" style="padding:0.45rem 0.75rem;" placeholder="Filter by subject" value="<%= filter.subject || '' %>" onchange="this.form.submit()">
    </div>

    <div class="form-group">
      <label class="form-label" for="dateFilter" style="margin-bottom:0.25rem;">Date</label>
      <input type="date" id="dateFilter" name="date" class="form-control" style="padding:0.45rem 0.75rem;" value="<%= filter.date || '' %>" onchange="this.form.submit()">
    </div>

    <div style="display:flex; gap:0.5rem; align-items:flex-end;">
      <a href="/student/updates" class="btn btn-ghost btn-sm">Clear</a>
    </div>
  </form>
</div>

<div class="card">
  <div class="card-header">
    <div class="card-title">Classroom Lesson logs</div>
  </div>
  <% if (updates.length === 0) { %>
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      <p>No class updates posted for your batch cohort yet.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Subject / Instructor</th>
            <th>Topics Covered</th>
            <th>Homework assigned</th>
            <th>Reference Files</th>
          </tr>
        </thead>
        <tbody>
          <% updates.forEach(up => { %>
            <%
              const topics = (up.coveredTopics || []).map(t => t.title).filter(Boolean);
              if (topics.length === 0 && up.topics && up.topics.length) {
                topics.push(...up.topics);
              }
              if (topics.length === 0 && up.content) {
                topics.push(...String(up.content).split(',').map(t => t.trim()).filter(Boolean));
              }
            %>
            <tr>
              <td class="mono text-sm fw-600"><%= up.date %></td>
              <td>
                <div style="font-weight:600;"><%= up.course && up.course.name ? up.course.name : up.subject %></div>
                <div class="td-muted text-sm">Instructor: <%= up.teacher && up.teacher.user ? up.teacher.user.name : 'Faculty' %></div>
              </td>
              <td>
                <div class="topics-list" style="margin-top:0;">
                  <% if (topics.length > 0) { %>
                    <% topics.forEach(topic => { %>
                      <span class="topic-tag"><%= topic %></span>
                    <% }) %>
                  <% } else { %>
                    <span class="td-muted">—</span>
                  <% } %>
                </div>
              </td>
              <td class="text-sm" style="max-width:250px; line-height:1.4;"><%= up.homework || 'None assigned' %></td>
              <td>
                <% if (up.fileUrl) { %>
                  <a href="<%= up.fileUrl %>" class="btn btn-ghost btn-xs" target="_blank" download="<%= up.fileName %>">
                    📥 Download Notes
                  </a>
                <% } else { %>
                  <span class="td-muted">No attachment</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
