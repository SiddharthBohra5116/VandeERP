<%
  layout = 'main';
  title = 'Attendance History';
  subtitle = 'Review previously marked class attendance logs';
  page = 'attendance-history';
%>

<%
  let totalLogs = records.length;
  let presentCount = records.filter(r => r.status === 'present').length;
  let absentCount = records.filter(r => r.status === 'absent').length;
  let lateCount = records.filter(r => r.status === 'late').length;
  let presentRate = totalLogs ? Math.round((presentCount / totalLogs) * 100) : 0;
%>

<style>
  tr.session-row {
    cursor: pointer;
    transition: background 0.2s ease;
  }
  tr.session-row:hover td {
    background: rgba(255, 204, 0, 0.03) !important;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .stat-card-premium {
    background: linear-gradient(145deg, var(--bg-card), #1b1b1b);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .stat-card-premium:hover {
    transform: translateY(-2px);
    border-color: var(--gold-border);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4), 0 0 15px rgba(255, 204, 0, 0.05);
  }

  .stat-card-premium::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 3px;
    background: transparent;
  }

  .stat-card-premium.total::after { background: var(--text-muted); }
  .stat-card-premium.present::after { background: var(--green); }
  .stat-card-premium.absent::after { background: var(--red); }
  .stat-card-premium.late::after { background: var(--orange); }

  .stat-value {
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1;
    margin: 0.5rem 0 0.25rem 0;
    font-family: var(--font-display);
  }

  .stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .stat-desc {
    font-size: 0.75rem;
    color: var(--text-sub);
  }

  .premium-filter-bar {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: flex-end;
  }

  .premium-filter-group {
    flex: 1;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .premium-filter-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-sub);
  }

  .premium-select, .premium-input {
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    padding: 0.65rem 1rem;
    font-size: 0.88rem;
    transition: all 0.2s ease;
    width: 100%;
  }

  .premium-select:focus, .premium-input:focus {
    border-color: var(--gold);
    outline: none;
    box-shadow: 0 0 0 3px var(--gold-dim);
  }

  .premium-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }

  .premium-table th {
    background: rgba(255, 255, 255, 0.02);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .premium-table td {
    padding: 1.25rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
    transition: background 0.2s ease;
  }

  .premium-table tbody tr:hover td {
    background: rgba(255, 255, 255, 0.01);
  }

  /* Mini Pills for Summary stats */
  .summary-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.55rem;
    border-radius: var(--radius);
    font-size: 0.72rem;
    font-weight: 600;
  }
  .summary-pill.present { background: rgba(34, 197, 94, 0.08); color: var(--green); }
  .summary-pill.absent { background: rgba(239, 68, 68, 0.08); color: var(--red); }
  .summary-pill.late { background: rgba(249, 115, 22, 0.08); color: var(--orange); }

  /* Modal Details */
  .details-modal-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(5px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    transition: opacity 0.2s ease;
    padding: 1.5rem;
  }
  .details-modal-overlay.open {
    display: flex;
    opacity: 1;
  }
  .details-modal {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 580px;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 25px 50px rgba(0,0,0,0.6), 0 0 0 1px var(--border-light);
    transform: translateY(20px);
    transition: transform 0.25s ease;
    overflow: hidden;
  }
  .details-modal-overlay.open .details-modal {
    transform: translateY(0);
  }
  .details-modal-header {
    padding: 1.5rem;
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  .details-modal-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .details-modal-close:hover {
    color: var(--text);
  }
  .details-modal-body {
    padding: 1.5rem;
    overflow-y: auto;
    flex: 1;
  }

  /* Roster table */
  .roster-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .roster-item {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .roster-status {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.25rem 0.55rem;
    border-radius: 50px;
  }
  .roster-status.present { background: rgba(34, 197, 94, 0.08); color: var(--green); border: 1px solid rgba(34, 197, 94, 0.15); }
  .roster-status.absent { background: rgba(239, 68, 68, 0.08); color: var(--red); border: 1px solid rgba(239, 68, 68, 0.15); }
  .roster-status.late { background: rgba(249, 115, 22, 0.08); color: var(--orange); border: 1px solid rgba(249, 115, 22, 0.15); }
</style>

<!-- Top Statistics Cards -->
<div class="stats-grid">
  <div class="stat-card-premium total">
    <div class="stat-label">Total Student Check-ins</div>
    <div class="stat-value"><%= totalLogs %></div>
    <div class="stat-desc">Historical logged records</div>
  </div>
  <div class="stat-card-premium present">
    <div class="stat-label">Average Present Rate</div>
    <div class="stat-value text-green"><%= presentRate %>%</div>
    <div class="stat-desc"><%= presentCount %> present logs</div>
  </div>
  <div class="stat-card-premium absent">
    <div class="stat-label">Total Absentees</div>
    <div class="stat-value text-red"><%= absentCount %></div>
    <div class="stat-desc">Required class follow-ups</div>
  </div>
  <div class="stat-card-premium late">
    <div class="stat-label">Total Late Checks</div>
    <div class="stat-value text-orange"><%= lateCount %></div>
    <div class="stat-desc">Exceptional late arrivals</div>
  </div>
</div>

<!-- Filters Bar -->
<div class="card" style="padding: 0; border: none; background: transparent; margin-bottom: 1.5rem;">
  <form method="GET" action="/teacher/attendance/history" class="filter-bar filter-form-container" style="margin:0;">
    <div class="premium-filter-bar">
      <!-- Course Selection First -->
      <div class="premium-filter-group">
        <label class="premium-filter-label">Course</label>
        <select name="course" id="historyCourseSelect" class="premium-select">
          <option value="">All Courses</option>
          <% courses.forEach(c => { %>
            <option value="<%= c._id %>" <%= String(filter.course) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>

      <!-- Batch Selection Second -->
      <div class="premium-filter-group">
        <label class="premium-filter-label">Batch</label>
        <select name="batch" id="historyBatchSelect" class="premium-select">
          <option value="">All Batches</option>
          <% batches.forEach(b => { %>
            <option value="<%= b._id %>" <%= String(filter.batch) === String(b._id) ? 'selected' : '' %>><%= b.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="premium-filter-group">
        <label class="premium-filter-label">Month</label>
        <input type="month" name="month" class="premium-input" value="<%= filter.month || '' %>">
      </div>

      <div style="display:flex; gap:0.5rem; align-items:flex-end; justify-content: flex-end;">
        <a href="/teacher/attendance/history" class="btn btn-ghost btn-sm" style="padding: 0.65rem 1.25rem; border-color: var(--border);">Reset Filters</a>
      </div>
    </div>
  </form>
</div>

<!-- Results Data Board -->
<div class="card" id="results-container" style="padding:0; overflow: hidden; border: 1px solid var(--border);">
  <% if (sessions.length === 0) { %>
    <div class="empty-state" style="padding: 4rem 2rem;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: 48px; height: 48px; margin-bottom: 1rem; color: var(--text-muted);">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      <p style="color: var(--text-sub); font-size: 0.95rem; font-weight: 500;">No class sessions found matching the active filters.</p>
      <span style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem;">Try choosing a different month or batch.</span>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table class="premium-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Course</th>
            <th>Batch</th>
            <th>Attendance Summary</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% sessions.forEach((s, idx) => { %>
            <tr class="session-row" data-students="<%= JSON.stringify(s.roster) %>" data-date="<%= s.date %>" data-batch="<%= s.batchName %>" data-course="<%= s.courseName %>">
              <td class="mono text-sm fw-600" style="color: var(--gold);"><%= s.date %></td>
              <td style="font-weight: 600;"><%= s.courseName %></td>
              <td>
                <span class="badge badge-grey" style="font-weight:600;"><%= s.batchName %></span>
              </td>
              <td>
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                  <span class="summary-pill present">🟢 <%= s.presentCount %> Present</span>
                  <span class="summary-pill absent">🔴 <%= s.absentCount %> Absent</span>
                  <span class="summary-pill late">🟡 <%= s.lateCount %> Late</span>
                </div>
              </td>
              <td>
                <button class="btn btn-ghost btn-xs" style="padding: 3px 8px; border-color: var(--border);">Details</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<!-- Class Session Details Modal -->
<div id="sessionDetailsModal" class="details-modal-overlay">
  <div class="details-modal">
    <div class="details-modal-header">
      <h3 id="modalSessionTitle" style="margin:0; font-family: var(--font-display); font-size: 1.1rem;">Class Session</h3>
      <div id="modalSessionSubtitle" style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.2rem;">Batch & Course info</div>
      <button class="details-modal-close" onclick="closeSessionDetailsModal()">&times;</button>
    </div>
    <div class="details-modal-body">
      <div class="students-list" id="modalRosterList">
        <!-- Populated dynamically -->
      </div>
    </div>
  </div>
</div>

<script>
// Cascading dropdown configuration
const teacherSchedules = <%- JSON.stringify(teacherSchedules || []) %>;

const setupCascadingDropdowns = () => {
  const courseSelect = document.getElementById('historyCourseSelect');
  const batchSelect = document.getElementById('historyBatchSelect');

  if (!courseSelect || !batchSelect) return;

  if (!batchSelect.dataset.originalOptions) {
    const opts = Array.from(batchSelect.options).map(opt => ({
      value: opt.value,
      text: opt.textContent
    }));
    batchSelect.dataset.originalOptions = JSON.stringify(opts);
  }

  const allBatchOptions = JSON.parse(batchSelect.dataset.originalOptions);

  courseSelect.addEventListener('change', () => {
    const selectedCourse = courseSelect.value;
    if (!selectedCourse) {
      batchSelect.innerHTML = '<option value="">All Batches</option>';
      allBatchOptions.forEach(opt => {
        if (opt.value) {
          batchSelect.add(new Option(opt.text, opt.value));
        }
      });
      return;
    }

    const validBatchIds = teacherSchedules
      .filter(s => s.course && s.course._id === selectedCourse)
      .map(s => s.batch ? s.batch._id : null)
      .filter(Boolean);

    const currentSelectedBatch = batchSelect.value;
    batchSelect.innerHTML = '<option value="">All Batches</option>';

    allBatchOptions.forEach(opt => {
      if (opt.value && validBatchIds.includes(opt.value)) {
        const newOpt = new Option(opt.text, opt.value);
        if (opt.value === currentSelectedBatch) newOpt.selected = true;
        batchSelect.add(newOpt);
      }
    });
  });

  batchSelect.addEventListener('change', () => {
    const selectedBatch = batchSelect.value;
    if (!selectedBatch) return;

    const match = teacherSchedules.find(s => s.batch && s.batch._id === selectedBatch);
    if (match && match.course) {
      const targetCourseId = match.course._id;
      if (courseSelect.value !== targetCourseId) {
        courseSelect.value = targetCourseId;
        courseSelect.dispatchEvent(new Event('change'));
      }
    }
  });

  if (courseSelect.value) {
    courseSelect.dispatchEvent(new Event('change'));
  }
};

const openSessionDetailsModal = (sessionRow) => {
  const date = sessionRow.dataset.date;
  const batch = sessionRow.dataset.batch;
  const course = sessionRow.dataset.course;
  const studentsList = JSON.parse(sessionRow.dataset.students);

  document.getElementById('modalSessionTitle').textContent = `Class Session: ${date}`;
  document.getElementById('modalSessionSubtitle').textContent = `${course} · Batch: ${batch}`;

  let studentsHtml = '';
  studentsList.forEach(r => {
    const statusClass = r.status === 'present' ? 'present' : r.status === 'absent' ? 'absent' : 'late';
    studentsHtml += `
      <div class="roster-item">
        <div>
          <div style="font-weight:600; color:var(--text);">${r.studentName}</div>
          ${r.note ? `<div style="font-size:0.75rem; color:var(--gold); margin-top:0.15rem;">Note: ${r.note}</div>` : ''}
        </div>
        <div>
          <span class="roster-status ${statusClass}">${r.status}</span>
        </div>
      </div>
    `;
  });

  document.getElementById('modalRosterList').innerHTML = studentsHtml;
  document.getElementById('sessionDetailsModal').classList.add('open');
};

const closeSessionDetailsModal = () => {
  document.getElementById('sessionDetailsModal').classList.remove('open');
};

const initHistoryPage = () => {
  setupCascadingDropdowns();

  // Attach session row click listener
  document.querySelectorAll('tr.session-row').forEach(row => {
    row.addEventListener('click', () => {
      openSessionDetailsModal(row);
    });
  });
};

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initHistoryPage);
} else {
  initHistoryPage();
}
document.addEventListener('resultsUpdated', initHistoryPage);

document.getElementById('sessionDetailsModal').addEventListener('click', function(e) {
  if (e.target === this) {
    closeSessionDetailsModal();
  }
});
</script>
<script src="/js/instant-filter.js"></script>
