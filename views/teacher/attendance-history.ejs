<%
  layout = 'main';
  title = 'Attendance History';
  subtitle = 'Review previously marked class attendance logs';
  page = 'attendance-history';
%>

<%
  const absentList = typeof absentRoster !== 'undefined' ? absentRoster : [];
  let totalLogs = records.length;
  let presentCount = records.filter(r => r.status === 'present').length;
  let absentCount = records.filter(r => r.status === 'absent').length;
  let lateCount = records.filter(r => r.status === 'late').length;
  let presentRate = totalLogs ? Math.round((presentCount / totalLogs) * 100) : 0;
  let sessionCount = sessions.length;
  const activeRangeLabel = filter.month
    ? new Date(`${filter.month}-01`).toLocaleDateString('en-IN', { month: 'long', year: 'numeric' })
    : ({ last_7: 'Last 7 days', this_month: 'This month', last_30: 'Last 30 days', all: 'All time' }[filter.range] || 'This month');
  const cleanSessionCount = sessions.filter(s => s.absentCount === 0 && s.lateCount === 0).length;
  const followUpSessionCount = sessions.filter(s => s.absentCount > 0 || s.lateCount > 0).length;
  const highestAbsenceSession = sessions.reduce((max, s) => !max || s.absentCount > max.absentCount ? s : max, null);
%>

<style>
  tr.session-row {
    cursor: pointer;
    transition: background 0.2s ease;
  }
  tr.session-row:hover td {
    background: rgba(255, 204, 0, 0.03) !important;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .stat-card-premium {
    background:
      linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.015)),
      var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    box-shadow: var(--ring-soft), var(--shadow-md);
  }

  .stat-card-premium:hover {
    transform: translateY(-2px);
    border-color: var(--gold-border);
    box-shadow: var(--ring-soft), var(--shadow-lg);
  }

  .stat-card-premium::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 3px;
    background: transparent;
  }

  .stat-card-premium.total::after { background: var(--text-muted); }
  .stat-card-premium.present::after { background: var(--green); }
  .stat-card-premium.absent::after { background: var(--red); }
  .stat-card-premium.late::after { background: var(--orange); }

  .stat-card-premium.is-clickable {
    width: 100%;
    color: inherit;
    cursor: pointer;
    text-align: left;
  }

  .stat-card-premium.is-clickable:hover .stat-desc {
    color: var(--red);
  }

  .stat-value {
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1;
    margin: 0.5rem 0 0.25rem 0;
    font-family: var(--font-display);
  }

  .stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .stat-desc {
    font-size: 0.75rem;
    color: var(--text-sub);
  }

  .premium-filter-bar {
    background:
      linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.015)),
      var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: flex-end;
    box-shadow: var(--ring-soft), var(--shadow-md);
  }

  .premium-filter-group {
    flex: 1;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .premium-filter-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-sub);
  }

  .premium-select, .premium-input {
    background:
      linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.018)),
      var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    padding: 0.65rem 1rem;
    font-size: 0.88rem;
    transition: all 0.2s ease;
    width: 100%;
  }

  .premium-select:focus, .premium-input:focus {
    border-color: var(--gold);
    outline: none;
    box-shadow: 0 0 0 3px var(--gold-dim);
  }

  html[data-theme="light"] .stat-card-premium,
  body.light-theme .stat-card-premium,
  html[data-theme="light"] .premium-filter-bar,
  body.light-theme .premium-filter-bar {
    background:
      linear-gradient(180deg, #ffffff, #ffffff),
      #fff;
    border-color: var(--border);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 14px 34px rgba(18,18,20,0.075);
  }

  html[data-theme="light"] .stat-card-premium:hover,
  body.light-theme .stat-card-premium:hover {
    border-color: var(--gold-border);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 18px 44px rgba(18,18,20,0.105);
  }

  html[data-theme="light"] .premium-select,
  html[data-theme="light"] .premium-input,
  body.light-theme .premium-select,
  body.light-theme .premium-input {
    background:
      linear-gradient(180deg, #ffffff, #ffffff),
      #ffffff;
    border-color: var(--border);
  }

  .premium-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }

  .premium-table th {
    background: rgba(255, 255, 255, 0.02);
    color: var(--text-muted);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .premium-table td {
    padding: 1.25rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
    transition: background 0.2s ease;
  }

  .premium-table tbody tr:hover td {
    background: rgba(255, 255, 255, 0.01);
  }

  /* Mini Pills for Summary stats */
  .summary-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.55rem;
    border-radius: var(--radius);
    font-size: 0.72rem;
    font-weight: 600;
  }
  .summary-pill.present { background: rgba(34, 197, 94, 0.08); color: var(--green); }
  .summary-pill.absent { background: rgba(239, 68, 68, 0.08); color: var(--red); }
  .summary-pill.late { background: rgba(249, 115, 22, 0.08); color: var(--orange); }

  /* Modal Details */
  .details-modal-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(5px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    transition: opacity 0.2s ease;
    padding: 1.5rem;
  }
  .details-modal-overlay.open {
    display: flex;
    opacity: 1;
  }
  .details-modal {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 580px;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 25px 50px rgba(0,0,0,0.6), 0 0 0 1px var(--border-light);
    transform: translateY(20px);
    transition: transform 0.25s ease;
    overflow: hidden;
  }
  .details-modal-overlay.open .details-modal {
    transform: translateY(0);
  }
  .details-modal-header {
    padding: 1.5rem;
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  .details-modal-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .details-modal-close:hover {
    color: var(--text);
  }
  .details-modal-body {
    padding: 1.5rem;
    overflow-y: auto;
    flex: 1;
  }

  /* Roster table */
  .roster-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .roster-item {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .roster-status {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.25rem 0.55rem;
    border-radius: 50px;
  }
  .roster-status.present { background: rgba(34, 197, 94, 0.08); color: var(--green); border: 1px solid rgba(34, 197, 94, 0.15); }
  .roster-status.absent { background: rgba(239, 68, 68, 0.08); color: var(--red); border: 1px solid rgba(239, 68, 68, 0.15); }
  .roster-status.late { background: rgba(249, 115, 22, 0.08); color: var(--orange); border: 1px solid rgba(249, 115, 22, 0.15); }

  .range-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .range-chip-row a {
    text-decoration: none;
  }

  .absent-modal-tools {
    margin-bottom: 1rem;
  }

  .absent-session-group {
    margin-bottom: 1rem;
  }

  .absent-session-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
    color: var(--text-sub);
    font-size: 0.82rem;
  }

  .absent-session-head strong {
    color: var(--text);
  }

  .attendance-history-shell {
    display: grid;
    gap: 1.15rem;
  }

  .attendance-history-overview {
    border: 1px solid rgba(255, 204, 0, 0.18);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at top left, rgba(255, 204, 0, 0.12), transparent 34%),
      linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.01)),
      var(--bg-card);
    box-shadow: var(--ring-soft), var(--shadow-lg);
    padding: 1.15rem;
  }

  .attendance-history-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .attendance-history-head h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.28rem;
  }

  .attendance-history-head p {
    margin: 0.32rem 0 0;
    color: var(--text-sub);
    font-size: 0.86rem;
  }

  .history-health-chip {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255,255,255,0.035);
    padding: 0.45rem 0.7rem;
    color: var(--text-sub);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .history-health-chip strong {
    color: <%= presentRate >= 85 ? 'var(--green)' : presentRate >= 75 ? 'var(--orange)' : 'var(--red)' %>;
    font-family: var(--mono);
  }

  .attendance-insight-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .attendance-insight {
    min-width: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: rgba(255,255,255,0.025);
    padding: 0.85rem 0.95rem;
  }

  .attendance-insight span {
    display: block;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }

  .attendance-insight strong {
    display: block;
    color: var(--text);
    font-size: 1.35rem;
    font-family: var(--font-display);
    line-height: 1.1;
  }

  .attendance-insight small {
    display: block;
    color: var(--text-sub);
    font-size: 0.76rem;
    margin-top: 0.32rem;
    overflow-wrap: anywhere;
  }

  .history-filter-strip {
    display: grid;
    grid-template-columns: minmax(220px, 0.65fr) minmax(0, 1.35fr);
    gap: 0.8rem;
    align-items: stretch;
  }

  .active-view-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, rgba(255,204,0,0.08), rgba(255,255,255,0.018)),
      var(--bg-card);
    padding: 0.85rem;
  }

  .active-view-card span {
    display: block;
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.45rem;
  }

  .active-view-card strong {
    color: var(--gold);
    font-family: var(--font-display);
    font-size: 1.05rem;
  }

  .active-view-card p {
    margin: 0.45rem 0 0;
    color: var(--text-sub);
    font-size: 0.76rem;
    line-height: 1.4;
  }

  .attendance-history-overview .stats-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .attendance-history-overview .stat-card-premium {
    border-radius: var(--radius);
    padding: 1rem;
    box-shadow: none;
  }

  .attendance-history-overview .stat-value {
    font-size: 2.1rem;
  }

  .attendance-history-overview .premium-filter-bar {
    display: grid;
    grid-template-columns: repeat(3, minmax(180px, 1fr)) auto;
    gap: 0.8rem;
    padding: 0.85rem;
    margin-bottom: 0;
    box-shadow: none;
  }

  .attendance-history-overview .premium-filter-group {
    min-width: 0;
  }

  .attendance-history-overview .premium-select,
  .attendance-history-overview .premium-input {
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 750;
  }

  .attendance-history-overview .range-chip-row {
    margin-bottom: 0.85rem;
  }

  .attendance-history-overview .range-chip-row .btn {
    border-radius: 999px;
  }

  .sessions-board {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--ring-soft), var(--shadow-md);
    overflow: hidden;
  }

  .sessions-board-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.01));
  }

  .sessions-board-header h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1rem;
  }

  .sessions-board-header p {
    margin: 0.25rem 0 0;
    color: var(--text-sub);
    font-size: 0.78rem;
  }

  .sessions-tools {
    flex: 0 1 340px;
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .sessions-search {
    width: 100%;
    min-height: 38px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-input);
    color: var(--text);
    padding: 0.5rem 0.75rem;
    font-size: 0.82rem;
  }

  .sessions-search:focus {
    outline: none;
    border-color: var(--gold-border);
    box-shadow: 0 0 0 3px var(--gold-dim);
  }

  .session-card-list {
    display: grid;
  }

  .session-card {
    display: grid;
    grid-template-columns: minmax(130px, 0.7fr) minmax(220px, 1.3fr) minmax(280px, 1.5fr) auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .session-card:last-child {
    border-bottom: 0;
  }

  .session-card:hover {
    background: rgba(255,204,0,0.035);
  }

  .session-card.is-attention {
    background:
      linear-gradient(90deg, rgba(239,68,68,0.065), transparent 44%),
      transparent;
  }

  .session-card.is-clean {
    background:
      linear-gradient(90deg, rgba(34,197,94,0.055), transparent 42%),
      transparent;
  }

  .session-date-block strong {
    display: block;
    color: var(--gold);
    font-family: var(--mono);
    font-size: 0.92rem;
  }

  .session-date-block span,
  .session-context span,
  .session-rate-label {
    display: block;
    margin-top: 0.25rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .session-context strong {
    display: block;
    color: var(--text);
    font-size: 0.95rem;
    overflow-wrap: anywhere;
  }

  .session-summary-line {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 0.55rem;
  }

  .session-rate-track {
    height: 5px;
    border-radius: 999px;
    background: rgba(255,255,255,0.07);
    overflow: hidden;
  }

  .session-rate-fill {
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--green), #86efac);
  }

  .session-action {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .session-attention-chip {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0.25rem 0.55rem;
    border: 1px solid rgba(239,68,68,0.24);
    border-radius: 999px;
    background: rgba(239,68,68,0.08);
    color: var(--red);
    font-size: 0.68rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .sessions-no-match {
    display: none;
    padding: 2.5rem 1rem;
    text-align: center;
    color: var(--text-sub);
    border-top: 1px solid var(--border);
  }

  @media (max-width: 1100px) {
    .attendance-history-overview .stats-grid,
    .attendance-history-overview .premium-filter-bar,
    .attendance-insight-grid,
    .history-filter-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .session-card {
      grid-template-columns: 1fr;
      align-items: stretch;
    }

    .session-action,
    .session-action .btn {
      width: 100%;
      justify-self: stretch;
      justify-content: stretch;
    }
  }

  @media (max-width: 700px) {
    .attendance-history-head {
      flex-direction: column;
    }

    .attendance-history-overview .stats-grid,
    .attendance-history-overview .premium-filter-bar,
    .attendance-insight-grid,
    .history-filter-strip {
      grid-template-columns: 1fr;
    }

    .sessions-board-header {
      flex-direction: column;
    }

    .sessions-tools {
      width: 100%;
      flex-basis: auto;
    }
  }
</style>

<div class="attendance-history-shell">
  <section class="attendance-history-overview">
    <div class="attendance-history-head">
      <div>
        <h2>Attendance Review</h2>
        <p>Track class sessions, absence patterns, late checks, and session rosters from one place.</p>
      </div>
      <div class="history-health-chip">Current view rate <strong><%= presentRate %>%</strong></div>
    </div>

    <div class="attendance-insight-grid">
      <div class="attendance-insight">
        <span>Needs follow-up</span>
        <strong><%= followUpSessionCount %></strong>
        <small>Sessions with absent or late students</small>
      </div>
      <div class="attendance-insight">
        <span>Clean sessions</span>
        <strong><%= cleanSessionCount %></strong>
        <small>No absent or late marks</small>
      </div>
      <div class="attendance-insight">
        <span>Highest absence</span>
        <strong><%= highestAbsenceSession ? highestAbsenceSession.absentCount : 0 %></strong>
        <small><%= highestAbsenceSession ? `${highestAbsenceSession.date} · ${highestAbsenceSession.batchName}` : 'No sessions in this view' %></small>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card-premium total">
        <div class="stat-label">Sessions</div>
        <div class="stat-value"><%= sessionCount %></div>
        <div class="stat-desc"><%= totalLogs %> student entries</div>
      </div>
      <div class="stat-card-premium present">
        <div class="stat-label">Present Rate</div>
        <div class="stat-value text-green"><%= presentRate %>%</div>
        <div class="stat-desc"><%= presentCount %> present entries</div>
      </div>
      <button type="button" class="stat-card-premium absent is-clickable" data-open-absent-modal>
        <div class="stat-label">Absences</div>
        <div class="stat-value text-red"><%= absentCount %></div>
        <div class="stat-desc"><%= absentCount ? 'Open absent students' : 'No absent students' %></div>
      </button>
      <div class="stat-card-premium late">
        <div class="stat-label">Late Checks</div>
        <div class="stat-value text-orange"><%= lateCount %></div>
        <div class="stat-desc">Late arrivals in view</div>
      </div>
    </div>

    <div class="history-filter-strip">
      <div class="active-view-card">
        <span>Current view</span>
        <strong><%= activeRangeLabel %></strong>
        <p><%= sessionCount %> sessions and <%= totalLogs %> attendance entries are included.</p>
      </div>

      <div>
        <div class="range-chip-row">
          <a href="/teacher/attendance/history?range=last_7<%= filter.course ? '&course=' + filter.course : '' %><%= filter.batch ? '&batch=' + filter.batch : '' %>" class="btn btn-sm <%= filter.range === 'last_7' ? 'btn-primary' : 'btn-ghost' %>">Last 7 days</a>
          <a href="/teacher/attendance/history?range=this_month<%= filter.course ? '&course=' + filter.course : '' %><%= filter.batch ? '&batch=' + filter.batch : '' %>" class="btn btn-sm <%= filter.range === 'this_month' ? 'btn-primary' : 'btn-ghost' %>">This month</a>
          <a href="/teacher/attendance/history?range=last_30<%= filter.course ? '&course=' + filter.course : '' %><%= filter.batch ? '&batch=' + filter.batch : '' %>" class="btn btn-sm <%= filter.range === 'last_30' ? 'btn-primary' : 'btn-ghost' %>">Last 30 days</a>
          <a href="/teacher/attendance/history?range=all<%= filter.course ? '&course=' + filter.course : '' %><%= filter.batch ? '&batch=' + filter.batch : '' %>" class="btn btn-sm <%= filter.range === 'all' ? 'btn-primary' : 'btn-ghost' %>">All time</a>
        </div>

        <form method="GET" action="/teacher/attendance/history" class="filter-bar filter-form-container" style="margin:0;">
          <div class="premium-filter-bar">
            <input type="hidden" name="range" value="<%= filter.range || 'this_month' %>">
            <div class="premium-filter-group">
              <label for="historyCourseSelect" class="premium-filter-label">Course</label>
              <select name="course" id="historyCourseSelect" class="premium-select">
                <option value="">All Courses</option>
                <% courses.forEach(c => { %>
                  <option value="<%= c._id %>" <%= String(filter.course) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="premium-filter-group">
              <label for="historyBatchSelect" class="premium-filter-label">Batch</label>
              <select name="batch" id="historyBatchSelect" class="premium-select">
                <option value="">All Batches</option>
                <% batches.forEach(b => { %>
                  <option value="<%= b._id %>" <%= String(filter.batch) === String(b._id) ? 'selected' : '' %>><%= b.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="premium-filter-group">
              <label for="historyMonthInput" class="premium-filter-label">Month</label>
              <input type="month" name="month" id="historyMonthInput" class="premium-input" value="<%= filter.month || '' %>">
            </div>

            <div style="display:flex; gap:0.5rem; align-items:flex-end; justify-content: flex-end;">
              <a href="/teacher/attendance/history" class="btn btn-ghost btn-sm" style="padding: 0.65rem 1.25rem; border-color: var(--border);">Reset</a>
            </div>
          </div>
        </form>
      </div>
    </div>
  </section>

<div class="sessions-board" id="results-container">
  <div class="sessions-board-header">
    <div>
      <h3>Class Session Log</h3>
      <p>Open any session to inspect the full roster and notes.</p>
    </div>
    <div class="sessions-tools">
      <input type="search" id="sessionSearchInput" class="sessions-search" placeholder="Search date, course, batch...">
      <span class="badge badge-grey"><%= sessionCount %> sessions</span>
    </div>
  </div>
  <% if (sessions.length === 0) { %>
    <div class="empty-state" style="padding: 4rem 2rem;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: 48px; height: 48px; margin-bottom: 1rem; color: var(--text-muted);">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      <p style="color: var(--text-sub); font-size: 0.95rem; font-weight: 500;">No class sessions found matching the active filters.</p>
      <span style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem;">Try choosing a different month or batch.</span>
    </div>
  <% } else { %>
    <div class="session-card-list">
      <% sessions.forEach((s) => { %>
        <% const sessionRate = s.totalCount ? Math.round(((s.presentCount + s.lateCount) / s.totalCount) * 100) : 0; %>
        <div class="session-card session-row <%= s.absentCount > 0 || s.lateCount > 0 ? 'is-attention' : 'is-clean' %>" data-session-card data-search="<%= `${s.date} ${s.courseName} ${s.batchName}`.toLowerCase() %>" data-students="<%= JSON.stringify(s.roster) %>" data-date="<%= s.date %>" data-batch="<%= s.batchName %>" data-course="<%= s.courseName %>">
          <div class="session-date-block">
            <strong><%= s.date %></strong>
            <span><%= s.totalCount %> students</span>
          </div>
          <div class="session-context">
            <strong><%= s.courseName %></strong>
            <span><%= s.batchName %></span>
          </div>
          <div class="session-summary-block">
            <div class="session-summary-line">
              <span class="summary-pill present">Present <%= s.presentCount %></span>
              <span class="summary-pill absent">Absent <%= s.absentCount %></span>
              <span class="summary-pill late">Late <%= s.lateCount %></span>
            </div>
            <div class="session-rate-track" aria-label="Session present rate">
              <div class="session-rate-fill" style="width:<%= sessionRate %>%"></div>
            </div>
            <span class="session-rate-label"><%= sessionRate %>% present including late</span>
          </div>
          <div class="session-action">
            <% if (s.absentCount > 0 || s.lateCount > 0) { %>
              <span class="session-attention-chip">Follow up</span>
            <% } %>
            <button type="button" class="btn btn-ghost btn-sm" data-session-details>Details</button>
          </div>
        </div>
      <% }) %>
    </div>
    <div id="sessionsNoMatch" class="sessions-no-match">No sessions match this search.</div>
  <% } %>
</div>
</div>

<!-- Class Session Details Modal -->
<div id="sessionDetailsModal" class="details-modal-overlay">
  <div class="details-modal">
    <div class="details-modal-header">
      <h3 id="modalSessionTitle" style="margin:0; font-family: var(--font-display); font-size: 1.1rem;">Class Session</h3>
      <div id="modalSessionSubtitle" style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.2rem;">Batch & Course info</div>
      <button class="details-modal-close" onclick="closeSessionDetailsModal()">&times;</button>
    </div>
    <div class="details-modal-body">
      <div class="students-list" id="modalRosterList">
        <!-- Populated dynamically -->
      </div>
    </div>
  </div>
</div>

<script>
// Cascading dropdown configuration
var teacherSchedules = <%- JSON.stringify(teacherSchedules || []) %>;
var absentRoster = <%- JSON.stringify(absentList || []) %>;

var setupCascadingDropdowns = () => {
  const courseSelect = document.getElementById('historyCourseSelect');
  const batchSelect = document.getElementById('historyBatchSelect');

  if (!courseSelect || !batchSelect) return;

  if (!batchSelect.dataset.originalOptions) {
    const opts = Array.from(batchSelect.options).map(opt => ({
      value: opt.value,
      text: opt.textContent
    }));
    batchSelect.dataset.originalOptions = JSON.stringify(opts);
  }

  const allBatchOptions = JSON.parse(batchSelect.dataset.originalOptions);

  courseSelect.addEventListener('change', () => {
    const selectedCourse = courseSelect.value;
    if (!selectedCourse) {
      batchSelect.innerHTML = '<option value="">All Batches</option>';
      allBatchOptions.forEach(opt => {
        if (opt.value) {
          batchSelect.add(new Option(opt.text, opt.value));
        }
      });
      return;
    }

    const validBatchIds = teacherSchedules
      .filter(s => s.course && s.course._id === selectedCourse)
      .map(s => s.batch ? s.batch._id : null)
      .filter(Boolean);

    const currentSelectedBatch = batchSelect.value;
    batchSelect.innerHTML = '<option value="">All Batches</option>';

    allBatchOptions.forEach(opt => {
      if (opt.value && validBatchIds.includes(opt.value)) {
        const newOpt = new Option(opt.text, opt.value);
        if (opt.value === currentSelectedBatch) newOpt.selected = true;
        batchSelect.add(newOpt);
      }
    });
  });

  batchSelect.addEventListener('change', () => {
    const selectedBatch = batchSelect.value;
    if (!selectedBatch) return;

    const match = teacherSchedules.find(s => s.batch && s.batch._id === selectedBatch);
    if (match && match.course) {
      const targetCourseId = match.course._id;
      if (courseSelect.value !== targetCourseId) {
        courseSelect.value = targetCourseId;
        courseSelect.dispatchEvent(new Event('change'));
      }
    }
  });

  if (courseSelect.value) {
    courseSelect.dispatchEvent(new Event('change'));
  }
};

window.openSessionDetailsModal = (sessionRow) => {
  const date = sessionRow.dataset.date;
  const batch = sessionRow.dataset.batch;
  const course = sessionRow.dataset.course;
  const studentsList = JSON.parse(sessionRow.dataset.students);

  document.getElementById('modalSessionTitle').textContent = `Class Session: ${date}`;
  document.getElementById('modalSessionSubtitle').textContent = `${course} · Batch: ${batch}`;

  let studentsHtml = '';
  studentsList.forEach(r => {
    const statusClass = r.status === 'present' ? 'present' : r.status === 'absent' ? 'absent' : 'late';
    studentsHtml += `
      <div class="roster-item">
        <div>
          <div style="font-weight:600; color:var(--text);">${r.studentName}</div>
          ${r.note ? `<div style="font-size:0.75rem; color:var(--gold); margin-top:0.15rem;">Note: ${r.note}</div>` : ''}
        </div>
        <div>
          <span class="roster-status ${statusClass}">${r.status}</span>
        </div>
      </div>
    `;
  });

  document.getElementById('modalRosterList').innerHTML = studentsHtml;
  document.getElementById('sessionDetailsModal').classList.add('open');
};

window.closeSessionDetailsModal = () => {
  document.getElementById('sessionDetailsModal')?.classList.remove('open');
};

window.openAbsentListModal = () => {
  document.getElementById('modalSessionTitle').textContent = 'Absent Students';
  document.getElementById('modalSessionSubtitle').textContent = absentRoster.length
    ? `${absentRoster.length} absence entries in the current view`
    : 'No absent students in the current view';

  const groupedByDate = absentRoster.reduce((groups, item) => {
    const key = `${item.date} · ${item.courseName} · ${item.batchName}`;
    if (!groups[key]) groups[key] = [];
    groups[key].push(item);
    return groups;
  }, {});

  const html = absentRoster.length
    ? `
      <div class="absent-modal-tools">
        <input type="search" id="absentSearchInput" class="form-control" placeholder="Search absent student...">
      </div>
      <div id="absentGroupedList">
        ${Object.entries(groupedByDate).map(([label, items]) => `
          <section class="absent-session-group" data-absent-group>
            <div class="absent-session-head">
              <strong>${label}</strong>
              <span class="badge badge-red">${items.length} absent</span>
            </div>
            <div class="roster-list">
              ${items.map(item => `
                <div class="roster-item" data-absent-name="${item.studentName.toLowerCase()}">
                  <div>
                    <div style="font-weight:600; color:var(--text);">${item.studentName}</div>
                    ${item.note ? `<div style="font-size:0.75rem; color:var(--gold); margin-top:0.15rem;">Note: ${item.note}</div>` : ''}
                  </div>
                  <span class="roster-status absent">Absent</span>
                </div>
              `).join('')}
            </div>
          </section>
        `).join('')}
      </div>
    `
    : '<div class="empty-state compact">No absent students found for the active filters.</div>';

  document.getElementById('modalRosterList').innerHTML = html;
  document.getElementById('sessionDetailsModal').classList.add('open');
  const searchInput = document.getElementById('absentSearchInput');
  if (searchInput) {
    searchInput.addEventListener('input', () => window.filterAbsentModal(searchInput.value));
    searchInput.focus();
  }
};

window.filterAbsentModal = (query) => {
  const q = String(query || '').trim().toLowerCase();
  document.querySelectorAll('[data-absent-group]').forEach(group => {
    let visibleCount = 0;
    group.querySelectorAll('[data-absent-name]').forEach(item => {
      const visible = !q || item.dataset.absentName.includes(q);
      item.style.display = visible ? 'flex' : 'none';
      if (visible) visibleCount++;
    });
    group.style.display = visibleCount > 0 ? 'block' : 'none';
  });
};

var initHistoryPage = () => {
  setupCascadingDropdowns();

  const filterForm = document.querySelector('form.filter-bar');
  if (filterForm && !filterForm.dataset.autoSubmitReady) {
    filterForm.dataset.autoSubmitReady = 'true';
    filterForm.addEventListener('change', (event) => {
      if (event.target.matches('select, input')) {
        filterForm.submit();
      }
    });
  }

  const modal = document.getElementById('sessionDetailsModal');
  if (modal && !modal.dataset.closeBound) {
    modal.addEventListener('click', function(e) {
      if (e.target === this) {
        window.closeSessionDetailsModal();
      }
    });
    modal.dataset.closeBound = '1';
  }

  const searchInput = document.getElementById('absentSearchInput');
  if (searchInput && !searchInput.dataset.filterBound) {
    searchInput.addEventListener('input', () => window.filterAbsentModal(searchInput.value));
    searchInput.dataset.filterBound = '1';
  }

  if (!document.body.dataset.attendanceHistoryDelegated) {
    document.addEventListener('click', event => {
      const absentCard = event.target.closest('[data-open-absent-modal]');
      if (absentCard) {
        window.openAbsentListModal();
        return;
      }

      const row = event.target.closest('tr.session-row');
      const card = event.target.closest('.session-card.session-row');
      const sessionTarget = row || card;
      if (!sessionTarget) return;
      if (event.target.closest('a, input, select, textarea, label')) return;
      if (event.target.closest('button') && !event.target.closest('[data-session-details]')) return;
      window.openSessionDetailsModal(sessionTarget);
    });
    document.body.dataset.attendanceHistoryDelegated = '1';
  }
};

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initHistoryPage);
} else {
  initHistoryPage();
}
document.addEventListener('resultsUpdated', initHistoryPage);
document.addEventListener('softnav:load', initHistoryPage);
</script>
