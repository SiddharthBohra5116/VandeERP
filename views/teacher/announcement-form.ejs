<%
  layout = 'main';
  title = 'Share with Batch';
  page = 'teacher-announcements';
%>

<div class="card form-shell-narrow">
  <form action="/teacher/announcements/create" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label class="form-label" for="title">Title *</label>
      <input type="text" id="title" name="title" class="form-control" placeholder="e.g. Schedule Update / Quiz Announcement" required>
    </div>

    <div class="form-group">
      <label class="form-label" for="content">Message *</label>
      <textarea id="content" name="content" class="form-control" style="min-height: 120px;" placeholder="Add a short note about the announcement or material..." required></textarea>
    </div>

    <div class="form-group">
      <label class="form-label" for="attachments">Resources or materials</label>
      <input type="file" id="attachments" name="attachments" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.webp,.csv,.txt" multiple>
      <div class="form-hint">Optional. Add up to 5 files (25 MB each). Students can open them from the announcement.</div>
    </div>

    <div class="form-group">
      <label class="form-label" for="batch">Target Batch *</label>
      <select id="batch" name="batch" class="form-control" required>
        <option value="" disabled selected>Select Target Batch</option>
        <% batches.forEach(b => { %>
          <option value="<%= b._id %>"><%= b.name %></option>
        <% }) %>
      </select>
      <div class="form-hint">Only students enrolled in this batch will see this announcement.</div>
    </div>

    <div class="form-actions">
      <a href="/teacher/announcements" class="btn btn-ghost btn-sm">Cancel</a>
      <button type="submit" class="btn btn-primary btn-sm">Share with Batch</button>
    </div>
  </form>
</div>
