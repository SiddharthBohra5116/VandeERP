<%
  layout = 'main';
  title = 'Post Announcement to Batch';
  page = 'teacher-announcements';
%>

<div class="card" style="max-width: 600px; margin: 0 auto;">
  <form action="/teacher/announcements/create" method="POST">
    <div class="form-group">
      <label class="form-label" for="title">Title *</label>
      <input type="text" id="title" name="title" class="form-control" placeholder="e.g. Schedule Update / Quiz Announcement" required>
    </div>

    <div class="form-group">
      <label class="form-label" for="content">Content *</label>
      <textarea id="content" name="content" class="form-control" style="min-height: 120px;" placeholder="Describe the announcement details..." required></textarea>
    </div>

    <div class="form-group">
      <label class="form-label" for="batch">Target Batch *</label>
      <select id="batch" name="batch" class="form-control" required>
        <option value="" disabled selected>Select Target Batch</option>
        <% batches.forEach(b => { %>
          <option value="<%= b._id %>"><%= b.name %></option>
        <% }) %>
      </select>
      <div class="form-hint">Only students enrolled in this batch will see this announcement.</div>
    </div>

    <div style="display:flex; gap:10px; justify-content:flex-end; padding-top:12px; border-top:1px solid var(--border); margin-top:20px;">
      <a href="/teacher/announcements" class="btn btn-ghost btn-sm">Cancel</a>
      <button type="submit" class="btn btn-primary btn-sm">Post Announcement</button>
    </div>
  </form>
</div>
