<%
  layout = 'main';
  title = 'Post Class Update';
  subtitle = 'Record topics taught and assign home tasks for your student groups';
  page = 'updates';
  const formPrefill = prefill || {};
  const today = new Date().toISOString().split('T')[0];
  const selectedDate = formPrefill.date || today;
%>

<% if (formPrefill.completed) { %>
  <div class="alert-card warning" style="margin-bottom:1rem;">
    <div>
      <strong>Class marked complete.</strong>
      <p class="td-muted text-sm" style="margin:0.2rem 0 0;">Post a daily update now if you are ready. You can also skip it and come back later.</p>
    </div>
  </div>
<% } %>

<div class="card form-shell class-update-form">
  <form action="/teacher/updates/create" method="POST" enctype="multipart/form-data">
    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="batch">Select Batch</label>
        <select id="batch" name="batch" class="form-control" required>
          <option value="" disabled <%= formPrefill.batch ? '' : 'selected' %>>Select Batch</option>
          <% batches.forEach(b => { %>
            <option value="<%= b._id %>" <%= String(formPrefill.batch || '') === String(b._id) ? 'selected' : '' %>><%= b.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label" for="date">Class Date</label>
        <input type="date" id="date" name="date" class="form-control" value="<%= selectedDate %>" max="<%= today %>" required>
      </div>
    </div>

    <% if (formPrefill.courseName) { %>
      <div class="class-update-context">
        <span>Completed class</span>
        <strong><%= formPrefill.courseName %></strong>
      </div>
    <% } %>

    <div class="form-group">
      <label class="form-label" for="topics">Topics Covered</label>
      <input type="text" id="topics" name="topics" class="form-control" placeholder="e.g. Lumetri Color, Vectorscopes, 3-Way Corrector (comma separated)" required>
      <div class="form-hint">Separate multiple topics with a comma.</div>
    </div>

    <div class="form-group">
      <label class="form-label" for="homework">Homework / Tasks Assigned</label>
      <textarea id="homework" name="homework" class="form-control" placeholder="Describe the homework assigned to students..."></textarea>
    </div>

    <div class="form-group">
      <label class="form-label" for="file">Supplementary Class Material</label>
      <input type="file" id="file" name="file" class="form-control">
      <div class="form-hint">Upload notes, PDF files, or reference assets.</div>
    </div>

    <div class="divider"></div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Post Updates</button>
      <a href="<%= formPrefill.completed ? '/teacher/dashboard' : '/teacher/updates' %>" class="btn btn-ghost">Skip for now</a>
    </div>
  </form>
</div>
