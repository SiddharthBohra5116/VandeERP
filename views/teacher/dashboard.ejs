<%
  layout = 'main';
  title = 'Teacher Dashboard';
  subtitle = `Welcome back! Roll: ${user.rollNumber || 'Not Generated'} &middot; Dept: ${user.subject || 'Faculty'}`;
  page = 'dashboard';
%>

<!-- Greeting Header -->
<h2 id="dashboardGreeting" style="font-family: var(--font-display); font-weight: 800; font-size: 1.6rem; color: var(--gold); margin-bottom: 1.5rem;">Welcome back!</h2>

<div class="stats-grid">
  <a href="/teacher/attendance" class="stat-card green" style="display: block; text-decoration: none; transition: transform 0.2s;">
    <div class="stat-label">Students Logged Today</div>
    <div class="stat-value"><%= todayAttendance %></div>
    <div class="stat-sub">Attendance records marked today</div>
  </a>
  <a href="/teacher/assignments" class="stat-card gold" style="display: block; text-decoration: none; transition: transform 0.2s;">
    <div class="stat-label">Pending Deadlines</div>
    <div class="stat-value"><%= pendingAssignments.length %></div>
    <div class="stat-sub">Active assignments due soon</div>
  </a>
</div>

<!-- Today's Schedule Card -->
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">
    <div class="card-title" style="display:flex; align-items:center; gap:0.4rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Today's Classes & Schedule
    </div>
  </div>
  <% if (typeof todaySchedules === 'undefined' || !todaySchedules || todaySchedules.length === 0) { %>
    <div class="empty-state" style="padding: 1.5rem 1rem;">
      <p style="font-size:0.78rem; color: var(--text-muted);">No classes scheduled for today.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Subject</th>
            <th>Batch</th>
            <th>Classroom</th>
            <th>Time Slot</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% todaySchedules.forEach(sched => { %>
            <tr>
              <td><strong><%= sched.subject %></strong></td>
              <td><span class="badge badge-grey"><%= sched.batch %></span></td>
              <td><%= sched.classroom ? sched.classroom.name : '—' %></td>
              <td class="mono text-xs"><%= sched.startTime %> - <%= sched.endTime %></td>
              <td>
                <span class="badge <%= sched.status === 'scheduled' ? 'badge-green' : (sched.status === 'completed' ? 'badge-blue' : 'badge-red') %>">
                  <%= sched.status %>
                </span>
              </td>
              <td>
                <% if (sched.status === 'scheduled') { %>
                  <button type="button" class="btn btn-primary btn-xs" onclick="openCompleteScheduleModal('<%= sched._id %>', '<%= sched.subject %>')">Mark Complete</button>
                <% } else { %>
                  <span style="opacity: 0.5; font-style: italic;">Completed</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<!-- Admin Notifications & Class Calendar (Left Column) vs Assignments & Daily Updates (Right Column) -->
<div class="grid-2">
  <div style="display: flex; flex-direction: column; gap: 1rem;">
    <!-- Admin Notifications / Alerts -->
    <div class="card" style="border-color: var(--gold-border); background: linear-gradient(180deg, rgba(255,204,0,0.02) 0%, rgba(0,0,0,0) 100%);">
      <div class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">
        <div class="card-title" style="color:var(--gold); font-size:0.75rem; letter-spacing:0.05em; display:flex; align-items:center; gap:0.4rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          Admin Alerts & Announcements
        </div>
      </div>
      
      <% if (typeof messages === 'undefined' || !messages || messages.length === 0) { %>
        <div class="empty-state" style="padding: 1.5rem 1rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.2; margin-bottom:0.5rem;"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <p style="font-size:0.78rem;">No admin messages or alerts.</p>
        </div>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:0.6rem;">
          <% messages.forEach(msg => { %>
            <div style="background:var(--bg-input); padding:0.65rem 0.85rem; border-radius:var(--radius); border-left: 2px solid var(--gold); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); border-right: 1px solid var(--border);">
              <p style="font-size:0.82rem; color:var(--text); line-height:1.4;"><%= msg.content %></p>
              <div style="display:flex; justify-content:space-between; font-size:0.7rem; color:var(--text-muted); margin-top:0.35rem;">
                <span>Sender: <%= msg.sender ? msg.sender.name : 'Administrator' %> (<%= msg.sender ? msg.sender.role : 'admin' %>)</span>
                <span><%= new Date(msg.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %></span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Class Schedule & Calendar (Weekly Grid) -->
    <div>
      <%- include('../partials/_weekly_timetable', { daysTimetable, weekDates, weekOffset, viewType: 'teacher' }) %>
    </div>
  </div>

  <div style="display: flex; flex-direction: column; gap: 1rem;">
    <!-- Active Assignment Goals -->
    <div class="card">
      <div class="card-header">
        <div class="card-title" style="display:flex; align-items:center; gap:0.4rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
          Active Assignment Goals
        </div>
        <a href="/teacher/assignments" class="btn btn-ghost btn-sm" style="font-size: 0.7rem; padding: 2px 6px;">All Assignments</a>
      </div>
      
      <% if (pendingAssignments.length === 0) { %>
        <div class="empty-state">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
          <p>No active assignments pending deadlines.</p>
        </div>
      <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Target Batch</th>
                <th>Due Date</th>
              </tr>
            </thead>
            <tbody>
              <% pendingAssignments.forEach(assign => { %>
                <tr>
                  <td class="td-name"><a href="/teacher/assignments/<%= assign._id %>" style="color: var(--gold);"><%= assign.title %></a></td>
                  <td><span class="badge badge-grey"><%= assign.batch %></span></td>
                  <td class="mono text-sm text-red"><%= new Date(assign.dueDate).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Recent Daily Updates -->
    <div class="card">
      <div class="card-header">
        <div class="card-title" style="display:flex; align-items:center; gap:0.4rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          Recent Class Updates
        </div>
        <a href="/teacher/updates" class="btn btn-ghost btn-sm" style="font-size: 0.7rem; padding: 2px 6px;">All Updates</a>
      </div>
      
      <% if (recentUpdates.length === 0) { %>
        <div class="empty-state">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          <p>No class updates posted yet.</p>
        </div>
      <% } else { %>
        <div class="timeline" style="margin-top: 0.5rem; padding-left: 0.5rem;">
          <% recentUpdates.forEach((up, index) => { %>
            <div class="timeline-item">
              <div class="timeline-dot <%= index === 0 ? 'active' : '' %>"></div>
              <div class="timeline-body">
                <div style="font-size:13px; font-weight:600;"><%= up.subject %> &nbsp;·&nbsp; <span class="badge badge-grey" style="font-size:9px; padding:1px 4px;"><%= up.batch %></span></div>
                <div class="timeline-meta"><%= new Date(up.date).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %></div>
                <div class="mt-1 text-sm text-sub" style="line-height:1.4;"><%= up.homework ? 'Homework: ' + up.homework : 'Topics: ' + (up.topics ? up.topics.join(', ') : 'No topics details') %></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
    <!-- Contact Admin Form -->
    <div class="card" style="margin-top: 1rem;">
      <div class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.75rem;">
        <div class="card-title" style="display:flex; align-items:center; gap:0.4rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gold"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Send Message Note to Admin
        </div>
      </div>
      <form action="/teacher/messages/send" method="POST" style="margin: 0; padding: 0;">
        <input type="hidden" name="redirect" value="/teacher/dashboard">
        <% if (typeof admin !== 'undefined' && admin) { %>
          <input type="hidden" name="recipientId" value="<%= admin._id %>">
        <% } %>
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Message / Note to Admin *</label>
          <textarea name="content" class="form-control" placeholder="Type notification or message query to send to Admin..." required style="min-height: 80px;"></textarea>
        </div>
        <div style="display: flex; justify-content: flex-end; margin-top: 0.75rem;">
          <button type="submit" class="btn btn-primary btn-sm">Send Note to Admin</button>
        </div>
      </form>
    </div>
</div>

<!-- Mark Complete Modal -->
<div id="completeScheduleModal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 1000; align-items: center; justify-content: center;">
  <div class="card" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; width: 90%; max-width: 450px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); position: relative;">
    <h3 style="margin-top: 0; margin-bottom: 0.5rem; color: var(--text);">Mark Class Complete</h3>
    <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1rem;" id="modal_schedule_info"></p>
    <form id="completeScheduleForm" action="" method="POST" style="margin: 0;">
      <div class="form-group">
        <label class="form-label" for="complete_note">Lesson Note (Optional)</label>
        <textarea id="complete_note" name="note" class="form-control" style="min-height: 80px;" placeholder="Enter details about what was covered today..."></textarea>
      </div>
      <div style="display: flex; justify-content: flex-end; gap: 8px; margin-top: 1rem;">
        <button type="button" onclick="closeCompleteScheduleModal()" class="btn btn-ghost btn-sm" style="border: 1px solid var(--border);">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm">Submit & Complete</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openCompleteScheduleModal(scheduleId, subject) {
    const modal = document.getElementById('completeScheduleModal');
    const form = document.getElementById('completeScheduleForm');
    const info = document.getElementById('modal_schedule_info');
    
    if (modal && form && info) {
      form.action = `/teacher/schedules/${scheduleId}/complete`;
      info.innerText = `Mark the class "${subject}" as completed.`;
      modal.style.display = 'flex';
    }
  }

  function closeCompleteScheduleModal() {
    const modal = document.getElementById('completeScheduleModal');
    if (modal) {
      modal.style.display = 'none';
    }
  }
</script>
