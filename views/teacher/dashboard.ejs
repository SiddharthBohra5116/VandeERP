<%
  layout = 'main';
  title = 'Teacher Dashboard';
  subtitle = `Welcome back, ${user.name}!`;
  page = 'dashboard';

  const todayList = todaySchedules || [];
  const assignmentList = pendingAssignments || [];
  const updateList = recentUpdates || [];
  const messageList = messages || [];
  const nextClass = todayList.find(s => s.status === 'scheduled') || todayList[0] || (schedules || [])[0] || null;
  const unreadMessages = messageList.filter(msg => msg.isAnnouncement && !msg.isRead);
  const weekClasses = [];
  const weekdayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

  if (daysTimetable) {
    weekdayNames.forEach((day, index) => {
      const classes = daysTimetable[day] || [];
      if (classes.length) weekClasses.push({ day, date: weekDates[index], classes });
    });
  }

  let primaryAction = {
    label: 'Open students',
    href: '/teacher/students',
    title: 'Everything looks calm',
    body: 'No urgent class action is waiting. Review students or prepare the next update when ready.',
    tone: 'calm'
  };

  if (nextClass && nextClass.status === 'scheduled' && nextClass.date === (typeof today !== 'undefined' ? today : nextClass.date)) {
    primaryAction = {
      label: 'Mark attendance',
      href: '/teacher/attendance',
      title: 'Class scheduled today',
      body: `${nextClass.course && nextClass.course.name ? nextClass.course.name : 'Class'} · ${nextClass.startTime || ''}${nextClass.endTime ? ' - ' + nextClass.endTime : ''}`,
      tone: 'warn'
    };
  } else if (assignmentList.length > 0) {
    primaryAction = {
      label: 'Review assignments',
      href: '/teacher/assignments',
      title: `${assignmentList.length} active assignment${assignmentList.length > 1 ? 's' : ''}`,
      body: 'Check upcoming deadlines and submissions from your assignment board.',
      tone: 'warn'
    };
  } else if (unreadMessages.length > 0) {
    primaryAction = {
      label: 'Open announcements',
      href: '/teacher/announcements',
      title: `${unreadMessages.length} unread announcement${unreadMessages.length > 1 ? 's' : ''}`,
      body: 'Read the newest academy communication before class.',
      tone: 'warn'
    };
  }
%>

<div class="teacher-dashboard">
  <section class="teacher-hero">
    <div>
      <p class="student-kicker">Teaching workspace</p>
      <h2 id="dashboardGreeting" class="dashboard-greeting">Welcome back!</h2>
      <p class="student-hero-sub">Your class actions, assignment deadlines, and academy messages are grouped here so the next step is obvious.</p>
    </div>

    <div class="next-action-card <%= primaryAction.tone %>">
      <span class="next-action-label">Next teaching step</span>
      <strong><%= primaryAction.title %></strong>
      <p><%= primaryAction.body %></p>
      <a href="<%= primaryAction.href %>" class="btn btn-primary btn-sm"><%= primaryAction.label %></a>
    </div>
  </section>

  <section class="teacher-metric-grid">
    <a href="/teacher/attendance" class="student-metric-card">
      <span>Attendance today</span>
      <strong><%= todayAttendance || 0 %></strong>
      <small>Records marked today</small>
    </a>
    <a href="/teacher/assignments" class="student-metric-card">
      <span>Assignment goals</span>
      <strong><%= assignmentList.length %></strong>
      <small><%= assignmentList.length ? 'Active deadlines' : 'No pending deadlines' %></small>
    </a>
    <a href="/teacher/updates" class="student-metric-card">
      <span>Recent updates</span>
      <strong><%= updateList.length %></strong>
      <small>Latest class update posts</small>
    </a>
    <a href="/teacher/announcements" class="student-metric-card">
      <span>Announcements</span>
      <strong><%= unreadMessages.length %></strong>
      <small><%= unreadMessages.length ? 'Unread academy notes' : 'No unread notes' %></small>
    </a>
  </section>

  <section class="teacher-dashboard-grid">
    <div class="card teacher-panel teacher-panel-wide" id="today-classes">
      <div class="student-panel-head">
        <div>
          <span class="student-kicker">Classes</span>
          <h3>Today</h3>
        </div>
        <a href="/teacher/attendance" class="btn btn-ghost btn-sm">Mark attendance</a>
      </div>

      <% if (todayList.length === 0) { %>
        <div class="student-empty">No classes scheduled for today.</div>
      <% } else { %>
        <div class="teacher-class-list">
          <% todayList.forEach(sched => { %>
            <div class="teacher-class-card">
              <div class="teacher-class-main">
                <strong><%= (sched.course && sched.course.name) || sched.note || 'Class' %></strong>
                <span><%= sched.batch && sched.batch.name ? sched.batch.name : 'Batch not assigned' %> · <%= sched.classroom ? sched.classroom.name : 'Classroom not assigned' %></span>
              </div>
              <time><%= sched.startTime %> - <%= sched.endTime %></time>
              <% if (sched.status === 'scheduled') { %>
                <form action="/teacher/schedules/<%= sched._id %>/complete" method="POST" class="teacher-complete-form">
                  <input type="text" name="note" class="form-control" placeholder="Optional lesson note">
                  <button type="submit" class="btn btn-primary btn-sm">Done</button>
                </form>
              <% } else { %>
                <span class="badge badge-blue">Completed</span>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="card teacher-panel teacher-panel-wide">
      <div class="student-panel-head">
        <div>
          <span class="student-kicker">Weekly timetable</span>
          <h3><%= weekDates && weekDates.length ? `${weekDates[0].toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })} - ${weekDates[6].toLocaleDateString('en-IN', { day: 'numeric', month: 'short' })}` : 'This week' %></h3>
        </div>
        <div class="student-week-actions">
          <a href="?weekOffset=<%= weekOffset - 1 %>" class="btn btn-ghost btn-sm">Previous</a>
          <% if (weekOffset !== 0) { %><a href="?weekOffset=0" class="btn btn-ghost btn-sm">Current</a><% } %>
          <a href="?weekOffset=<%= weekOffset + 1 %>" class="btn btn-ghost btn-sm">Next</a>
        </div>
      </div>

      <% if (weekClasses.length === 0) { %>
        <div class="student-empty">No classes scheduled this week.</div>
      <% } else { %>
        <div class="student-week-strip">
          <% weekClasses.forEach(dayBlock => { %>
            <div class="student-week-day">
              <span><%= dayBlock.day.slice(0, 3) %> · <%= dayBlock.date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></span>
              <% dayBlock.classes.slice(0, 2).forEach(sched => { %>
                <div>
                  <strong><%= sched.startTime %></strong>
                  <small><%= sched.course && sched.course.name ? sched.course.name : 'Class' %> · <%= sched.batch && sched.batch.name ? sched.batch.name : 'Batch' %></small>
                </div>
              <% }) %>
              <% if (dayBlock.classes.length > 2) { %>
                <em>+<%= dayBlock.classes.length - 2 %> more</em>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="card teacher-panel">
      <div class="student-panel-head">
        <div>
          <span class="student-kicker">Assignments</span>
          <h3>Active goals</h3>
        </div>
        <a href="/teacher/assignments" class="btn btn-ghost btn-sm">All</a>
      </div>

      <% if (assignmentList.length === 0) { %>
        <div class="student-empty">No active assignment deadlines.</div>
      <% } else { %>
        <div class="student-task-list">
          <% assignmentList.slice(0, 3).forEach(assign => { %>
            <a href="/teacher/assignments/<%= assign._id %>" class="student-task-item">
              <strong><%= assign.title %></strong>
              <span><%= assign.batch && assign.batch.name ? assign.batch.name : 'Target batch' %> · Due <%= new Date(assign.dueDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></span>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="card teacher-panel">
      <div class="student-panel-head">
        <div>
          <span class="student-kicker">Academy notes</span>
          <h3>Admin alerts</h3>
        </div>
        <a href="/auth/inbox" class="btn btn-ghost btn-sm">Inbox</a>
      </div>

      <% if (messageList.length === 0) { %>
        <div class="student-empty">No admin messages or alerts.</div>
      <% } else { %>
        <div class="student-message-list">
          <% messageList.slice(0, 3).forEach(msg => { %>
            <div class="student-message-item">
              <strong><%= msg.content %></strong>
              <span><%= msg.sender ? msg.sender.name : 'Administrator' %> · <%= new Date(msg.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></span>
              <% if (msg.isAnnouncement && !msg.isRead) { %>
                <form action="/auth/announcements/<%= msg._id %>/read" method="POST" class="teacher-inline-form">
                  <button type="submit" class="btn btn-ghost btn-sm">Mark read</button>
                </form>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="card teacher-panel teacher-panel-wide">
      <div class="student-panel-head">
        <div>
          <span class="student-kicker">Class updates</span>
          <h3>Recently posted</h3>
        </div>
        <a href="/teacher/updates" class="btn btn-ghost btn-sm">All</a>
      </div>

      <% if (updateList.length === 0) { %>
        <div class="student-empty">No class updates posted yet.</div>
      <% } else { %>
        <div class="teacher-update-grid">
          <% updateList.slice(0, 4).forEach(up => { %>
            <a href="/teacher/updates" class="student-update-item">
              <strong><%= (up.course && up.course.name) || up.subject || 'Class update' %></strong>
              <span><%= up.homework ? up.homework : (up.topics && up.topics.length ? up.topics.join(', ') : 'No topic details') %></span>
              <small><%= up.batch && up.batch.name ? up.batch.name + ' · ' : '' %><%= new Date(up.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></small>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>
</div>
