<%
  layout = 'main';
  title = 'Daily Updates';
  subtitle = 'Review lessons posted for each batch and quickly find homework notes';
  page = 'updates';
  const activeFilter = filter || { batch: 'all', date: '', q: '' };
%>

<div class="daily-update-toolbar card">
  <form method="GET" action="/teacher/updates" class="daily-update-filter" id="dailyUpdateFilterForm">
    <div class="daily-update-fields">
      <div class="form-group">
        <label class="form-label" for="q">Search updates</label>
        <input type="search" id="q" name="q" class="form-control" value="<%= activeFilter.q || '' %>" placeholder="Topic, homework, course..." data-auto-filter="search">
      </div>
      <div class="form-group">
        <label class="form-label" for="batch">Batch</label>
        <select id="batch" name="batch" class="form-control" data-auto-filter>
          <option value="all">All batches</option>
          <% (batches || []).forEach(b => { %>
            <option value="<%= b._id %>" <%= String(activeFilter.batch || 'all') === String(b._id) ? 'selected' : '' %>><%= b.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label" for="date">Class date</label>
        <input type="date" id="date" name="date" class="form-control" value="<%= activeFilter.date || '' %>" data-auto-filter>
      </div>
    </div>
    <div class="daily-update-actions">
      <a href="/teacher/updates" class="btn btn-ghost btn-sm">Clear</a>
      <a href="/teacher/updates/create" class="btn btn-primary btn-sm daily-update-post-btn">Post daily update</a>
    </div>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('dailyUpdateFilterForm');
    if (!form) return;

    let searchTimer = null;
    const submitFilters = () => {
      if (form.requestSubmit) form.requestSubmit();
      else form.submit();
    };

    form.querySelectorAll('[data-auto-filter]').forEach(input => {
      input.addEventListener('change', submitFilters);
    });

    const search = form.querySelector('[data-auto-filter="search"]');
    if (search) {
      search.addEventListener('input', () => {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(submitFilters, 450);
      });
    }
  });
</script>

<div class="daily-update-summary">
  <div>
    <span>Total shown</span>
    <strong><%= updates.length %></strong>
  </div>
  <div>
    <span>With homework</span>
    <strong><%= updates.filter(up => up.homework).length %></strong>
  </div>
  <div>
    <span>With material</span>
    <strong><%= updates.filter(up => up.fileUrl).length %></strong>
  </div>
</div>

<div class="daily-update-board">
  <% if (updates.length === 0) { %>
    <div class="card">
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        <p>No class updates match these filters.</p>
      </div>
    </div>
  <% } else { %>
    <% updates.forEach(up => { %>
      <%
        const topics = (up.coveredTopics || []).map(t => t.title).filter(Boolean);
        if (topics.length === 0 && up.topics && up.topics.length) {
          topics.push(...up.topics);
        }
        if (topics.length === 0 && up.content) {
          topics.push(...String(up.content).split(',').map(t => t.trim()).filter(Boolean));
        }
      %>
      <article class="daily-update-card">
        <div class="daily-update-date">
          <strong><%= new Date(up.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></strong>
          <span><%= new Date(up.date).toLocaleDateString('en-IN', { weekday: 'short' }) %></span>
        </div>
        <div class="daily-update-body">
          <div class="daily-update-head">
            <div>
              <h3><%= up.course && up.course.name ? up.course.name : 'Class update' %></h3>
              <p><%= up.batch && up.batch.name ? up.batch.name : 'Batch not available' %></p>
            </div>
            <% if (up.fileUrl) { %>
              <a href="<%= up.fileUrl %>" class="btn btn-ghost btn-xs" target="_blank" download="<%= up.fileName %>">Material</a>
            <% } %>
          </div>

          <div class="topics-list">
            <% if (topics.length) { %>
              <% topics.forEach(topic => { %>
                <span class="topic-tag"><%= topic %></span>
              <% }) %>
            <% } else { %>
              <span class="td-muted">No topics written</span>
            <% } %>
          </div>

          <div class="daily-update-homework <%= up.homework ? '' : 'is-empty' %>">
            <span>Homework</span>
            <p><%= up.homework || 'No homework assigned.' %></p>
          </div>
        </div>
      </article>
    <% }) %>
  <% } %>
</div>
