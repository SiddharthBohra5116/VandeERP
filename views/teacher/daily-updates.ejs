<%
  layout = 'main';
  title = 'Daily Updates';
  subtitle = 'Log of lessons taught and assignments posted for students';
  page = 'updates';
%>

<div style="display:flex; justify-content:flex-end; margin-bottom:1.25rem;">
  <a href="/teacher/updates/create" class="btn btn-primary btn-sm">+ Post Daily Update</a>
</div>

<div class="card">
  <% if (updates.length === 0) { %>
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      <p>No class updates posted yet. Click "+ Post Daily Update" to publish one.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Batch & Subject</th>
            <th>Topics Covered</th>
            <th>Homework assigned</th>
            <th>Material</th>
          </tr>
        </thead>
        <tbody>
          <% updates.forEach(up => { %>
            <tr>
              <td class="mono text-sm fw-600"><%= up.date %></td>
              <td>
                <div style="font-weight:600;"><%= up.subject %></div>
                <div class="td-muted text-xs">Batch: <%= up.batch %></div>
              </td>
              <td>
                <div class="topics-list" style="margin-top:0;">
                  <% if (up.topics && up.topics.length > 0) { %>
                    <% up.topics.forEach(topic => { %>
                      <span class="topic-tag"><%= topic %></span>
                    <% }) %>
                  <% } else { %>
                    <span class="td-muted">—</span>
                  <% } %>
                </div>
              </td>
              <td class="text-sm" style="max-width:250px; line-height:1.4;"><%= up.homework || 'None assigned' %></td>
              <td>
                <% if (up.fileUrl) { %>
                  <a href="<%= up.fileUrl %>" class="btn btn-ghost btn-xs" target="_blank" download="<%= up.fileName %>">
                    📥 Download
                  </a>
                <% } else { %>
                  <span class="td-muted">No files</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
