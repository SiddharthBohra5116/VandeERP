<%
  layout = 'main';
  title = 'Mark Attendance';
  subtitle = 'Record student presence for a specific batch and subject';
  page = 'attendance';
%>

<!-- Batch Selection Filters -->
<% if (typeof noCoursesConfigured !== 'undefined' && noCoursesConfigured) { %>
  <div class="card" style="border-color:var(--orange); background:rgba(249,115,22,0.05); margin-bottom:1.25rem; padding:12px 16px; color:var(--orange); font-size:13px; font-weight:500; border-left:4px solid var(--orange);">
    ⚠️ No courses have been configured yet. Please ask the admin to create a schedule.
  </div>
<% } %>

<%
  const singleCourse = courses.length === 1 ? courses[0] : null;
  const singleBatch = batches.length === 1 ? batches[0] : null;
%>

<div class="card attendance-filter-card">
  <form method="GET" action="/teacher/attendance" class="filter-bar" style="margin:0; display: flex; gap: 1rem; flex-wrap: wrap; align-items: flex-end;">
    
    <!-- Course select first -->
    <div class="form-group attendance-context-field" style="margin:0; min-width:200px; flex: 1;">
      <label class="form-label" style="margin-bottom:0.25rem;">Course</label>
      <% if (singleCourse) { %>
        <input type="hidden" name="course" id="courseSelect" value="<%= singleCourse._id %>">
        <div class="locked-context-pill"><%= singleCourse.name %></div>
      <% } else { %>
        <select name="course" id="courseSelect" class="form-control" style="padding:0.45rem 0.75rem;" required>
          <option value="" <%= !filter.course ? 'selected' : '' %>>Select Course</option>
          <% courses.forEach(c => { %>
            <option value="<%= c._id %>" <%= String(filter.course) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      <% } %>
    </div>

    <!-- Batch select second -->
    <div class="form-group attendance-context-field" style="margin:0; min-width:200px; flex: 1;">
      <label class="form-label" style="margin-bottom:0.25rem;">Batch</label>
      <% if (singleBatch) { %>
        <input type="hidden" name="batch" id="batchSelect" value="<%= singleBatch._id %>">
        <div class="locked-context-pill"><%= singleBatch.name %></div>
      <% } else { %>
        <select name="batch" id="batchSelect" class="form-control" style="padding:0.45rem 0.75rem;" required>
          <option value="" <%= !filter.batch ? 'selected' : '' %>>Select Batch</option>
          <% batches.forEach(b => { %>
            <option value="<%= b._id %>" <%= String(filter.batch) === String(b._id) ? 'selected' : '' %>><%= b.name %></option>
          <% }) %>
        </select>
      <% } %>
    </div>

    <div class="form-group attendance-context-field" style="margin:0; min-width:160px;">
      <label class="form-label" style="margin-bottom:0.25rem;">Session Date</label>
      <div class="locked-context-pill"><%= filter.date %></div>
    </div>

    <a href="/teacher/attendance" class="btn btn-ghost">Reset</a>
  </form>
</div>

<!-- Attendance Form Sheet / Lock Panel -->
<div id="results-container" style="width: 100%;">
<% if (filter.batch && filter.course) { %>
  
  <% if (typeof isTimeValid !== 'undefined' && !isTimeValid) { %>
    <!-- Attendance locked alert -->
    <div class="card" style="border-color:var(--orange); background:rgba(249,115,22,0.04); padding:3rem 2rem; text-align:center; border-radius: var(--radius-lg); border-left: 4px solid var(--orange);">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 54px; height: 54px; margin-bottom: 1.25rem;">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      <h3 style="color:var(--orange); margin:0 0 0.5rem 0; font-family: var(--font-display); font-size: 1.25rem;">Class Session Locked</h3>
      <p style="color:var(--text-sub); margin:0 0 1rem 0; font-size: 0.88rem; max-width: 500px; margin-left: auto; margin-right: auto; line-height: 1.5;">
        <%= scheduleError %>
      </p>
      <% if (timeSlot) { %>
        <span class="badge badge-orange" style="font-size: 11px; padding: 4px 8px;">Scheduled Time: <%= timeSlot %></span>
      <% } %>
    </div>
  <% } else if (attendanceSaved && !allowAttendanceEdit) { %>
    <%
      const currentBatchDoc = batches.find(b => String(b._id) === String(filter.batch));
      const currentCourseDoc = courses.find(c => String(c._id) === String(filter.course));
    %>
    <div class="card attendance-saved-card">
      <div class="attendance-saved-head">
        <div>
          <span class="badge badge-green">Saved</span>
          <h3>Attendance already marked for today</h3>
          <p>
            <strong><%= currentCourseDoc ? currentCourseDoc.name : 'Course' %></strong>
            <span>·</span>
            <strong><%= currentBatchDoc ? currentBatchDoc.name : 'Batch' %></strong>
            <span>·</span>
            <strong><%= filter.date %></strong>
            <% if (timeSlot) { %>
              <span>·</span>
              <strong><%= timeSlot %></strong>
            <% } %>
          </p>
        </div>
        <div class="attendance-saved-actions">
          <a href="/teacher/attendance/history?course=<%= filter.course %>&batch=<%= filter.batch %>&range=last_7" class="btn btn-ghost">View history</a>
          <a href="/teacher/attendance?course=<%= filter.course %>&batch=<%= filter.batch %>&edit=1" class="btn btn-primary">Edit attendance</a>
        </div>
      </div>

      <div class="attendance-saved-grid">
        <div class="attendance-saved-stat">
          <span>Total students</span>
          <strong><%= attendanceSummary.total %></strong>
        </div>
        <div class="attendance-saved-stat is-present">
          <span>Present</span>
          <strong><%= attendanceSummary.present %></strong>
        </div>
        <div class="attendance-saved-stat is-absent">
          <span>Absent</span>
          <strong><%= attendanceSummary.absent %></strong>
        </div>
        <div class="attendance-saved-stat is-late">
          <span>Late</span>
          <strong><%= attendanceSummary.late %></strong>
        </div>
      </div>
    </div>
  <% } else { %>
    <!-- Marking sheet -->
    <div class="card">
      <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div>
          <% 
            const currentBatchDoc = batches.find(b => String(b._id) === String(filter.batch));
            const currentCourseDoc = courses.find(c => String(c._id) === String(filter.course));
          %>
          <h3 style="margin: 0; font-family: var(--font-display);">Marking Attendance: Batch <span style="color:var(--gold);"><%= currentBatchDoc ? currentBatchDoc.name : '—' %></span></h3>
          <p class="td-muted text-sm" style="margin: 0.35rem 0 0.5rem 0; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
            <span>Course: <strong class="text-gold"><%= currentCourseDoc ? currentCourseDoc.name : '—' %></strong></span>
            <span>·</span>
            <span>Date: <strong><%= filter.date %></strong></span>
            <% if (timeSlot) { %>
              <span>·</span>
              <span>Time Slot: <strong style="color: var(--green);"><%= timeSlot %></strong></span>
            <% } %>
          </p>
          <div style="margin-top: 0.5rem; display: inline-flex; gap: 0.75rem; font-size: 0.8rem; background: rgba(255,255,255,0.02); padding: 4px 10px; border-radius: var(--radius); border: 1px solid var(--border); font-weight: 600;">
            <span>Total Students: <strong id="liveTotalCount">0</strong></span>
            <span style="color: var(--green);">Present: <strong id="livePresentCount">0</strong></span>
            <span style="color: var(--red);">Absent: <strong id="liveAbsentCount">0</strong></span>
            <span style="color: var(--orange);">Late: <strong id="liveLateCount">0</strong></span>
          </div>
        </div>
        
        <!-- Quick Action Shortcuts -->
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <button type="button" id="markAllPresentBtn" class="btn btn-ghost btn-sm" style="color: var(--green); border-color: rgba(34, 197, 94, 0.3);">🟢 Mark All Present</button>
          <button type="button" id="markAllAbsentBtn" class="btn btn-ghost btn-sm" style="color: var(--red); border-color: rgba(239, 68, 68, 0.3);">🔴 Mark All Absent</button>
        </div>
      </div>
      
      <% if (students.length === 0) { %>
        <div class="empty-state" style="padding: 3rem 1.5rem;">
          <p>No active or inactive students registered under this Batch.</p>
        </div>
      <% } else { %>
        <form action="/teacher/attendance" method="POST" id="attendanceForm">
          <!-- Pass hidden filters context -->
          <input type="hidden" name="batch" value="<%= filter.batch %>">
          <input type="hidden" name="course" value="<%= filter.course %>">
          <input type="hidden" name="date" value="<%= filter.date %>">
          
          <div class="table-wrap" style="margin-bottom: 1.5rem;">
            <table>
              <thead>
                <tr>
                  <th>Student Name</th>
                  <th>Status</th>
                  <th>Remarks / Notes</th>
                </tr>
              </thead>
              <tbody>
                <% students.forEach(student => { %>
                  <% 
                    const record = existing.find(e => e.student.toString() === student._id.toString());
                    const currentStatus = record ? record.status : '';
                    const currentNote = record ? record.note : '';
                  %>
                  <tr style="transition: background 0.2s ease;">
                    <td class="td-name">
                      <%= student.name %>
                      <% if (student.status === 'inactive') { %>
                        <span class="badge badge-grey" style="margin-left: 6px; font-size: 9px; padding: 2px 4px;">INACTIVE</span>
                      <% } %>
                    </td>
                    <td>
                      <div class="status-radio">
                        <label style="margin: 0;">
                          <input type="radio" name="statuses[<%= student._id %>]" value="present" <%= currentStatus === 'present' ? 'checked' : '' %> required>
                          <span>Present</span>
                        </label>
                        <label style="margin: 0;">
                          <input type="radio" name="statuses[<%= student._id %>]" value="absent" <%= (currentStatus === 'absent' || !currentStatus) ? 'checked' : '' %> required>
                          <span>Absent</span>
                        </label>
                        <label style="margin: 0;">
                          <input type="radio" name="statuses[<%= student._id %>]" value="late" <%= currentStatus === 'late' ? 'checked' : '' %> required>
                          <span>Late</span>
                        </label>
                      </div>
                    </td>
                    <td>
                      <input type="text" name="notes[<%= student._id %>]" class="form-control" style="padding:0.45rem 0.75rem; font-size:13px; min-width: 200px;" value="<%= currentNote %>" placeholder="e.g. Arrived 15m late">
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          
          <button type="submit" class="btn btn-primary" style="padding: 0.6rem 2rem;">Save Attendance Sheet</button>
        </form>
      <% } %>
    </div>
  <% } %>
<% } else { %>
  <div class="card">
    <div class="empty-state" style="padding: 3rem 1.5rem;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 48px; height: 48px; margin-bottom: 1rem; color: var(--text-muted);"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      <p style="color: var(--text-sub); font-weight: 500;">Select a Course and its Batch above to load the student list.</p>
    </div>
  </div>
<% } %>
</div>

<script>
// JSON array of schedules for dynamic cascading dropdowns
const teacherSchedules = <%- JSON.stringify(teacherSchedules || []) %>;

const setupDependentDropdowns = () => {
  const courseSelect = document.getElementById('courseSelect');
  const batchSelect = document.getElementById('batchSelect');

  if (!courseSelect || !batchSelect) return;
  const courseIsSelect = courseSelect.tagName === 'SELECT';
  const batchIsSelect = batchSelect.tagName === 'SELECT';
  if (!courseIsSelect && !batchIsSelect) return;

  // Cache the complete set of original batch options
  if (batchIsSelect && !batchSelect.dataset.originalOptions) {
    const opts = Array.from(batchSelect.options).map(opt => ({
      value: opt.value,
      text: opt.textContent
    }));
    batchSelect.dataset.originalOptions = JSON.stringify(opts);
  }

  const allBatchOptions = batchIsSelect ? JSON.parse(batchSelect.dataset.originalOptions) : [];

  // 1. Course Change Handler
  if (courseIsSelect && batchIsSelect) courseSelect.addEventListener('change', () => {
    const selectedCourse = courseSelect.value;
    if (!selectedCourse) {
      // Re-populate all batches
      batchSelect.innerHTML = '<option value="">Select Batch</option>';
      allBatchOptions.forEach(opt => {
        if (opt.value) {
          const newOpt = new Option(opt.text, opt.value);
          batchSelect.add(newOpt);
        }
      });
      return;
    }

    // Get batch IDs scheduled under selected course
    const validBatchIds = teacherSchedules
      .filter(s => s.course && s.course._id === selectedCourse)
      .map(s => s.batch ? s.batch._id : null)
      .filter(Boolean);

    // Filter the batch select list options
    const currentSelectedBatch = batchSelect.value;
    batchSelect.innerHTML = '<option value="">Select Batch</option>';
    
    allBatchOptions.forEach(opt => {
      if (opt.value && validBatchIds.includes(opt.value)) {
        const newOpt = new Option(opt.text, opt.value);
        if (opt.value === currentSelectedBatch) {
          newOpt.selected = true;
        }
        batchSelect.add(newOpt);
      }
    });
  });

  // 2. Batch Change Handler (Direct auto-setting of Course)
  if (batchIsSelect && courseIsSelect) batchSelect.addEventListener('change', () => {
    const selectedBatch = batchSelect.value;
    if (!selectedBatch) return;

    // Find course schedules matching this batch
    const match = teacherSchedules.find(s => s.batch && s.batch._id === selectedBatch);
    if (match && match.course) {
      const targetCourseId = match.course._id;
      if (courseSelect.value !== targetCourseId) {
        courseSelect.value = targetCourseId;
        // Trigger manual change event on course select to filter batches properly
        courseSelect.dispatchEvent(new Event('change'));
      }
    }
  });

  // Initial trigger to filter batches on load if course is selected
  if (courseIsSelect && courseSelect.value) {
    courseSelect.dispatchEvent(new Event('change'));
  }
};

const initAttendancePage = () => {
  setupDependentDropdowns();

  const form = document.getElementById('attendanceForm');
  if (!form) return;

  const markAllPresentBtn = document.getElementById('markAllPresentBtn');
  const markAllAbsentBtn = document.getElementById('markAllAbsentBtn');

  // Quick mark shortcuts
  markAllPresentBtn?.addEventListener('click', () => {
    form.querySelectorAll('input[type="radio"][value="present"]').forEach(r => {
      r.checked = true;
      r.dispatchEvent(new Event('change'));
    });
  });

  markAllAbsentBtn?.addEventListener('click', () => {
    form.querySelectorAll('input[type="radio"][value="absent"]').forEach(r => {
      r.checked = true;
      r.dispatchEvent(new Event('change'));
    });
  });

  // Dynamic row colors and live stats
  const updateRowColorsAndStats = () => {
    form.querySelectorAll('tbody tr').forEach(tr => {
      const checkedInput = tr.querySelector('input[type="radio"]:checked');
      if (checkedInput) {
        tr.style.background = {
          present: 'rgba(34, 197, 94, 0.06)',
          absent: 'rgba(239, 68, 68, 0.06)',
          late: 'rgba(249, 115, 22, 0.06)'
        }[checkedInput.value] || '';
      }
    });

    const total = form.querySelectorAll('tbody tr').length;
    const present = form.querySelectorAll('input[type="radio"][value="present"]:checked').length;
    const absent = form.querySelectorAll('input[type="radio"][value="absent"]:checked').length;
    const late = form.querySelectorAll('input[type="radio"][value="late"]:checked').length;

    const totalEl = document.getElementById('liveTotalCount');
    const presentEl = document.getElementById('livePresentCount');
    const absentEl = document.getElementById('liveAbsentCount');
    const lateEl = document.getElementById('liveLateCount');

    if (totalEl) totalEl.textContent = total;
    if (presentEl) presentEl.textContent = present;
    if (absentEl) absentEl.textContent = absent;
    if (lateEl) lateEl.textContent = late;
  };

  form.querySelectorAll('input[type="radio"]').forEach(r => {
    r.addEventListener('change', updateRowColorsAndStats);
  });

  updateRowColorsAndStats(); // initial run
};

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initAttendancePage);
} else {
  initAttendancePage();
}
document.addEventListener('resultsUpdated', initAttendancePage);
</script>
<script src="/js/instant-filter.js"></script>
