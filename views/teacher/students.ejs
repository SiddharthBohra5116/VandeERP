<%
  layout = 'main';
  title = 'My Students';
  subtitle = 'Directory of students registered in your active classes';
  page = 'students';
%>

<div class="card" style="padding: 1rem 1.25rem; margin-bottom: 1.25rem;">
  <form method="GET" action="/teacher/students" class="filter-bar" style="margin:0; gap:0.75rem;">
    <div class="form-group" style="margin:0; flex:1; min-width:200px;">
      <label class="form-label" style="margin-bottom:0.25rem;">Search by Student Name</label>
      <input type="text" name="search" class="form-control" placeholder="Type student name..." value="<%= filter.search || '' %>" style="padding:0.45rem 0.75rem;">
    </div>

    <div class="form-group" style="margin:0; min-width:160px;">
      <label class="form-label" style="margin-bottom:0.25rem;">Batch</label>
      <select name="batch" class="form-control" style="padding:0.45rem 0.75rem;">
        <option value="">All Batches</option>
        <% batches.forEach(b => { %>
          <option value="<%= b %>" <%= filter.batch === b ? 'selected' : '' %>><%= b %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-group" style="margin:0; min-width:160px;">
      <label class="form-label" style="margin-bottom:0.25rem;">Attendance Tier</label>
      <select name="attendance" class="form-control" style="padding:0.45rem 0.75rem;">
        <option value="">All Attendance Tiers</option>
        <option value="low" <%= filter.attendance === 'low' ? 'selected' : '' %>>Low (< 75%)</option>
        <option value="medium" <%= filter.attendance === 'medium' ? 'selected' : '' %>>Medium (75% - 85%)</option>
        <option value="high" <%= filter.attendance === 'high' ? 'selected' : '' %>>High (> 85%)</option>
        <option value="not_marked_today" <%= filter.attendance === 'not_marked_today' ? 'selected' : '' %>>Not Marked Today</option>
      </select>
    </div>

    <div style="display:flex; gap:0.5rem; align-items:flex-end;">
      <button type="submit" class="btn btn-primary btn-sm">Filter Directory</button>
      <a href="/teacher/students" class="btn btn-ghost btn-sm">Clear</a>
    </div>
  </form>
</div>

<div id="results-container" class="card">
  <% if (students.length === 0) { %>
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      <p>No active students enrolled in the selected batch.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Student Name</th>
            <th>Contact info</th>
            <th>Course & Batch</th>
            <th>Attendance</th>
            <th>Academic Progress</th>
            <th>Ungraded Tasks</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(s => { %>
            <tr>
              <td class="td-name">
                <div class="d-flex align-center gap-2">
                  <div class="avatar" style="width:30px; height:30px; font-size:10px;">
                    <%= s.name ? s.name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2) : '?' %>
                  </div>
                  <%= s.name %>
                </div>
              </td>
              <td class="text-sm td-muted">
                <div><%= s.email %></div>
                <div class="mono text-xs"><%= s.phone || '—' %></div>
              </td>
              <td>
                <span class="badge badge-orange" style="margin-bottom: 4px; display: inline-block;"><%= s.course %></span>
                <div class="text-xs fw-600"><%= s.batch || '—' %></div>
              </td>
              <td>
                <% 
                  const pct = typeof s.attendancePct !== 'undefined' ? s.attendancePct : 100;
                  const pctBadge = pct < 75 ? 'badge-red' : pct >= 85 ? 'badge-green' : 'badge-gold';
                %>
                <span class="badge <%= pctBadge %>" style="font-family: var(--mono);"><%= pct %>%</span>
                <% if (!s.isMarkedToday) { %>
                  <span class="badge badge-grey" style="font-size: 8px; padding: 1px 3px; display: block; margin-top: 4px; width: max-content;">Unmarked today</span>
                <% } %>
              </td>
              <td>
                <% const progressVal = s.overallProgress || 0; %>
                <div style="min-width:110px;">
                  <div style="display:flex; justify-content:space-between; font-size:10px; color:var(--text-muted); font-family:var(--mono); margin-bottom:4px;">
                    <span>Overall Score</span>
                    <span style="font-weight:600;"><%= progressVal %>%</span>
                  </div>
                  <div class="progress-bar" style="height:4px; background:rgba(255,255,255,0.05); border-radius: 4px;">
                    <div class="progress-fill <%= progressVal >= 80 ? 'green' : progressVal >= 50 ? 'orange' : 'red' %>"
                         style="width:<%= progressVal %>%"></div>
                  </div>
                </div>
              </td>
              <td>
                <% if (s.ungradedCount > 0) { %>
                  <span class="badge badge-red" style="font-family: var(--mono);"><%= s.ungradedCount %> pending</span>
                <% } else { %>
                  <span class="badge badge-grey" style="font-family: var(--mono);">0 pending</span>
                <% } %>
              </td>
              <td>
                <div style="display: flex; flex-direction: column; gap: 4px;">
                  <a href="/teacher/assignments" class="btn btn-ghost btn-xs" style="font-size: 10px; text-decoration: none; padding: 2px 6px; text-align: center;">Grade Tasks</a>
                  <a href="/teacher/progress?batch=<%= encodeURIComponent(s.batch) %>&subject=<%= encodeURIComponent(s.course === 'Both' ? 'Video Editing' : s.course) %>" class="btn btn-primary btn-xs" style="font-size: 10px; text-decoration: none; padding: 2px 6px; text-align: center; color: #fff;">Add test result</a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<script src="/js/instant-filter.js"></script>

