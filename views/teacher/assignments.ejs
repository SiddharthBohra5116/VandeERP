<%
  layout = 'main';
  title = 'Assignments';
  subtitle = 'Manage assignment goals, deadlines, and grade student submissions';
  page = 'assignments';

  const rows = typeof assignmentCards !== 'undefined'
    ? assignmentCards
    : (assignments || []).map(assignment => ({
      assignment,
      totalStudents: assignment.submissions ? assignment.submissions.length : 0,
      handinsCount: assignment.submissions ? assignment.submissions.length : 0,
      gradedCount: assignment.submissions ? assignment.submissions.filter(s => s.status === 'graded' || s.marks !== null).length : 0,
      ungradedCount: assignment.submissions ? assignment.submissions.filter(s => ['submitted', 'late'].includes(s.status) && s.marks === null).length : 0
    }));
  const now = new Date();
  const activeCount = rows.filter(row => row.assignment.isActive).length;
  const overdueCount = rows.filter(row => new Date(row.assignment.dueDate) < now).length;
  const ungradedCount = rows.reduce((sum, row) => sum + (row.ungradedCount || 0), 0);
%>

<div class="assignment-board">
  <section class="assignment-board-hero">
    <div>
      <span class="student-kicker">Assignment board</span>
      <h2>Review work without digging through rows</h2>
      <p>Each assignment now shows deadline health, batch context, submission progress, and grading workload in one place.</p>
    </div>
    <a href="/teacher/assignments/create" class="btn btn-primary">Create assignment</a>
  </section>

  <section class="assignment-board-summary" aria-label="Assignment filters">
    <button type="button" class="assignment-summary-card is-active" data-assignment-filter="all" aria-pressed="true">
      <span>Total</span>
      <strong><%= rows.length %></strong>
      <small>Assignments posted</small>
    </button>
    <button type="button" class="assignment-summary-card" data-assignment-filter="active" aria-pressed="false">
      <span>Active</span>
      <strong><%= activeCount %></strong>
      <small>Open assignment goals</small>
    </button>
    <button type="button" class="assignment-summary-card <%= overdueCount ? 'is-danger' : '' %>" data-assignment-filter="overdue" aria-pressed="false">
      <span>Past due</span>
      <strong><%= overdueCount %></strong>
      <small>Need review or follow-up</small>
    </button>
    <button type="button" class="assignment-summary-card <%= ungradedCount ? 'is-warning' : '' %>" data-assignment-filter="ungraded" aria-pressed="false">
      <span>Ungraded</span>
      <strong><%= ungradedCount %></strong>
      <small>Submitted work pending</small>
    </button>
  </section>

  <% if (rows.length === 0) { %>
    <div class="card">
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
        <p>No assignments posted yet. Create the first one when homework is ready.</p>
      </div>
    </div>
  <% } else { %>
    <div id="assignmentFilterEmpty" class="card assignment-filter-empty" hidden>
      <div class="empty-state">
        <p>No assignments match this filter.</p>
      </div>
    </div>
    <section class="assignment-card-grid" id="assignmentCardGrid">
      <% rows.forEach(row => { %>
        <%
          const assign = row.assignment;
          const due = new Date(assign.dueDate);
          const isOverdue = due < now;
          const totalStudents = row.totalStudents || 0;
          const handinsCount = row.handinsCount || 0;
          const gradedCount = row.gradedCount || 0;
          const progress = totalStudents > 0 ? Math.min(100, Math.round((handinsCount / totalStudents) * 100)) : 0;
          const ungraded = row.ungradedCount || 0;
        %>
        <article class="assignment-card <%= isOverdue ? 'is-overdue' : '' %>"
          data-assignment-card
          data-active="<%= assign.isActive ? 'true' : 'false' %>"
          data-overdue="<%= isOverdue ? 'true' : 'false' %>"
          data-ungraded="<%= ungraded > 0 ? 'true' : 'false' %>">
          <div class="assignment-card-head">
            <div>
              <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.15rem;">
                <span class="assignment-card-kicker" style="margin-bottom: 0;"><%= assign.course && assign.course.name ? assign.course.name : 'Course not set' %></span>
                <% if (assign.createdAt) { %>
                  <span style="font-size: 0.68rem; color: var(--text-muted); background: rgba(255,255,255,0.06); padding: 1px 6px; border-radius: 4px; display: inline-flex; align-items: center; font-weight: 500; text-transform: none; letter-spacing: normal;" title="Date when this assignment was posted">
                    Posted <%= new Date(assign.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %>
                  </span>
                <% } %>
              </div>
              <h3><a href="/teacher/assignments/<%= assign._id %>"><%= assign.title %></a></h3>
              <p><%= assign.batch && assign.batch.name ? assign.batch.name : 'Batch not assigned' %></p>
            </div>
            <span class="badge <%= assign.isActive ? (isOverdue ? 'badge-orange' : 'badge-green') : 'badge-grey' %>">
              <%= assign.isActive ? (isOverdue ? 'Past due' : 'Active') : 'Archived' %>
            </span>
          </div>

          <div class="assignment-card-meta">
            <div>
              <span>Due</span>
              <strong class="<%= isOverdue ? 'text-red' : '' %>"><%= due.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></strong>
            </div>
            <div>
              <span>Marks</span>
              <strong><%= assign.totalMarks %></strong>
            </div>
            <div>
              <span>Submitted</span>
              <strong><%= handinsCount %>/<%= totalStudents %></strong>
            </div>
            <div <% if (ungraded > 0) { %> onclick="openUngradedModal('<%= assign._id %>')" style="cursor: pointer;" title="Click to view ungraded submissions" <% } %> >
              <span>Ungraded</span>
              <strong class="<%= ungraded ? 'text-gold' : '' %>"><%= ungraded %></strong>
            </div>
          </div>

          <div class="assignment-progress">
            <div>
              <span>Submission progress</span>
              <strong><%= progress %>%</strong>
            </div>
            <div class="student-mini-progress"><span style="width:<%= progress %>%"></span></div>
          </div>

          <div class="assignment-card-foot">
            <% if (assign.fileName) { %>
              <span class="assignment-file-chip"><%= assign.fileName %></span>
            <% } else { %>
              <span class="td-muted text-xs">No reference file</span>
            <% } %>
            <a href="/teacher/assignments/<%= assign._id %>" class="btn btn-ghost btn-sm">Open grading</a>
          </div>
        </article>
      <% }) %>
    </section>
  <% } %>
</div>

<script>
  (() => {
    const buttons = document.querySelectorAll('[data-assignment-filter]');
    const cards = document.querySelectorAll('[data-assignment-card]');
    const empty = document.getElementById('assignmentFilterEmpty');

    const applyAssignmentFilter = (filter) => {
      let shown = 0;
      cards.forEach(card => {
        const visible =
          filter === 'all' ||
          (filter === 'active' && card.dataset.active === 'true' && card.dataset.overdue !== 'true') ||
          (filter === 'overdue' && card.dataset.overdue === 'true') ||
          (filter === 'ungraded' && card.dataset.ungraded === 'true');

        card.hidden = !visible;
        if (visible) shown++;
      });

      if (empty) empty.hidden = shown !== 0;

      buttons.forEach(button => {
        const isActive = button.dataset.assignmentFilter === filter;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-pressed', String(isActive));
      });

      const url = new URL(window.location.href);
      if (filter === 'all') url.searchParams.delete('view');
      else url.searchParams.set('view', filter);
      window.history.replaceState(window.history.state || {}, document.title, url.pathname + (url.searchParams.toString() ? `?${url.searchParams.toString()}` : ''));
    };

    buttons.forEach(button => {
      button.addEventListener('click', (e) => {
        if (button.dataset.assignmentFilter === 'ungraded') {
          e.preventDefault();
          openUngradedModal();
          return;
        }
        applyAssignmentFilter(button.dataset.assignmentFilter);
        document.getElementById('assignmentCardGrid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    const initialView = new URL(window.location.href).searchParams.get('view') || 'all';
    applyAssignmentFilter(['all', 'active', 'overdue', 'ungraded'].includes(initialView) ? initialView : 'all');
  })();

  window.openUngradedModal = (assignmentId) => {
    const modal = document.getElementById('ungradedSubmissionsModal');
    if (modal) {
      modal.classList.add('open');
      
      const groups = modal.querySelectorAll('.ungraded-assignment-group');
      let visibleCount = 0;
      groups.forEach(group => {
        if (!assignmentId || group.classList.contains(`assignment-group-${assignmentId}`)) {
          group.style.display = 'block';
          visibleCount++;
        } else {
          group.style.display = 'none';
        }
      });

      const emptyEl = document.getElementById('ungradedModalEmptyState');
      if (emptyEl) {
        emptyEl.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    }
  };

  window.closeUngradedModal = () => {
    const modal = document.getElementById('ungradedSubmissionsModal');
    if (modal) {
      modal.classList.remove('open');
    }
  };

  document.getElementById('ungradedSubmissionsModal')?.addEventListener('click', function(e) {
    if (e.target === this) {
      closeUngradedModal();
    }
  });
</script>

<!-- Ungraded Submissions Modal -->
<div id="ungradedSubmissionsModal" class="modal-overlay">
  <div class="modal" style="max-width: 600px;">
    <div class="modal-header" style="border-bottom: 1px solid var(--border); padding-bottom: 0.85rem;">
      <div class="modal-title" style="font-family: var(--font-display); color: var(--text);">Ungraded Submissions</div>
      <button class="modal-close" onclick="closeUngradedModal()">&times;</button>
    </div>
    <div class="modal-body" style="max-height: 400px; overflow-y: auto; padding: 1.25rem 1.5rem;">
      <% 
        let hasAnyUngraded = false;
        rows.forEach(row => {
          const assign = row.assignment;
          const ungradedSubs = assign.submissions.filter(s => ['submitted', 'late'].includes(s.status) && s.marks === null);
          if (ungradedSubs.length > 0) {
            hasAnyUngraded = true;
      %>
        <div class="ungraded-assignment-group assignment-group-<%= assign._id %>" style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--border); padding-bottom: 1.25rem;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem;">
            <div>
              <strong style="color: var(--gold); font-size: 0.95rem; font-family: var(--font-display);"><%= assign.title %></strong>
              <div class="td-muted text-xs" style="margin-top: 2px;"><%= assign.course && assign.course.name ? assign.course.name : '' %> &middot; <%= assign.batch && assign.batch.name ? assign.batch.name : '' %></div>
            </div>
            <span class="badge badge-orange" style="font-size: 10px; padding: 2px 6px;"><%= ungradedSubs.length %> pending</span>
          </div>
          <div style="display: flex; flex-direction: column; gap: 0.65rem; padding-left: 0.25rem;">
            <% ungradedSubs.forEach(sub => { %>
              <a href="/teacher/assignments/<%= assign._id %>?gradeSubmission=<%= sub._id %>" class="ungraded-student-item" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; background: var(--bg-input); border: 1px solid var(--border); border-radius: var(--radius); text-decoration: none; color: var(--text); transition: all 0.22s ease;">
                <div>
                  <span style="font-weight: 600; font-size: 0.88rem; color: var(--text);"><%= sub.student && sub.student.user ? sub.student.user.name : 'Student' %></span>
                  <div class="td-muted" style="font-size: 0.75rem; margin-top: 3px;">
                    Submitted: <%= sub.submittedAt ? new Date(sub.submittedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) : '—' %>
                  </div>
                </div>
                <div style="display: flex; align-items: center; gap: 0.65rem;">
                  <span class="badge <%= sub.status === 'late' ? 'badge-orange' : 'badge-blue' %>" style="font-size: 9px; padding: 1px 5px;"><%= sub.status %></span>
                  <span style="color: var(--gold); font-size: 1.15rem; line-height: 1;">&rarr;</span>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      <% 
          }
        });
      %>
      
      <div id="ungradedModalEmptyState" class="empty-state" style="padding: 2.5rem 0; text-align: center; display: <%= hasAnyUngraded ? 'none' : 'block' %>;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 48px; height: 48px; margin-bottom: 1rem; color: var(--text-muted);"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <p style="color: var(--text-sub); font-weight: 500; font-size: 0.9rem;">All clear! No ungraded submissions pending.</p>
      </div>
    </div>
  </div>
</div>

<style>
  .ungraded-student-item:hover {
    border-color: rgba(255, 204, 0, 0.45) !important;
    background: rgba(255, 204, 0, 0.04) !important;
    transform: translateX(4px);
  }
</style>
