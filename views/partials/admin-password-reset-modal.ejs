<div id="resetModal" class="modal-overlay">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Reset Password</div>
      <button type="button" class="modal-close" onclick="closeResetModal()">&times;</button>
    </div>
    <form id="resetForm" method="POST" onsubmit="window.handleResetPasswordSubmit && window.handleResetPasswordSubmit(event)">
      <input type="hidden" name="redirect" value="<%= passwordResetRedirect %>">
      <p style="font-size:13px; color:var(--text-sub); margin-bottom:1.25rem;">
        Set a new password for <strong id="resetUserName">User</strong>:
      </p>
      <div class="form-group">
        <label class="form-label" for="resetPasswordInput">New Password</label>
        <div class="password-toggle-field">
          <input type="password" id="resetPasswordInput" name="newPassword" form="resetForm" class="form-control" placeholder="Min. 8 characters" minlength="8" required>
          <button type="button" id="toggleResetPasswordVisibility" class="password-toggle-btn" aria-label="Show password" aria-pressed="false">
            Show
          </button>
        </div>
      </div>
      <div id="resetPasswordError" class="modal-inline-error" hidden></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost btn-sm" onclick="closeResetModal()">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm">Save New Password</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/admin-password-reset.js?v=20260618-reset-json"></script>
