<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Vande Digital Academy</title>
  <!-- NProgress Loader -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <script>
    // Early theme initialization to prevent flash of dark theme in light mode
    (function() {
      const savedTheme = localStorage.getItem('theme') || 'light';
      if (savedTheme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
        document.addEventListener('DOMContentLoaded', () => {
          document.body.classList.add('light-theme');
        });
      }
    })();
  </script>
</head>
<body>
  <!-- Global Custom Confirmation Modal -->
  <div id="confirmModalOverlay" class="modal-overlay" style="z-index:9999;">
    <div class="modal" style="max-width:400px; padding:1.25rem;">
      <div class="modal-header" style="margin-bottom:12px; padding-bottom:8px;">
        <span class="modal-title">Confirm Action</span>
        <button type="button" class="modal-close" onclick="closeGlobalConfirmModal()">&times;</button>
      </div>
      <div id="confirmModalBody" style="font-size:0.875rem; color:var(--text-sub); line-height:1.5; margin-bottom:20px;"></div>
      <div style="display:flex; justify-content:flex-end; gap:8px; border-top:1px solid var(--border); padding-top:12px;">
        <button type="button" class="btn btn-ghost btn-sm" onclick="closeGlobalConfirmModal()">Cancel</button>
        <button type="button" id="confirmModalSubmitBtn" class="btn btn-red btn-sm">Delete</button>
      </div>
    </div>
  </div>

  <div class="app-layout">
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>
    <%- include('../partials/sidebar') %>

    <div class="main-wrap">
      <%- include('../partials/topbar') %>

      <main class="page-content">
        <%
          const successList = Array.isArray(success) ? success.filter(msg => String(msg || '').trim()) : (success ? [success] : []);
          const errorList = Array.isArray(error) ? error.filter(msg => String(msg || '').trim() && String(msg).trim() !== '1') : (error && String(error).trim() !== '1' ? [error] : []);
        %>

        <% if (successList.length) { %>
          <div class="alert alert-success">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span><%= successList[0] %></span>
          </div>
        <% } %>

        <% if (errorList.length) { %>
          <div class="alert alert-error">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span><%= errorList[0] %></span>
          </div>
        <% } %>

        <%- body %>
      </main>
    </div>
  </div>

  <!-- NProgress Library -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.js"></script>

  <script>
    // 1. NProgress Navigation loader
    NProgress.configure({ showSpinner: false, minimum: 0.1 });
    window.addEventListener('beforeunload', () => {
      NProgress.start();
    });

    document.querySelectorAll('a').forEach(link => {
      // Don't show progress for javascript hrefs, hashes, or blank target links
      const href = link.getAttribute('href');
      if (href && !href.startsWith('#') && !href.startsWith('javascript:') && link.getAttribute('target') !== '_blank') {
        link.addEventListener('click', () => {
          NProgress.start();
        });
      }
    });

    // 2. Responsive Mobile Sidebar with persistence
    const menuToggleBtn = document.getElementById('menuToggleBtn');
    const sidebar = document.querySelector('.sidebar');
    const sidebarBackdrop = document.getElementById('sidebarBackdrop');    const restoreSidebarState = () => {
      const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
      if (window.innerWidth > 900) {
        const btn = document.getElementById('desktopSidebarCollapseBtn');
        const span = btn ? btn.querySelector('span') : null;
        const svg = btn ? btn.querySelector('svg') : null;
        if (isCollapsed) {
          sidebar.classList.add('collapsed');
          document.querySelector('.main-wrap').classList.add('expanded');
          if (span) span.style.display = 'none';
          if (svg) svg.innerHTML = '<path d="M9 18l6-6-6-6"/>';
        } else {
          sidebar.classList.remove('collapsed');
          document.querySelector('.main-wrap').classList.remove('expanded');
          if (span) span.style.display = 'inline';
          if (svg) svg.innerHTML = '<path d="M15 18l-6-6 6-6"/>';
        }
      }
    };

    if (sidebar && sidebarBackdrop) {
      if (menuToggleBtn) {
        menuToggleBtn.addEventListener('click', () => {
          if (window.innerWidth <= 900) {
            sidebar.classList.add('open');
            sidebarBackdrop.classList.add('active');
          }
        });
      }

      sidebarBackdrop.addEventListener('click', () => {
        sidebar.classList.remove('open');
        sidebarBackdrop.classList.remove('active');
      });

      const desktopSidebarCollapseBtn = document.getElementById('desktopSidebarCollapseBtn');
      if (desktopSidebarCollapseBtn) {
        desktopSidebarCollapseBtn.addEventListener('click', () => {
          sidebar.classList.toggle('collapsed');
          document.querySelector('.main-wrap').classList.toggle('expanded');
          const isCollapsed = sidebar.classList.contains('collapsed');
          localStorage.setItem('sidebar-collapsed', isCollapsed);

          const span = desktopSidebarCollapseBtn.querySelector('span');
          const svg = desktopSidebarCollapseBtn.querySelector('svg');
          if (isCollapsed) {
            if (span) span.style.display = 'none';
            if (svg) svg.innerHTML = '<path d="M9 18l6-6-6-6"/>';
          } else {
            if (span) span.style.display = 'inline';
            if (svg) svg.innerHTML = '<path d="M15 18l-6-6 6-6"/>';
          }
        });
      }

      // Auto-restore state on desktop load
      restoreSidebarState();
    }

    // 3. Live Digital Clock & Date
    const liveClock = document.getElementById('liveClock');
    if (liveClock) {
      const updateClock = () => {
        const now = new Date();
        const year = now.getFullYear();
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');
        const hrs = String(now.getHours()).padStart(2, '0');
        const mins = String(now.getMinutes()).padStart(2, '0');
        const secs = String(now.getSeconds()).padStart(2, '0');
        liveClock.textContent = `${year}-${month}-${day} ${hrs}:${mins}:${secs}`;
      };
      updateClock();
      setInterval(updateClock, 1000);
    }

    // 4. Time-Aware Greetings Injector
    const greetingText = "<%= typeof greeting !== 'undefined' ? greeting : '' %>";
    const userName = "<%= typeof user !== 'undefined' && user ? user.name.split(' ')[0] : '' %>";
    const greetingBanner = document.getElementById('dashboardGreeting');
    if (greetingBanner && userName) {
      greetingBanner.textContent = `${greetingText}, ${userName}! ✨`;
    }

    // 5. Notification dropdown toggle is handled inside partials/topbar.ejs.
    // Keep this slot reserved so the newer notification center does not get duplicate click handlers.
    /*
    const notificationBellBtn = document.getElementById('notificationBellBtn');
    const notificationDropdown = document.getElementById('notificationDropdown');

    if (notificationBellBtn && notificationDropdown) {
      notificationBellBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const visible = notificationDropdown.style.display === 'block';
        notificationDropdown.style.display = visible ? 'none' : 'block';
        // Hide theme toggle dropdown if open
      });

      document.addEventListener('click', (e) => {
        if (!notificationDropdown.contains(e.target) && e.target !== notificationBellBtn) {
          notificationDropdown.style.display = 'none';
        }
      });
    }
    */

    // 6. Theme Toggle Logic
    const themeToggleBtn = document.getElementById('themeToggleBtn');
    if (themeToggleBtn) {
      const sunIcon = themeToggleBtn.querySelector('.icon-sun');
      const moonIcon = themeToggleBtn.querySelector('.icon-moon');

      const updateIcons = (theme) => {
        if (theme === 'light') {
          sunIcon.style.display = 'none';
          moonIcon.style.display = 'block';
        } else {
          sunIcon.style.display = 'block';
          moonIcon.style.display = 'none';
        }
      };

      // Set initial icons state
      updateIcons(localStorage.getItem('theme') || 'light');

      themeToggleBtn.addEventListener('click', () => {
        const currentTheme = localStorage.getItem('theme') || 'light';
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

        localStorage.setItem('theme', newTheme);
        updateIcons(newTheme);

        if (newTheme === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
          document.body.classList.add('light-theme');
        } else {
          document.documentElement.removeAttribute('data-theme');
          document.body.classList.remove('light-theme');
        }
      });
    }

    // 7. Textarea auto-resize & counter
    document.querySelectorAll('textarea').forEach(textarea => {
      const autoResize = () => {
        textarea.style.height = 'auto';
        textarea.style.height = textarea.scrollHeight + 'px';
      };
      textarea.addEventListener('input', autoResize);
      if (textarea.value) autoResize();

      const maxLength = textarea.getAttribute('maxlength');
      if (maxLength) {
        const counter = document.createElement('div');
        counter.className = 'char-counter';
        counter.style.fontSize = '0.72rem';
        counter.style.color = 'var(--text-muted)';
        counter.style.textAlign = 'right';
        counter.style.marginTop = '4px';

        const updateCounter = () => {
          counter.textContent = `${textarea.value.length} / ${maxLength}`;
        };
        textarea.parentNode.insertBefore(counter, textarea.nextSibling);
        textarea.addEventListener('input', updateCounter);
        updateCounter();
      }
    });

    // 7b. Rounded themed date picker for native date fields.
    (() => {
      const monthFmt = new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric' });
      const monthOnlyFmt = new Intl.DateTimeFormat('en-US', { month: 'long' });
      let activeInput = null;
      let viewDate = new Date();
      let picker = null;
      let pickerMode = 'day';

      const pad = (n) => String(n).padStart(2, '0');
      const toISODate = (date) => `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
      const parseISODate = (value) => {
        const match = String(value || '').match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if (!match) return null;
        return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3]));
      };

      const closePicker = () => {
        if (picker) picker.remove();
        picker = null;
        activeInput = null;
      };

      const selectDate = (date) => {
        if (!activeInput) return;
        activeInput.value = toISODate(date);
        activeInput.dispatchEvent(new Event('input', { bubbles: true }));
        activeInput.dispatchEvent(new Event('change', { bubbles: true }));
        closePicker();
      };

      const positionPicker = () => {
        if (!picker || !activeInput) return;
        const rect = activeInput.getBoundingClientRect();
        const gap = 8;
        const top = rect.bottom + gap + picker.offsetHeight > window.innerHeight
          ? Math.max(8, rect.top - picker.offsetHeight - gap)
          : rect.bottom + gap;
        const left = Math.min(Math.max(8, rect.left), window.innerWidth - picker.offsetWidth - 8);
        picker.style.top = `${top}px`;
        picker.style.left = `${left}px`;
      };

      const handlePickerAction = (e) => {
        const target = e.target.closest('button');
        if (!target || !picker || !picker.contains(target)) return;

        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();

        if (target.hasAttribute('data-month-view')) {
          pickerMode = 'month';
          renderPicker();
          return;
        }

        if (target.hasAttribute('data-year-view')) {
          pickerMode = 'year';
          renderPicker();
          return;
        }

        if (target.hasAttribute('data-prev')) {
          if (pickerMode === 'day') {
            viewDate = new Date(viewDate.getFullYear(), viewDate.getMonth() - 1, 1);
          } else if (pickerMode === 'month') {
            viewDate = new Date(viewDate.getFullYear() - 1, viewDate.getMonth(), 1);
          } else {
            viewDate = new Date(viewDate.getFullYear() - 12, viewDate.getMonth(), 1);
          }
          renderPicker();
          return;
        }

        if (target.hasAttribute('data-next')) {
          if (pickerMode === 'day') {
            viewDate = new Date(viewDate.getFullYear(), viewDate.getMonth() + 1, 1);
          } else if (pickerMode === 'month') {
            viewDate = new Date(viewDate.getFullYear() + 1, viewDate.getMonth(), 1);
          } else {
            viewDate = new Date(viewDate.getFullYear() + 12, viewDate.getMonth(), 1);
          }
          renderPicker();
          return;
        }

        if (target.hasAttribute('data-month')) {
          viewDate = new Date(viewDate.getFullYear(), Number(target.dataset.month), 1);
          pickerMode = 'day';
          renderPicker();
          return;
        }

        if (target.hasAttribute('data-year')) {
          viewDate = new Date(Number(target.dataset.year), viewDate.getMonth(), 1);
          pickerMode = 'month';
          renderPicker();
          return;
        }

        if (target.hasAttribute('data-date')) {
          selectDate(parseISODate(target.dataset.date));
          return;
        }

        if (target.hasAttribute('data-clear')) {
          if (activeInput) {
            activeInput.value = '';
            activeInput.dispatchEvent(new Event('input', { bubbles: true }));
            activeInput.dispatchEvent(new Event('change', { bubbles: true }));
          }
          closePicker();
          return;
        }

        if (target.hasAttribute('data-today')) {
          selectDate(new Date());
        }
      };

      const renderPicker = () => {
        if (!picker) return;
        const selected = parseISODate(activeInput.value);
        const today = new Date();
        const year = viewDate.getFullYear();
        const month = viewDate.getMonth();
        const changeMonth = (offset) => {
          viewDate = new Date(viewDate.getFullYear(), viewDate.getMonth() + offset, 1);
          renderPicker();
        };
        const changeYear = (offset) => {
          viewDate = new Date(viewDate.getFullYear() + offset, viewDate.getMonth(), 1);
          renderPicker();
        };

        if (pickerMode === 'month') {
          picker.innerHTML = `
            <div class="app-date-picker-head">
              <button type="button" class="app-date-picker-title is-clickable" data-year-view>${year}</button>
              <div class="app-date-picker-nav">
                <button type="button" data-prev aria-label="Previous year">‹</button>
                <button type="button" data-next aria-label="Next year">›</button>
              </div>
            </div>
            <div class="app-date-picker-month-grid">
              ${Array.from({ length: 12 }, (_, i) => `
                <button type="button" class="app-date-picker-month${i === month ? ' is-selected' : ''}" data-month="${i}">
                  ${monthOnlyFmt.format(new Date(year, i, 1)).slice(0, 3)}
                </button>
              `).join('')}
            </div>
          `;

          picker.querySelector('[data-year-view]').addEventListener('click', () => {
            pickerMode = 'year';
            renderPicker();
          });
          picker.querySelector('[data-prev]').addEventListener('click', () => changeYear(-1));
          picker.querySelector('[data-next]').addEventListener('click', () => changeYear(1));
          picker.querySelectorAll('[data-month]').forEach(btn => {
            btn.addEventListener('click', () => {
              viewDate = new Date(viewDate.getFullYear(), Number(btn.dataset.month), 1);
              pickerMode = 'day';
              renderPicker();
            });
          });
          positionPicker();
          return;
        }

        if (pickerMode === 'year') {
          const startYear = Math.floor(year / 12) * 12;
          picker.innerHTML = `
            <div class="app-date-picker-head">
              <div class="app-date-picker-title">${startYear} - ${startYear + 11}</div>
              <div class="app-date-picker-nav">
                <button type="button" data-prev aria-label="Previous years">‹</button>
                <button type="button" data-next aria-label="Next years">›</button>
              </div>
            </div>
            <div class="app-date-picker-year-grid">
              ${Array.from({ length: 12 }, (_, i) => {
                const y = startYear + i;
                return `
                  <button type="button" class="app-date-picker-year${y === year ? ' is-selected' : ''}" data-year="${y}">
                    ${y}
                  </button>
                `;
              }).join('')}
            </div>
          `;

          picker.querySelector('[data-prev]').addEventListener('click', () => {
            viewDate = new Date(viewDate.getFullYear() - 12, viewDate.getMonth(), 1);
            renderPicker();
          });
          picker.querySelector('[data-next]').addEventListener('click', () => {
            viewDate = new Date(viewDate.getFullYear() + 12, viewDate.getMonth(), 1);
            renderPicker();
          });
          picker.querySelectorAll('[data-year]').forEach(btn => {
            btn.addEventListener('click', () => {
              viewDate = new Date(Number(btn.dataset.year), viewDate.getMonth(), 1);
              pickerMode = 'month';
              renderPicker();
            });
          });
          positionPicker();
          return;
        }

        const first = new Date(year, month, 1);
        const start = new Date(year, month, 1 - first.getDay());

        const days = [];
        for (let i = 0; i < 42; i++) {
          const day = new Date(start);
          day.setDate(start.getDate() + i);
          const isCurrentMonth = day.getMonth() === month;
          const isToday = toISODate(day) === toISODate(today);
          const isSelected = selected && toISODate(day) === toISODate(selected);
          days.push(`
            <button type="button" class="app-date-picker-day${isCurrentMonth ? '' : ' is-muted'}${isToday ? ' is-today' : ''}${isSelected ? ' is-selected' : ''}" data-date="${toISODate(day)}">
              ${day.getDate()}
            </button>
          `);
        }

        picker.innerHTML = `
          <div class="app-date-picker-head">
            <button type="button" class="app-date-picker-title is-clickable" data-month-view>${monthFmt.format(viewDate)}</button>
            <div class="app-date-picker-nav">
              <button type="button" data-prev aria-label="Previous month">‹</button>
              <button type="button" data-next aria-label="Next month">›</button>
            </div>
          </div>
          <div class="app-date-picker-grid">
            ${['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'].map(d => `<div class="app-date-picker-weekday">${d}</div>`).join('')}
            ${days.join('')}
          </div>
          <div class="app-date-picker-foot">
            <button type="button" data-clear>Clear</button>
            <button type="button" data-today>Today</button>
          </div>
        `;

        picker.querySelector('[data-month-view]').addEventListener('click', () => {
          pickerMode = 'month';
          renderPicker();
        });
        picker.querySelector('[data-prev]').addEventListener('click', () => {
          changeMonth(-1);
        });
        picker.querySelector('[data-next]').addEventListener('click', () => {
          changeMonth(1);
        });
        picker.querySelector('[data-clear]').addEventListener('click', () => {
          if (activeInput) {
            activeInput.value = '';
            activeInput.dispatchEvent(new Event('input', { bubbles: true }));
            activeInput.dispatchEvent(new Event('change', { bubbles: true }));
          }
          closePicker();
        });
        picker.querySelector('[data-today]').addEventListener('click', () => selectDate(new Date()));
        picker.querySelectorAll('[data-date]').forEach(btn => {
          btn.addEventListener('click', () => selectDate(parseISODate(btn.dataset.date)));
        });
        positionPicker();
      };

      const openPicker = (input) => {
        activeInput = input;
        viewDate = parseISODate(input.value) || new Date();
        pickerMode = 'day';
        if (!picker) {
          picker = document.createElement('div');
          picker.className = 'app-date-picker';
          picker.addEventListener('click', handlePickerAction, true);
          picker.addEventListener('pointerdown', (e) => e.stopPropagation());
          document.body.appendChild(picker);
        }
        renderPicker();
      };

      document.querySelectorAll('input[type="date"]').forEach(input => {
        if (!input.parentElement.classList.contains('date-input-wrap')) {
          const wrapper = document.createElement('span');
          wrapper.className = 'date-input-wrap';
          input.parentNode.insertBefore(wrapper, input);
          wrapper.appendChild(input);
        }

        input.addEventListener('click', (e) => {
          e.preventDefault();
          openPicker(input);
        });
        input.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowDown' || e.key === 'Enter') {
            e.preventDefault();
            openPicker(input);
          }
        });
      });

      document.addEventListener('click', (e) => {
        if (!picker) return;
        if (picker.contains(e.target) || e.target === activeInput) return;
        closePicker();
      });
      window.addEventListener('resize', positionPicker);
      window.addEventListener('scroll', positionPicker, true);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closePicker();
      });
    })();

    // 8. Submit button loading states (form locks)
    document.querySelectorAll('form').forEach(form => {
      form.addEventListener('submit', (e) => {
        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) {
          if (submitBtn.disabled) {
            e.preventDefault();
            return;
          }
          submitBtn.disabled = true;
          submitBtn.setAttribute('data-original-text', submitBtn.innerHTML);
          submitBtn.innerHTML = `<span class="spinner-border" style="display:inline-block; width:12px; height:12px; border:2px solid currentColor; border-top-color:transparent; border-radius:50%; animation:spin 0.6s linear infinite; margin-right:6px; vertical-align: middle;"></span> Processing...`;
        }
      });
    });

    // 9. Confirm dialogs on destructive actions
    let activeConfirmForm = null;
    let activeConfirmElement = null;

    window.closeGlobalConfirmModal = function() {
      const modal = document.getElementById('confirmModalOverlay');
      modal.classList.remove('open');
      activeConfirmForm = null;
      activeConfirmElement = null;
    }

    document.getElementById('confirmModalSubmitBtn').addEventListener('click', () => {
      if (activeConfirmForm) {
        // Submit the form
        // Disable loading logic temporarily to submit
        const submitBtn = activeConfirmForm.querySelector('button[type="submit"]');
        if (submitBtn) submitBtn.disabled = false;
        activeConfirmForm.submit();
      } else if (activeConfirmElement) {
        // Trigger click bypassing data-confirm logic
        const clickEvent = new MouseEvent('click', { bubbles: true, cancelable: true });
        // Temporarily remove attribute to avoid infinite recursion
        const confirmMsg = activeConfirmElement.getAttribute('data-confirm');
        activeConfirmElement.removeAttribute('data-confirm');
        activeConfirmElement.dispatchEvent(clickEvent);
        activeConfirmElement.setAttribute('data-confirm', confirmMsg);
        closeGlobalConfirmModal();
      }
    });

    document.addEventListener('click', (e) => {
      const target = e.target.closest('[data-confirm]');
      if (target) {
        e.preventDefault();
        e.stopPropagation();

        const msg = target.getAttribute('data-confirm') || 'Are you sure you want to perform this action?';
        const isDelete = msg.toLowerCase().includes('delete') || msg.toLowerCase().includes('lost') || msg.toLowerCase().includes('remove');

        const submitBtn = document.getElementById('confirmModalSubmitBtn');
        submitBtn.className = isDelete ? 'btn btn-red btn-sm' : 'btn btn-primary btn-sm';
        submitBtn.textContent = isDelete ? 'Delete' : 'Proceed';

        document.getElementById('confirmModalBody').textContent = msg;
        document.getElementById('confirmModalOverlay').classList.add('open');

        // Find if target is inside a form
        activeConfirmForm = target.closest('form');
        activeConfirmElement = target;
      }
    });

    // Also support forms with onsubmit overrides that use native confirm
    document.addEventListener('submit', (e) => {
      const form = e.target;
      const onsubmitAttr = form.getAttribute('onsubmit');
      if (onsubmitAttr && onsubmitAttr.includes('confirm(')) {
        e.preventDefault();
        e.stopPropagation();

        // Extract message from onsubmitconfirm text
        let msg = 'Are you sure you want to delete this permanently?';
        const matches = onsubmitAttr.match(/confirm\(['"](.*?)['"]\)/);
        if (matches && matches[1]) {
          msg = matches[1];
        }

        const isDelete = msg.toLowerCase().includes('delete') || msg.toLowerCase().includes('lost') || msg.toLowerCase().includes('remove');
        const submitBtn = document.getElementById('confirmModalSubmitBtn');
        submitBtn.className = isDelete ? 'btn btn-red btn-sm' : 'btn btn-primary btn-sm';
        submitBtn.textContent = isDelete ? 'Delete' : 'Proceed';

        document.getElementById('confirmModalBody').textContent = msg;
        document.getElementById('confirmModalOverlay').classList.add('open');
        activeConfirmForm = form;

        // Temporarily strip onsubmit to prevent loop on confirmModalForm submit
        form.setAttribute('data-old-onsubmit', onsubmitAttr);
        form.removeAttribute('onsubmit');
      }
    });

    // 10. Close alerts/toasts automatically after 4 seconds
    setTimeout(() => {
      document.querySelectorAll('.alert-toast').forEach(el => {
        el.style.opacity = '0';
        el.style.transition = 'opacity 0.5s ease';
        setTimeout(() => el.remove(), 500);
      });
    }, 4000);
    // 11. CSRF Token Injection for POST Forms and AJAX calls
    document.addEventListener("DOMContentLoaded", () => {
      const tokenMeta = document.querySelector('meta[name="csrf-token"]');
      if (!tokenMeta) return;
      const token = tokenMeta.getAttribute('content');

      const injectToken = () => {
        document.querySelectorAll('form').forEach(form => {
          if (form.method.toUpperCase() === 'POST') {
            if (form.enctype === 'multipart/form-data') {
              const url = new URL(form.action, window.location.href);
              url.searchParams.set('_csrf', token);
              form.action = url.pathname + url.search;
            } else {
              if (!form.querySelector('input[name="_csrf"]')) {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = '_csrf';
                input.value = token;
                form.appendChild(input);
              }
            }
          }
        });
      };

      injectToken();
      // Also monitor dynamically added forms
      const observer = new MutationObserver(injectToken);
      observer.observe(document.body, { childList: true, subtree: true });

      // Intercept fetch
      const originalFetch = window.fetch;
      window.fetch = function(url, options) {
        options = options || {};
        options.headers = options.headers || {};
        if (options.method && ['POST', 'PUT', 'DELETE', 'PATCH'].includes(options.method.toUpperCase())) {
          if (options.headers instanceof Headers) {
            options.headers.set('X-CSRF-Token', token);
          } else {
            options.headers['X-CSRF-Token'] = token;
          }
        }
        return originalFetch(url, options);
      };
    });
  </script>

  <!-- Global Image Lightbox Modal -->
  <div id="imageLightboxModal" style="display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.9); align-items: center; justify-content: center; backdrop-filter: blur(10px); transition: opacity 0.2s ease;" onclick="closeImageLightbox()">
    <span style="position: absolute; top: 15px; right: 35px; color: #f1f1f1; font-size: 40px; font-weight: 200; transition: 0.3s; cursor: pointer; user-select: none;" onmouseover="this.style.color='#bbb'" onmouseout="this.style.color='#f1f1f1'" onclick="closeImageLightbox()">&times;</span>
    <img id="lightboxTargetImage" src="" alt="Profile Image" style="margin: auto; display: block; max-width: 85%; max-height: 85%; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.7); object-fit: contain; transform: scale(0.92); transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);" onclick="event.stopPropagation()">
  </div>

  <script>
    window.openImageLightbox = (src) => {
      const modal = document.getElementById('imageLightboxModal');
      const img = document.getElementById('lightboxTargetImage');
      if (modal && img) {
        img.src = src;
        modal.style.display = 'flex';
        modal.style.opacity = '0';
        // force reflow
        void modal.offsetWidth;
        modal.style.opacity = '1';
        img.style.transform = 'scale(1)';
      }
    };

    window.closeImageLightbox = () => {
      const modal = document.getElementById('imageLightboxModal');
      const img = document.getElementById('lightboxTargetImage');
      if (modal && img) {
        modal.style.opacity = '0';
        img.style.transform = 'scale(0.92)';
        setTimeout(() => {
          modal.style.display = 'none';
        }, 200);
      }
    };

    // Close lightbox on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeImageLightbox();
      }
    });
  </script>
</body>
</html>
