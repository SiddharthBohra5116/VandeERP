<%
  layout = 'main';
  title = 'Pending Profile Approvals';
  subtitle = 'Manage student profile data update request approvals';
  page = 'profile-requests';
%>

<% if (students.length === 0) { %>
  <div class="card">
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      <p>No pending profile update requests found.</p>
    </div>
  </div>
<% } else { %>
  <% students.forEach(student => { %>
    <% const pending = student.pendingProfileUpdate; %>
    <div class="card" style="margin-bottom: 1.5rem; border: 1px solid var(--border);">
      <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.25rem; border-bottom: 1px solid var(--border);">
        <div>
          <h3 style="font-weight: 700; color: var(--gold); margin: 0; font-size: 1.1rem;"><%= student.name %></h3>
          <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 2px;">
            Email: <span class="mono"><%= student.email %></span> | Roll: <span class="mono"><%= student.rollNumber || '—' %></span> | Requested: <span class="mono"><%= new Date(pending.requestedAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
          </div>
        </div>
        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <form action="/admin/students/<%= student._id %>/approve-profile" method="POST" style="margin:0;">
            <input type="hidden" name="redirect" value="/admin/profile-requests?updated=1">
            <button type="submit" class="btn btn-primary btn-sm">Approve</button>
          </form>
          <form action="/admin/students/<%= student._id %>/reject-profile" method="POST" style="margin:0;">
            <input type="hidden" name="redirect" value="/admin/profile-requests?updated=1">
            <button type="submit" class="btn btn-danger btn-sm">Reject</button>
          </form>
        </div>
      </div>
      
      <div class="table-wrap" style="padding: 0;">
        <table style="width: 100%; border-collapse: collapse; margin: 0;">
          <thead>
            <tr>
              <th style="padding: 0.75rem 1.25rem; text-align: left; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: 1px solid var(--border);">Field</th>
              <th style="padding: 0.75rem 1.25rem; text-align: left; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: 1px solid var(--border);">Current Value</th>
              <th style="padding: 0.75rem 1.25rem; text-align: left; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: 1px solid var(--border);">Proposed Value</th>
            </tr>
          </thead>
          <tbody>
            <% 
              const fields = [
                { key: 'name', label: 'Full Name' },
                { key: 'phone', label: 'Phone Number' },
                { key: 'profilePic', label: 'Profile Picture URL' },
                { key: 'fatherName', label: "Father's Name" },
                { key: 'motherName', label: "Mother's Name" },
                { key: 'address', label: 'Address' },
                { key: 'city', label: 'City' },
                { key: 'dob', label: 'Date of Birth' }
              ];
            %>
            <% fields.forEach(f => { %>
              <% if (pending[f.key] !== null && pending[f.key] !== undefined) { %>
                <% 
                  let currentVal = student[f.key];
                  let proposedVal = pending[f.key];
                  if (f.key === 'dob' && currentVal) {
                    currentVal = new Date(currentVal).toISOString().split('T')[0];
                  }
                  if (f.key === 'dob' && proposedVal) {
                    proposedVal = new Date(proposedVal).toISOString().split('T')[0];
                  }
                %>
                <% if (String(currentVal) !== String(proposedVal)) { %>
                  <tr>
                    <td style="padding: 0.75rem 1.25rem; font-weight: 600; color: var(--text); border-bottom: 1px solid var(--border); font-size: 0.85rem;"><%= f.label %></td>
                    <td style="padding: 0.75rem 1.25rem; color: var(--text-muted); border-bottom: 1px solid var(--border); font-size: 0.85rem;"><%= currentVal || '—' %></td>
                    <td style="padding: 0.75rem 1.25rem; color: var(--gold-light); font-weight: 600; border-bottom: 1px solid var(--border); font-size: 0.85rem;"><%= proposedVal || '—' %></td>
                  </tr>
                <% } %>
              <% } %>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% }) %>
<% } %>
