<%
  layout = 'main';
  title = 'Class Schedules';
  subtitle = 'Master calendar, classrooms layout, and visual batch planning';
  page = 'schedules';
%>

<!-- Style block for visual weekly planner & premium grid -->
<style>
  .tab-btn {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    border-radius: 0 !important;
    color: var(--text-muted);
    padding: 0.75rem 1.25rem;
    font-weight: 700;
    font-family: var(--font-display);
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .tab-btn.active {
    border-bottom-color: var(--gold);
    color: var(--gold);
  }
  .tab-btn:hover {
    color: var(--text);
  }
  
  /* Weekly Planner Grid */
  .weekly-planner-wrapper {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }
  @media (max-width: 900px) {
    .weekly-planner-wrapper {
      grid-template-columns: 1fr;
    }
  }

  .weekly-grid-container {
    display: grid;
    grid-template-columns: 60px repeat(7, 1fr);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    overflow: hidden;
    position: relative;
    user-select: none;
  }
  
  .weekly-grid-header {
    grid-column: 2 / span 7;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    background: rgba(0, 0, 0, 0.25);
    border-bottom: 1px solid var(--border);
    text-align: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .weekly-grid-header-day {
    padding: 0.75rem;
    border-right: 1px solid var(--border);
  }
  .weekly-grid-header-day:last-child {
    border-right: none;
  }

  .weekly-grid-hours-sidebar {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.15);
  }
  .weekly-grid-hour-label {
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-muted);
    border-bottom: 1px dashed var(--border-light);
  }

  .weekly-grid-body-columns {
    grid-column: 2 / span 7;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    position: relative;
    height: 720px; /* 12 hours * 60px */
  }

  .weekly-grid-day-col {
    position: relative;
    height: 100%;
    border-right: 1px solid var(--border);
    background-image: linear-gradient(var(--border-light) 1px, transparent 1px);
    background-size: 100% 60px; /* hourly lines */
    cursor: cell;
    transition: background 0.15s;
  }
  .weekly-grid-day-col:last-child {
    border-right: none;
  }
  .weekly-grid-day-col:hover {
    background-color: rgba(255, 204, 0, 0.01);
  }

  /* Timetable visually placed blocks */
  .weekly-grid-block {
    position: absolute;
    left: 4px;
    right: 4px;
    border-radius: 6px;
    padding: 0.45rem;
    font-size: 0.7rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
    cursor: pointer;
    overflow: hidden;
    line-height: 1.25;
    border-left: 3px solid var(--gold);
    background: rgba(255, 204, 0, 0.04);
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }
  .weekly-grid-block:hover {
    transform: scale(1.02);
    box-shadow: 0 6px 20px rgba(255, 204, 0, 0.1);
    background: rgba(255, 204, 0, 0.08);
    z-index: 10;
  }
  
  .weekly-grid-block.clashed {
    border-left-color: var(--red) !important;
    background: rgba(239, 68, 68, 0.06) !important;
  }
  .weekly-grid-block.clashed:hover {
    box-shadow: 0 6px 20px rgba(239, 68, 68, 0.15);
    background: rgba(239, 68, 68, 0.1) !important;
  }

  .slot-subject {
    font-weight: 800;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .slot-teacher {
    color: var(--gold-light);
    font-weight: 600;
    font-size: 0.65rem;
  }
  .slot-classroom {
    color: var(--text-muted);
    font-size: 0.6rem;
  }
  .slot-time {
    font-family: monospace;
    font-size: 0.6rem;
    color: var(--text-muted);
    margin-top: auto;
  }
  .clash-badge {
    background: var(--red);
    color: #fff;
    font-size: 0.55rem;
    font-weight: 800;
    padding: 1px 4px;
    border-radius: 3px;
    position: absolute;
    top: 4px; right: 4px;
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0% { opacity: 0.7; }
    50% { opacity: 1; }
    100% { opacity: 0.7; }
  }

  /* Popover config */
  .slot-popover {
    position: absolute;
    width: 280px;
    background: #1e1e1ecf;
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    z-index: 1000;
    padding: 1rem;
    display: none;
    flex-direction: column;
    gap: 0.75rem;
  }
  .slot-popover-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.4rem;
    margin-bottom: 0.2rem;
  }
  .slot-popover-header h5 {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--gold);
    margin: 0;
  }
  .tab-hidden {
    display: none !important;
  }
</style>

<!-- Header Tabs Navigation -->
<div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); margin-bottom: 1.5rem; flex-wrap: wrap; gap: 10px;">
  <div style="display: flex; gap: 0.25rem; flex-wrap: wrap;">
    <button type="button" class="btn tab-btn active" onclick="switchTab('monthCalendar')" id="btn-monthCalendar">Monthly Calendar View</button>
    <button type="button" class="btn tab-btn" onclick="switchTab('dailyTimeline')" id="btn-dailyTimeline">Daily Room Planner</button>
    <button type="button" class="btn tab-btn" onclick="switchTab('hierarchyTree')" id="btn-hierarchyTree">Classroom Hierarchy Tree</button>
    <button type="button" class="btn tab-btn" onclick="switchTab('templates')" id="btn-templates">Weekly Templates (Auto-Generator)</button>
    <button type="button" class="btn tab-btn" onclick="switchTab('classroomView')" id="btn-classroomView">Classroom Grid View</button>
    <button type="button" class="btn tab-btn" onclick="switchTab('classrooms')" id="btn-classrooms">Manage Classrooms</button>
  </div>
  <div style="padding-bottom: 0.5rem; display: flex; gap: 0.5rem;">
    <button type="button" class="btn btn-primary btn-sm" onclick="openCreateDrawer('')">+ Add Schedule</button>
  </div>
</div>

<!-- ==================== TAB 1: MONTHLY CALENDAR GRID ==================== -->
<div id="tab-monthCalendar" class="tab-pane">
  <div class="card" style="padding: 1.25rem; margin-bottom: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; flex-wrap: wrap; gap: 10px;">
      <div style="display: flex; align-items: center; gap: 0.5rem;">
        <h3 style="font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; color: var(--text); margin: 0;"><%= currentMonthLabel %></h3>
      </div>
      <div style="display: flex; gap: 0.5rem; align-items: center;">
        <a href="?month=<%= prevMonthStr %>" class="btn btn-ghost btn-xs" style="padding: 0.35rem 0.65rem;">&larr; Previous Month</a>
        <a href="?month=<%= new Date().toISOString().slice(0, 7) %>" class="btn btn-ghost btn-xs" style="padding: 0.35rem 0.65rem; color: var(--gold);">Current Month</a>
        <a href="?month=<%= nextMonthStr %>" class="btn btn-ghost btn-xs" style="padding: 0.35rem 0.65rem;">Next Month &rarr;</a>
      </div>
    </div>

    <!-- Monthly Calendar Grid Layout -->
    <div style="display: grid; grid-template-columns: repeat(7, 1fr); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background: var(--bg-card);">
      <% ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].forEach(day => { %>
        <div style="background: rgba(0,0,0,0.25); text-align: center; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); padding: 0.65rem; border-bottom: 1px solid var(--border);"><%= day %></div>
      <% }) %>

      <% for (let i = 0; i < startDayOfWeek; i++) { %>
        <div style="background: rgba(0,0,0,0.05); border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); min-height: 120px;"></div>
      <% } %>

      <% 
        const [yStr, mStr] = monthParam.split('-');
      %>
      <% for (let d = 1; d <= daysInMonth; d++) { 
          const dateStr = `${yStr}-${mStr}-${String(d).padStart(2,'0')}`;
          const isToday = new Date().toDateString() === new Date(yStr, parseInt(mStr)-1, d).toDateString();
          const daySchedules = monthSchedulesGrouped[d] || [];
      %>
        <div class="calendar-day-cell" <%= `style="min-height: 120px; border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 0.5rem; display: flex; flex-direction: column; gap: 0.35rem; position: relative; background: ${isToday ? 'rgba(255,204,0,0.02)' : 'transparent'}; transition: background 0.15s;"` %> onmouseover="this.querySelector('.day-cell-add-btn').style.opacity='1'" onmouseout="this.querySelector('.day-cell-add-btn').style.opacity='0'">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <span <%= `style="font-size: 0.78rem; font-weight: 700; color: ${isToday ? 'var(--gold)' : 'var(--text-muted)'}"` %>><%= d %></span>
            <button class="day-cell-add-btn" onclick="openCreateDrawer('<%= dateStr %>')" style="opacity: 0; background: none; border: none; color: var(--gold-light); font-size: 0.85rem; font-weight: bold; cursor: pointer; transition: opacity 0.15s; display: flex; align-items: center; justify-content: center; width: 16px; height: 16px; border-radius: 50%;">+</button>
          </div>

          <div style="display: flex; flex-direction: column; gap: 0.25rem; flex: 1; padding-bottom: 4px;">
            <% daySchedules.forEach(sched => { 
                const isCancelled = sched.status === 'cancelled';
                const isCompleted = sched.status === 'completed';
            %>
              <div class="calendar-event-card" 
                   data-id="<%= sched._id %>"
                   data-subject="<%= sched.note || '—' %>"
                   data-batch="<%= sched.batch %>"
                   data-teacher="<%= sched.teacher ? sched.teacher._id : '' %>"
                   data-classroom="<%= sched.classroom ? sched.classroom._id : '' %>"
                   data-date="<%= sched.date %>"
                   data-starttime="<%= sched.startTime %>"
                   data-endtime="<%= sched.endTime %>"
                   data-status="<%= sched.status %>"
                   onclick="openEditDrawer(this)"
                   <%= `style="background: var(--bg-hover); border-left: 2px solid ${isCancelled ? 'var(--red)' : (isCompleted ? 'var(--blue)' : 'var(--gold)')}; border-radius: 4px; padding: 0.35rem 0.45rem; font-size: 0.65rem; color: var(--text-sub); cursor: pointer; display: flex; flex-direction: column; gap: 2px; transition: transform 0.1s; line-height: 1.2;"` %>
                   onmouseover="this.style.transform='translateY(-1px)';" onmouseout="this.style.transform='none';">
                <div style="font-weight: 700; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= sched.note || '—' %></div>
                <div style="display: flex; justify-content: space-between; color: var(--text-muted); font-size: 0.58rem;">
                  <span><%= sched.startTime.split(' ')[0] %>-<%= sched.endTime.split(' ')[0] %></span>
                  <span style="color: var(--gold-light); font-weight:600;"><%= sched.classroom ? sched.classroom.name.replace(/^(classroom|room)\s+/i, '') : 'Room' %></span>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <% 
        const totalCellsFilled = startDayOfWeek + daysInMonth;
        const trailingCells = totalCellsFilled % 7 === 0 ? 0 : 7 - (totalCellsFilled % 7);
      %>
      <% for (let i = 0; i < trailingCells; i++) { %>
        <div style="background: rgba(0,0,0,0.05); border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); min-height: 120px;"></div>
      <% } %>
    </div>
  </div>
</div>

<!-- ==================== TAB 2: DAILY CLASSROOM TIMELINE PLANNER ==================== -->
<div id="tab-dailyTimeline" class="tab-pane tab-hidden">
  <div class="card" style="padding: 1.25rem; margin-bottom: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 10px;">
      <div style="display: flex; align-items: center; gap: 0.75rem;">
        <span style="font-size: 0.85rem; font-weight: 700; color: var(--text-sub);">Target Day:</span>
        <input type="date" id="dailyTimelineDatePicker" class="form-control" style="width: auto; padding: 0.35rem 0.75rem; font-size: 0.8rem; background: var(--bg-hover);" value="<%= dayParam %>" onchange="changeDailyPlannerDate(this.value)">
      </div>
      <div style="font-size: 0.8rem; color: var(--text-muted);">Daily classroom scheduling allocations</div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
      <% classrooms.forEach(room => { 
          const roomSchedules = timelineClassroomData[room._id.toString()] || [];
      %>
        <div style="background: var(--bg-hover); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; min-height: 350px; display: flex; flex-direction: column;">
          <div style="background: rgba(0,0,0,0.2); padding: 0.75rem; border-bottom: 1px solid var(--border); text-align: center;">
            <h4 style="font-family: var(--font-display); font-size: 0.85rem; font-weight: 800; color: var(--gold); margin: 0;"><%= room.name %></h4>
            <span style="font-size: 0.65rem; color: var(--text-muted);"><%= room.location || 'First Floor' %> &middot; Cap: <%= room.capacity %></span>
          </div>

          <div style="padding: 0.75rem; display: flex; flex-direction: column; gap: 0.6rem; flex: 1; overflow-y: auto;">
            <% if (roomSchedules.length === 0) { %>
              <div style="flex: 1; display: flex; align-items: center; justify-content: center; font-size: 0.72rem; color: var(--text-muted); font-style: italic; opacity: 0.6;">Room Available</div>
            <% } else { %>
              <% roomSchedules.forEach(sched => { %>
                <div class="calendar-event-card"
                     data-id="<%= sched._id %>"
                     data-subject="<%= sched.note || '—' %>"
                     data-batch="<%= sched.batch %>"
                     data-teacher="<%= sched.teacher ? sched.teacher._id : '' %>"
                     data-classroom="<%= sched.classroom ? sched.classroom._id : '' %>"
                     data-date="<%= sched.date %>"
                     data-starttime="<%= sched.startTime %>"
                     data-endtime="<%= sched.endTime %>"
                     data-status="<%= sched.status %>"
                     onclick="openEditDrawer(this)"
                     style="background: var(--bg-card); border-left: 3px solid var(--gold); border-radius: 4px; padding: 0.6rem; display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.7rem; cursor: pointer; transition: border-color 0.15s, transform 0.15s;"
                     onmouseover="this.style.borderColor='var(--gold-hover)'; this.style.transform='translateY(-1px)'" onmouseout="this.style.borderColor='var(--gold)'; this.style.transform='none'">
                  <div style="font-weight: 700; color: var(--text);"><%= sched.note || '—' %></div>
                  <div style="font-size: 0.65rem; color: var(--text-sub); display: flex; flex-direction: column; gap: 1px; margin-top: auto; padding-top: 4px; border-top: 1px dashed var(--border-light);">
                    <span style="font-weight: 600;"><%= sched.batch %></span>
                    <% if (sched.teacher) { %>
                      <span style="color: var(--gold-light);">👨‍🏫 <%= sched.teacher.name %></span>
                    <% } %>
                    <span style="font-family: monospace; font-size: 0.65rem; color: var(--text-muted); margin-top: 2px;">⏰ <%= sched.startTime %> - <%= sched.endTime %></span>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- ==================== TAB 3: CLASSROOM HIERARCHY TREE ==================== -->
<div id="tab-hierarchyTree" class="tab-pane tab-hidden">
  <% 
    const classroomTree = {};
    classrooms.forEach(c => {
      classroomTree[c.name] = { id: c._id, courses: {} };
    });
    schedules.forEach(s => {
      if (s.classroom) {
        const cName = s.classroom.name;
        if (!classroomTree[cName]) {
          classroomTree[cName] = { id: s.classroom._id, courses: {} };
        }
        
        let courseName = 'Other General';
        const bLower = s.batch.toLowerCase();
        if (bLower.includes('video')) {
          courseName = 'Video Editing';
        } else if (bLower.includes('marketing')) {
          courseName = 'Digital Marketing';
        }
        
        if (!classroomTree[cName].courses[courseName]) {
          classroomTree[cName].courses[courseName] = {};
        }
        if (!classroomTree[cName].courses[courseName][s.batch]) {
          classroomTree[cName].courses[courseName][s.batch] = [];
        }
        classroomTree[cName].courses[courseName][s.batch].push(s);
      }
    });
  %>

  <div class="card" style="padding: 1.25rem;">
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <% Object.keys(classroomTree).forEach((cName, idx) => { 
          const node = classroomTree[cName];
      %>
        <details style="background: var(--bg-hover); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;" <%= idx === 0 ? 'open' : '' %>>
          <summary style="padding: 0.85rem 1.25rem; font-weight: 700; font-size: 0.9rem; color: var(--text); cursor: pointer; display: flex; justify-content: space-between; align-items: center; user-select: none;">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
              <span style="color: var(--gold);">🏫</span>
              <%= cName %>
            </div>
            <span style="font-size: 0.72rem; color: var(--text-muted); font-weight: normal;">
              <%= Object.keys(node.courses).length %> courses active
            </span>
          </summary>
          
          <div style="padding: 1rem; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 1rem; background: var(--bg-card);">
            <% if (Object.keys(node.courses).length === 0) { %>
              <p style="font-size:0.75rem; color: var(--text-muted); font-style: italic;">No classes currently scheduled in this classroom.</p>
            <% } else { %>
              <% Object.keys(node.courses).forEach(courseName => { %>
                <div style="border: 1px solid var(--border); border-radius: 6px; overflow: hidden; margin-bottom: 0.5rem;">
                  <div style="background: rgba(0,0,0,0.1); padding: 0.5rem 0.75rem; font-weight: 700; font-size: 0.78rem; color: var(--gold-light);">📁 Course: <%= courseName %></div>
                  <div style="padding: 0.75rem; display: flex; flex-direction: column; gap: 0.75rem;">
                    <% Object.keys(node.courses[courseName]).forEach(batchName => { 
                        const batchSchedules = node.courses[courseName][batchName];
                    %>
                      <div style="border: 1px solid var(--border-light); border-radius: 4px; overflow: hidden;">
                        <div style="background: rgba(255,255,255,0.02); padding: 0.4rem 0.6rem; font-size: 0.72rem; font-weight: 600; color: var(--text-sub); border-bottom: 1px solid var(--border-light);">👥 Batch: <%= batchName %></div>
                        <div class="table-wrap">
                          <table style="margin: 0; font-size: 0.75rem;">
                            <thead>
                              <tr>
                                <th>Subject</th>
                                <th>Teacher</th>
                                <th>Date & Time</th>
                                <th>Status</th>
                                <th>Action</th>
                              </tr>
                            </thead>
                            <tbody>
                              <% batchSchedules.forEach(sched => { %>
                                <tr>
                                  <td><strong><%= sched.note || '—' %></strong></td>
                                  <td><%= sched.teacher ? sched.teacher.name : '—' %></td>
                                  <td><%= new Date(sched.date + "T00:00:00").toLocaleDateString('en-IN') %> &middot; <span class="text-gold"><%= sched.startTime %> - <%= sched.endTime %></span></td>
                                  <td>
                                    <span class="badge <%= sched.status === 'scheduled' ? 'badge-green' : sched.status === 'completed' ? 'badge-blue' : 'badge-red' %>" style="font-size: 0.55rem;">
                                      <%= sched.status %>
                                    </span>
                                  </td>
                                  <td>
                                    <button class="btn btn-ghost btn-xs"
                                            data-id="<%= sched._id %>"
                                            data-subject="<%= sched.note || '—' %>"
                                            data-batch="<%= sched.batch %>"
                                            data-teacher="<%= sched.teacher ? sched.teacher._id : '' %>"
                                            data-classroom="<%= sched.classroom ? sched.classroom._id : '' %>"
                                            data-date="<%= sched.date %>"
                                            data-starttime="<%= sched.startTime %>"
                                            data-endtime="<%= sched.endTime %>"
                                            data-status="<%= sched.status %>"
                                            onclick="openEditDrawer(this)"
                                            style="padding: 0.2rem 0.4rem; font-size: 0.65rem;">Edit</button>
                                  </td>
                                </tr>
                              <% }) %>
                            </tbody>
                          </table>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </details>
      <% }) %>
    </div>
  </div>
</div>

<!-- ==================== TAB 4: VISUAL WEEKLY TIMETABLE GENERATOR ==================== -->
<div id="tab-templates" class="tab-pane tab-hidden">
  <div class="card" style="padding: 1.25rem;">
    
    <!-- Top control parameters -->
    <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: flex-end; border-bottom: 1px solid var(--border); padding-bottom: 1.25rem; margin-bottom: 1rem;">
      <div class="form-group" style="margin: 0; min-width: 220px;">
        <label class="form-label">Selected Planning Batch *</label>
        <select id="v_select_batch" class="form-control" onchange="loadBatchTemplate(this.value)">
          <option value="">-- Select Batch to Configure --</option>
          <% batches.forEach(b => { %>
            <option value="<%= b %>"><%= b %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group" style="margin: 0; width: 140px;">
        <label class="form-label">Start Date</label>
        <input type="date" id="v_startDate" class="form-control">
      </div>
      <div class="form-group" style="margin: 0; width: 140px;">
        <label class="form-label">End Date</label>
        <input type="date" id="v_endDate" class="form-control">
      </div>
      
