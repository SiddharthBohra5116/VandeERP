                          👨‍🏫 <%= sched.teacher ? sched.teacher.name : 'No Teacher' %>
                        </div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <span style="color: var(--text-muted); opacity: 0.4; font-style: italic;">Free</span>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
