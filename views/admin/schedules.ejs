          </div>
          
          <input type="hidden" id="pop_slot_id">
          
          <div class="form-group" style="margin-bottom: 0.5rem;">
            <label style="font-size: 0.6rem; color: var(--text-muted); display: block; margin-bottom: 2px;">Day of Week</label>
            <select id="pop_day" class="form-control" style="font-size: 0.75rem; padding: 0.3rem;">
              <option value="Monday">Monday</option>
              <option value="Tuesday">Tuesday</option>
              <option value="Wednesday">Wednesday</option>
              <option value="Thursday">Thursday</option>
              <option value="Friday">Friday</option>
              <option value="Saturday">Saturday</option>
              <option value="Sunday">Sunday</option>
            </select>
          </div>
          
          <div class="form-group" style="margin-bottom: 0.5rem;">
            <label style="font-size: 0.6rem; color: var(--text-muted); display: block; margin-bottom: 2px;">Instructor *</label>
            <select id="pop_teacher" class="form-control" style="font-size: 0.75rem; padding: 0.3rem;">
              <% teachers.forEach(t => { %>
                <option value="<%= t._id %>"><%= t.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group" style="margin-bottom: 0.5rem;">
            <label style="font-size: 0.6rem; color: var(--text-muted); display: block; margin-bottom: 2px;">Classroom / Hall *</label>
            <select id="pop_classroom" class="form-control" style="font-size: 0.75rem; padding: 0.3rem;">
              <% classrooms.forEach(r => { %>
                <option value="<%= r._id %>"><%= r.name %></option>
              <% }) %>
