            <option value="<%= t._id %>"><%= t.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label" for="e_classroom">Target Classroom / Suite *</label>
        <select id="e_classroom" name="classroom" class="form-control" required>
          <option value="">-- Select Classroom --</option>
          <% classrooms.forEach(r => { %>
            <option value="<%= r._id %>"><%= r.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label" for="e_date">Schedule Date *</label>
        <input type="date" id="e_date" name="date" class="form-control" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="e_startTime">Start Time *</label>
          <input type="time" id="e_startTime" name="startTime" class="form-control" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="e_endTime">End Time *</label>
          <input type="time" id="e_endTime" name="endTime" class="form-control" required>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="e_status">Session Status</label>
        <select id="e_status" name="status" class="form-control">
          <option value="scheduled">Scheduled</option>
          <option value="completed">Completed</option>
          <option value="cancelled">Cancelled</option>
        </select>
      </div>

      <div style="display: flex; gap: 0.5rem; margin-top: 1.5rem; justify-content: flex-end;">
        <button type="button" class="btn btn-danger btn-sm" onclick="triggerDeleteSession()" style="margin-right: auto;">Delete</button>
        <button type="button" class="btn btn-ghost btn-sm" onclick="closeAllDrawers()">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm">Save Changes</button>
      </div>
    </form>

    <form action="" method="POST" id="deleteScheduleForm" style="display: none;" onsubmit="return confirm('Delete this schedule slot permanently?')">
    </form>
  </div>
</div>

<!-- JSON Data Store for schedule configurations to bypass linter warnings -->
<textarea id="schedules-data" style="display: none;"><%- JSON.stringify({
  timetables: typeof timetables !== 'undefined' ? timetables : [],
  teachers: typeof teachers !== 'undefined' ? teachers : [],
  classrooms: typeof classrooms !== 'undefined' ? classrooms : []
}) %></textarea>

<!-- ==================== DYNAMIC DATA SCRIPTS ==================== -->
<script>
  // Global reference variables
  const schedulesStorage = JSON.parse(document.getElementById('schedules-data').value);
  const timetablesData = schedulesStorage.timetables;
  const teachersData = schedulesStorage.teachers;
  const classroomsData = schedulesStorage.classrooms;
  
  let activeBatch = "";
  let activeSlots = []; // local slots for current selected batch

  // Helper to format AM/PM to 24h string (HH:mm) for input[type="time"]
  function formatTimeTo24h(timeStr) {
    if (!timeStr) return '';
    timeStr = timeStr.trim().toUpperCase();
    const matches = timeStr.match(/^(\d+):(\d+)\s*(AM|PM)$/);
    if (!matches) return timeStr;
    let hours = parseInt(matches[1], 10);
    const minutes = matches[2];
    const ampm = matches[3];
    if (ampm === 'PM' && hours < 12) hours += 12;
    if (ampm === 'AM' && hours === 12) hours = 0;
    return `${String(hours).padStart(2, '0')}:${minutes}`;
  }

  // Convert "HH:mm" standard string back to "hh:mm AM/PM"
  function format24hToAMPM(timeStr) {
    if (!timeStr) return '';
    const parts = timeStr.split(':');
    let hours = parseInt(parts[0], 10);
    const minutes = parts[1];
    const ampm = hours >= 12 ? 'PM' : 'AM';
    hours = hours % 12;
    hours = hours ? hours : 12; // 0 hour is 12
    return `${hours}:${minutes} ${ampm}`;
  }

  function parseTimeToMinutes(timeStr) {
    if (!timeStr) return 0;
    timeStr = timeStr.trim().toUpperCase();
    let hours = 0;
    let minutes = 0;
    
    if (timeStr.includes('AM') || timeStr.includes('PM')) {
      const matches = timeStr.match(/^(\d+):(\d+)\s*(AM|PM)$/);
      if (matches) {
        hours = parseInt(matches[1], 10);
        minutes = parseInt(matches[2], 10);
        const ampm = matches[3];
        if (ampm === 'PM' && hours < 12) hours += 12;
        if (ampm === 'AM' && hours === 12) hours = 0;
      }
    } else {
      const parts = timeStr.split(':');
      if (parts.length >= 2) {
        hours = parseInt(parts[0], 10);
        minutes = parseInt(parts[1], 10);
      }
    }
    return hours * 60 + minutes;
  }

  // Active tab state management
  function switchTab(tabId) {
    document.querySelectorAll('.tab-pane').forEach(el => {
      el.classList.add('tab-hidden');
    });
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.remove('active');
    });

    const activePane = document.getElementById('tab-' + tabId);
    if (activePane) {
      activePane.classList.remove('tab-hidden');
    }
    const activeBtn = document.getElementById('btn-' + tabId);
    if (activeBtn) {
      activeBtn.classList.add('active');
    }

    try {
      sessionStorage.setItem('adminSchedulesActiveTab', tabId);
    } catch (e) {
      // Ignored: fails safely in strict privacy/incognito mode
    }
  }

  function changeDailyPlannerDate(val) {
    window.location.href = `?day=${val}&month=<%= monthParam %>`;
  }

  function changeClassroomGridDate(val) {
    window.location.href = `?day=${val}&month=<%= monthParam %>&view=classroom`;
  }

  // Slide-over drawer actions
  function openCreateDrawer(dateStr) {
    closeAllDrawers();
    document.getElementById('c_subject').value = '';
    document.getElementById('c_batch').value = '';
    document.getElementById('c_teacher').value = '';
    document.getElementById('c_classroom').value = '';
    document.getElementById('c_startTime').value = '10:00';
    document.getElementById('c_endTime').value = '11:30';
    document.getElementById('c_status').value = 'scheduled';
    
    if (dateStr) {
      document.getElementById('c_date').value = dateStr;
    } else {
      document.getElementById('c_date').value = new Date().toISOString().split('T')[0];
    }

    document.getElementById('createDrawer').classList.add('open');
    document.getElementById('drawerOverlay').classList.add('active');
  }

  function openEditDrawer(element) {
    closeAllDrawers();
    let target = element;
    if (!target.classList.contains('calendar-event-card') && !target.classList.contains('btn')) {
      target = target.closest('.calendar-event-card') || target.closest('.btn');
    }
    
    const id = target.getAttribute('data-id');
    const subject = target.getAttribute('data-subject');
    const batch = target.getAttribute('data-batch');
    const teacher = target.getAttribute('data-teacher');
    const classroom = target.getAttribute('data-classroom');
    const date = target.getAttribute('data-date');
    const starttime = target.getAttribute('data-starttime');
    const endtime = target.getAttribute('data-endtime');
    const status = target.getAttribute('data-status');

    document.getElementById('editScheduleForm').action = `/admin/schedules/${id}/edit`;
    document.getElementById('deleteScheduleForm').action = `/admin/schedules/${id}/delete`;
    
    document.getElementById('e_subject').value = subject;
    document.getElementById('e_batch').value = batch;
    document.getElementById('e_teacher').value = teacher;
    document.getElementById('e_classroom').value = classroom;
    document.getElementById('e_date').value = date;
    document.getElementById('e_startTime').value = formatTimeTo24h(starttime);
    document.getElementById('e_endTime').value = formatTimeTo24h(endtime);
    document.getElementById('e_status').value = status;

    document.getElementById('editDrawer').classList.add('open');
    document.getElementById('drawerOverlay').classList.add('active');
  }

  function closeAllDrawers() {
    document.getElementById('createDrawer').classList.remove('open');
    document.getElementById('editDrawer').classList.remove('open');
    document.getElementById('drawerOverlay').classList.remove('active');
    closePopover();
  }

  function triggerDeleteSession() {
    document.getElementById('deleteScheduleForm').submit();
  }

  // Classroom Modals
  function toggleRoomModal(modalId, show) {
    const m = document.getElementById(modalId);
    if (m) m.style.display = show ? 'flex' : 'none';
  }
  function openEditRoomModal(btn) {
    const id = btn.getAttribute('data-id');
    const name = btn.getAttribute('data-name');
    const capacity = btn.getAttribute('data-capacity');
    const location = btn.getAttribute('data-location');
    const isActive = btn.getAttribute('data-active') === 'true';

    document.getElementById('editRoomForm').action = `/admin/classrooms/${id}/edit`;
    document.getElementById('room_e_name').value = name;
    document.getElementById('room_e_capacity').value = capacity;
    document.getElementById('room_e_location').value = location;
    document.getElementById('room_e_isActive').checked = isActive;
    toggleRoomModal('editRoomModal', true);
  }

  // ==================== VISUAL WEEKLY GRID CONTROLLER ====================
  
  function loadBatchTemplate(batchName) {
    activeBatch = batchName;
    if (!batchName) {
      document.getElementById('v_active_template_card').style.display = 'none';
      clearWeeklyGridBlocks();
      return;
    }

    const t = timetablesData.find(item => item.batch === batchName);
    const statusInfo = document.getElementById('v_status_info');
    
    if (t) {
      document.getElementById('v_startDate').value = t.startDate ? t.startDate.split('T')[0] : '';
      document.getElementById('v_endDate').value = t.endDate ? t.endDate.split('T')[0] : '';
      
      activeSlots = t.slots.map(s => ({
        id: s._id,
        dayOfWeek: s.dayOfWeek,
        subject: s.subject,
        teacher: s.teacher ? (s.teacher._id || s.teacher) : '',
        classroom: s.classroom ? (s.classroom._id || s.classroom) : '',
        startTime: s.startTime,
        endTime: s.endTime
      }));

      statusInfo.innerHTML = `
        <span>Status: <strong class="text-green">Template Active</strong></span>
        <span>Start Date: <strong>${new Date(t.startDate).toLocaleDateString('en-IN')}</strong></span>
        <span>End Date: <strong>${new Date(t.endDate).toLocaleDateString('en-IN')}</strong></span>
        <span>Total Class Slots: <strong>${activeSlots.length}</strong></span>
      `;
    } else {
      // Setup defaults for a new template configuration
      document.getElementById('v_startDate').value = new Date().toISOString().split('T')[0];
      const nextMonth = new Date();
      nextMonth.setMonth(nextMonth.getMonth() + 2);
      document.getElementById('v_endDate').value = nextMonth.toISOString().split('T')[0];
      
      activeSlots = [];
      statusInfo.innerHTML = `<span>Status: <strong class="text-gold">New Configuration</strong></span>`;
    }

    document.getElementById('v_active_template_card').style.display = 'block';
    renderWeeklyGridSlots();
  }

  function clearWeeklyGridBlocks() {
    document.querySelectorAll('.weekly-grid-day-col').forEach(col => {
      col.innerHTML = '';
    });
  }

  function renderWeeklyGridSlots() {
    clearWeeklyGridBlocks();
    
    activeSlots.forEach((slot, index) => {
      const col = document.querySelector(`.weekly-grid-day-col[data-day="${slot.dayOfWeek}"]`);
      if (!col) return;

      const startMin = parseTimeToMinutes(slot.startTime);
      const endMin = parseTimeToMinutes(slot.endTime);
      
      // Calculate layout offsets: grid spans 8:00 AM (480 mins) to 8:00 PM (1200 mins)
      const gridStart = 8 * 60; 
      const gridHeightMins = 12 * 60; // 12 hours total
      
      const topOffset = ((startMin - gridStart) / gridHeightMins) * 100;
      const heightVal = ((endMin - startMin) / gridHeightMins) * 100;

      // Cross-reference details
      const teacher = teachersData.find(x => x._id === slot.teacher);
      const classroom = classroomsData.find(x => x._id === slot.classroom);

      // Check for clashes in other templates in real-time
      const clash = checkClientClash(slot, index);

      const block = document.createElement('div');
      block.className = `weekly-grid-block ${clash.clashed ? 'clashed' : ''}`;
      block.style.top = `${topOffset}%`;
      block.style.height = `${heightVal}%`;
      block.title = clash.clashed ? clash.reason : `${slot.subject} with ${teacher ? teacher.name : 'Faculty'}`;
      
      block.innerHTML = `
        ${clash.clashed ? '<span class="clash-badge" title="' + clash.reason + '">⚠️ Clash</span>' : ''}
        <div class="slot-subject">${slot.subject}</div>
        <div class="slot-teacher">👨‍🏫 ${teacher ? teacher.name.split(' ')[0] : 'Faculty'}</div>
        <div class="slot-classroom">🏫 ${classroom ? classroom.name : 'Room'}</div>
        <div class="slot-time">${slot.startTime} - ${slot.endTime}</div>
      `;

      block.addEventListener('click', (e) => {
        e.stopPropagation();
        openSlotPopover(block, slot, index);
      });

      col.appendChild(block);
    });
  }

  function checkClientClash(activeSlot, indexToExclude) {
    const newStart = parseTimeToMinutes(activeSlot.startTime);
    const newEnd = parseTimeToMinutes(activeSlot.endTime);
    
    // 1. Check inside active slots of this template first
    for (let i = 0; i < activeSlots.length; i++) {
      if (i === indexToExclude) continue;
      const slot = activeSlots[i];
      if (slot.dayOfWeek !== activeSlot.dayOfWeek) continue;

      const extStart = parseTimeToMinutes(slot.startTime);
      const extEnd = parseTimeToMinutes(slot.endTime);

      if (newStart < extEnd && extStart < newEnd) {
        if (slot.classroom === activeSlot.classroom) {
          const room = classroomsData.find(r => r._id === slot.classroom);
          return { clashed: true, reason: `Local Room Clash: "${room ? room.name : 'Classroom'}" is double-booked with another slot in this batch.` };
        }
        if (slot.teacher === activeSlot.teacher) {
          const t = teachersData.find(x => x._id === slot.teacher);
          return { clashed: true, reason: `Local Teacher Clash: Instructor "${t ? t.name : 'Teacher'}" is scheduled at two slots simultaneously.` };
        }
      }
    }

    // 2. Check across other saved timetables database
    for (const t of timetablesData) {
      if (t.batch === activeBatch) continue; // ignore self
      
      for (const slot of t.slots) {
        if (slot.dayOfWeek !== activeSlot.dayOfWeek) continue;

        const extStart = parseTimeToMinutes(slot.startTime);
        const extEnd = parseTimeToMinutes(slot.endTime);

        if (newStart < extEnd && extStart < newEnd) {
          const targetRoomId = slot.classroom ? (slot.classroom._id || slot.classroom) : '';
          const targetTeacherId = slot.teacher ? (slot.teacher._id || slot.teacher) : '';

          if (targetRoomId === activeSlot.classroom) {
            const room = classroomsData.find(r => r._id === activeSlot.classroom);
            return { clashed: true, reason: `System Room Clash: Classroom "${room ? room.name : 'Room'}" is already allocated to Batch "${t.batch}" (${slot.subject}) from ${slot.startTime} to ${slot.endTime}.` };
          }
          if (targetTeacherId === activeSlot.teacher) {
            const teacher = teachersData.find(x => x._id === activeSlot.teacher);
            return { clashed: true, reason: `System Teacher Clash: Instructor "${teacher ? teacher.name : 'Teacher'}" is scheduled to teach Batch "${t.batch}" (${slot.subject}) from ${slot.startTime} to ${slot.endTime}.` };
          }
        }
      }
    }

    return { clashed: false };
  }

  function onGridColumnClick(event, day) {
    if (!activeBatch) {
      alert("Please select a batch from the dropdown first!");
      return;
    }
    
    // Prevent trigger when clicking on slot cards
    if (event.target.closest('.weekly-grid-block')) return;

    const colRect = event.currentTarget.getBoundingClientRect();
    const clickY = event.clientY - colRect.top;
    const clickPercent = clickY / colRect.height;
    
    // Grid spans 8:00 AM (480 min) to 8:00 PM (1200 min = 720 min total span)
    const totalMinutes = 12 * 60;
    const clickedMinute = (clickPercent * totalMinutes) + (8 * 60);
    
    // Round to nearest 30 mins
    const roundedMin = Math.round(clickedMinute / 30) * 30;
    const startHour = Math.floor(roundedMin / 60);
    const startMin = roundedMin % 60;
    
    const endHour = Math.floor((roundedMin + 90) / 60);
    const endMin = (roundedMin + 90) % 60;

    const startTimeStr = `${String(startHour).padStart(2,'0')}:${String(startMin).padStart(2,'0')}`;
    const endTimeStr = `${String(endHour).padStart(2,'0')}:${String(endMin).padStart(2,'0')}`;

    openSlotPopover(event.currentTarget, {
      dayOfWeek: day,
      subject: '',
      teacher: teachersData[0] ? teachersData[0]._id : '',
      classroom: classroomsData[0] ? classroomsData[0]._id : '',
      startTime: format24hToAMPM(startTimeStr),
      endTime: format24hToAMPM(endTimeStr)
    }, -1);
  }

  function openSlotPopover(anchorElement, slot, index) {
    const popover = document.getElementById('slotPopover');
    
    document.getElementById('pop_slot_id').value = index;
    document.getElementById('pop_day').value = slot.dayOfWeek;
    document.getElementById('pop_subject').value = slot.subject || '';
    document.getElementById('pop_teacher').value = slot.teacher || '';
    document.getElementById('pop_classroom').value = slot.classroom || '';
    document.getElementById('pop_start').value = formatTimeTo24h(slot.startTime);
    document.getElementById('pop_end').value = formatTimeTo24h(slot.endTime);

    // Hide or show delete button
    document.getElementById('pop_delete_btn').style.display = index === -1 ? 'none' : 'block';
    document.getElementById('popoverTitle').innerText = index === -1 ? 'Add Class Slot' : 'Configure Slot';

    // Position popover relative to column element
    popover.style.display = 'flex';
    
    const anchorRect = anchorElement.getBoundingClientRect();
    const gridRect = document.getElementById('weeklyPlannerGrid').getBoundingClientRect();
    
    // Compute positions
    let left = anchorRect.left - gridRect.left + 10;
    if (left + 300 > gridRect.width) {
      left = anchorRect.left - gridRect.left - 290;
    }
    
    let top = anchorRect.top - gridRect.top;
    if (index === -1) {
      // Spawned from click coordinates
      const e = window.event;
      if (e) {
        top = e.clientY - gridRect.top - 100;
      }
    }
    
    popover.style.left = `${left}px`;
    popover.style.top = `${Math.max(10, top)}px`;
  }

  function closePopover() {
    document.getElementById('slotPopover').style.display = 'none';
  }

  function savePopoverSlot() {
    const index = parseInt(document.getElementById('pop_slot_id').value, 10);
    const day = document.getElementById('pop_day').value;
    const subject = document.getElementById('pop_subject').value;
    const teacher = document.getElementById('pop_teacher').value;
    const classroom = document.getElementById('pop_classroom').value;
    const start = document.getElementById('pop_start').value;
    const end = document.getElementById('pop_end').value;

    if (!subject || !teacher || !classroom || !start || !end) {
      alert("All fields are required!");
      return;
    }

    const startMin = parseTimeToMinutes(start);
    const endMin = parseTimeToMinutes(end);
    if (startMin >= endMin) {
      alert("Error: Start time must be scheduled before end time.");
      return;
    }

    const slotData = {
      dayOfWeek: day,
      subject: subject,
      teacher: teacher,
      classroom: classroom,
      startTime: format24hToAMPM(start),
      endTime: format24hToAMPM(end)
    };

    if (index === -1) {
      activeSlots.push(slotData);
    } else {
      activeSlots[index] = slotData;
    }

    closePopover();
    renderWeeklyGridSlots();
  }

  function deleteActiveSlot() {
    const index = parseInt(document.getElementById('pop_slot_id').value, 10);
    if (index !== -1) {
      activeSlots.splice(index, 1);
    }
    closePopover();
    renderWeeklyGridSlots();
  }

  // Submit and Save visual timetable to DB
  function saveActiveTemplate() {
    if (!activeBatch) {
      alert("Please select a batch first!");
      return;
    }
    
    const startDate = document.getElementById('v_startDate').value;
    const endDate = document.getElementById('v_endDate').value;
    
    if (!startDate || !endDate) {
      alert("Please set both Batch Start and End dates.");
      return;
    }

    // Build POST form dynamically
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/admin/timetables';

    // Append standard parameters
    appendHiddenField(form, 'batch', activeBatch);
    appendHiddenField(form, 'startDate', startDate);
    appendHiddenField(form, 'endDate', endDate);

    // Append slot vectors
    activeSlots.forEach(slot => {
      appendHiddenField(form, 'dayOfWeek', slot.dayOfWeek);
      appendHiddenField(form, 'subject', slot.subject);
      appendHiddenField(form, 'teacher', slot.teacher);
      appendHiddenField(form, 'classroom', slot.classroom);
      appendHiddenField(form, 'startTime', slot.startTime);
      appendHiddenField(form, 'endTime', slot.endTime);
    });

    document.body.appendChild(form);
    form.submit();
  }

  function appendHiddenField(form, name, value) {
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = name;
    input.value = value;
    form.appendChild(input);
  }

  // Load state on start
  document.addEventListener('DOMContentLoaded', () => {
    // Restore tab
    const urlParams = new URLSearchParams(window.location.search);
    const queryTab = urlParams.get('tab');
    const queryView = urlParams.get('view');
    let cachedTab = null;
    try {
      cachedTab = sessionStorage.getItem('adminSchedulesActiveTab');
    } catch (e) {
      // Ignored: fails safely in strict privacy/incognito mode
    }
    let activeTab = queryTab || cachedTab || 'monthCalendar';
    if (queryView === 'classroom') {
      activeTab = 'classroomView';
    }
    switchTab(activeTab);

    // Check for alerts/messages
    const err = urlParams.get('error');
    if (err) {
      if (typeof showToast !== 'undefined') {
        showToast(decodeURIComponent(err), 'error');
      } else {
        alert(decodeURIComponent(err));
      }
    }

    const openCreate = urlParams.get('openCreate');
    const openEdit = urlParams.get('openEdit');
    if (openCreate) {
      openCreateDrawer(urlParams.get('date'));
      document.getElementById('c_subject').value = urlParams.get('subject') || '';
      document.getElementById('c_batch').value = urlParams.get('batch') || '';
      document.getElementById('c_teacher').value = urlParams.get('teacher') || '';
      document.getElementById('c_classroom').value = urlParams.get('classroom') || '';
      document.getElementById('c_startTime').value = urlParams.get('startTime') || '';
      document.getElementById('c_endTime').value = urlParams.get('endTime') || '';
      document.getElementById('c_status').value = urlParams.get('status') || 'scheduled';
    } else if (openEdit) {
      const matchCard = document.querySelector(`.calendar-event-card[data-id="${openEdit}"]`);
      if (matchCard) openEditDrawer(matchCard);
    }
  });
</script>
