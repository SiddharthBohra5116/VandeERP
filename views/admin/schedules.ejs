<!-- ==================== TAB 6: CLASSROOM GRID VIEW ==================== -->
<div id="tab-classroomView" class="tab-pane tab-hidden">
  <div class="card" style="padding: 1.25rem; margin-bottom: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 10px;">
      <div style="display: flex; align-items: center; gap: 0.75rem;">
        <span style="font-size: 0.85rem; font-weight: 700; color: var(--text-sub);">Select Day:</span>
        <input type="date" id="classroomGridDatePicker" class="form-control" style="width: auto; padding: 0.35rem 0.75rem; font-size: 0.8rem; background: var(--bg-hover);" value="<%= dayParam %>" onchange="changeClassroomGridDate(this.value)">
      </div>
      <div style="font-size: 0.8rem; color: var(--text-muted);">Classroom-wise allocation grid for the day</div>
    </div>

    <%
      const defaultTimeSlots = [
        "09:00 AM - 11:00 AM",
        "11:00 AM - 01:00 PM",
        "01:00 PM - 03:00 PM",
        "03:00 PM - 05:00 PM",
        "05:00 PM - 07:00 PM"
      ];
      
      const dynamicSlots = [];
      schedules.forEach(s => {
        if (s.date === dayParam && s.status !== 'cancelled') {
          const slotStr = `${s.startTime} - ${s.endTime}`;
          if (!defaultTimeSlots.includes(slotStr) && !dynamicSlots.includes(slotStr)) {
            dynamicSlots.push(slotStr);
          }
        }
      });
      
      const timeStringToMinutes = (timeStr) => {
        const parts = timeStr.split(' ');
        if (parts.length < 2) return 0;
        const [time, modifier] = parts;
        let [hours, minutes] = time.split(':').map(Number);
        if (hours === 12) {
          hours = 0;
        }
        if (modifier === 'PM') {
          hours += 12;
        }
        return hours * 60 + minutes;
      };

      const sortedTimeSlots = [...defaultTimeSlots, ...dynamicSlots].sort((a, b) => {
        const startA = a.split(' - ')[0];
        const startB = b.split(' - ')[0];
        return timeStringToMinutes(startA) - timeStringToMinutes(startB);
      });
    %>

    <div class="table-wrap" style="overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; min-width: 800px; text-align: center;">
        <thead>
          <tr style="background: rgba(0,0,0,0.25);">
            <th style="padding: 10px; border: 1px solid var(--border); text-align: left; font-weight: 700; color: var(--text-muted); font-size: 0.8rem;">Time Slot</th>
            <% classrooms.forEach(room => { %>
              <th style="padding: 10px; border: 1px solid var(--border); font-weight: 700; color: var(--gold); font-size: 0.8rem;"><%= room.name %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% sortedTimeSlots.forEach(slot => { %>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; border: 1px solid var(--border); text-align: left; font-weight: 600; font-size: 0.75rem; color: var(--text-sub);"><%= slot %></td>
              <% classrooms.forEach(room => { 
                  const slotStart = slot.split(' - ')[0];
                  const slotEnd = slot.split(' - ')[1];
                  const matchedClasses = schedules.filter(s => 
                     s.date === dayParam &&
                     s.status !== 'cancelled' &&
                     s.classroom && 
                     s.classroom._id.toString() === room._id.toString() &&
                     s.startTime === slotStart && 
                     s.endTime === slotEnd
                  );
              %>
                <td style="padding: 10px; border: 1px solid var(--border); vertical-align: middle; min-width: 150px; font-size: 0.72rem; position: relative;">
                  <% if (matchedClasses.length > 0) { %>
                    <% if (matchedClasses.length > 1) { %>
                      <div class="clash-badge" style="position: static; display: inline-block; margin-bottom: 4px; background: var(--red);">Double Booked</div>
                    <% } %>
                    <% matchedClasses.forEach(sched => { %>
                      <div class="calendar-event-card"
                           data-id="<%= sched._id %>"
                           data-subject="<%= sched.note || '—' %>"
                           data-batch="<%= sched.batch %>"
                           data-teacher="<%= sched.teacher ? sched.teacher._id : '' %>"
                           data-classroom="<%= sched.classroom ? sched.classroom._id : '' %>"
                           data-date="<%= sched.date %>"
                           data-starttime="<%= sched.startTime %>"
                           data-endtime="<%= sched.endTime %>"
                           data-status="<%= sched.status %>"
                           onclick="openEditDrawer(this)"
                           <%= `style="background: var(--bg-hover); border-left: 3px solid ${matchedClasses.length > 1 ? 'var(--red)' : 'var(--gold)'}; border-radius: 4px; padding: 0.4rem; text-align: left; cursor: pointer; transition: transform 0.1s; margin-bottom: 4px;"` %>
                           onmouseover="this.style.transform='translateY(-1px)';" onmouseout="this.style.transform='none';">
                        <div style="font-weight: 700; color: var(--text);"><%= sched.note || '—' %></div>
                        <div style="color: var(--text-muted); font-size: 0.65rem; margin-top: 2px;">
                          👥 <%= sched.batch %><br>
                          👨‍🏫 <%= sched.teacher ? sched.teacher.name : 'No Teacher' %>
                        </div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <span style="color: var(--text-muted); opacity: 0.4; font-style: italic;">Free</span>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
