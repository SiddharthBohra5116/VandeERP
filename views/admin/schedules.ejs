          <div style="display: flex; gap: 0.4rem; justify-content: flex-end;">
            <button type="button" class="btn btn-danger btn-xs" id="pop_delete_btn" onclick="deleteActiveSlot()" style="margin-right: auto; padding: 0.2rem 0.4rem;">Delete</button>
            <button type="button" class="btn btn-ghost btn-xs" onclick="closePopover()">Cancel</button>
            <button type="button" class="btn btn-primary btn-xs" onclick="savePopoverSlot()">Apply</button>
