<% 
  layout = 'main'; 
  title = 'Attendance Overview'; 
  page = 'attendance'; 

  const activeBatchDoc = typeof batches !== 'undefined' ? batches.find(b => String(b._id) === String(batch)) : null;
  const batchNameStr = activeBatchDoc ? activeBatchDoc.name : '';
%>

<style>
.calendar-container {
  margin-top: 1.5rem;
  margin-bottom: 2rem;
}
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 0.5rem;
  margin-top: 0.5rem;
}
.calendar-header-day {
  text-align: center;
  font-weight: 600;
  font-size: 0.85rem;
  color: var(--gold);
  padding: 0.5rem 0;
  text-transform: uppercase;
  background: rgba(212, 175, 55, 0.05);
  border-radius: 4px;
  border: 1px solid rgba(212, 175, 55, 0.15);
}
.calendar-day-card {
  min-height: 95px;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 0.5rem;
  background: rgba(255, 255, 255, 0.01);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  cursor: pointer;
  transition: all 0.2s ease;
  position: relative;
}
.calendar-day-card:hover {
  border-color: var(--gold-border);
  background: rgba(212, 175, 55, 0.05);
  transform: translateY(-2px);
}
.calendar-day-card.active {
  border-color: var(--gold);
  box-shadow: 0 0 12px rgba(212, 175, 55, 0.3);
  background: rgba(212, 175, 55, 0.08);
}
.calendar-day-card.holiday {
  background: rgba(239, 68, 68, 0.06);
  border-color: rgba(239, 68, 68, 0.2);
}
.calendar-day-card.empty {
  visibility: hidden;
  pointer-events: none;
}
.day-num-lbl {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
}
.day-pct-badge {
  font-size: 0.75rem;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 4px;
  align-self: flex-end;
}
.pct-high {
  background: rgba(16, 185, 129, 0.15);
  color: var(--green);
  border: 1px solid rgba(16, 185, 129, 0.3);
}
.pct-low {
  background: rgba(239, 68, 68, 0.15);
  color: var(--red);
  border: 1px solid rgba(239, 68, 68, 0.3);
}
.pct-none {
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-muted);
  border: 1px solid var(--border);
}
.holiday-tag {
  font-size: 0.65rem;
  font-weight: 600;
  color: var(--red);
  background: rgba(239, 68, 68, 0.1);
  padding: 2px 4px;
  border-radius: 3px;
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
  max-width: 100%;
  margin-top: 0.25rem;
}
.student-matrix-table th {
  font-size: 0.75rem;
  padding: 0.5rem 0.25rem;
  text-align: center;
  min-width: 30px;
}
.student-matrix-table td {
  padding: 0.5rem 0.25rem;
  text-align: center;
  font-weight: 700;
  font-size: 0.8rem;
}
.cell-status-p {
  color: var(--green);
  background: rgba(16, 185, 129, 0.15);
  border-radius: 3px;
  padding: 2px;
  display: block;
}
.cell-status-a {
  color: var(--red);
  background: rgba(239, 68, 68, 0.15);
  border-radius: 3px;
  padding: 2px;
  display: block;
}
.cell-status-none {
  color: var(--text-muted);
  font-weight: 400;
}
</style>

<!-- Filter Bar -->
<div class="card" style="padding: 1rem 1.25rem; margin-bottom: 1.5rem;">
  <form method="GET" action="/admin/attendance" class="filter-bar" style="margin:0; display: flex; gap: 1rem; flex-wrap: wrap; align-items: flex-end;">
    
    <div class="form-group" style="margin: 0; min-width: 200px; flex: 1;">
      <label class="form-label" style="margin-bottom: 0.25rem;">Select Batch</label>
      <select name="batch" class="form-control" style="padding: 0.45rem 0.75rem;">
        <option value="">Choose Batch (Show Academy Overall)...</option>
        <% batches.forEach(b => { %>
          <option value="<%= b._id %>" <%= String(batch) === String(b._id) ? 'selected' : '' %>><%= b.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-group" style="margin: 0; min-width: 180px;">
      <label class="form-label" style="margin-bottom: 0.25rem;">Select Month</label>
      <select name="month" class="form-control" style="padding: 0.45rem 0.75rem;" required>
        <% monthsList.forEach(m => { %>
          <option value="<%= m.value %>" <%= selectedMonth === m.value ? 'selected' : '' %>><%= m.label %></option>
        <% }) %>
      </select>
    </div>

    <button type="submit" class="btn btn-primary" style="padding: 0.55rem 1.5rem;">Apply Filters</button>
  </form>
</div>

<!-- Calendar Card -->
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
    <div>
      <h3 style="margin: 0;">Attendance Calendar: <%= batchNameStr ? batchNameStr : 'Academy Overall' %></h3>
      <p class="td-muted text-sm" style="margin: 0.25rem 0 0 0;">Interactive monthly log. Percentage displays average student attendance rates per class session. Click any day block to view details.</p>
    </div>
    <div class="mono fw-600 text-gold" style="font-size: 1.1rem; text-transform: uppercase;">
      <%= new Date(selectedMonth + '-02').toLocaleDateString('en-IN', {month: 'long', year: 'numeric'}) %>
    </div>
  </div>
  <div style="padding: 1.25rem;">
    <div class="calendar-grid">
      <div class="calendar-header-day">Sun</div>
      <div class="calendar-header-day">Mon</div>
      <div class="calendar-header-day">Tue</div>
      <div class="calendar-header-day">Wed</div>
      <div class="calendar-header-day">Thu</div>
      <div class="calendar-header-day">Fri</div>
      <div class="calendar-header-day">Sat</div>

      <!-- Preceding Blank Days -->
      <% const firstDayOfWeek = calendarDays[0].dayOfWeek; %>
      <% for(let i = 0; i < firstDayOfWeek; i++) { %>
        <div class="calendar-day-card empty"></div>
      <% } %>

      <!-- Calendar Day Blocks -->
      <% calendarDays.forEach(day => { %>
        <div class="calendar-day-card <%= day.isHoliday ? 'holiday' : '' %>" 
             data-date="<%= day.dateStr %>"
             data-holiday="<%= day.isHoliday %>"
             data-holiday-name="<%= day.holidayName %>">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
            <span class="day-num-lbl"><%= day.dayNum %></span>
            <% if (day.attendancePct !== null) { %>
              <span class="day-pct-badge <%= day.attendancePct >= 75 ? 'pct-high' : 'pct-low' %>">
                <%= day.attendancePct %>%
              </span>
            <% } else { %>
              <span class="day-pct-badge pct-none">—</span>
            <% } %>
          </div>
          <% if (day.isHoliday) { %>
            <div class="holiday-tag" title="Holiday: <%= day.holidayName %>">🎉 <%= day.holidayName %></div>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- Row of Grid Matrix + Click Details -->
<!-- Student Grid matrix -->
<% if (batch) { %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h3 style="margin: 0;">Cohort Student Attendance Matrix: <%= batchNameStr %></h3>
      <p class="td-muted text-sm" style="margin: 0.25rem 0 0 0;">Monthly grid (skipping holidays). Showing Present/Late (<span class="text-green fw-700">P</span>), Absent (<span class="text-red fw-700">A</span>), or Not Marked (<span class="text-muted">—</span>).</p>
    </div>
    <% if (studentGrid.length === 0) { %>
      <div class="empty-state" style="padding: 3rem 1rem;">
        No student enrollments found in batch <%= batchNameStr %>.
      </div>
    <% } else { %>
      <div class="table-wrap" style="max-height: 450px; overflow: auto;">
        <table class="student-matrix-table">
          <thead>
            <tr>
              <th style="text-align: left; position: sticky; left: 0; background: var(--card-bg); z-index: 2; min-width: 120px;">Student</th>
              <% gridDates.forEach(dateStr => { %>
                <th><%= Number(dateStr.slice(8)) %></th>
              <% }) %>
            </tr>
          </thead>
          <tbody>
            <% studentGrid.forEach(row => { %>
              <tr>
                <td style="text-align: left; position: sticky; left: 0; background: var(--card-bg); z-index: 2; font-weight: 600;" class="td-name">
                  <%= row.name %>
                </td>
                <% gridDates.forEach(dateStr => { %>
                  <% 
                    const status = row.attendanceByDate[dateStr];
                  %>
                  <td>
                    <% if (status === 'present' || status === 'late') { %>
                      <span class="cell-status-p" title="<%= dateStr %>: <%= status.toUpperCase() %>">P</span>
                    <% } else if (status === 'absent') { %>
                      <span class="cell-status-a" title="<%= dateStr %>: ABSENT">A</span>
                    <% } else { %>
                      <span class="cell-status-none">—</span>
                    <% } %>
                  </td>
                <% }) %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
<% } else { %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h3 style="margin: 0;">Cohort Attendance Summaries</h3>
      <p class="td-muted text-sm" style="margin: 0.25rem 0 0 0;">Active cohorts overall attendance rate for the selected month. Click a cohort card to drill down into detailed attendance grid logs.</p>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
        <% batchSummaries.forEach(b => { %>
          <% 
            const isLow = b.attendancePct !== null && b.attendancePct < 75;
            const borderStyle = isLow ? '3px solid var(--red)' : '3px solid var(--gold)';
          %>
          <a href="/admin/attendance?batch=<%= encodeURIComponent(b._id) %>&month=<%= selectedMonth %>" 
             class="card" 
             <%= `style="text-decoration: none; padding: 1.25rem; border-left: ${borderStyle}; transition: all 0.2s ease; cursor: pointer; display: flex; flex-direction: column; justify-content: space-between; gap: 0.75rem; background: rgba(255, 255, 255, 0.02); height: 100%;"` %>>
            <div>
              <div style="font-weight: 700; font-size: 1.1rem; color: var(--gold);"><%= b.name %></div>
              <div class="td-muted text-xs" style="margin-top: 0.25rem;"><%= b.studentCount %> Active Students</div>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: flex-end;">
              <span class="text-xs td-muted">Monthly Rate</span>
              <span class="mono fw-700" <%= `style="font-size: 1.8rem; line-height: 1; color: ${b.attendancePct === null ? 'var(--text-muted)' : (isLow ? 'var(--red)' : 'var(--green)')};"` %>>
                <%= b.attendancePct !== null ? b.attendancePct + '%' : '—' %>
              </span>
            </div>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
<% } %>

<!-- Click Details Panel -->
<div class="card" id="daily-attendance-detail" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h3 style="margin: 0;" id="detail-date-header">Daily Attendance Log</h3>
    <p class="td-muted text-sm" style="margin: 0.25rem 0 0 0;">Roster audit detail for the selected calendar date.</p>
  </div>
  <div style="padding: 1rem;">
    <div id="detail-no-records" class="empty-state" style="padding: 3rem 1rem;">
      Select a marked date block on the calendar above to view student roster details.
    </div>
    <div class="table-wrap" id="detail-table-wrap" style="display: none;">
      <table>
        <thead>
          <tr>
            <th>Student</th>
            <th>Status</th>
            <th>Note</th>
          </tr>
        </thead>
        <tbody id="detail-table-body">
          <!-- Dynamically populated via JS -->
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- JSON Data Store for client-side calendar interactions -->
<textarea id="monthly-attendance-data" style="display: none;"><%- JSON.stringify(monthlyAttendanceRecords || []) %></textarea>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const dayCards = document.querySelectorAll('.calendar-day-card:not(.empty)');
  const detailSection = document.getElementById('daily-attendance-detail');
  const detailDateHeader = document.getElementById('detail-date-header');
  const detailTableBody = document.getElementById('detail-table-body');
  const noRecordsMsg = document.getElementById('detail-no-records');
  const tableWrap = document.getElementById('detail-table-wrap');

  let attendanceRecords = [];
  try {
    const rawData = document.getElementById('monthly-attendance-data').value;
    attendanceRecords = JSON.parse(rawData);
  } catch(e) {
    console.error("Failed to parse attendance records:", e);
  }

  dayCards.forEach(card => {
    card.addEventListener('click', () => {
      dayCards.forEach(c => c.classList.remove('active'));
      card.classList.add('active');

      const dateStr = card.getAttribute('data-date');
      const isHoliday = card.getAttribute('data-holiday') === 'true';
      const holidayName = card.getAttribute('data-holiday-name');

      const dateObj = new Date(dateStr);
      const formattedDate = dateObj.toLocaleDateString('en-IN', {
        weekday: 'short',
        day: 'numeric',
        month: 'short',
        year: 'numeric'
      });
      detailDateHeader.textContent = `Daily Log: ${formattedDate}` + (isHoliday ? ` (Holiday: ${holidayName})` : '');

      const filtered = attendanceRecords.filter(r => r.date === dateStr);

      if (filtered.length === 0) {
        detailSection.style.display = 'none';
      } else {
        detailSection.style.display = 'block';
        tableWrap.style.display = 'block';
        detailTableBody.innerHTML = '';

        filtered.forEach(rec => {
         const studentName = rec.student?.user?.name || rec.student?.name || 'Unknown Student';
          const status = rec.status.toUpperCase();
          const badgeClass = status === 'PRESENT' || status === 'LATE' ? 'badge-green' : 'badge-red';
          const note = rec.note || '—';

          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td class="td-name">${studentName}</td>
            <td><span class="badge ${badgeClass}">${status}</span></td>
            <td>${note}</td>
          `;
          detailTableBody.appendChild(tr);
        });
      }
    });
  });

  // Auto-select latest day card with marked attendance or first day card
  if (dayCards.length > 0) {
    let initialCard = null;
    const todayStr = new Date().toLocaleDateString('en-CA', {timeZone: 'Asia/Kolkata'});
    initialCard = Array.from(dayCards).find(c => c.getAttribute('data-date') === todayStr);

    if (!initialCard) {
      initialCard = Array.from(dayCards).reverse().find(c => c.querySelector('.day-pct-badge:not(.pct-none)'));
    }
    if (!initialCard) {
      initialCard = dayCards[0];
    }
    if (initialCard) {
      initialCard.click();
    }
  }
});
</script>