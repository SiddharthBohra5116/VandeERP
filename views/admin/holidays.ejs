<div class="container mt-4">
  <h2 class="mb-4">Manage Holidays</h2>

  <div class="card mb-4">
    <div class="card-body">
      <form action="/admin/holidays/create" method="POST" class="row g-3">
        <div class="col-md-5">
          <input type="text" name="name" class="form-control" placeholder="Holiday Name (e.g., Diwali)" required>
        </div>
        <div class="col-md-5">
          <input type="date" name="date" class="form-control" required>
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100">Add</button>
        </div>
      </form>
    </div>
  </div>

  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Date</th>
        <th>Name</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% holidays.forEach(holiday => { %>
        <tr>
          <td><%= holiday.date %></td>
          <td><%= holiday.name %></td>
          <td>
            <form action="/admin/holidays/<%= holiday._id %>/delete" method="POST">
              <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>