<%
  layout = 'main';
  title = lead.name;
  subtitle = `Lead File · ${lead.course}`;
  page = 'leads';
%>

<div style="display:flex; justify-content:flex-end; margin-bottom:1.25rem;">
  <a href="/admin/leads" class="btn btn-ghost btn-sm">&larr; Back to Pipeline</a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="card" style="border-color:var(--red); background:rgba(239,68,68,0.05); margin-bottom:20px; padding:12px 16px; color:var(--red); font-size:13px; font-weight:500; border-left:4px solid var(--red);">
    ❌ <%= error %>
  </div>
<% } %>

<%
  const statusBadge = {
    new: 'badge-orange',
    contacted: 'badge-blue',
     mentorship_scheduled: 'badge-blue',
    mentorship_attended: 'badge-yellow',
    follow_up: 'badge-yellow',
    joining_interested: 'badge-gold',
    admission_completed: 'badge-green',
    lost: 'badge-red'
  }[lead.status] || 'badge-grey';
%>

<div class="grid-2" style="align-items:start;">

  <!-- Left: Lead Info -->
  <div style="display:flex; flex-direction:column; gap:1.25rem;">
    <div class="card">
      <div style="display:flex; align-items:center; gap:14px; margin-bottom:20px;">
        <div style="width:48px; height:48px; border-radius:10px; background:var(--gold-dim); border:1px solid var(--gold-border); display:flex; align-items:center; justify-content:center; font-size:18px; font-weight:800; color:var(--gold);">
          <%= lead.name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2) %>
        </div>
        <div>
          <div style="font-size:18px; font-weight:700;"><%= lead.name %></div>
          <div style="display:flex; gap:8px; align-items:center; margin-top:4px;">
            <span class="badge <%= statusBadge %>"><%= lead.status %></span>
            <span class="badge badge-orange"><%= lead.course %></span>
          </div>
          <%
            const calls = lead.followUpHistory.filter(h => h.channel === 'Call');
          %>
          <div style="display:flex; align-items:center; gap:6px; margin-top:8px;">
            <span style="font-size:10px; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.05em;">Calls:</span>
            <div style="display:flex; gap:4px;">
              <% for (let i = 0; i < Math.max(3, calls.length); i++) { %>
                <%
                  const call = calls[i];
                  let dotColor = '#242424';
                  let dotBorder = '1px solid var(--border)';
                  let titleText = `Call ${i + 1}: No Attempt`;
                  if (call) {
                    titleText = `Call ${i + 1}: ${call.callOutcome.toUpperCase()} (${call.callDuration || 'no duration'}) - ${call.note}`;
                    if (call.callOutcome === 'answered') {
                      dotColor = 'var(--green)';
                    } else if (call.callOutcome === 'busy' || call.callOutcome === 'no-answer') {
                      dotColor = 'var(--red)';
                    } else {
                      dotColor = 'var(--orange)';
                    }
                    dotBorder = 'none';
                  }
                %>
                <span class="call-dot" title="<%= titleText %>" <%= `style="width:10px; height:10px; border-radius:50%; background:${dotColor}; border:${dotBorder}; display:inline-block; cursor:help;"` %>></span>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <hr class="divider">

      <div style="display:flex; flex-direction:column; gap:12px;">
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Phone</span>
          <a href="tel:<%= lead.phone %>" style="font-family:var(--mono); font-size:13px; color:var(--gold); font-weight:600;">
            <%= lead.phone %>
          </a>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Email</span>
          <span class="mono text-sm"><%= lead.email || '—' %></span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Source</span>
          <span class="text-sm"><%= lead.source %></span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Course Interest</span>
          <span class="text-sm"><%= lead.course %></span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Follow-up Date</span>
         <% const isOverdue = lead.followUpDate && new Date(lead.followUpDate) < new Date() && lead.status !== 'admission_completed' && lead.status !== 'lost'; %>
          <span class="mono text-sm" <%= isOverdue ? 'style="color: var(--red);"' : 'style="color: var(--text);"' %>>
            <%= lead.followUpDate ? new Date(lead.followUpDate).toLocaleDateString('en-IN', {weekday:'short',day:'numeric',month:'short',year:'numeric'}) : '—' %>
            <% if (isOverdue) { %> ⚠️<% } %>
          </span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Counsellor Assigned</span>
          <span class="text-sm" style="font-weight:600;"><%= lead.assignedTo ? lead.assignedTo.name : 'Unassigned' %></span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Added On</span>
          <span class="mono text-sm"><%= new Date(lead.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></span>
        </div>
      </div>

      <% if (lead.notes) { %>
        <hr class="divider">
        <div>
          <div class="text-muted text-sm" style="margin-bottom:6px;">Original Inquiry Notes</div>
          <div style="font-size:13px; color:var(--text-sub); line-height:1.6; background:var(--bg-input); padding:10px 12px; border-radius:var(--radius); border: 1px solid var(--border);">
            <%= lead.notes %>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Reassign Counsellor -->
    <div class="card">
      <div class="card-title" style="margin-bottom:12px;">Counsellor Assignment</div>
      <form action="/admin/leads/<%= lead._id %>/assign" method="POST" style="display:flex; gap:0.5rem; align-items:center;">
        <select name="counsellorId" class="form-control" style="flex:1;">
          <option value="">Unassigned</option>
          <% counsellors.forEach(c => { %>
            <option value="<%= c._id %>" <%= (lead.assignedTo && lead.assignedTo._id.toString() === c._id.toString()) ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
        <button type="submit" class="btn btn-primary btn-sm">Assign</button>
      </form>
    </div>

    <% if (lead.status !== 'admission_completed') { %>
      <!-- Convert to Student -->
      <div class="card" style="border-color: rgba(34,197,94,0.25); background: linear-gradient(180deg, rgba(34,197,94,0.02) 0%, rgba(0,0,0,0) 100%);">
        <div class="card-title" style="color:var(--green); margin-bottom:4px; display:flex; align-items:center; gap:0.4rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Admit as Student
        </div>
        <div class="form-hint" style="margin-bottom:12px;">Mark this lead as admitted and generate their invoice & student portal account.</div>
        <a href="/admin/leads/<%= lead._id %>/convert" class="btn btn-success btn-sm btn-block" style="text-align: center;">
          Convert to Admitted Student
        </a>
      </div>
    <% } else { %>
      <div class="card" style="border-color:rgba(34,197,94,0.25); text-align:center; padding:20px;">
        <div style="font-size:24px; margin-bottom:6px;">✅</div>
        <div style="font-size:13px; color:var(--green); font-weight:600;">Converted to Student</div>
        <% if (lead.convertedStudent) { %>
          <a href="/admin/students/<%= lead.convertedStudent._id || lead.convertedStudent %>" class="btn btn-success btn-sm" style="margin-top:12px; display:inline-flex;">View Student Profile</a>
        <% } %>
      </div>
    <% } %>
  </div>

  <!-- Right: Follow-up Timeline & Commenting -->
  <div style="display:flex; flex-direction:column; gap:1.25rem;">
    
    <%
      const timelineEvents = [
        { title: 'Created', date: lead.createdAt, channel: lead.source || 'Walk-in', note: 'Lead registered' }
      ];
      lead.followUpHistory.forEach(fu => {
        timelineEvents.push({
          title: fu.status.toUpperCase(),
          date: fu.doneAt,
          channel: fu.channel || 'Call',
          note: fu.note,
          outcome: fu.callOutcome
        });
      });
      timelineEvents.sort((a, b) => new Date(a.date) - new Date(b.date));
    %>
    
    <div class="card" style="overflow-x: auto; padding: 20px;">
      <div class="card-title" style="margin-bottom: 16px;">Touchpoint Timeline</div>
      <div style="display: flex; align-items: center; min-width: max-content; padding: 10px 0;">
        <% for (let i = 0; i < timelineEvents.length; i++) { %>
          <% const event = timelineEvents[i]; %>
          <div style="display: flex; flex-direction: column; align-items: center; position: relative; z-index: 2; width: 90px; text-align: center;">
            <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--bg-input); border: 2px solid var(--gold-border); display: flex; align-items: center; justify-content: center; font-size: 16px; margin-bottom: 8px; box-shadow: 0 0 10px rgba(0,0,0,0.2);">
              <% if (event.channel === 'WhatsApp') { %>
                💬
              <% } else if (event.channel === 'In-person') { %>
                🚶
              <% } else if (event.channel === 'Call') { %>
                📞
              <% } else { %>
                🌐
              <% } %>
            </div>
            <div style="font-size: 10px; font-weight: 700; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 100%;" title="<%= event.title %>">
              <%= event.title %>
            </div>
            <div style="font-size: 9px; color: var(--text-muted); font-family: var(--mono); margin-top: 2px;">
              <%= new Date(event.date).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %>
            </div>
          </div>

          <% if (i < timelineEvents.length - 1) { %>
            <%
              const nextEvent = timelineEvents[i + 1];
              const diffMs = new Date(nextEvent.date) - new Date(event.date);
              const gapDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
              
              let lineColor = 'var(--border)';
              let textColor = 'var(--text-muted)';
              let gapLabel = '';
              
              if (gapDays >= 1) {
                gapLabel = `${gapDays}d`;
              } else {
                const gapHours = Math.floor(diffMs / (1000 * 60 * 60));
                gapLabel = `${gapHours}h`;
              }

              if (gapDays > 7) {
                lineColor = 'var(--red)';
                textColor = 'var(--red)';
              } else if (gapDays > 3) {
                lineColor = 'var(--orange)';
                textColor = 'var(--orange)';
              } else {
                lineColor = 'var(--green)';
                textColor = 'var(--green)';
              }
            %>
            <div <%= `style="flex-grow: 1; min-width: 50px; height: 2px; background: ${lineColor}; margin: -26px -10px 0 -10px; position: relative; display: flex; align-items: center; justify-content: center; z-index: 1;"` %>>
              <span <%= `style="background: var(--bg-card); padding: 1px 5px; border-radius: 8px; font-size: 8px; font-weight: 700; font-family: var(--mono); color: ${textColor}; border: 1px solid ${lineColor}; margin-top: -2px;"` %>>
                <%= gapLabel %> gap
              </span>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>

    <!-- Add Admin Comment / Instruction -->
    <div class="card" style="border-color: var(--gold-border); background: linear-gradient(180deg, rgba(255,204,0,0.02) 0%, rgba(0,0,0,0) 100%);">
      <div class="card-title" style="color:var(--gold); margin-bottom:12px; display:flex; align-items:center; gap:0.4rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Write Comment / Instruction for Counsellor
      </div>
      <form action="/admin/leads/<%= lead._id %>/comment" method="POST">
        <div class="form-group" style="margin-bottom:0.75rem;">
          <textarea name="note" class="form-control" placeholder="Type comments or instructions here... The counsellor will see this log on their lead dashboard." required style="min-height:90px;" maxlength="500"></textarea>
        </div>
        <div style="display:flex; justify-content:flex-end;">
          <button type="submit" class="btn btn-primary btn-sm">Save Log Note</button>
        </div>
      </form>
    </div>

    <!-- Follow-up Logs timeline -->
    <div class="card">
      <div class="card-title" style="margin-bottom:16px;">Activity Logs & Interaction History</div>
      
      <% if (lead.followUpHistory.length === 0) { %>
        <div class="empty-state" style="padding: 2rem 1rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <p>No activity logs recorded yet.</p>
        </div>
      <% } else { %>
        <div class="timeline" style="padding-left:0.5rem;">
          <% lead.followUpHistory.slice().reverse().forEach(fu => { %>
            <%
              const fuBadge = {
                new: 'badge-orange',
                contacted: 'badge-blue',
                mentorship_scheduled: 'badge-blue',
                mentorship_attended: 'badge-yellow',
                follow_up: 'badge-yellow',
                joining_interested: 'badge-gold',
                admission_completed: 'badge-green',
                lost: 'badge-red'
              }[fu.status] || 'badge-grey';
            %>
            <div class="timeline-item">
              <div class="timeline-dot <%= fu.doneBy && fu.doneBy.role === 'admin' ? 'active' : '' %>"></div>
              <div class="timeline-body" <%= fu.doneBy && fu.doneBy.role === 'admin' ? 'style="border-left: 2px solid var(--gold-border); padding-left: 10px;"' : '' %>>
                <div style="display:flex; align-items:center; gap:8px; margin-bottom:2px; flex-wrap: wrap;">
                  <% if (fu.doneBy && fu.doneBy.role === 'admin') { %>
                    <div style="font-size:12px; font-weight:700; color:var(--gold); display:flex; align-items:center; gap:0.25rem;">
                      👑 Admin Instruction
                    </div>
                  <% } else { %>
                    <div style="font-size:12px; font-weight:600; color:var(--text);">
                      Status change &rarr; <span class="badge <%= fuBadge %>" style="font-size:9px; padding:1px 4px;"><%= fu.status %></span>
                    </div>
                  <% } %>

                  <% if (fu.channel) { %>
                    <span class="badge badge-grey" style="font-size:9px; padding:1px 4px; display:inline-flex; align-items:center; gap:3px;">
                      <% if (fu.channel === 'Call') { %>
                        📞 Call <%= fu.callAttemptNumber ? `#${fu.callAttemptNumber}` : '' %>
                        <% if (fu.callOutcome) { %>
                          (<%= fu.callOutcome %> <%= fu.callDuration ? `· ${fu.callDuration}` : '' %>)
                        <% } %>
                      <% } else if (fu.channel === 'WhatsApp') { %>
                        💬 WhatsApp
                      <% } else if (fu.channel === 'In-person') { %>
                        🚶 In-person
                      <% } %>
                    </span>
                  <% } %>
                </div>
                <div class="timeline-meta">
                  <%= fu.doneBy ? fu.doneBy.name : 'System' %> (<%= fu.doneBy ? fu.doneBy.role : 'admin' %>) &nbsp;·&nbsp;
                  <%= new Date(fu.doneAt).toLocaleDateString('en-IN', {weekday:'short',day:'numeric',month:'short'}) %> &nbsp;·&nbsp;
                  <%= new Date(fu.doneAt).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %>
                </div>
                <div class="mt-1 text-sm" <%= fu.doneBy && fu.doneBy.role === 'admin' ? 'style="line-height:1.4; color:var(--text); font-style:italic;"' : 'style="line-height:1.4; color:var(--text-sub);"' %>>
                  <%= fu.note %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>

</div>

<!-- Convert Lead Modal -->
<div id="convertModal" class="modal-overlay">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Convert Lead to Student</div>
      <button class="modal-close" onclick="closeConvertModal()">&times;</button>
    </div>
    <form id="convertForm" method="POST">
      <p style="font-size:13px; color:var(--text-sub); margin-bottom:1.25rem;">
        Converting lead <strong id="convertLeadName">Prospect</strong>. This will create an active student account and initialize their fee structure.
      </p>
      
      <div class="form-group">
        <label class="form-label" for="student_email">Student Login Email</label>
        <input type="email" id="student_email" name="email" class="form-control" required>
      </div>

      <div class="form-group">
        <label class="form-label" for="student_password">Initial Login Password</label>
        <input type="text" id="student_password" name="password" class="form-control" required>
        <div class="form-hint">By default, the student's mobile number will be set. You can override it here.</div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="student_batch">Assign Batch</label>
          <input type="text" id="student_batch" name="batch" class="form-control" placeholder="e.g. Morning 10AM" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="student_fees">Total Invoice Fees (INR)</label>
          <input type="number" id="student_fees" name="fees_total" class="form-control" placeholder="e.g. 30000" required min="0" oninput="checkAdminDownpayment()">
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="student_paid">Fees Paid (INR)</label>
        <input type="number" id="student_paid" name="fees_paid" class="form-control" placeholder="e.g. 15000" value="0" min="0" oninput="checkAdminDownpayment()">
      </div>

      <div id="downpayment_warning" style="display:none; color:var(--orange); font-size:12px; font-weight:500; margin-bottom:12px; border-left:2px solid var(--orange); padding-left:8px;">
        ⚠️ Warning: Paid amount is less than the standard 50% down payment requirement. Admin authorization will bypass this check.
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-ghost btn-sm" onclick="closeConvertModal()">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm">Confirm Admission</button>
      </div>
    </form>
  </div>
</div>

<script>
  function triggerConvertLead(leadId, leadName, phone) {
    const form = document.getElementById('convertForm');
    form.action = '/admin/leads/' + leadId + '/convert';
    document.getElementById('convertLeadName').innerText = leadName;
    
    // Auto populate defaults (removed fake/insecure defaults)
    document.getElementById('convertModal').classList.add('open');
  }

  function closeConvertModal() {
    document.getElementById('convertModal').classList.remove('open');
    document.getElementById('student_email').value = '';
    document.getElementById('student_password').value = '';
    document.getElementById('student_batch').value = '';
    document.getElementById('student_fees').value = '';
    document.getElementById('student_paid').value = '0';
    document.getElementById('downpayment_warning').style.display = 'none';
  }

  function checkAdminDownpayment() {
    const total = Number(document.getElementById('student_fees').value) || 0;
    const paid = Number(document.getElementById('student_paid').value) || 0;
    const warning = document.getElementById('downpayment_warning');
    if (total > 0 && paid < total * 0.5) {
      warning.style.display = 'block';
    } else {
      warning.style.display = 'none';
    }
  }

  document.getElementById('convertModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeConvertModal();
    }
  });
</script>
