<%
  layout = 'main';
  title = lead.name;
  subtitle = `Lead file - ${lead.interestedCourse ? lead.interestedCourse.name : 'Undecided'}`;
  page = 'leads';

  const history = lead.followUpHistory || [];
  const activityRecords = typeof leadActivities !== 'undefined' && Array.isArray(leadActivities) ? leadActivities : [];
  const assignedName = lead.assignedTo
    ? (lead.assignedTo.user ? lead.assignedTo.user.name : lead.assignedTo.name)
    : 'Unassigned';
  const courseName = lead.interestedCourse ? lead.interestedCourse.name : 'Undecided';
  const isClosed = lead.status === 'admission_completed' || lead.status === 'lost';
  const isOverdue = lead.nextFollowUpAt && new Date(lead.nextFollowUpAt) < new Date() && !isClosed;
  const initials = String(lead.name || 'L').split(/\s+/).map(part => part[0]).join('').toUpperCase().slice(0, 2);
  const statusLabels = {
    new: 'New',
    contacted: 'Contacted',
    mentorship_scheduled: 'Mentorship scheduled',
    mentorship_attended: 'Mentorship attended',
    follow_up: 'Follow up',
    joining_interested: 'Joining interested',
    admission_completed: 'Admission completed',
    lost: 'Lost'
  };
  const statusBadge = {
    new: 'badge-orange',
    contacted: 'badge-blue',
    mentorship_scheduled: 'badge-blue',
    mentorship_attended: 'badge-yellow',
    follow_up: 'badge-yellow',
    joining_interested: 'badge-gold',
    admission_completed: 'badge-green',
    lost: 'badge-red'
  }[lead.status] || 'badge-grey';
  const progressStages = [
    ['new', 'New'],
    ['contacted', 'Contacted'],
    ['mentorship_scheduled', 'Mentorship scheduled'],
    ['mentorship_attended', 'Mentorship attended'],
    ['follow_up', 'Follow up'],
    ['joining_interested', 'Ready for admission'],
    ['admission_completed', 'Admitted']
  ];
  const currentStageIndex = progressStages.findIndex(stage => stage[0] === lead.status);
  const activityFeed = [];
  activityFeed.push({
    key: `created-${lead._id}`,
    source: 'system',
    title: 'Lead created',
    type: 'lead_created',
    status: 'new',
    note: lead.notes || `Lead came from ${lead.source || 'manual entry'}.`,
    actorName: lead.createdBy && lead.createdBy.name ? lead.createdBy.name : 'System',
    actorRole: lead.createdBy && lead.createdBy.role ? lead.createdBy.role : '',
    channel: lead.source || '',
    date: lead.createdAt
  });
  (lead.ownershipHistory || []).forEach((item, index) => {
    const counsellorName = item.counsellor && item.counsellor.user && item.counsellor.user.name
      ? item.counsellor.user.name
      : item.counsellor && item.counsellor.name
        ? item.counsellor.name
        : 'Counsellor';
    activityFeed.push({
      key: `ownership-${index}-${item.assignedAt}`,
      source: 'assignment',
      title: index === 0 ? 'Lead assigned' : 'Lead reassigned',
      type: index === 0 ? 'assigned' : 'reassigned',
      note: item.note || `Assigned to ${counsellorName}.`,
      actorName: item.assignedBy ? item.assignedBy.name : 'Admin',
      actorRole: item.assignedBy ? item.assignedBy.role : 'admin',
      channel: 'Assignment',
      date: item.assignedAt
    });
  });
  activityRecords.forEach(item => {
    activityFeed.push({
      key: `activity-${item._id}`,
      source: 'activity',
      title: item.title || 'Lead activity',
      type: item.type,
      status: item.newStatus || item.oldStatus || '',
      note: item.note || item.whatsapp?.message || '',
      actorName: item.doneBy ? item.doneBy.name : 'System',
      actorRole: item.doneBy ? item.doneBy.role : '',
      channel: item.type === 'call' ? 'Call' : item.type === 'whatsapp' ? 'WhatsApp' : item.type,
      callOutcome: item.call?.outcome && item.call.outcome !== 'not-applicable' ? item.call.outcome : '',
      callDuration: item.call?.duration || '',
      nextFollowUpDate: item.followUp?.scheduledFor || '',
      date: item.createdAt
    });
  });
  const activityMatchKeys = new Set(activityRecords.map(item => {
    const when = item.followUp?.completedAt || item.createdAt;
    const minuteBucket = when ? Math.floor(new Date(when).getTime() / 60000) : '';
    const actor = item.doneBy ? item.doneBy.name : 'System';
    const status = item.newStatus || item.oldStatus || '';
    const itemNote = String(item.note || item.whatsapp?.message || '').trim().toLowerCase();
    return `${minuteBucket}|${actor}|${status}|${itemNote}`;
  }));
  history.forEach((fu, index) => {
    const fuMinuteBucket = fu.doneAt ? Math.floor(new Date(fu.doneAt).getTime() / 60000) : '';
    const fuActor = fu.doneBy ? fu.doneBy.name : 'System';
    const fuNote = String(fu.note || '').trim().toLowerCase();
    const fuKey = `${fuMinuteBucket}|${fuActor}|${fu.status || ''}|${fuNote}`;
    if (activityMatchKeys.has(fuKey)) return;
    activityFeed.push({
      key: `followup-${index}-${fu.doneAt}`,
      source: 'followup',
      title: fu.channel ? `${fu.channel} logged` : (fu.doneBy && fu.doneBy.role === 'admin' ? 'Admin comment' : 'Counsellor follow-up'),
      type: fu.channel === 'Call' ? 'call' : fu.channel === 'WhatsApp' ? 'whatsapp' : 'follow_up_completed',
      status: fu.status || '',
      note: fu.note || '',
      actorName: fu.doneBy ? fu.doneBy.name : 'System',
      actorRole: fu.doneBy ? fu.doneBy.role : '',
      channel: fu.channel || '',
      callOutcome: fu.callOutcome || '',
      callDuration: fu.callDuration || '',
      nextFollowUpDate: fu.nextFollowUpAt || '',
      date: fu.doneAt
    });
  });
  const scheduledFollowUpDate = lead.nextFollowUpAt ? new Date(lead.nextFollowUpAt) : null;
  const hasCompletedScheduledFollowUp = scheduledFollowUpDate && activityRecords.some(item => {
    const completedAt = item.followUp?.completedAt ? new Date(item.followUp.completedAt) : null;
    return completedAt && completedAt >= scheduledFollowUpDate;
  });
  const todayStart = new Date();
  todayStart.setHours(0, 0, 0, 0);
  if (scheduledFollowUpDate && scheduledFollowUpDate < todayStart && !isClosed && !hasCompletedScheduledFollowUp) {
    activityFeed.push({
      key: `missed-${lead._id}-${scheduledFollowUpDate.getTime()}`,
      source: 'followup',
      title: 'Follow-up missed',
      type: 'follow_up_missed',
      status: 'follow_up',
      note: 'Scheduled follow-up date passed without a completed follow-up log.',
      actorName: assignedName,
      actorRole: 'counsellor',
      channel: 'scheduled',
      callOutcome: 'missed',
      callDuration: '',
      nextFollowUpDate: scheduledFollowUpDate,
      date: scheduledFollowUpDate
    });
  }
  const seenActivity = new Set();
  const completeActivityFeed = activityFeed
    .filter(item => item.date)
    .sort((a, b) => new Date(b.date) - new Date(a.date))
    .filter(item => {
      const compactNote = String(item.note || '').trim().slice(0, 90);
      const minuteBucket = Math.floor(new Date(item.date).getTime() / 60000);
      const identity = `${minuteBucket}|${item.actorName}|${item.status}|${item.channel}|${compactNote.toLowerCase()}`;
      if (seenActivity.has(identity)) return false;
      seenActivity.add(identity);
      return true;
    });
  const timelineFeed = completeActivityFeed.slice().sort((a, b) => new Date(b.date) - new Date(a.date));
  const lastActivity = completeActivityFeed.length ? completeActivityFeed[0] : null;
%>

<style>
  .lead-page-actions { display:flex; justify-content:space-between; align-items:center; gap:1rem; margin-bottom:1rem; flex-wrap:wrap; }
  .lead-detail-shell { display:grid; grid-template-columns:1fr; gap:1rem; align-items:start; }
  .lead-panel { padding:1rem; }
  .lead-panel-title { display:flex; align-items:center; gap:.45rem; margin-bottom:.8rem; font-size:.78rem; font-weight:850; text-transform:uppercase; letter-spacing:.04em; }
  .lead-panel-title::before { content:''; width:6px; height:20px; border-radius:999px; background:var(--gold); }
  .lead-hero { display:grid; grid-template-columns:auto minmax(0,1fr); gap:1rem; align-items:center; }
  .lead-avatar { width:58px; height:58px; border-radius:8px; display:flex; align-items:center; justify-content:center; background:var(--gold-dim); border:1px solid var(--gold-border); color:var(--gold); font-weight:900; font-size:1.15rem; }
  .lead-name { font-size:1.35rem; font-weight:900; line-height:1.2; }
  .lead-badges { display:flex; gap:.4rem; align-items:center; flex-wrap:wrap; margin-top:.45rem; }
  .lead-fact-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:.75rem; margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border); }
  .lead-fact { min-width:0; padding:.75rem; border:1px solid var(--border); border-radius:8px; background:var(--bg-input); }
  .lead-fact-label { display:block; color:var(--text-muted); font-size:.68rem; font-weight:850; text-transform:uppercase; letter-spacing:.04em; }
  .lead-fact-value { display:block; margin-top:.25rem; color:var(--text); font-size:.88rem; font-weight:750; overflow-wrap:anywhere; }
  .lead-fact-value.mono { font-family:var(--mono); }
  .lead-note-box { margin-top:1rem; padding:.8rem; border:1px solid var(--border); border-radius:8px; background:var(--bg-input); color:var(--text-sub); line-height:1.55; }
  .next-action { display:grid; gap:.75rem; }
  .next-action-main { padding:1rem; border-radius:8px; border:1px solid var(--gold-border); background:linear-gradient(180deg, rgba(212,175,55,.08), rgba(0,0,0,0)); }
  .next-action-label { color:var(--text-muted); font-size:.68rem; font-weight:850; text-transform:uppercase; letter-spacing:.04em; }
  .next-action-value { margin-top:.25rem; font-size:1rem; font-weight:900; }
  .lead-progress { display:grid; gap:.55rem; }
  .lead-stage { display:grid; grid-template-columns:auto minmax(0,1fr); gap:.65rem; align-items:center; color:var(--text-muted); }
  .lead-stage-dot { width:13px; height:13px; border-radius:50%; border:2px solid var(--border); background:var(--bg-card); }
  .lead-stage.is-done { color:var(--text); }
  .lead-stage.is-done .lead-stage-dot { border-color:var(--gold); background:var(--gold); }
  .lead-stage.is-current .lead-stage-dot { box-shadow:0 0 0 4px var(--gold-dim); }
  .lead-stage-label { font-size:.8rem; font-weight:800; }
  .lead-action-stack { display:grid; gap:.7rem; }
  .lead-detail-side { grid-template-columns:minmax(0,1fr) minmax(0,1fr); align-items:start; }
  .lead-inline-form { display:grid; grid-template-columns:minmax(0,1fr) auto; gap:.55rem; align-items:end; }
  .activity-list { display:grid; gap:.85rem; }
  .activity-item { display:grid; grid-template-columns:auto minmax(0,1fr); gap:.75rem; }
  .activity-dot { width:12px; height:12px; border-radius:50%; margin-top:.25rem; background:var(--gold); box-shadow:0 0 0 4px var(--gold-dim); }
  .activity-body { padding-bottom:.85rem; border-bottom:1px solid var(--border); }
  .activity-item:last-child .activity-body { border-bottom:0; padding-bottom:0; }
  .activity-head { display:flex; gap:.45rem; align-items:center; flex-wrap:wrap; margin-bottom:.25rem; }
  .activity-title { font-size:.82rem; font-weight:850; }
  .activity-meta { color:var(--text-muted); font-size:.72rem; }
  .activity-note { margin-top:.45rem; color:var(--text-sub); font-size:.88rem; line-height:1.5; overflow-wrap:anywhere; }
  .lead-timeline-toolbar { display:flex; justify-content:space-between; align-items:center; gap:.75rem; flex-wrap:wrap; margin-bottom:1rem; }
  .lead-timeline-tools { display:flex; gap:.55rem; align-items:center; flex-wrap:wrap; }
  .lead-timeline-tools select { min-height:36px; padding:.35rem .65rem; border-radius:6px; border:1px solid var(--border); background:var(--bg-input); color:var(--text); font-size:.75rem; font-weight:800; }
  .lead-timeline-tools .app-select { width:auto; min-width:150px; }
  .lead-timeline-tools .app-select-button { min-height:40px; padding:.52rem .7rem; border-radius:8px; font-size:.78rem; font-weight:850; }
  .lead-timeline-tools .app-select-menu { min-width:100%; }
  .lead-story { position:relative; display:grid; gap:1rem; padding-left:1.55rem; }
  .lead-story::before { content:''; position:absolute; left:.52rem; top:.35rem; bottom:.35rem; width:2px; background:var(--border); }
  .lead-story-item { position:relative; display:grid; grid-template-columns:minmax(110px,140px) minmax(0,1fr) auto; gap:.8rem; align-items:start; padding:.85rem; border:1px solid var(--border); border-radius:10px; background:var(--bg-input); transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
  .lead-story-item:hover { background:var(--bg-hover); border-color: rgba(255,204,0,0.15); }
  .lead-story-item::before { content:''; position:absolute; left:-1.48rem; top:1.05rem; width:13px; height:13px; border-radius:50%; background:var(--gold); border:3px solid var(--bg-card); box-shadow:0 0 0 2px var(--gold-border); z-index: 2; }
  .lead-story-time { color:var(--text); font-weight:900; font-size:.82rem; line-height:1.35; background: transparent; border: 0; padding: 0; text-align: left; cursor: pointer; }
  .lead-story-time span { display:block; color:var(--text-muted); font-size:.72rem; font-weight:750; margin-top:.15rem; }
  .lead-story-time:hover { color: var(--gold); }
  .lead-story-main { min-width:0; }
  .lead-story-top { display:flex; align-items:center; gap:.45rem; flex-wrap:wrap; margin-bottom:.35rem; }
  .lead-story-action { font-size:.92rem; font-weight:900; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem; }
  .lead-story-icon-wrap { width: 22px; height: 22px; border-radius: 50%; background: var(--gold-dim); border: 1px solid var(--gold-border); display: inline-flex; align-items: center; justify-content: center; color: var(--gold); flex-shrink: 0; }
  .lead-story-actor { color:var(--text-muted); font-size:.76rem; font-weight:750; }
  .lead-story-summary { color:var(--text-sub); font-size:.78rem; margin-top:.2rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; transition: opacity 0.2s ease; }
  .lead-story-item.is-active .lead-story-summary { opacity: 0; pointer-events: none; }
  .lead-story-detail { grid-column: 1 / span 3; display: grid; max-height: 0; opacity: 0; overflow: hidden; transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease, padding 0.3s ease, margin 0.3s ease; border-top: 1px solid transparent; padding-top: 0; margin-top: 0; }
  .lead-story-item.is-active .lead-story-detail { max-height: 800px; opacity: 1; border-color: var(--border); padding-top: 0.85rem; margin-top: 0.65rem; }
  .lead-story-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:.6rem; margin:.65rem 0; }
  .lead-story-fact { padding:.55rem .65rem; border:1px solid var(--border); border-radius:8px; background:var(--bg-card); min-width:0; }
  .lead-story-fact b { display:block; color:var(--text-muted); font-size:.62rem; font-weight:900; text-transform:uppercase; letter-spacing:.04em; margin-bottom:.18rem; }
  .lead-story-fact span { display:block; color:var(--text); font-size:.78rem; font-weight:800; overflow-wrap:anywhere; }
  .lead-story-note { color:var(--text-sub); font-size:.85rem; line-height:1.55; overflow-wrap:anywhere; background: var(--bg-card); padding: 0.75rem; border-radius: 8px; border: 1px solid var(--border); }
  .lead-detail-modal { position:fixed; inset:0; z-index:1200; display:none; align-items:center; justify-content:center; padding:1rem; background:rgba(0,0,0,.62); backdrop-filter:blur(4px); }
  .lead-detail-modal.is-open { display:flex; }
  .lead-detail-dialog { width:min(720px,100%); max-height:86vh; overflow:auto; border:1px solid var(--border); border-radius:10px; background:var(--bg-card); box-shadow:0 24px 70px rgba(0,0,0,.45); }
  .lead-detail-dialog-head { display:flex; justify-content:space-between; align-items:center; gap:1rem; padding:1rem; border-bottom:1px solid var(--border); }
  .lead-detail-dialog-body { padding:1rem; }
  .lead-detail-close { border:1px solid var(--border); background:var(--bg-input); color:var(--text); border-radius:6px; width:34px; height:34px; cursor:pointer; font-size:1.1rem; }
  .timeline-comment-box { margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border); }
  .counsellor-log { display:grid; gap:.75rem; }
  .counsellor-log-row { display:grid; grid-template-columns:minmax(130px,.8fr) minmax(140px,.9fr) minmax(145px,1fr) minmax(145px,1fr) minmax(130px,.8fr) minmax(220px,1.35fr); gap:.75rem; align-items:start; padding:.85rem; border:1px solid var(--border); border-radius:8px; background:var(--bg-input); }
  .counsellor-log-head { color:var(--text-muted); font-size:.65rem; font-weight:900; text-transform:uppercase; letter-spacing:.04em; background:transparent; padding:.2rem .85rem; border:0; }
  .counsellor-log-cell { min-width:0; color:var(--text); font-size:.8rem; line-height:1.45; overflow-wrap:anywhere; }
  .counsellor-log-label { display:none; color:var(--text-muted); font-size:.62rem; font-weight:900; text-transform:uppercase; letter-spacing:.04em; margin-bottom:.15rem; }
  .counsellor-log-main { font-weight:850; }
  .counsellor-log-muted { color:var(--text-muted); font-size:.72rem; }
  @media (max-width:1050px) {
    .lead-detail-shell { grid-template-columns:1fr; }
    .lead-detail-side { grid-template-columns:1fr; }
    .counsellor-log-head { display:none; }
    .counsellor-log-row { grid-template-columns:repeat(2,minmax(0,1fr)); }
    .counsellor-log-label { display:block; }
  }
  @media (max-width:720px) {
    .lead-fact-grid { grid-template-columns:1fr; }
    .lead-page-actions { align-items:stretch; }
    .lead-page-actions .btn { width:100%; justify-content:center; }
    .lead-timeline-toolbar { align-items:stretch; }
    .lead-timeline-tools { width:100%; display:grid; grid-template-columns:1fr; }
    .lead-timeline-tools .app-select { width:100%; }
    .lead-inline-form { grid-template-columns:1fr; }
    .lead-inline-form .btn { width:100%; justify-content:center; }
    .lead-story { padding-left:1.1rem; }
    .lead-story-item { grid-template-columns:1fr; gap:.55rem; }
    .lead-story-summary { white-space:normal; }
    .lead-story-open { width:100%; }
    .lead-story-grid { grid-template-columns:1fr; }
    .counsellor-log-row { grid-template-columns:1fr; }
  }
</style>

<div class="lead-page-actions">
  <a href="/admin/leads" class="btn btn-ghost btn-sm">&larr; Back to Pipeline</a>
  <% if (lead.status !== 'admission_completed') { %>
    <a href="/admin/leads/<%= lead._id %>/convert" class="btn btn-success btn-sm">Admit as Student</a>
  <% } else if (lead.convertedStudent) { %>
    <a href="/admin/students/<%= lead.convertedStudent._id || lead.convertedStudent %>" class="btn btn-success btn-sm">View Student Profile</a>
  <% } %>
</div>

<%
  const hasError = typeof error !== 'undefined' && error &&
    (Array.isArray(error) ? error.length > 0 : String(error).trim()) &&
    String(error).trim() !== '1' && String(error).trim() !== 'true';
%>
<% if (hasError) { %>
  <div class="card" style="border-color:var(--red); background:rgba(239,68,68,0.05); margin-bottom:20px; padding:12px 16px; color:var(--red); font-size:13px; font-weight:500; border-left:4px solid var(--red);">
    <%= Array.isArray(error) ? error.join(', ') : error %>
  </div>
<% } %>

<div class="lead-detail-shell">
  <div class="lead-action-stack">
    <section class="card lead-panel">
      <div class="lead-hero">
        <div class="lead-avatar"><%= initials %></div>
        <div>
          <div class="lead-name"><%= lead.name %></div>
          <div class="lead-badges">
            <span class="badge <%= statusBadge %>"><%= statusLabels[lead.status] || lead.status %></span>
            <span class="badge badge-orange"><%= courseName %></span>
            <span class="badge badge-grey"><%= lead.source || 'Source not set' %></span>
          </div>
        </div>
      </div>

      <div class="lead-fact-grid">
        <div class="lead-fact"><span class="lead-fact-label">Phone</span><a class="lead-fact-value mono" href="tel:<%= lead.phone %>"><%= lead.phone || 'Not added' %></a></div>
        <div class="lead-fact"><span class="lead-fact-label">Email</span><span class="lead-fact-value mono"><%= lead.email || 'Not added' %></span></div>
        <div class="lead-fact"><span class="lead-fact-label">Counsellor</span><span class="lead-fact-value"><%= assignedName %></span></div>
        <div class="lead-fact"><span class="lead-fact-label">Added on</span><span class="lead-fact-value mono"><%= new Date(lead.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %></span></div>
        <div class="lead-fact"><span class="lead-fact-label">Next follow-up</span><span class="lead-fact-value mono" style="<%= isOverdue ? 'color:var(--red);' : '' %>"><%= lead.nextFollowUpAt ? new Date(lead.nextFollowUpAt).toLocaleDateString('en-IN', { weekday:'short', day:'numeric', month:'short', year:'numeric' }) : 'Not scheduled' %><%= isOverdue ? ' - overdue' : '' %></span></div>
        <div class="lead-fact"><span class="lead-fact-label">Last activity</span><span class="lead-fact-value"><%= lastActivity ? (statusLabels[lastActivity.status] || lastActivity.status || 'Activity logged') : 'No activity yet' %></span></div>
        <% if (lead.referredBy) { %><div class="lead-fact"><span class="lead-fact-label">Referred by</span><span class="lead-fact-value"><%= lead.referredBy %></span></div><% } %>
      </div>

      <% if (lead.notes) { %>
        <div class="lead-note-box">
          <span class="lead-fact-label">Original inquiry notes</span>
          <div style="margin-top:.35rem;"><%= lead.notes %></div>
        </div>
      <% } %>
    </section>

    <section class="card lead-panel">
      <div class="lead-timeline-toolbar">
        <div class="lead-panel-title" style="margin-bottom:0;">Lead timeline</div>
        <div class="lead-timeline-tools">
          <select id="timelineSort" class="form-control" aria-label="Sort timeline">
            <option value="recent" selected>Recent first</option>
            <option value="oldest">Oldest first</option>
          </select>
          <select id="timelineFilter" class="form-control" aria-label="Filter timeline">
            <option value="all" selected>All activity</option>
            <option value="call">Calls</option>
            <option value="whatsapp">WhatsApp</option>
            <option value="note">Comments</option>
            <option value="assigned">Assignment</option>
          </select>
        </div>
      </div>
      <% if (!timelineFeed.length) { %>
        <div class="empty-state" style="padding:1.5rem 1rem;"><p>No activity logs recorded yet.</p></div>
      <% } else { %>
        <%
          const getTimelineIcon = (type) => {
            const t = String(type).toLowerCase();
            if (t.includes('call')) {
              return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`;
            }
            if (t.includes('whatsapp') || t.includes('chat') || t.includes('message')) {
              return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`;
            }
            if (t.includes('created')) {
              return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>`;
            }
            if (t.includes('assign')) {
              return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`;
            }
            if (t.includes('missed')) {
              return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`;
            }
            if (t.includes('completed') || t.includes('admit') || t.includes('convert')) {
              return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>`;
            }
            return `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>`;
          };
        %>
        <div class="lead-story" id="leadTimelineList">
          <% timelineFeed.forEach((item, index) => { %>
            <%
              const itemDateMs = new Date(item.date).getTime();
              const rowStatusBadge = {
                new: 'badge-orange',
                contacted: 'badge-blue',
                mentorship_scheduled: 'badge-blue',
                mentorship_attended: 'badge-yellow',
                follow_up: 'badge-yellow',
                joining_interested: 'badge-gold',
                admission_completed: 'badge-green',
                lost: 'badge-red'
              }[item.status] || 'badge-grey';
              const actorLabel = item.actorName || 'System';
              const roleLabel = item.actorRole ? item.actorRole : item.source === 'assignment' ? 'admin' : '';
              const channelLabel = item.channel || 'Activity';
              const resultLabel = item.callOutcome || item.callDuration
                ? `${item.callOutcome || 'Outcome'}${item.callDuration ? ' - ' + item.callDuration : ''}`
                : 'No result';
              const itemType = item.type || item.channel || 'activity';
              const contextLabel = `Step ${index + 1} - ${new Date(item.date).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' })} - ${item.title}`;
            %>
            <article class="lead-story-item" data-date-ms="<%= itemDateMs %>" data-type="<%= String(itemType).toLowerCase() %>">
              <button type="button" class="lead-story-time toggle-detail-btn" aria-label="Toggle details for <%= item.title %>">
                <%= new Date(item.date).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                <span><%= new Date(item.date).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' }) %></span>
              </button>
              <div class="lead-story-main">
                <div class="lead-story-top">
                  <span class="badge badge-grey">Step <%= index + 1 %></span>
                  <% if (item.status) { %><span class="badge <%= rowStatusBadge %>"><%= statusLabels[item.status] || item.status %></span><% } %>
                </div>
                <div class="lead-story-action">
                  <span class="lead-story-icon-wrap">
                    <%- getTimelineIcon(itemType) %>
                  </span>
                  <%= item.title %>
                </div>
                <div class="lead-story-actor">By <strong><%= actorLabel %></strong><%= roleLabel ? ` (${roleLabel})` : '' %></div>
                <div class="lead-story-summary"><%= channelLabel %> · <%= resultLabel %><%= item.note ? ` · ${String(item.note).slice(0, 86)}${String(item.note).length > 86 ? '...' : ''}` : '' %></div>
              </div>
              <button type="button" class="btn btn-ghost btn-xs toggle-detail-btn" style="min-width: 90px; justify-content: center;">View details</button>
              
              <div class="lead-story-detail">
                <div class="lead-story-top">
                  <span class="badge badge-grey">Step <%= index + 1 %></span>
                  <% if (item.status) { %><span class="badge <%= rowStatusBadge %>"><%= statusLabels[item.status] || item.status %></span><% } %>
                </div>
                <h3 style="margin:.35rem 0 .2rem; font-size:1.02rem; font-weight: 800; color: var(--text);"><%= item.title %></h3>
                <div class="activity-meta" style="color: var(--text-muted); font-size: 0.72rem; margin-bottom: 0.5rem;">
                  <%= actorLabel %><%= roleLabel ? ` (${roleLabel})` : '' %> ·
                  <%= new Date(item.date).toLocaleDateString('en-IN', { weekday:'short', day:'numeric', month:'short', year:'numeric' }) %> ·
                  <%= new Date(item.date).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' }) %>
                </div>
                <div class="lead-story-grid">
                  <div class="lead-story-fact"><b>Channel</b><span><%= channelLabel %></span></div>
                  <div class="lead-story-fact"><b>Result</b><span><%= resultLabel %></span></div>
                  <div class="lead-story-fact"><b>Next follow-up</b><span><%= item.nextFollowUpDate ? new Date(item.nextFollowUpDate).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) : 'Not scheduled' %></span></div>
                </div>
                <div class="lead-story-note">
                  <div style="font-size: 10px; font-weight: 900; text-transform: uppercase; color: var(--text-muted); margin-bottom: 4px; letter-spacing: 0.05em;">Log Note:</div>
                  <%= item.note || 'No descriptive note added.' %>
                </div>
                <form action="/admin/leads/<%= lead._id %>/comment" method="POST" class="timeline-comment-box">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <input type="hidden" name="context" value="<%= contextLabel %>">
                  <label class="form-label" for="timeline-comment-<%= index %>" style="color: var(--gold); font-size: 10px; font-weight: 700; margin-bottom: 6px;">Add comment to this event</label>
                  <textarea id="timeline-comment-<%= index %>" name="note" class="form-control" placeholder="Write comment details here..." required maxlength="500" style="min-height:80px; border-radius: 8px; font-size: 13px;"></textarea>
                  <button type="submit" class="btn btn-primary btn-sm" style="margin-top:.7rem; font-weight: 800;">Save Comment</button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>

  <aside class="lead-action-stack lead-detail-side">
    <section class="card lead-panel next-action">
      <div class="lead-panel-title">What needs attention</div>
      <div class="next-action-main">
        <div class="next-action-label">Current status</div>
        <div class="next-action-value"><%= statusLabels[lead.status] || lead.status %></div>
        <div class="text-sm" style="margin-top:.5rem; color:var(--text-sub); line-height:1.5;">
          <% if (lead.status === 'joining_interested') { %>
            This lead is ready for admission. Convert it when fee and batch details are confirmed.
          <% } else if (isOverdue) { %>
            Follow-up is overdue. Ask the counsellor for the latest update.
          <% } else if (lead.nextFollowUpAt) { %>
            Next follow-up is scheduled. Keep the counsellor assignment correct.
          <% } else if (lead.status === 'lost') { %>
            This lead is closed as lost. Review the activity history before reopening manually.
          <% } else if (lead.status === 'admission_completed') { %>
            This lead has already been admitted as a student.
          <% } else { %>
            No follow-up date is set. Assign a counsellor or add an instruction.
          <% } %>
        </div>
      </div>
    </section>

    <section class="card lead-panel">
      <div class="lead-panel-title">Counsellor assignment</div>
      <form action="/admin/leads/<%= lead._id %>/assign" method="POST" class="lead-inline-form">
        <div class="form-group" style="margin:0;">
          <label class="form-label" for="counsellorId">Assigned counsellor</label>
          <select id="counsellorId" name="counsellorId" class="form-control">
            <option value="">Unassigned</option>
            <% counsellors.forEach(c => { %>
              <option value="<%= c._id %>" <%= (lead.assignedTo && lead.assignedTo._id.toString() === c._id.toString()) ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Assign</button>
      </form>
    </section>

  </aside>
</div>

<script>
  function initLeadTimelineControls() {
    const list = document.getElementById('leadTimelineList');
    const sortSelect = document.getElementById('timelineSort');
    const filterSelect = document.getElementById('timelineFilter');

    if (!list) return;

    const applyTimelineView = () => {
      const sortValue = sortSelect ? sortSelect.value : 'recent';
      const filterValue = filterSelect ? filterSelect.value : 'all';
      const rows = Array.from(list.querySelectorAll('.lead-story-item'));

      rows.sort((a, b) => {
        const aDate = Number(a.dataset.dateMs || 0);
        const bDate = Number(b.dataset.dateMs || 0);
        return sortValue === 'oldest' ? aDate - bDate : bDate - aDate;
      });

      rows.forEach(row => {
        const type = String(row.dataset.type || '').toLowerCase();
        const isVisible = filterValue === 'all' || type.includes(filterValue);
        row.style.display = isVisible ? '' : 'none';
        list.appendChild(row);
      });
    };

    list.querySelectorAll('.toggle-detail-btn').forEach(btn => {
      if (btn.dataset.bound === '1') return;
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const row = btn.closest('.lead-story-item');
        if (!row) return;

        const isAlreadyActive = row.classList.contains('is-active');

        // Collapse all others
        list.querySelectorAll('.lead-story-item').forEach(r => {
          if (r !== row) {
            r.classList.remove('is-active');
            const otherBtn = r.querySelector('.btn.toggle-detail-btn');
            if (otherBtn) otherBtn.textContent = 'View details';
          }
        });

        // Toggle active row
        if (isAlreadyActive) {
          row.classList.remove('is-active');
          const rowBtn = row.querySelector('.btn.toggle-detail-btn');
          if (rowBtn) rowBtn.textContent = 'View details';
        } else {
          row.classList.add('is-active');
          const rowBtn = row.querySelector('.btn.toggle-detail-btn');
          if (rowBtn) rowBtn.textContent = 'Hide details';
        }
      });
      btn.dataset.bound = '1';
    });

    sortSelect?.addEventListener('change', applyTimelineView);
    filterSelect?.addEventListener('change', applyTimelineView);

    applyTimelineView();
  }

  initLeadTimelineControls();
  document.addEventListener('softnav:load', initLeadTimelineControls);
</script>
