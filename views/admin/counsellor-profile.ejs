<%
  layout = 'main';
  title = counsellor.name;
  subtitle = `Counsellor · ${counsellor.rollNumber || 'No Roll Number'}`;
  page = 'users';
%>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
  <a href="/admin/counsellors" class="btn btn-ghost btn-sm">&larr; Back to Counsellors</a>
  <div style="display:flex; gap:0.5rem;">
    <a href="/admin/users/<%= counsellor._id %>/edit" class="btn btn-primary btn-sm">Edit Profile</a>
  </div>
</div>

<div class="profile-header">
  <div class="avatar-lg">
    <% if (counsellor.profilePic) { %>
      <img src="<%= counsellor.profilePic %>" alt="<%= counsellor.name %>">
    <% } else { %>
      <%= counsellor.initials %>
    <% } %>
  </div>
  <div style="flex:1;">
    <h2 class="profile-name" style="font-size:1.5rem; font-weight:800; color:var(--text);"><%= counsellor.name %></h2>
    <div style="display:flex; flex-wrap:wrap; gap:12px; margin-top:0.35rem; font-size:0.8rem; color:var(--text-sub);">
      <span>Roll: <strong style="color:var(--gold);"><%= counsellor.rollNumber || 'Not Generated' %></strong></span>
      <span>&middot;</span>
      <span>Role: <strong style="color:var(--text);">CRM Academy Counsellor</strong></span>
    </div>
  </div>
</div>

<!-- Performance Metrics -->
<div class="stats-grid" style="margin-bottom:1.5rem;">
  <div class="stat-card gold">
    <div class="stat-label">Total Leads Handled</div>
    <div class="stat-value"><%= stats.totalLeads %></div>
    <div class="stat-sub">Assigned prospects</div>
  </div>
  <div class="stat-card green">
    <div class="stat-label">Converted Students</div>
    <div class="stat-value" style="color:var(--green);"><%= stats.convertedLeads %></div>
    <div class="stat-sub">Successful admissions</div>
  </div>
  <div class="stat-card blue">
    <div class="stat-label">Conversion Rate</div>
    <div class="stat-value" style="color:var(--blue);"><%= stats.conversionRate %>%</div>
    <div class="stat-sub">Efficiency index</div>
  </div>
  <div class="stat-card orange">
    <div class="stat-label">Active Pipeline</div>
    <div class="stat-value" style="color:var(--orange);"><%= stats.activeLeads %></div>
    <div class="stat-sub">Open opportunities</div>
  </div>
  <div class="stat-card red">
    <div class="stat-label">Lost Leads</div>
    <div class="stat-value" style="color:var(--red);"><%= stats.lostLeads %></div>
    <div class="stat-sub">Uninterested prospects</div>
  </div>
</div>

<div class="two-col">
  <!-- Left Side: Interactive Details Tabs -->
  <div>
    <!-- Tabs Navigation -->
    <div class="card" style="padding: 0.5rem; margin-bottom: 1rem;">
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <button class="btn btn-sm btn-primary tab-btn" onclick="openTab(event, 'leads')">Assigned Lead Pipeline</button>
        <button class="btn btn-sm btn-ghost tab-btn" onclick="openTab(event, 'messages')">Admin Messenger</button>
      </div>
    </div>

    <!-- Tab: Leads List -->
    <div id="leads" class="tab-content">
      <div class="card">
        <div class="card-header" style="margin-bottom:1.25rem;">
          <div class="card-title">Assigned Lead Pipeline</div>
        </div>

        <% if (leads.length === 0) { %>
          <div class="empty-state">
            <p>No prospects assigned to this counsellor yet.</p>
          </div>
        <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Lead Info</th>
                  <th>Course</th>
                  <th>Source</th>
                  <th>Status</th>
                  <th>Reassign Counsellor</th>
                  <th>Date Assigned</th>
                </tr>
              </thead>
              <tbody>
                <% leads.forEach(lead => { %>
                  <tr>
                    <td>
                      <div style="font-weight:600;"><%= lead.name %></div>
                      <div class="td-muted text-sm"><%= lead.phone %> &middot; <%= lead.email || '—' %></div>
                    </td>
                    <td><span class="badge badge-orange"><%= lead.course %></span></td>
                    <td><%= lead.source %></td>
                    <td>
                      <% 
                        const statusClass = {
                          new: 'badge-orange',
                          contacted: 'badge-blue',
                         mentorship_scheduled: 'badge-blue',
                          mentorship_attended: 'badge-yellow',
                          follow_up: 'badge-yellow',
                          joining_interested: 'badge-gold',
                          admission_completed: 'badge-green',
                          lost: 'badge-red'
                        }[lead.status] || 'badge-grey';
                      %>
                      <span class="badge <%= statusClass %>"><%= lead.status %></span>
                    </td>
                    <td>
                      <form action="/admin/leads/<%= lead._id %>/assign" method="POST" style="margin:0; display:flex; gap:0.5rem; align-items:center;">
                        <select name="counsellorId" class="form-control" style="padding: 0.35rem 0.5rem; font-size: 12px; min-width: 130px;" onchange="this.form.submit()">
                          <option value="">Unassigned</option>
                          <% counsellors.forEach(c => { %>
                            <option value="<%= c._id %>" <%= (lead.assignedTo && lead.assignedTo.toString() === c._id.toString()) ? 'selected' : '' %>><%= c.name %></option>
                          <% }) %>
                        </select>
                      </form>
                    </td>
                    <td class="mono text-xs"><%= new Date(lead.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Tab: Admin Messenger -->
    <div id="messages" class="tab-content" style="display:none;">
      <div class="card">
        <div class="card-header" style="margin-bottom:1.25rem;">
          <div class="card-title">Counsellor Inbox Notes</div>
        </div>
        <form action="/admin/messages/send" method="POST" style="background:var(--bg3); padding:1rem; border-radius:var(--radius); margin-bottom:1.5rem;">
          <input type="hidden" name="recipientId" value="<%= counsellor._id %>">
          <input type="hidden" name="redirect" value="/admin/counsellors/<%= counsellor._id %>">
          <div class="form-group">
            <label class="form-label" for="msg_content">Send Notification / Message Note</label>
            <textarea id="msg_content" name="content" class="form-control" placeholder="Type notification details or message to show on counsellor dashboard..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-sm">Send Note to Counsellor</button>
        </form>
        <div class="section-title">Sent Logs</div>
        <% if (messages.length === 0) { %>
          <div class="empty-state" style="padding:1.5rem;">
            <p>No messages sent to this counsellor yet.</p>
          </div>
        <% } else { %>
          <div style="display:flex; flex-direction:column; gap:10px;">
            <% messages.forEach(msg => { %>
              <div style="background:var(--bg2); border:1px solid var(--border); padding:10px 12px; border-radius:var(--radius-sm);">
                <p style="font-size:13px; color:var(--text); line-height:1.5;"><%= msg.content %></p>
                <div style="display:flex; justify-content:space-between; font-size:10px; color:var(--text-muted); margin-top:5px;">
                  <span>By: <%= msg.sender ? msg.sender.name : 'Admin' %> (<%= msg.sender ? msg.sender.role : 'System' %>)</span>
                  <span><%= new Date(msg.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %> &nbsp;·&nbsp; <%= new Date(msg.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %></span>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right Side: Contact info -->
  <div>
    <div class="card">
      <div class="card-title" style="margin-bottom:1rem;">Contact Card</div>
      
      <div style="display:flex; flex-direction:column; gap:12px;">
        <div>
          <div style="font-size:0.7rem; color:var(--text-muted); text-transform:uppercase;">Email Address</div>
          <div style="font-size:0.9rem; font-weight:500; word-break:break-all;"><%= counsellor.email %></div>
        </div>
        <div>
          <div style="font-size:0.7rem; color:var(--text-muted); text-transform:uppercase;">Mobile Number</div>
          <div style="font-size:0.9rem; font-weight:500; font-family:var(--mono);"><%= counsellor.phone || '—' %></div>
        </div>
        <div>
          <div style="font-size:0.7rem; color:var(--text-muted); text-transform:uppercase;">Joined On</div>
          <div style="font-size:0.9rem; font-weight:500; font-family:var(--mono);">
            <%= new Date(counsellor.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function openTab(evt, tabId) {
    const tabcontents = document.querySelectorAll(".tab-content");
    tabcontents.forEach(tab => tab.style.display = "none");

    const tablinks = document.querySelectorAll(".tab-btn");
    tablinks.forEach(link => {
      link.classList.remove("btn-primary");
      link.classList.add("btn-ghost");
    });

    document.getElementById(tabId).style.display = "block";
    evt.currentTarget.classList.remove("btn-ghost");
    evt.currentTarget.classList.add("btn-primary");
  }
</script>
