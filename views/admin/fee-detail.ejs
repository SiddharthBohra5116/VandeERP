<%
  layout = 'main';
  title = 'Fee Details';
  subtitle = `Tuition fee account ledger for ${fee.student.name}`;
  page = 'fees';
%>

<div class="profile-header">
  <div class="avatar-lg">
    <%= fee.student.name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2) %>
  </div>
  <div>
    <div class="profile-name"><%= fee.student.name %></div>
    <div class="profile-meta">
      Course: <strong><%= fee.course %></strong> &nbsp;·&nbsp; 
      Batch: <strong><%= fee.student.batch || '—' %></strong> &nbsp;·&nbsp; 
      Phone: <strong><%= fee.student.user && fee.student.user.phone ? fee.student.user.phone : '—' %></strong>
  </div>
</div>

<!-- Ledger Calculation -->
<% 
  const netFees = fee.totalAmount - (fee.discount || 0);
  const balanceDue = Math.max(0, fee.totalAmount - (fee.discount || 0) - fee.paidAmount);
  const paidPct = netFees > 0 ? Math.round((fee.paidAmount / netFees) * 100) : 0;
%>

<div class="fee-summary">
  <div class="stat-card gold">
    <div class="stat-label">Net Total Invoice</div>
    <div class="stat-value">₹<%= netFees.toLocaleString('en-IN') %></div>
    <div class="stat-sub">Base: ₹<%= fee.totalAmount.toLocaleString('en-IN') %> (Disc: ₹<%= (fee.discount || 0).toLocaleString('en-IN') %>)</div>
  </div>
  <div class="stat-card green">
    <div class="stat-label">Total Collected</div>
    <div class="stat-value">₹<%= fee.paidAmount.toLocaleString('en-IN') %></div>
    <div class="stat-sub">Receipts logged (<%= paidPct %>%)</div>
  </div>
  <div class="stat-card red">
    <div class="stat-label">Balance Due</div>
    <div class="stat-value">₹<%= balanceDue.toLocaleString('en-IN') %></div>
    <div class="stat-sub">Late fines are shown separately below</div>
  </div>
</div>

<!-- Installments Schedule -->
<div class="card" style="margin-bottom: 1.25rem;">
  <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
    <div class="card-title">Installments Payment Schedule</div>
    <% if (fee.totalFine > 0) { %>
      <span class="badge badge-red" style="font-size: 11px;">⚠️ Total Late Fines: +₹<%= fee.totalFine.toLocaleString('en-IN') %></span>
    <% } %>
  </div>
  <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; padding-top: 0.5rem;">
    <% fee.installments.forEach(inst => { %>
      <% 
        const isPaid = inst.paidAmount >= inst.amount;
        const isLate = !isPaid && inst.dueDate && new Date(inst.dueDate) < new Date();
        
        let fine = 0;
        if (isLate) {
          const diffDays = Math.ceil(Math.abs(new Date() - new Date(inst.dueDate)) / (1000 * 60 * 60 * 24));
          if (diffDays > 60) fine = 1000;
          else if (diffDays > 30) fine = 500;
          else fine = 250;
        }

        const statusLabel = isPaid ? 'Paid' : isLate ? 'Overdue' : 'Pending';
        const statusBadgeClass = isPaid ? 'badge-green' : isLate ? 'badge-red' : 'badge-orange';
        const instPct = inst.amount > 0 ? Math.round((inst.paidAmount / inst.amount) * 100) : 0;
      %>
      <div <%= isLate ? 'style="background:var(--bg-input); border: 1px solid rgba(239,68,68,0.2); border-radius:var(--radius); padding: 1rem; display:flex; flex-direction:column; gap:0.5rem; position:relative;"' : 'style="background:var(--bg-input); border: 1px solid var(--border); border-radius:var(--radius); padding: 1rem; display:flex; flex-direction:column; gap:0.5rem; position:relative;"' %>>
        <div style="display:flex; justify-content:space-between; align-items:start;">
          <div style="font-size:13px; font-weight:700; color:var(--text);"><%= inst.name %></div>
          <span class="badge <%= statusBadgeClass %>" style="font-size:9px; padding:1px 5px;"><%= statusLabel %></span>
        </div>
        
        <div style="font-size:18px; font-weight:800; color:var(--gold); font-family:var(--mono);">
          ₹<%= inst.amount.toLocaleString('en-IN') %>
        </div>

        <div style="font-size:11px; color:var(--text-muted);">
          Due Date: <span class="mono"><%= new Date(inst.dueDate).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></span>
        </div>

        <% if (fine > 0) { %>
          <div style="font-size:11px; color:var(--red); font-weight:700;">
            ⚠️ Late Fine: +₹<%= fine %>
          </div>
        <% } %>

        <div style="margin-top:auto; padding-top:0.5rem;">
          <div style="display:flex; justify-content:space-between; font-size:10px; color:var(--text-muted); margin-bottom:2px;">
            <span>Paid: ₹<%= inst.paidAmount.toLocaleString('en-IN') %></span>
            <span><%= instPct %>%.</span>
          </div>
          <div class="progress-bar" style="height:4px; background:rgba(255,255,255,0.05); border-radius: 4px;">
            <div class="progress-fill <%= isPaid ? 'green' : instPct > 0 ? 'orange' : 'red' %>" <%= `style="width: ${instPct}%"` %>></div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<div class="grid-2">
  <!-- Log payment -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">Record Payment</div>
    </div>
    <form action="/admin/fees/<%= fee.student._id %>/payment" method="POST" data-native-submit="true">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="form-group">
        <label class="form-label" for="amount">Payment Amount (INR)</label>
        <input type="number" id="amount" name="amount" class="form-control" placeholder="e.g. 5000" min="1" max="<%= balanceDue %>" required>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="method">Method</label>
          <select id="method" name="method" class="form-control" required>
            <option value="UPI">UPI (GPay/PhonePe/Paytm)</option>
            <option value="Cash">Cash</option>
            <option value="Bank Transfer">Bank Transfer</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="transactionId">Transaction ID / Ref</label>
          <input type="text" id="transactionId" name="transactionId" class="form-control" placeholder="e.g. UPI Ref Number">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="note">Collection Notes</label>
        <textarea id="note" name="note" class="form-control" placeholder="Optional comments..."></textarea>
      </div>
      <button type="submit" class="btn btn-primary" <%= balanceDue === 0 ? 'disabled' : '' %>>
        <%= balanceDue === 0 ? 'Fully Paid' : 'Record Receipt' %>
      </button>
    </form>
  </div>

  <!-- Update Fee Structure -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">Adjust Fee / Discount</div>
    </div>
    <form action="/admin/fees/<%= fee.student._id %>/update" method="POST" data-native-submit="true">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="totalAmount">Base Fee (INR)</label>
          <input type="number" id="totalAmount" name="totalAmount" class="form-control" value="<%= fee.totalAmount %>" min="0.01" step="0.01" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="discount">Discount (INR)</label>
          <input type="number" id="discount" name="discount" class="form-control" value="<%= fee.discount || 0 %>" min="0" step="0.01">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="discountReason">Reason for Discount</label>
        <input type="text" id="discountReason" name="discountReason" class="form-control" value="<%= fee.discountReason || '' %>" placeholder="e.g. Merit Scholarship, Seasonal Offer">
      </div>
      <!-- Installments Edit List -->
      <div style="margin-top: 1rem; border-top: 1px dashed var(--border); padding-top: 1rem;">
        <div style="font-size: 11px; font-weight: 700; color: var(--gold); text-transform: uppercase; margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: center;">
          <span>EMI / Installment Plan</span>
          <button type="button" class="btn btn-ghost btn-xs" onclick="addInstRow()">+ Add Row</button>
        </div>
        <p class="form-hint">EMI amounts must total the net fee (base fee minus discount). Payments already received are allocated to the earliest EMI first.</p>
        <div id="inst_list_container">
          <% if (fee.installments && fee.installments.length > 0) { %>
            <% fee.installments.forEach((inst, index) => { %>
              <div class="form-row inst-edit-row" style="margin-bottom: 0.5rem; align-items: flex-end; gap: 0.5rem;">
                <div class="form-group" style="flex: 2; margin-bottom: 0;">
                  <label class="form-label" style="font-size: 9px; margin-bottom: 2px;">Name</label>
                  <input type="text" name="instName[]" class="form-control form-control-sm" value="<%= inst.name %>" required>
                </div>
                <div class="form-group" style="flex: 1.5; margin-bottom: 0;">
                  <label class="form-label" style="font-size: 9px; margin-bottom: 2px;">Amount</label>
                  <input type="number" name="instAmount[]" class="form-control form-control-sm" value="<%= inst.amount %>" min="0.01" step="0.01" required>
                </div>
                <div class="form-group" style="flex: 2; margin-bottom: 0;">
                  <label class="form-label" style="font-size: 9px; margin-bottom: 2px;">Due Date</label>
                  <% 
                    let instDue = '';
                    if (inst.dueDate) {
                      instDue = new Date(inst.dueDate).toISOString().split('T')[0];
                    }
                  %>
                  <input type="date" name="instDueDate[]" class="form-control form-control-sm" value="<%= instDue %>" required>
                </div>
                <button type="button" class="btn btn-red btn-xs" style="padding: 4px 8px; margin-bottom: 2px;" onclick="removeInstRow(this)">X</button>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>

      <div class="form-hint" id="emiTotal" style="margin-top:0.75rem;"></div>

      <button type="submit" class="btn btn-ghost" style="margin-top: 1rem;">Save Adjustments</button>
    </form>
  </div>
</div>

<script>
  function addInstRow() {
    const container = document.getElementById('inst_list_container');
    const todayStr = new Date().toISOString().split('T')[0];
    const row = document.createElement('div');
    row.className = 'form-row inst-edit-row';
    row.style.marginBottom = '0.5rem';
    row.style.alignItems = 'flex-end';
    row.style.gap = '0.5rem';
    row.innerHTML = `
      <div class="form-group" style="flex: 2; margin-bottom: 0;">
        <label class="form-label" style="font-size: 9px; margin-bottom: 2px;">Name</label>
        <input type="text" name="instName[]" class="form-control form-control-sm" placeholder="e.g. Month 3" required>
      </div>
      <div class="form-group" style="flex: 1.5; margin-bottom: 0;">
        <label class="form-label" style="font-size: 9px; margin-bottom: 2px;">Amount</label>
        <input type="number" name="instAmount[]" class="form-control form-control-sm" placeholder="0" min="0.01" step="0.01" required>
      </div>
      <div class="form-group" style="flex: 2; margin-bottom: 0;">
        <label class="form-label" style="font-size: 9px; margin-bottom: 2px;">Due Date</label>
        <input type="date" name="instDueDate[]" class="form-control form-control-sm" value="${todayStr}" required>
      </div>
      <button type="button" class="btn btn-red btn-xs" style="padding: 4px 8px; margin-bottom: 2px;" onclick="removeInstRow(this)">X</button>
    `;
    container.appendChild(row);
    updateEmiTotal();
  }

  function removeInstRow(btn) {
    const row = btn.closest('.inst-edit-row');
    if (row) {
      row.remove();
      updateEmiTotal();
    }
  }

  function updateEmiTotal() {
    const net = (Number(document.getElementById('totalAmount').value) || 0) - (Number(document.getElementById('discount').value) || 0);
    const emi = [...document.querySelectorAll('input[name="instAmount[]"]')].reduce((sum, input) => sum + (Number(input.value) || 0), 0);
    const output = document.getElementById('emiTotal');
    output.textContent = `EMI total: ₹${emi.toLocaleString('en-IN')} / Net fee: ₹${net.toLocaleString('en-IN')}`;
    output.style.color = Math.abs(emi - net) < 0.01 ? 'var(--green)' : 'var(--red)';
  }

  document.querySelector('form[action$="/update"]').addEventListener('input', updateEmiTotal);
  updateEmiTotal();
</script>

<!-- Receipt Ledger -->
<div class="card" style="margin-top: 1.25rem;">
  <div class="card-header">
    <div class="card-title">Collection Transaction Ledger</div>
  </div>
  <% if (fee.payments.length === 0) { %>
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      <p>No transactions registered for this account.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Amount Collected</th>
            <th>Method</th>
            <th>Reference ID</th>
            <th>Received By</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          <% fee.payments.forEach(p => { %>
            <tr>
              <td class="mono text-sm"><%= new Date(p.paidAt || p.date).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></td>
              <td class="mono text-green fw-600">₹<%= p.amount.toLocaleString('en-IN') %></td>
              <td><span class="badge badge-grey"><%= p.method %></span></td>
              <td class="mono text-xs"><%= p.transactionId || '—' %></td>
              <td><%= p.receivedBy ? p.receivedBy.name : '—' %></td>
              <td class="text-sm"><%= p.note || '—' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
