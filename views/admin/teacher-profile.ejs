<%
  layout = 'main';
  title = teacher.name;
  subtitle = `Teacher · ${teacher.rollNumber || 'No Roll Number'}`;
  page = 'users';
%>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
  <a href="/admin/teachers" class="btn btn-ghost btn-sm">&larr; Back to Teachers</a>
  <div style="display:flex; gap:0.5rem;">
    <a href="/admin/users/<%= teacher._id %>/edit" class="btn btn-primary btn-sm">Edit Teacher Profile</a>
  </div>
</div>

<div class="profile-header">
  <div class="avatar-lg">
    <% if (teacher.profilePic) { %>
      <img src="<%= teacher.profilePic %>" alt="<%= teacher.name %>">
    <% } else { %>
      <%= teacher.initials %>
    <% } %>
  </div>
  <div style="flex:1;">
    <h2 class="profile-name" style="font-size:1.5rem; font-weight:800; color:var(--text);"><%= teacher.name %></h2>
    <div style="display:flex; flex-wrap:wrap; gap:12px; margin-top:0.35rem; font-size:0.8rem; color:var(--text-sub);">
      <span>Roll: <strong style="color:var(--gold);"><%= teacher.rollNumber || 'Not Generated' %></strong></span>
      <span>&middot;</span>
      <span>Domain: <strong style="color:var(--text);"><%= teacher.subject || 'Not Mapped' %></strong></span>
      <span>&middot;</span>
      <span>Qualification: <strong style="color:var(--text);"><%= teacher.qualification || '—' %></strong></span>
    </div>
  </div>
</div>

<div class="two-col">
  <!-- Left Side: Tabs -->
  <div>
    <!-- Tabs Nav -->
    <div class="card" style="padding:0.5rem; margin-bottom:1rem;">
      <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
        <button class="btn btn-sm btn-primary tab-btn" onclick="openTab(event, 'schedule')">Calendar & Schedule</button>
        <button class="btn btn-sm btn-ghost tab-btn" onclick="openTab(event, 'curriculum')">Syllabus Progress</button>
        <button class="btn btn-sm btn-ghost tab-btn" onclick="openTab(event, 'updates')">Daily Lesson Logs</button>
        <button class="btn btn-sm btn-ghost tab-btn" onclick="openTab(event, 'messages')">Admin Messenger</button>
      </div>
    </div>

    <!-- Tab: Schedule / Calendar -->
    <div id="schedule" class="tab-content card">
      <div class="card-header" style="margin-bottom:1.25rem;">
        <div class="card-title">Class Schedule Log</div>
      </div>

      <% if (schedules.length === 0 && updates.length === 0) { %>
        <div class="empty-state">
          <p>No classes scheduled or completed for this teacher.</p>
        </div>
      <% } else { %>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:1.5rem;">
          <div class="stat-card gold">
            <div class="stat-label">Scheduled Classes</div>
            <div class="stat-value" style="font-size:1.4rem; color:var(--gold);"><%= schedules.filter(s => s.status === 'scheduled').length %> slots</div>
          </div>
          <div class="stat-card green">
            <div class="stat-label">Lectures Completed</div>
            <div class="stat-value" style="font-size:1.4rem; color:var(--green);"><%= updates.length %> classes</div>
          </div>
        </div>

        <div class="section-title">Upcoming Schedules</div>
        <% const upcoming = schedules.filter(s => s.status === 'scheduled'); %>
        <% if (upcoming.length === 0) { %>
          <p style="font-size:0.8rem; color:var(--text-muted); margin-bottom:1.5rem;">No upcoming classes scheduled.</p>
        <% } else { %>
          <div class="table-wrap" style="margin-bottom:1.5rem;">
            <table>
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Batch / Course</th>
                  <th>Timings</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% upcoming.forEach(slot => { %>
                  <tr>
                    <td class="mono text-xs fw-600"><%= slot.date %></td>
                    <td>
                      <div style="font-weight:600;"><%= slot.subject %></div>
                      <div class="td-muted text-xs">Batch: <%= slot.batch %></div>
                    </td>
                    <td class="mono text-xs"><%= slot.startTime %> - <%= slot.endTime %></td>
                    <td><span class="badge badge-gold"><%= slot.status %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <div class="section-title">Schedule Calendar List</div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Subject & Batch</th>
                <th>Schedule Details</th>
                <th>Type</th>
              </tr>
            </thead>
            <tbody>
              <% /* Combine updates and schedules */ %>
              <% 
                const calendarItems = [];
                updates.forEach(u => calendarItems.push({ date: u.date, subject: u.subject, batch: u.batch, desc: 'Taught topics: ' + (u.topics ? u.topics.join(', ') : 'Lesson'), type: 'completed' }));
                schedules.forEach(s => calendarItems.push({ date: s.date, subject: s.subject, batch: s.batch, desc: s.startTime + ' - ' + s.endTime, type: s.status }));
                // Sort by date desc
                calendarItems.sort((a,b) => b.date.localeCompare(a.date));
              %>
              <% calendarItems.forEach(item => { %>
                <tr>
                  <td class="mono text-xs fw-600"><%= item.date %></td>
                  <td>
                    <div style="font-weight:600;"><%= item.subject %></div>
                    <div class="td-muted text-xs">Batch: <%= item.batch %></div>
                  </td>
                  <td style="font-size:12px; color:var(--text-sub);"><%= item.desc %></td>
                  <td>
                    <% if (item.type === 'completed') { %>
                      <span class="badge badge-green">Class Taken</span>
                    <% } else if (item.type === 'scheduled') { %>
                      <span class="badge badge-gold">Scheduled</span>
                    <% } else { %>
                      <span class="badge badge-red"><%= item.type %></span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Tab: Syllabus Progress -->
    <div id="curriculum" class="tab-content card" style="display:none;">
      <div class="card-header" style="margin-bottom:1.25rem;">
        <div class="card-title">Syllabus Curriculum Tracks</div>
      </div>

      <% if (curricula.length === 0) { %>
        <div class="empty-state">
          <p>No curriculums configured for this teacher.</p>
        </div>
      <% } else { %>
        <% curricula.forEach(curr => { %>
          <% 
            const total = curr.topics.length;
            const completed = curr.topics.filter(t => t.completed).length;
            const pct = total > 0 ? Math.round((completed / total) * 100) : 0;
          %>
          <div style="background:var(--bg3); padding:1rem; border-radius:var(--radius); margin-bottom:1.25rem;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
              <div>
                <strong style="color:var(--text);"><%= curr.subject %></strong>
                <div class="td-muted text-xs">Batch: <%= curr.batch && curr.batch.name ? curr.batch.name : curr.batch %></div>
              </div>
              <span class="badge badge-blue"><%= completed %> / <%= total %> completed (<%= pct %>%)</span>
            </div>
            
            <div class="progress-bar" style="margin-bottom:1rem;">
              <div class="progress-fill <%= pct === 100 ? 'green' : 'orange' %>" style="width:<%= pct %>%"></div>
            </div>

            <div style="font-size:12px; color:var(--text-sub); line-height:1.5; margin-bottom:0.75rem;"><%= curr.description %></div>

            <div class="section-title" style="font-size:11px; margin-bottom:5px;">Topic Completion Grid</div>
            <div style="max-height: 200px; overflow-y:auto; padding-right:5px;">
              <% curr.topics.forEach(t => { %>
                <div style="display:flex; justify-content:space-between; align-items:center; padding:6px 0; border-bottom:1px solid var(--border); font-size:12px;">
                  <span style="text-decoration: <%= t.completed ? 'line-through' : 'none' %>; color: <%= t.completed ? 'var(--text-muted)' : 'inherit' %>;"><%= t.name %></span>
                  <span class="badge <%= t.completed ? 'badge-green' : 'badge-grey' %>"><%= t.completed ? 'Done' : 'Pending' %></span>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <!-- Tab: Daily Lesson Logs -->
    <div id="updates" class="tab-content card" style="display:none;">
      <div class="card-header" style="margin-bottom:1.25rem;">
        <div class="card-title">Daily Class Updates Logs</div>
      </div>

      <% if (updates.length === 0) { %>
        <div class="empty-state">
          <p>No class updates posted by this teacher yet.</p>
        </div>
      <% } else { %>
        <div class="timeline" style="margin-left: 10px;">
          <% updates.forEach(up => { %>
            <div class="tl-item">
              <div style="font-weight:600; font-size:13px; color:var(--text);"><%= up.subject %> &nbsp;&middot;&nbsp; <span class="text-gold"><%= up.batch %></span></div>
              <div class="tl-meta">
                Posted: <%= up.date %>
              </div>
              <div class="tl-body" style="font-size:12px; margin-top:0.25rem;">
                <div style="margin-bottom:0.25rem;"><strong>Topics Covered:</strong> <%= up.topics ? up.topics.join(', ') : '—' %></div>
                <div><strong>Homework:</strong> <%= up.homework || 'None assigned' %></div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Tab: Admin Messenger -->
    <div id="messages" class="tab-content card" style="display:none;">
      <div class="card-header" style="margin-bottom:1.25rem;">
        <div class="card-title">Teacher Inbox Notes</div>
      </div>

      <!-- Send message form -->
      <form action="/admin/messages/send" method="POST" style="background:var(--bg3); padding:1rem; border-radius:var(--radius); margin-bottom:1.5rem;">
        <input type="hidden" name="recipientId" value="<%= teacher._id %>">
        <input type="hidden" name="redirect" value="/admin/teachers/<%= teacher._id %>">
        
        <div class="form-group">
          <label class="form-label" for="msg_content">Send Notification / Message Note</label>
          <textarea id="msg_content" name="content" class="form-control" placeholder="Type notification details or message to show on teacher dashboard..." required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Send Note to Teacher</button>
      </form>

      <div class="section-title">Sent Logs</div>
      <% if (messages.length === 0) { %>
        <div class="empty-state" style="padding:1.5rem;">
          <p>No messages sent to this teacher yet.</p>
        </div>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:10px;">
          <% messages.forEach(msg => { %>
            <div style="background:var(--bg2); border:1px solid var(--border); padding:10px 12px; border-radius:var(--radius-sm);">
              <p style="font-size:13px; color:var(--text); line-height:1.5;"><%= msg.content %></p>
              <div style="display:flex; justify-content:space-between; font-size:10px; color:var(--text-muted); margin-top:5px;">
                <span>By: <%= msg.sender ? msg.sender.name : 'Admin' %> (<%= msg.sender ? msg.sender.role : 'System' %>)</span>
                <span><%= new Date(msg.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %> &nbsp;·&nbsp; <%= new Date(msg.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %></span>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Right Side: Contact info -->
  <div>
    <div class="card">
      <div class="card-title" style="margin-bottom:1rem;">Contact Card</div>
      
      <div style="display:flex; flex-direction:column; gap:12px;">
        <div>
          <div style="font-size:0.7rem; color:var(--text-muted); text-transform:uppercase;">Email Address</div>
          <div style="font-size:0.9rem; font-weight:500; word-break:break-all;"><%= teacher.email %></div>
        </div>
        <div>
          <div style="font-size:0.7rem; color:var(--text-muted); text-transform:uppercase;">Mobile Number</div>
          <div style="font-size:0.9rem; font-weight:500; font-family:var(--mono);"><%= teacher.phone || '—' %></div>
        </div>
        <div>
          <div style="font-size:0.7rem; color:var(--text-muted); text-transform:uppercase;">Joined On</div>
          <div style="font-size:0.9rem; font-weight:500; font-family:var(--mono);">
            <%= new Date(teacher.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function openTab(evt, tabId) {
    const tabcontents = document.querySelectorAll(".tab-content");
    tabcontents.forEach(tab => tab.style.display = "none");

    const tablinks = document.querySelectorAll(".tab-btn");
    tablinks.forEach(link => {
      link.classList.remove("btn-primary");
      link.classList.add("btn-ghost");
    });

    document.getElementById(tabId).style.display = "block";
    evt.currentTarget.classList.remove("btn-ghost");
    evt.currentTarget.classList.add("btn-primary");
  }
</script>
