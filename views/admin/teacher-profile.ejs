<%
  layout = 'main';
  title = teacher.name;
  subtitle = `Teacher - ${teacher.rollNumber || 'No Roll Number'}`;
  page = 'users';

  const displayName = (value, fallback = '-') => {
    if (!value) return fallback;
    if (typeof value === 'object') return value.name || value.title || value.code || fallback;
    return value;
  };

  const courseName = item => {
    if (!item) return 'Class';
    return displayName(item.course, item.subject || item.note || 'Class');
  };

  const batchName = item => displayName(item && item.batch, 'Batch not set');
  const classroomName = item => displayName(item && item.classroom, 'Classroom not set');
  const lessonTopics = update => {
    const covered = Array.isArray(update.coveredTopics)
      ? update.coveredTopics.map(topic => topic.title).filter(Boolean)
      : [];
    if (covered.length) return covered;
    if (Array.isArray(update.topics) && update.topics.length) return update.topics.filter(Boolean);
    if (update.content) return String(update.content).split(',').map(topic => topic.trim()).filter(Boolean);
    return [];
  };

  const scheduledSlots = schedules.filter(slot => slot.status === 'scheduled');
  const completedSlots = schedules.filter(slot => slot.status === 'completed');
  const recentUpdates = updates.slice(0, 5);
  const nextSlot = scheduledSlots[0];
  const calendarItems = [
    ...updates.map(update => ({
      date: update.date,
      title: courseName(update),
      batch: batchName(update),
      desc: lessonTopics(update).length ? lessonTopics(update).join(', ') : (update.homework || 'Lesson update posted'),
      type: 'completed'
    })),
    ...schedules.map(slot => ({
      date: slot.date,
      title: courseName(slot),
      batch: batchName(slot),
      desc: `${slot.startTime} - ${slot.endTime} · ${classroomName(slot)}`,
      type: slot.status
    }))
  ].sort((a, b) => String(b.date).localeCompare(String(a.date)));
%>

<div class="teacher-profile-page">
  <div class="teacher-profile-actions">
    <a href="/admin/teachers" class="btn btn-ghost btn-sm">&larr; Back to Teachers</a>
    <a href="/admin/users/<%= teacher._id %>/edit" class="btn btn-primary btn-sm">Edit Teacher Profile</a>
  </div>

  <div class="teacher-profile-hero">
    <button class="avatar-lg profile-image-trigger" type="button" data-profile-image="<%= teacher.profilePic || '' %>" aria-label="View <%= teacher.name %> profile image">
      <% if (teacher.profilePic) { %>
        <img src="<%= teacher.profilePic %>" alt="<%= teacher.name %>">
      <% } else { %>
        <%= teacher.initials %>
      <% } %>
    </button>
    <div class="teacher-profile-identity">
      <p class="eyebrow">Teacher Profile</p>
      <h2 class="profile-name"><%= teacher.name %></h2>
      <div class="teacher-profile-meta">
        <span>Roll <strong><%= teacher.rollNumber || 'Not generated' %></strong></span>
        <span>Domain <strong><%= teacher.subject || 'Not mapped' %></strong></span>
        <span>Qualification <strong><%= teacher.qualification || '-' %></strong></span>
      </div>
    </div>
  </div>

  <div class="two-col teacher-profile-layout">
    <div>
      <div class="teacher-profile-tabs card">
        <button class="btn btn-sm btn-primary tab-btn" onclick="openTab(event, 'schedule')">Overview</button>
        <button class="btn btn-sm btn-ghost tab-btn" onclick="openTab(event, 'updates')">Daily Lesson Logs</button>
        <button class="btn btn-sm btn-ghost tab-btn" onclick="openTab(event, 'curriculum')">Syllabus Progress</button>
        <button class="btn btn-sm btn-ghost tab-btn" onclick="openTab(event, 'messages')">Admin Messenger</button>
      </div>

      <div id="schedule" class="tab-content card teacher-activity-card">
        <div class="card-header">
          <div>
            <div class="card-title">Teacher Activity Overview</div>
            <p class="section-subtitle">Schedules and lesson logs are together so admin does not have to jump around.</p>
          </div>
          <% if (recentUpdates.length) { %>
            <button class="btn btn-ghost btn-sm" type="button" onclick="openTabById('updates')">Open all logs</button>
          <% } %>
        </div>

        <% if (schedules.length === 0 && updates.length === 0) { %>
          <div class="empty-state">
            <p>No classes scheduled or completed for this teacher.</p>
          </div>
        <% } else { %>
          <div class="teacher-profile-stat-grid">
            <div class="stat-card gold">
              <div class="stat-label">Scheduled Slots</div>
              <div class="stat-value"><%= scheduledSlots.length %></div>
            </div>
            <div class="stat-card green">
              <div class="stat-label">Lesson Logs Posted</div>
              <div class="stat-value"><%= updates.length %></div>
            </div>
            <div class="stat-card blue">
              <div class="stat-label">Next Class</div>
              <div class="stat-value teacher-next-class"><%= nextSlot ? nextSlot.date : '-' %></div>
              <% if (nextSlot) { %>
                <div class="td-muted text-xs"><%= nextSlot.startTime %> - <%= nextSlot.endTime %></div>
              <% } %>
            </div>
          </div>

          <div class="teacher-overview-grid">
            <section class="teacher-mini-panel">
              <div class="section-title">Upcoming Schedules</div>
              <% if (scheduledSlots.length === 0) { %>
                <div class="empty-state compact">No upcoming classes scheduled.</div>
              <% } else { %>
                <div class="teacher-mini-list">
                  <% scheduledSlots.slice(0, 5).forEach(slot => { %>
                    <article class="teacher-mini-item">
                      <div>
                        <strong><%= courseName(slot) %></strong>
                        <span><%= batchName(slot) %> · <%= classroomName(slot) %></span>
                      </div>
                      <div class="teacher-mini-time">
                        <strong><%= slot.date %></strong>
                        <span><%= slot.startTime %> - <%= slot.endTime %></span>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>
            </section>

            <section class="teacher-mini-panel">
              <div class="section-title">Recent Daily Lesson Logs</div>
              <% if (recentUpdates.length === 0) { %>
                <div class="empty-state compact">No lesson logs posted yet.</div>
              <% } else { %>
                <div class="teacher-mini-list">
                  <% recentUpdates.forEach(update => { const topics = lessonTopics(update); %>
                    <article class="teacher-mini-item lesson">
                      <div>
                        <strong><%= courseName(update) %></strong>
                        <span><%= batchName(update) %> · <%= update.date %></span>
                        <p><%= topics.length ? topics.slice(0, 2).join(', ') : (update.homework || 'Lesson update posted') %></p>
                      </div>
                      <span class="badge badge-green">Logged</span>
                    </article>
                  <% }) %>
                </div>
              <% } %>
            </section>
          </div>

          <div class="section-title">Full Schedule Timeline</div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Course & Batch</th>
                  <th>Details</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% calendarItems.forEach(item => { %>
                  <tr>
                    <td class="mono text-xs fw-600"><%= item.date %></td>
                    <td>
                      <div class="fw-600"><%= item.title %></div>
                      <div class="td-muted text-xs"><%= item.batch %></div>
                    </td>
                    <td class="text-xs text-muted"><%= item.desc %></td>
                    <td>
                      <% if (item.type === 'completed') { %>
                        <span class="badge badge-green">Class Taken</span>
                      <% } else if (item.type === 'scheduled') { %>
                        <span class="badge badge-gold">Scheduled</span>
                      <% } else { %>
                        <span class="badge badge-red"><%= item.type %></span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <div id="updates" class="tab-content card" style="display:none;">
        <div class="card-header">
          <div>
            <div class="card-title">Daily Lesson Logs</div>
            <p class="section-subtitle">Every class update posted by this teacher, newest first.</p>
          </div>
        </div>

        <% if (updates.length === 0) { %>
          <div class="empty-state">
            <p>No class updates posted by this teacher yet.</p>
          </div>
        <% } else { %>
          <div class="teacher-lesson-list">
            <% updates.forEach(update => { const topics = lessonTopics(update); %>
              <article class="teacher-lesson-card">
                <div class="teacher-lesson-date">
                  <strong><%= update.date %></strong>
                  <span><%= batchName(update) %></span>
                </div>
                <div class="teacher-lesson-body">
                  <div class="teacher-lesson-head">
                    <h3><%= update.title || courseName(update) %></h3>
                    <span class="badge badge-green">Posted</span>
                  </div>
                  <p class="td-muted"><%= courseName(update) %></p>
                  <% if (topics.length) { %>
                    <div class="teacher-topic-chips">
                      <% topics.forEach(topic => { %>
                        <span><%= topic %></span>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <p class="text-xs text-muted">No covered topics were added.</p>
                  <% } %>
                  <div class="teacher-homework-box">
                    <strong>Homework</strong>
                    <p><%= update.homework || 'None assigned' %></p>
                  </div>
                  <% if (update.fileUrl) { %>
                    <a href="<%= update.fileUrl %>" class="btn btn-ghost btn-sm" target="_blank" rel="noopener">View material</a>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div id="curriculum" class="tab-content card" style="display:none;">
        <div class="card-header">
          <div class="card-title">Syllabus Curriculum Tracks</div>
        </div>

        <% if (curricula.length === 0) { %>
          <div class="empty-state">
            <p>No curriculums configured for this teacher.</p>
          </div>
        <% } else { %>
          <% curricula.forEach(curr => { %>
            <%
              const topics = Array.isArray(curr.topics) ? curr.topics : [];
              const total = topics.length;
              const completed = topics.filter(t => t.completed).length;
              const pct = total > 0 ? Math.round((completed / total) * 100) : 0;
            %>
            <div class="teacher-curriculum-card">
              <div class="teacher-curriculum-head">
                <div>
                  <strong><%= courseName(curr) %></strong>
                  <div class="td-muted text-xs">Batch: <%= batchName(curr) %></div>
                </div>
                <span class="badge badge-blue"><%= completed %> / <%= total %> completed</span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill <%= pct === 100 ? 'green' : 'orange' %>" style="width:<%= pct %>%"></div>
              </div>
              <% if (curr.description) { %>
                <p class="text-xs text-muted"><%= curr.description %></p>
              <% } %>
              <div class="teacher-topic-grid">
                <% topics.forEach(topic => { %>
                  <div>
                    <span class="<%= topic.completed ? 'is-complete' : '' %>"><%= topic.name %></span>
                    <span class="badge <%= topic.completed ? 'badge-green' : 'badge-grey' %>"><%= topic.completed ? 'Done' : 'Pending' %></span>
                  </div>
                <% }) %>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <div id="messages" class="tab-content card" style="display:none;">
        <div class="card-header">
          <div class="card-title">Teacher Inbox Notes</div>
        </div>

        <form action="/admin/messages/send" method="POST" class="teacher-message-form">
          <input type="hidden" name="recipientId" value="<%= teacher._id %>">
          <input type="hidden" name="redirect" value="/admin/teachers/<%= teacher._id %>">
          <div class="form-group">
            <label class="form-label" for="msg_content">Send Notification / Message Note</label>
            <textarea id="msg_content" name="content" class="form-control" placeholder="Type notification details or message to show on teacher dashboard..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-sm">Send Note to Teacher</button>
        </form>

        <div class="section-title">Sent Logs</div>
        <% if (messages.length === 0) { %>
          <div class="empty-state compact">No messages sent to this teacher yet.</div>
        <% } else { %>
          <div class="teacher-mini-list">
            <% messages.forEach(msg => { %>
              <article class="teacher-mini-item">
                <div>
                  <strong><%= msg.content %></strong>
                  <span>By <%= msg.sender ? msg.sender.name : 'Admin' %> · <%= new Date(msg.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></span>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <aside class="teacher-contact-stack">
      <div class="card">
        <div class="card-title">Contact Card</div>
        <div class="teacher-contact-list">
          <div>
            <span>Email Address</span>
            <strong><%= teacher.email %></strong>
          </div>
          <div>
            <span>Mobile Number</span>
            <strong><%= teacher.phone || '-' %></strong>
          </div>
          <div>
            <span>Joined On</span>
            <strong><%= new Date(teacher.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></strong>
          </div>
          <div>
            <span>Completed Schedules</span>
            <strong><%= completedSlots.length %></strong>
          </div>
        </div>
      </div>
    </aside>
  </div>
</div>

<script>
  function openTab(evt, tabId) {
    openTabById(tabId);
    evt.currentTarget.classList.remove('btn-ghost');
    evt.currentTarget.classList.add('btn-primary');
  }

  function openTabById(tabId) {
    document.querySelectorAll('.tab-content').forEach(tab => {
      tab.style.display = tab.id === tabId ? 'block' : 'none';
    });

    document.querySelectorAll('.tab-btn').forEach(button => {
      const target = button.getAttribute('onclick') || '';
      const isActive = target.includes(`'${tabId}'`);
      button.classList.toggle('btn-primary', isActive);
      button.classList.toggle('btn-ghost', !isActive);
    });
  }
</script>
