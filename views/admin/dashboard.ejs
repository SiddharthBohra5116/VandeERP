<%
  layout = 'main';
  title = 'Admin Dashboard';
  subtitle = 'Overview of Academy operations';
  page = 'dashboard';
%>

<!-- Greeting Header -->
<div style="display:flex; align-items:flex-end; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:1.25rem;">
  <div>
    <p class="student-kicker" style="margin-bottom:0.35rem;">Academy operations</p>
    <h2 id="dashboardGreeting" class="dashboard-greeting" style="margin:0;">Welcome back!</h2>
  </div>
  <div class="d-flex gap-1" style="flex-wrap:wrap;">
    <a href="/admin/users/create?role=student" class="btn btn-primary btn-sm">Add student</a>
    <a href="/admin/fees" class="btn btn-ghost btn-sm">Record payment</a>
    <a href="/admin/schedules" class="btn btn-ghost btn-sm">Plan classes</a>
  </div>
</div>

<!-- Stats Grid -->
<div class="stats-grid">
  <a href="/admin/fees" class="stat-card gold">
    <div class="stat-label">Today's Fee Collections</div>
    <div class="stat-value">₹<%= stats.todayCollections.toLocaleString('en-IN') %></div>
    <div class="stat-sub">Payments collected today</div>
  </a>
  <a href="/admin/schedules" class="stat-card blue">
    <div class="stat-label">Today's Scheduled Classes</div>
    <div class="stat-value"><%= stats.todayCompletedCount %> / <%= stats.todayScheduledCount %></div>
    <div class="stat-sub">Completed / Total scheduled</div>
  </a>
  <a href="/admin/leads?status=joining_interested" class="stat-card orange">
    <div class="stat-label">Leads Ready to Convert</div>
    <div class="stat-value"><%= stats.readyLeadsCount %></div>
    <div class="stat-sub">Converted status pending</div>
  </a>
  <a href="/admin/students?attendance=low" class="stat-card red">
    <div class="stat-label">At-Risk Students</div>
    <div class="stat-value"><%= stats.atRiskCount %></div>
    <div class="stat-sub">Attendance below 75%</div>
  </a>
  <a href="/admin/holidays-leaves" class="stat-card purple">
    <div class="stat-label">Pending Leave Requests</div>
    <div class="stat-value"><%= stats.pendingLeavesCount %></div>
    <div class="stat-sub">Awaiting admin approval</div>
  </a>
  <a href="/admin/students" class="stat-card green">
    <div class="stat-label">Ungraded Submissions</div>
    <div class="stat-value"><%= stats.ungradedSubmissionsCount %></div>
    <div class="stat-sub">Awaiting marks evaluation</div>
  </a>
</div>

<!-- Password Reset Requests -->
<% if (typeof resetRequests !== 'undefined' && resetRequests && resetRequests.length > 0) { %>
<div class="card" style="margin-bottom: 1.5rem; border-color: var(--gold-border); background: linear-gradient(180deg, rgba(255,204,0,0.03) 0%, rgba(0,0,0,0) 100%);">
  <div class="card-header card-header--divided">
    <div class="card-title" style="color: var(--gold);">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      Pending Password Reset Requests
    </div>
    <span class="badge badge-gold"><%= resetRequests.length %> requested</span>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>User</th>
          <th>Role</th>
          <th>Phone</th>
          <th class="td-actions">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% resetRequests.forEach(reqUser => { %>
          <tr data-reset-request-row="<%= reqUser._id %>">
            <td>
              <div class="td-name"><%= reqUser.name %></div>
              <div class="td-muted text-sm"><%= reqUser.email %></div>
            </td>
            <td>
              <span class="badge <%= reqUser.role === 'admin' ? 'badge-gold' : reqUser.role === 'teacher' ? 'badge-blue' : reqUser.role === 'counsellor' ? 'badge-orange' : 'badge-grey' %>">
                <%= reqUser.role %>
              </span>
            </td>
            <td class="mono text-sm"><%= reqUser.phone || '—' %></td>
            <td class="td-actions">
              <div class="d-flex gap-1">
                <button
                  type="button"
                  class="btn btn-primary btn-sm reset-password-btn"
                  data-user-id="<%= reqUser._id %>"
                  data-user-name="<%= reqUser.name %>"
                  data-user-phone="<%= reqUser.phone || '' %>">
                  Reset Password
                </button>
                <form action="/admin/users/<%= reqUser._id %>/dismiss-reset" method="POST" class="form-inline">
                  <input type="hidden" name="redirect" value="/admin/dashboard?updated=1">
                  <button type="submit" class="btn btn-ghost btn-sm">
                    Dismiss
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<div class="grid-2">
  <!-- Recent Students -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">Recent Admissions</div>
      <a href="/admin/users?role=student" class="btn btn-ghost btn-sm">All Students</a>
    </div>
    
    <% if (recentStudents.length === 0) { %>
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        <p>No student admissions yet.</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Course</th>
              <th>Batch</th>
            </tr>
          </thead>
          <tbody>
            <% recentStudents.forEach(student => { %>
              <tr style="cursor:pointer;" onclick="if(window.AppSoftNav){window.AppSoftNav.navigateTo('/admin/students/<%= student._id %>')}else{window.location.href='/admin/students/<%= student._id %>'}">
                <td class="td-name">
                  <%= student.user && student.user.name ? student.user.name : 'Unknown Student' %>
                  <div class="td-muted text-xs mono"><%= student.rollNumber || 'ID not generated' %></div>
                </td>
                <td><span class="badge badge-orange"><%= student.course && student.course.name ? student.course.name : '—' %></span></td>
                <td class="td-muted"><%= student.batch && student.batch.name ? student.batch.name : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Hot Leads -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">Leads requiring Follow-up</div>
      <a href="/admin/leads" class="btn btn-ghost btn-sm">All Leads</a>
    </div>
    
    <% if (hotLeads.length === 0) { %>
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/></svg>
        <p>No active follow-ups due.</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Assigned To</th>
              <th>Follow-up</th>
            </tr>
          </thead>
          <tbody>
            <% hotLeads.forEach(lead => { %>
              <% const isOverdue = lead.followUpDate && new Date(lead.followUpDate) < new Date(); %>
              <tr>
                <td class="td-name">
                  <div><%= lead.name %></div>
                  <div class="td-muted text-sm" style="font-family: monospace;"><%= lead.phone %></div>
                </td>
                <td><%= lead.assignedTo ? lead.assignedTo.name : 'Unassigned' %></td>
                <td <%= isOverdue ? 'style="color: var(--red); font-weight: bold;"' : '' %>>
                  <%= lead.followUpDate ? new Date(lead.followUpDate).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) : '—' %>
                  <%= isOverdue ? '⚠️' : '' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/admin-password-reset-modal', { passwordResetRedirect: '/admin/dashboard' }) %>
