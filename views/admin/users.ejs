<%
  layout = 'main';
  const roleName = typeof roleActive !== 'undefined' ? roleActive.charAt(0).toUpperCase() + roleActive.slice(1) : 'User';
  title = typeof roleActive !== 'undefined' ? `Manage ${roleName}s` : 'Manage Users';
  subtitle = typeof roleActive !== 'undefined' ? `Create and manage credentials for academy ${roleActive}s` : 'Create and manage credentials for students, teachers, and counsellors';
  page = typeof page !== 'undefined' ? page : 'users';
%>

<div class="card" style="padding: 1rem 1.25rem; margin-bottom: 1.25rem;">
  <form method="GET" action="<%= typeof roleActive !== 'undefined' ? '/admin/' + roleActive + 's' : '/admin/users' %>" class="filter-bar" style="margin: 0;">
    <input type="text" name="search" class="form-control" placeholder="Search..." value="<%= filter.search || '' %>" onchange="this.form.submit()">
    
    <% if (typeof roleActive === 'undefined') { %>
      <select name="role" class="form-control" onchange="this.form.submit()">
        <option value="">All Roles</option>
        <option value="student" <%= filter.role === 'student' ? 'selected' : '' %>>Student</option>
        <option value="teacher" <%= filter.role === 'teacher' ? 'selected' : '' %>>Teacher</option>
        <option value="counsellor" <%= filter.role === 'counsellor' ? 'selected' : '' %>>Counsellor</option>
        <option value="admin" <%= filter.role === 'admin' ? 'selected' : '' %>>Admin</option>
      </select>
    <% } %>

    <% if (typeof roleActive !== 'undefined' && roleActive === 'student') { %>
      <select name="attendance" class="form-control" onchange="this.form.submit()">
        <option value="">All Attendance Tiers</option>
        <option value="low" <%= filter.attendance === 'low' ? 'selected' : '' %>>Low (< 75%)</option>
        <option value="medium" <%= filter.attendance === 'medium' ? 'selected' : '' %>>Medium (75% - 85%)</option>
        <option value="high" <%= filter.attendance === 'high' ? 'selected' : '' %>>High (> 85%)</option>
        <option value="not_marked_today" <%= filter.attendance === 'not_marked_today' ? 'selected' : '' %>>Not Marked Today</option>
      </select>
    <% } %>
    
    <a href="<%= typeof roleActive !== 'undefined' ? '/admin/' + roleActive + 's' : '/admin/users' %>" class="btn btn-ghost btn-sm">Clear</a>
    
    <a href="/admin/users/create<%= typeof roleActive !== 'undefined' ? '?role=' + roleActive : '' %>" class="btn btn-primary btn-sm" style="margin-left: auto;">+ Add <%= roleName %></a>
  </form>
</div>

<div id="results-container" class="card">
  <% if (users.length === 0) { %>
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      <p>No users found matching the filter criteria.</p>
    </div>
  <% } else { %>
    <% if (typeof roleActive !== 'undefined' && roleActive === 'student') { %>
      <form id="bulkKycForm" action="/admin/students/bulk-verify-id" method="POST"></form>
      <div style="display:flex; justify-content:flex-end; gap:0.5rem; margin-bottom:0.75rem; flex-wrap:wrap;">
        <button type="button" class="btn btn-ghost btn-sm" onclick="toggleAllKycChecks(this)">Select Pending KYC</button>
        <button type="submit" form="bulkKycForm" class="btn btn-primary btn-sm">Bulk Verify Selected IDs</button>
      </div>
    <% } %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <% if (typeof roleActive !== 'undefined' && roleActive === 'student') { %>
              <th style="width:42px;">Select</th>
            <% } %>
            <th>User</th>
            <th>Role</th>
            <th>Phone</th>
            <th>Role Specifics</th>
            <% if (typeof roleActive !== 'undefined' && roleActive === 'student') { %>
              <th>Attendance</th>
              <th>KYC Status</th>
            <% } %>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr>
              <% if (typeof roleActive !== 'undefined' && roleActive === 'student') { %>
                <td>
                  <% if (u.studentProfile && u.idProof && !u.idVerified) { %>
                    <input type="checkbox" form="bulkKycForm" name="studentIds" value="<%= u.studentProfile._id %>" class="kyc-check">
                  <% } else { %>
                    <span class="td-muted">—</span>
                  <% } %>
                </td>
              <% } %>
              <td>
                <div class="d-flex align-center gap-2">
                  <div class="avatar" style="width:34px; height:34px; border-radius:8px;">
                    <% if (u.profilePic) { %>
                      <img src="<%= u.profilePic %>" alt="<%= u.name %>">
                    <% } else { %>
                      <%= u.initials %>
                    <% } %>
                  </div>
                  <div>
                    <div class="td-name">
                      <% if (u.role === 'student' && u.studentProfile) { %>
                        <a href="/admin/students/<%= u.studentProfile._id %>" style="color:var(--gold);"><%= u.name %></a>
                      <% } else if (u.role === 'teacher') { %>
                        <a href="/admin/teachers/<%= u._id %>" style="color:var(--gold);"><%= u.name %></a>
                      <% } else if (u.role === 'counsellor') { %>
                        <a href="/admin/counsellors/<%= u._id %>" style="color:var(--gold);"><%= u.name %></a>
                      <% } else { %>
                        <%= u.name %>
                      <% } %>
                    </div>
                    <div class="td-muted text-sm"><%= u.email %></div>
                    <% if (u.lastLoginAt) { %>
                      <% 
                        const timeDiff = new Date() - new Date(u.lastLoginAt);
                        const mins = Math.floor(timeDiff / (1000 * 60));
                        const hrs = Math.floor(mins / 60);
                        const days = Math.floor(hrs / 24);
                        let timeStr = 'Just now';
                        if (days > 0) timeStr = `${days} day${days > 1 ? 's' : ''} ago`;
                        else if (hrs > 0) timeStr = `${hrs} hr${hrs > 1 ? 's' : ''} ago`;
                        else if (mins > 0) timeStr = `${mins} min${mins > 1 ? 's' : ''} ago`;
                      %>
                      <div style="font-size: 0.68rem; color: var(--text-muted); margin-top: 2px;">Active: <%= timeStr %></div>
                    <% } else { %>
                      <div style="font-size: 0.68rem; color: var(--text-muted); margin-top: 2px;">Active: Never</div>
                    <% } %>
                  </div>
                </div>
              </td>
              <td>
                <span class="badge <%= u.role === 'admin' ? 'badge-gold' : u.role === 'teacher' ? 'badge-blue' : u.role === 'counsellor' ? 'badge-orange' : 'badge-grey' %>">
                  <%= u.role %>
                </span>
              </td>
              <td class="mono text-sm"><%= u.phone || '—' %></td>
              <td>
               <% if (u.role === 'student') { %>
                  <div class="text-sm">Course: <strong><%= u.studentProfile && u.studentProfile.course ? (u.studentProfile.course.name || u.studentProfile.course) : '—' %></strong></div>
                  <div class="td-muted text-xs">Batch: <%= u.studentProfile && u.studentProfile.batch ? (u.studentProfile.batch.name || u.studentProfile.batch) : '—' %></div>
                <% } else if (u.role === 'teacher') { %>
                  <div class="text-sm">Subject: <strong><%= u.teacherProfile && u.teacherProfile.subjects && u.teacherProfile.subjects.length > 0 ? u.teacherProfile.subjects[0] : '—' %></strong></div>
                  <div class="td-muted text-xs">Qual: <%= u.qualification || '—' %></div>
                <% } else { %>
                  <span class="td-muted">—</span>
                <% } %>
              </td>
              <% if (typeof roleActive !== 'undefined' && roleActive === 'student') { %>
                <td>
                  <% 
                    const pct = typeof u.attendancePct !== 'undefined' ? u.attendancePct : 100;
                    const pctBadge = pct < 75 ? 'badge-red' : pct >= 85 ? 'badge-green' : 'badge-gold';
                  %>
                  <span class="badge <%= pctBadge %>" style="font-family: var(--mono);"><%= pct %>%</span>
                  <% if (!u.isMarkedToday) { %>
                    <span class="badge badge-grey" style="font-size: 8px; padding: 1px 3px; display: block; margin-top: 4px; width: max-content;">Unmarked today</span>
                  <% } %>
                </td>
                <td>
                  <% 
                    const hasKycDocs = u.idProof && u.fatherName && u.guardianPhone;
                    const kycBadgeClass = u.idVerified ? 'badge-green' : (hasKycDocs ? 'badge-gold' : 'badge-red');
                    const kycLabel = u.idVerified ? 'Verified' : (hasKycDocs ? 'Ready to verify' : 'Pending');
                  %>
                  <span class="badge <%= kycBadgeClass %>"><%= kycLabel %></span>
                </td>
              <% } %>
              <td>
                <% 
                  const statusVal = u.status || (u.isActive ? 'active' : 'inactive');
                  const statusBadgeClass = {
                    active: 'badge-green',
                    inactive: 'badge-grey',
                    drop: 'badge-red',
                    complete: 'badge-gold'
                  }[statusVal];
                %>
                <form action="/admin/users/<%= u._id %>/toggle" method="POST" style="margin:0; padding:0;">
                  <button type="submit" class="badge <%= statusBadgeClass %>" style="border: none; cursor: pointer; padding: 0.25rem 0.55rem; font-family: inherit;" title="Click to toggle status">
                    <%= statusVal %>
                  </button>
                </form>
              </td>
              <td>
                <div class="d-flex gap-1">
                  <a href="/admin/users/<%= u._id %>/edit" class="btn btn-ghost btn-xs">Edit</a>
                  <button
                    type="button"
                    class="btn btn-ghost btn-xs reset-password-btn"
                    data-user-id="<%= u._id %>"
                    data-user-name="<%= u.name %>"
                    data-user-phone="<%= u.phone || '' %>">
                    Reset Password
                  </button>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% if (typeof pagination !== 'undefined' && pagination && pagination.pages > 1) { %>
      <% const pageUrl = (p) => {
        const params = new URLSearchParams(filter || {});
        params.set('page', p);
        params.set('limit', pagination.limit);
        return '?' + params.toString();
      }; %>
      <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap; margin-top:1rem; padding-top:1rem; border-top:1px solid var(--border);">
        <div class="td-muted text-sm">
          Showing page <strong><%= pagination.page %></strong> of <strong><%= pagination.pages %></strong> · <%= pagination.total %> records
        </div>
        <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
          <a class="btn btn-ghost btn-sm <%= pagination.page <= 1 ? 'disabled' : '' %>" href="<%= pagination.page <= 1 ? '#' : pageUrl(pagination.page - 1) %>">Previous</a>
          <% for (let p = Math.max(1, pagination.page - 2); p <= Math.min(pagination.pages, pagination.page + 2); p++) { %>
            <a class="btn btn-sm <%= p === pagination.page ? 'btn-primary' : 'btn-ghost' %>" href="<%= pageUrl(p) %>"><%= p %></a>
          <% } %>
          <a class="btn btn-ghost btn-sm <%= pagination.page >= pagination.pages ? 'disabled' : '' %>" href="<%= pagination.page >= pagination.pages ? '#' : pageUrl(pagination.page + 1) %>">Next</a>
        </div>
      </div>
    <% } %>
  <% } %>
</div>

<%- include('../partials/admin-password-reset-modal', { passwordResetRedirect: '/admin/users' }) %>
<script src="/js/instant-filter.js"></script>
<script>
  function toggleAllKycChecks(button) {
    const checks = Array.from(document.querySelectorAll('.kyc-check'));
    if (checks.length === 0) return;

    const shouldCheck = checks.some(check => !check.checked);
    checks.forEach(check => {
      check.checked = shouldCheck;
    });

    if (button) {
      button.textContent = shouldCheck ? 'Clear Selection' : 'Select Pending KYC';
    }
  }
</script>
