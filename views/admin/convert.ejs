<%
  layout = 'main';
  title = `Convert Lead: ${lead.name}`;
  subtitle = 'Establish student portal account & fee ledger';
  page = 'leads';
  topbarActions = `<a href="/admin/leads/${lead._id}" class="btn btn-ghost btn-sm">&larr; Back</a>`;
%>

<div style="max-width:640px;">
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="card" style="border-color:var(--red); background:rgba(239,68,68,0.05); margin-bottom:20px; padding:12px 16px; color:var(--red); font-size:13px; font-weight:500; border-left:4px solid var(--red);">
      ❌ <%= error %>
    </div>
  <% } %>

  <div class="card" style="border-color:rgba(34,197,94,0.25); background: linear-gradient(180deg, rgba(34,197,94,0.02) 0%, rgba(0,0,0,0) 100%); margin-bottom:20px; padding:16px 20px;">
    <div style="display:flex; gap:12px; align-items:center;">
      <div style="font-size:24px;">🎓</div>
      <div>
        <div style="font-size:14px; font-weight:600; color:var(--green);">Converting Lead to Student Profile (Administrator)</div>
        <div style="font-size:12px; color:var(--text-muted); margin-top:2px;">
          This will generate an active student account in the registry and initialize their financial record.
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <form action="/admin/leads/<%= lead._id %>/convert" method="POST">

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Student Name *</label>
          <input type="text" name="name" class="form-control" value="<%= lead.name %>" required>
        </div>
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Phone Contact *</label>
          <input type="tel" name="phone" class="form-control" value="<%= lead.phone %>" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Portal Login Email *</label>
          <input type="email" name="email" class="form-control" value="<%= lead.email || '' %>" placeholder="student@email.com" required>
        </div>
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Portal Password *</label>
          <input type="text" name="password" class="form-control" placeholder="Minimum 8 characters" required>
          <div class="form-hint">Student can reset this on first login.</div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Selected Course *</label>
          <select name="course" class="form-control" required>
            <% ['Video Editing','Digital Marketing','Both'].forEach(c => { %>
              <option value="<%= c %>" <%= lead.course === c ? 'selected' : '' %>><%= c %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Assign Roster Batch *</label>
          <select id="batch_select" name="batch" class="form-control" onchange="toggleCustomBatch()">
            <% if (batches && batches.length > 0) { %>
              <% batches.forEach(b => { %>
                <option value="<%= b %>"><%= b %></option>
              <% }); %>
            <% } %>
            <option value="">-- Create New Batch --</option>
          </select>
        </div>
      </div>

      <div class="form-row" id="custom_batch_container" <%= `style="display: ${(batches && batches.length > 0) ? 'none' : 'block'};"` %>>
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">New Batch Name *</label>
          <input type="text" id="customBatch" name="customBatch" class="form-control" placeholder="e.g. DM-03PM-A2" <%= (batches && batches.length > 0) ? '' : 'required' %>>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Total Invoice Fees (₹) *</label>
          <input type="number" id="fees_total" name="fees_total" class="form-control" placeholder="30000" required min="0" oninput="checkDownpayment()">
        </div>
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Initial Down Payment (₹)</label>
          <input type="number" id="fees_paid" name="fees_paid" class="form-control" placeholder="0" value="0" min="0" oninput="checkDownpayment()">
        </div>
      </div>

      <div id="downpayment_warning" style="display:none; color:var(--orange); font-size:12px; font-weight:500; margin-bottom:12px; border-left:2px solid var(--orange); padding-left:8px;">
        ⚠️ Warning: Paid amount is less than the standard 50% down payment requirement. Admin authorization will bypass this check.
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Assign Primary Teacher *</label>
          <select name="teacherId" class="form-control" required>
            <option value="">-- Select Teacher --</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t._id %>"><%= t.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" style="font-size: 10px;">Registration/Enrollment Date</label>
          <input type="date" name="enrollmentDate" class="form-control"
            value="<%= new Date().toISOString().split('T')[0] %>">
        </div>
      </div>

      <!-- Day 4: Installment configuration section -->
      <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px dashed var(--border);">
        <div style="font-size: 11px; font-weight: 700; color: var(--gold); text-transform: uppercase; margin-bottom: 0.75rem; display: flex; justify-content: space-between; align-items: center;">
          <span>Define Fee Installments</span>
          <button type="button" class="btn btn-ghost btn-xs" onclick="addInstallmentRow()">+ Add Installment</button>
        </div>
        <div id="installments_container">
          <!-- Initial template row 1 -->
          <div class="form-row installment-row" style="margin-bottom: 0.5rem;">
            <div class="form-group" style="flex: 2;">
              <label class="form-label" style="font-size: 9px;">Name</label>
              <input type="text" name="instName[]" class="form-control form-control-sm" value="Down Payment (50%)" required>
            </div>
            <div class="form-group" style="flex: 1.5;">
              <label class="form-label" style="font-size: 9px;">Amount (₹)</label>
              <input type="number" name="instAmount[]" class="form-control form-control-sm" placeholder="0" required>
            </div>
            <div class="form-group" style="flex: 2;">
              <label class="form-label" style="font-size: 9px;">Due Date</label>
              <input type="date" name="instDueDate[]" class="form-control form-control-sm" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            <div style="display: flex; align-items: flex-end; padding-bottom: 6px;">
              <button type="button" class="btn btn-red btn-xs" style="padding: 4px 8px;" onclick="removeInstallmentRow(this)">Delete</button>
            </div>
          </div>
        </div>
        <div class="form-hint" style="margin-top: 0.25rem; color: var(--text-muted);">
          Leave empty or delete all rows to automatically generate default 50% / 25% / 25% installments.
        </div>
      </div>

      <div style="display:flex; gap:10px; justify-content:flex-end; padding-top:12px; border-top:1px solid var(--border); margin-top:16px;">
        <a href="/admin/leads/<%= lead._id %>" class="btn btn-ghost">Cancel</a>
        <button type="submit" class="btn btn-success">Confirm & Enroll Student</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleCustomBatch() {
    const select = document.getElementById('batch_select');
    const container = document.getElementById('custom_batch_container');
    const input = document.getElementById('customBatch');
    if (select.value === '') {
      container.style.display = 'block';
      input.setAttribute('required', 'required');
    } else {
      container.style.display = 'none';
      input.removeAttribute('required');
    }
  }

  function checkDownpayment() {
    const total = Number(document.getElementById('fees_total').value) || 0;
    const paid = Number(document.getElementById('fees_paid').value) || 0;
    const warning = document.getElementById('downpayment_warning');
    if (total > 0 && paid < total * 0.5) {
      warning.style.display = 'block';
    } else {
      warning.style.display = 'none';
    }
  }

  function addInstallmentRow() {
    const container = document.getElementById('installments_container');
    const todayStr = new Date().toISOString().split('T')[0];
    const row = document.createElement('div');
    row.className = 'form-row installment-row';
    row.style.marginBottom = '0.5rem';
    row.innerHTML = `
      <div class="form-group" style="flex: 2;">
        <label class="form-label" style="font-size: 9px;">Name</label>
        <input type="text" name="instName[]" class="form-control form-control-sm" placeholder="e.g. Month 1" required>
      </div>
      <div class="form-group" style="flex: 1.5;">
        <label class="form-label" style="font-size: 9px;">Amount (₹)</label>
        <input type="number" name="instAmount[]" class="form-control form-control-sm" placeholder="0" required>
      </div>
      <div class="form-group" style="flex: 2;">
        <label class="form-label" style="font-size: 9px;">Due Date</label>
        <input type="date" name="instDueDate[]" class="form-control form-control-sm" value="${todayStr}" required>
      </div>
      <div style="display: flex; align-items: flex-end; padding-bottom: 6px;">
        <button type="button" class="btn btn-red btn-xs" style="padding: 4px 8px;" onclick="removeInstallmentRow(this)">Delete</button>
      </div>
    `;
    container.appendChild(row);
  }

  function removeInstallmentRow(btn) {
    const row = btn.closest('.installment-row');
    if (row) {
      row.remove();
    }
  }
</script>
