<%
  layout = 'main';
  title = `Convert Lead: ${lead.name}`;
  subtitle = 'Create student account and initialize fee ledger';
  page = 'leads';
%>

<div class="convert-page">
  <div class="convert-hero">
    <div>
      <div class="convert-kicker">Lead Conversion</div>
      <h2>Enroll <%= lead.name %> as a student</h2>
      <p>Create the portal account, assign course and batch, then generate the fee ledger in one step.</p>
    </div>
    <a href="/admin/leads/<%= lead._id %>" class="btn btn-ghost btn-sm">Back to Lead</a>
  </div>

  <% if (typeof error !== 'undefined' && error && String(error).trim() && String(error).trim() !== '1') { %>
    <div class="convert-alert convert-alert-error">
      <strong>Could not convert lead.</strong>
      <span><%= error %></span>
    </div>
  <% } %>

  <div class="convert-summary">
    <div class="convert-summary-item">
      <span>Lead</span>
      <strong><%= lead.name %></strong>
    </div>
    <div class="convert-summary-item">
      <span>Phone</span>
      <strong><%= lead.phone || 'Not set' %></strong>
    </div>
    <div class="convert-summary-item">
      <span>Suggested Course</span>
      <strong><%= lead.interestedCourse && lead.interestedCourse.name ? lead.interestedCourse.name : 'Select below' %></strong>
    </div>
  </div>

  <form action="/admin/leads/<%= lead._id %>/convert" method="POST" class="convert-card" data-no-soft-nav="true" data-native-submit="true" onsubmit="return lockConversionSubmit(this)">
    <section class="convert-section">
      <div class="convert-section-head">
        <div>
          <h3>Portal Account</h3>
          <p>The student will be forced to set a new password on first login.</p>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Student Name *</label>
          <input type="text" name="name" class="form-control" value="<%= lead.name %>" required>
        </div>
        <div class="form-group">
          <label class="form-label">Phone Contact *</label>
          <input type="tel" name="phone" class="form-control" value="<%= lead.phone %>" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Portal Login Email *</label>
          <input type="email" name="email" class="form-control" value="<%= lead.email || '' %>" placeholder="student@email.com" required>
        </div>
        <div class="form-group">
          <label class="form-label">Temporary Password *</label>
          <input type="text" name="password" class="form-control" placeholder="Minimum 8 characters" minlength="8" required>
          <div class="form-hint">This is only for first login. The student must replace it immediately.</div>
        </div>
      </div>
    </section>

    <section class="convert-section">
      <div class="convert-section-head">
        <div>
          <h3>Course Assignment</h3>
          <p>Assign the student to a course and primary teacher.</p>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Selected Course *</label>
          <select id="course_select" name="course" class="form-control" required>
            <% if (typeof courses !== 'undefined' && courses && courses.length > 0) { %>
              <% courses.forEach(course => { %>
                <option value="<%= course._id || course.name %>" <%= (lead.interestedCourse && String(lead.interestedCourse._id || '') === String(course._id || '')) ? 'selected' : '' %>><%= course.name %></option>
              <% }); %>
            <% } else { %>
              <% ['Video Editing','Digital Marketing','Both'].forEach(c => { %>
                <option value="<%= c %>" <%= (lead.interestedCourse && lead.interestedCourse.name === c) ? 'selected' : '' %>><%= c %></option>
              <% }); %>
            <% } %>
          </select>
        </div>
        <div class="form-group" style="display:none" aria-hidden="true" hidden>
          <label class="form-label">Assign Roster Batch *</label>
          <select id="batch_select" name="batch" class="form-control" onchange="toggleCustomBatch()">
            <% if (batches && batches.length > 0) { %>
              <% batches.forEach(b => { %>
                <% const batchValue = b && b._id ? b._id : b; const batchLabel = b && b.name ? b.name : b; %>
                <option value="<%= batchValue %>"><%= batchLabel %></option>
              <% }); %>
            <% } %>
            <option value="">Create New Batch</option>
          </select>
        </div>
      </div>

      <div class="form-row" id="custom_batch_container" style="display:none" aria-hidden="true" hidden>
        <div class="form-group">
          <label class="form-label">New Batch Name *</label>
          <input type="text" id="customBatch" name="customBatch" class="form-control" placeholder="e.g. DM-03PM-A2">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Assign Primary Teacher *</label>
          <select id="teacher_select" name="teacherId" class="form-control" required>
            <option value="">Select Teacher</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t._id %>"><%= t.name %></option>
            <% }); %>
          </select>
          <div class="form-hint">Choose the teacher responsible for this course.</div>
        </div>
        <div class="form-group">
          <label class="form-label">Registration Date</label>
          <input type="date" name="enrollmentDate" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
        </div>
      </div>
    </section>

    <section class="convert-section">
      <div class="convert-section-head">
        <div>
          <h3>Fee Setup</h3>
          <p>Set the invoice amount, initial payment, and installment schedule.</p>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Total Invoice Fees (Rs.) *</label>
          <input type="number" id="fees_total" name="fees_total" class="form-control" placeholder="30000" required min="0" oninput="checkDownpayment()">
        </div>
        <div class="form-group">
          <label class="form-label">Initial Down Payment (Rs.)</label>
          <input type="number" id="fees_paid" name="fees_paid" class="form-control" placeholder="0" value="0" min="0" oninput="checkDownpayment()">
        </div>
      </div>

      <div class="fee-live-summary">
        <div>
          <span>Opening Payment</span>
          <strong id="suggested_downpayment">Rs. 0</strong>
        </div>
        <div>
          <span>Balance After Payment</span>
          <strong id="balance_due">Rs. 0</strong>
        </div>
        <div>
          <span>Default Plan</span>
          <strong>50 / 25 / 25</strong>
        </div>
      </div>

      <div class="installment-panel">
        <div class="installment-panel-head">
          <div>
            <h4>Fee Installments</h4>
            <p>Use one installment for full payment, or add/remove rows for any custom schedule.</p>
          </div>
          <button type="button" class="btn btn-ghost btn-xs" onclick="addInstallmentRow()">Add Installment</button>
        </div>

        <div id="installments_container">
          <div class="installment-row">
            <div class="form-group" data-label="Name">
              <input type="text" name="instName[]" class="form-control form-control-sm" value="Down Payment (50%)" required>
            </div>
            <div class="form-group" data-label="Amount (Rs.)">
              <input type="number" name="instAmount[]" class="form-control form-control-sm" placeholder="0" required>
            </div>
            <div class="form-group" data-label="Due Date">
              <input type="date" name="instDueDate[]" class="form-control form-control-sm" value="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            <button type="button" class="btn btn-red btn-xs" onclick="removeInstallmentRow(this)">Delete</button>
          </div>
        </div>
      </div>
    </section>

    <div class="convert-actions">
      <a href="/admin/leads/<%= lead._id %>" class="btn btn-ghost">Cancel</a>
      <button type="submit" class="btn btn-success">Confirm & Enroll Student</button>
    </div>
  </form>
</div>

<script>
  const courseOptions = <%- JSON.stringify((courses || []).map(course => ({
    id: String(course._id || course.name || ''),
    name: course.name || String(course),
    fees: Number(course.fees || 0),
    durationMonths: Number(course.durationMonths || 3)
  }))).replace(/</g, '\\u003c') %>;

  const batchOptions = <%- JSON.stringify((batches || []).map(batch => {
    if (batch && batch._id) {
      return {
        id: String(batch._id),
        name: batch.name || '',
        courseId: String(batch.courseId || ''),
        courseName: batch.courseName || '',
        teacherProfileId: String(batch.teacherProfileId || ''),
        teacherProfileIds: (batch.teacherProfileIds || []).map(String),
        teacherName: batch.teacherName || ''
      };
    }
    return {
      id: String(batch || ''),
      name: String(batch || ''),
      courseId: '',
      courseName: '',
      teacherProfileId: '',
      teacherProfileIds: [],
      teacherName: ''
    };
  })).replace(/</g, '\\u003c') %>;

  const teacherOptions = <%- JSON.stringify((teachers || []).map(teacher => ({
    id: String(teacher._id || ''),
    name: teacher.name || '',
    courseIds: (teacher.courseIds || []).map(String)
  }))).replace(/</g, '\\u003c') %>;

  const formatINR = (value) => `Rs. ${Math.max(0, Math.round(Number(value) || 0)).toLocaleString('en-IN')}`;

  function lockConversionSubmit(form) {
    if (form.dataset.submitting === 'true') return false;
    form.dataset.submitting = 'true';
    const button = form.querySelector('[type="submit"]');
    if (button) {
      button.disabled = true;
      button.textContent = 'Enrolling...';
    }
    setTimeout(() => HTMLFormElement.prototype.submit.call(form), 0);
    return false;
  }

  function selectedCourse() {
    const value = document.getElementById('course_select').value;
    return courseOptions.find(course => course.id === value || course.name === value) || null;
  }

  function selectedBatch() {
    const value = document.getElementById('batch_select').value;
    return batchOptions.find(batch => batch.id === value || batch.name === value) || null;
  }

  function filterBatchesForCourse() {
    const course = selectedCourse();
    const batchSelect = document.getElementById('batch_select');
    const currentValue = batchSelect.value;
    const matchingBatches = batchOptions.filter(batch => {
      if (!course || !batch.courseId) return true;
      return batch.courseId === course.id || batch.courseName === course.name;
    });

    batchSelect.innerHTML = '';
    matchingBatches.forEach(batch => {
      const option = document.createElement('option');
      option.value = batch.id || batch.name;
      option.textContent = batch.name;
      batchSelect.appendChild(option);
    });

    const createOption = document.createElement('option');
    createOption.value = '';
    createOption.textContent = 'Create New Batch';
    batchSelect.appendChild(createOption);

    if (matchingBatches.some(batch => batch.id === currentValue || batch.name === currentValue)) {
      batchSelect.value = currentValue;
    } else if (matchingBatches.length > 0) {
      batchSelect.value = matchingBatches[0].id || matchingBatches[0].name;
    } else {
      batchSelect.value = '';
    }
  }

  function syncFeesFromCourse() {
    const course = selectedCourse();
    const totalInput = document.getElementById('fees_total');
    const paidInput = document.getElementById('fees_paid');

    if (course && course.fees > 0 && (!totalInput.value || Number(totalInput.value) === 0)) {
      totalInput.value = course.fees;
    }

    if (Number(totalInput.value) > 0 && (!paidInput.value || Number(paidInput.value) === 0)) {
      paidInput.value = Math.round(Number(totalInput.value) * 0.5);
    }
  }

  function syncTeacherFromBatch() {
    const batch = selectedBatch();
    const teacherSelect = document.getElementById('teacher_select');
    const course = selectedCourse();
    const preferredTeacherIds = batch && batch.teacherProfileIds && batch.teacherProfileIds.length
      ? batch.teacherProfileIds
      : (course ? teacherOptions.filter(teacher => teacher.courseIds.includes(course.id)).map(teacher => teacher.id) : []);

    teacherSelect.innerHTML = '';

    const placeholder = document.createElement('option');
    placeholder.value = '';
    placeholder.textContent = teacherOptions.length ? 'Select Teacher' : 'No active teachers available';
    teacherSelect.appendChild(placeholder);

    const visibleTeachers = preferredTeacherIds.length
      ? teacherOptions.filter(teacher => preferredTeacherIds.includes(teacher.id))
      : teacherOptions;

    visibleTeachers.forEach(teacher => {
      const option = document.createElement('option');
      option.value = teacher.id;
      option.textContent = teacher.name;
      teacherSelect.appendChild(option);
    });

    if (batch && batch.teacherProfileId) {
      teacherSelect.value = batch.teacherProfileId;
      return;
    }

    if (visibleTeachers.length === 1) {
      teacherSelect.value = visibleTeachers[0].id;
    }
  }

  function toggleCustomBatch() {
    const select = document.getElementById('batch_select');
    const container = document.getElementById('custom_batch_container');
    const input = document.getElementById('customBatch');
    if (select.value === '') {
      container.style.display = 'grid';
      input.setAttribute('required', 'required');
    } else {
      container.style.display = 'none';
      input.removeAttribute('required');
    }

    syncTeacherFromBatch();
  }

  function checkDownpayment() {
    const total = Number(document.getElementById('fees_total').value) || 0;
    const paid = Number(document.getElementById('fees_paid').value) || 0;
    document.getElementById('suggested_downpayment').textContent = formatINR(paid);
    document.getElementById('balance_due').textContent = formatINR(total - paid);
    recalcInstallments();
  }

  function setInstallmentRows(rows) {
    const container = document.getElementById('installments_container');
    const todayStr = document.querySelector('input[name="enrollmentDate"]').value || new Date().toISOString().split('T')[0];
    container.innerHTML = '';

    rows.forEach((row, index) => {
      const dueDate = new Date(todayStr);
      dueDate.setMonth(dueDate.getMonth() + index);
      const dueValue = dueDate.toISOString().split('T')[0];
      addInstallmentRow(row.name, row.amount, dueValue);
    });
  }

  function recalcInstallments() {
    const total = Number(document.getElementById('fees_total').value) || 0;
    const paid = Number(document.getElementById('fees_paid').value) || 0;
    const rows = document.querySelectorAll('.installment-row');

    if (rows.length !== 3 && rows.length !== 1) return;

    if (paid >= total && total > 0) {
      setInstallmentRows([{ name: 'Full Fee', amount: total }]);
      return;
    }
    const first = Math.round(total * 0.5);
    const remaining = Math.max(0, total - first);
    setInstallmentRows([
      { name: 'Down Payment (50%)', amount: first },
      { name: 'Installment 2 (25%)', amount: Math.round(remaining / 2) },
      { name: 'Installment 3 (25%)', amount: remaining - Math.round(remaining / 2) }
    ]);
  }

  function addInstallmentRow(name = '', amount = '', dueDate = '') {
    const container = document.getElementById('installments_container');
    const todayStr = dueDate || new Date().toISOString().split('T')[0];
    const row = document.createElement('div');
    row.className = 'installment-row';
    row.innerHTML = `
      <div class="form-group" data-label="Name">
        <input type="text" name="instName[]" class="form-control form-control-sm" placeholder="e.g. Month 1" value="${String(name).replace(/"/g, '&quot;')}" required>
      </div>
      <div class="form-group" data-label="Amount (Rs.)">
        <input type="number" name="instAmount[]" class="form-control form-control-sm" placeholder="0" value="${amount}" required>
      </div>
      <div class="form-group" data-label="Due Date">
        <input type="date" name="instDueDate[]" class="form-control form-control-sm" value="${todayStr}" required>
      </div>
      <button type="button" class="btn btn-red btn-xs" onclick="removeInstallmentRow(this)">Delete</button>
    `;
    container.appendChild(row);
  }

  function removeInstallmentRow(btn) {
    const row = btn.closest('.installment-row');
    if (row) row.remove();
  }

  document.getElementById('course_select').addEventListener('change', () => {
    const totalInput = document.getElementById('fees_total');
    totalInput.value = '';
    filterBatchesForCourse();
    syncFeesFromCourse();
    syncTeacherFromBatch();
    checkDownpayment();
  });

  document.getElementById('batch_select').addEventListener('change', () => {
    toggleCustomBatch();
    checkDownpayment();
  });

  document.querySelector('input[name="enrollmentDate"]').addEventListener('change', recalcInstallments);

  filterBatchesForCourse();
  syncFeesFromCourse();
  syncTeacherFromBatch();
  checkDownpayment();
</script>
