<%
  layout = 'main';
  const isEdit = !!target;
  const activeRole = typeof defaultRole !== 'undefined' ? defaultRole : (isEdit ? target.role : '');
  const roleLabel = activeRole ? activeRole.charAt(0).toUpperCase() + activeRole.slice(1) : 'User';
  const studentData = typeof studentProfile !== 'undefined' && studentProfile ? studentProfile : null;
  const teacherData = typeof teacherProfile !== 'undefined' && teacherProfile ? teacherProfile : null;
  const counsellorData = typeof counsellorProfile !== 'undefined' && counsellorProfile ? counsellorProfile : null;
  const academyId = studentData?.rollNumber || teacherData?.rollNumber || counsellorData?.rollNumber || '';
  const inputDate = value => value ? new Date(value).toISOString().split('T')[0] : '';
  const placeholderEmail = isEdit && /@(pending\.local|staff\.invalid)$/i.test(target.email || '');
  title = isEdit ? `Edit ${roleLabel}` : `Add ${roleLabel}`;
  subtitle = isEdit ? `Modify profile details for ${target.name}` : `Create new credentials for academy ${roleLabel ? roleLabel.toLowerCase() + 's' : 'students or staff'}`;
  page = activeRole === 'student' ? 'students' : activeRole === 'teacher' ? 'teachers' : activeRole === 'counsellor' ? 'counsellors' : 'users';
%>

<div class="card" style="max-width: 700px; margin: 0 auto;">
  <form action="<%= isEdit ? '/admin/users/' + target._id + '/edit' : '/admin/users/create' %>" method="POST" enctype="multipart/form-data">
    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="name">Full Name</label>
        <input type="text" id="name" name="name" class="form-control" value="<%= isEdit ? target.name : '' %>" placeholder="e.g. John Doe" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="email">Email Address</label>
        <input type="email" id="email" name="email" class="form-control" value="<%= isEdit && !placeholderEmail ? target.email : '' %>" placeholder="Student's real email address" required>
      </div>
    </div>

    <% if (!isEdit) { %>
      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="Minimum 8 characters" minlength="8" required>
      </div>
    <% } else if (target.profileIncomplete) { %>
      <div class="alert alert-warning" role="alert">Set the student's real email and a temporary password. They will use these to sign in and must change the password after login.</div>
      <div class="form-group">
        <label class="form-label" for="password">Temporary Password</label>
        <input type="password" id="password" name="password" class="form-control" minlength="8" required>
      </div>
    <% } %>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="role">User Role</label>
        <select id="role" name="role" class="form-control" required <%= isEdit ? 'disabled' : '' %>>
          <option value="" disabled <%= !activeRole ? 'selected' : '' %>>Select Role</option>
          <option value="student" <%= activeRole === 'student' ? 'selected' : '' %>>Student</option>
          <option value="teacher" <%= activeRole === 'teacher' ? 'selected' : '' %>>Teacher</option>
          <option value="counsellor" <%= activeRole === 'counsellor' ? 'selected' : '' %>>Counsellor</option>
          <option value="admin" <%= activeRole === 'admin' ? 'selected' : '' %>>Admin</option>
        </select>
        <% if (isEdit) { %>
          <!-- Include hidden input to submit role because select is disabled -->
          <input type="hidden" name="role" value="<%= target.role %>">
        <% } %>
      </div>
      <div class="form-group">
        <label class="form-label" for="phone">Phone Number</label>
        <input type="tel" id="phone" name="phone" class="form-control" value="<%= isEdit ? target.phone : '' %>" placeholder="10-digit mobile number" pattern="[0-9]{10}" inputmode="numeric" maxlength="10">
      </div>
    </div>

    <div class="form-group">
      <label class="form-label" for="status">Account Status</label>
      <select id="status" name="status" class="form-control" required>
        <option value="active" <%= (isEdit && target.status === 'active') || !isEdit ? 'selected' : '' %>>Active</option>
        <option value="inactive" <%= (isEdit && target.status === 'inactive') ? 'selected' : '' %>>Inactive</option>
        <option value="drop" <%= (isEdit && target.status === 'drop') ? 'selected' : '' %>>Drop</option>
        <option value="complete" <%= (isEdit && target.status === 'complete') ? 'selected' : '' %>>Complete</option>
      </select>
    </div>

    <% if (isEdit) { %>
      <div class="form-group">
        <label class="form-label" for="academyId">Academy ID</label>
        <input type="text" id="academyId" class="form-control" value="<%= academyId || 'Not generated' %>" readonly>
        <div class="form-hint">Generated by the academy and kept stable for records.</div>
      </div>
    <% } %>

    <div class="form-group">
      <label class="form-label" for="profilePic">Profile Picture</label>
      <input type="file" id="profilePic" name="profilePic" class="form-control" accept="image/*">
      <% if (isEdit && target.profilePic) { %>
        <div class="form-hint">Current: <a href="<%= target.profilePic %>" target="_blank">View Uploaded Image</a></div>
      <% } %>
    </div>

    <!-- STUDENT SPECIFIC FIELDS -->
    <div id="student-fields" style="display: none; border-top: 1px solid var(--border); padding-top: 1.25rem; margin-top: 1.25rem;">
      <div class="section-title">Student Specific Information</div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="course">Course</label>
          <select id="course" name="course" class="form-control">
            <option value="" disabled <%= !studentData?.course ? 'selected' : '' %>>Select Course</option>
            <% (courses || []).forEach(courseItem => { %>
              <option value="<%= courseItem._id %>" <%= String(studentData?.course || teacherData?.courses?.[0] || '') === String(courseItem._id) ? 'selected' : '' %>><%= courseItem.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group" style="display:none" aria-hidden="true" hidden>
          <label class="form-label" for="batch">Batch Title</label>
          <select id="batch" name="batch" class="form-control">
            <option value="" <%= !studentData?.batch ? 'selected' : '' %>>No batch assigned</option>
            <% (batches || []).forEach(batchItem => { %>
              <option value="<%= batchItem._id %>" data-course="<%= batchItem.course?._id || batchItem.course || '' %>" <%= String(studentData?.batch || '') === String(batchItem._id) ? 'selected' : '' %>><%= batchItem.name %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="teacher">Assigned Teacher</label>
          <select id="teacher" name="teacher" class="form-control">
            <option value="">Not assigned</option>
            <% (typeof teachers !== 'undefined' ? teachers : []).forEach(profile => { %>
              <option value="<%= profile._id %>" <%= String(studentData?.teacher || '') === String(profile._id) ? 'selected' : '' %>><%= profile.user?.name || profile.rollNumber %><%= profile.user?.profileIncomplete ? ' (temporary)' : '' %></option>
            <% }) %>
          </select>
          <div class="d-flex gap-1" style="margin-top:0.5rem;"><input id="newTeacherName" class="form-control" placeholder="Type future teacher name"><button type="button" class="btn btn-ghost btn-sm" onclick="createTemporaryStaff('teacher')">Add temporary</button></div>
        </div>
        <div class="form-group">
          <label class="form-label" for="counsellor">Assigned Counsellor</label>
          <select id="counsellor" name="counsellor" class="form-control">
            <option value="">Not assigned</option>
            <% (typeof counsellors !== 'undefined' ? counsellors : []).forEach(profile => { %>
              <option value="<%= profile._id %>" <%= String(studentData?.counsellor || '') === String(profile._id) ? 'selected' : '' %>><%= profile.user?.name || profile.rollNumber %><%= profile.user?.profileIncomplete ? ' (temporary)' : '' %></option>
            <% }) %>
          </select>
          <div class="d-flex gap-1" style="margin-top:0.5rem;"><input id="newCounsellorName" class="form-control" placeholder="Type future counsellor name"><button type="button" class="btn btn-ghost btn-sm" onclick="createTemporaryStaff('counsellor')">Add temporary</button></div>
        </div>
      </div>
      
      <% if (!isEdit) { %>
        <div class="form-group">
          <label class="form-label" for="fees_total">Total Fees (INR)</label>
          <input type="number" id="fees_total" name="fees_total" class="form-control" placeholder="e.g. 25000">
          <div class="form-hint">This will automatically open a fee collection account for the student.</div>
        </div>
      <% } %>

      <!-- Parent/Guardian Details -->
      <div style="border-top: 1px dashed var(--border); margin-top: 1rem; padding-top: 1rem;">
        <div style="font-size: 0.75rem; color: var(--gold); text-transform: uppercase; font-weight: 700; margin-bottom: 0.75rem;">Parent / Guardian Information</div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="fatherName">Father's Name</label>
            <input type="text" id="fatherName" name="fatherName" class="form-control" value="<%= studentData?.family?.father?.name || '' %>" placeholder="Father's full name">
          </div>
          <div class="form-group">
            <label class="form-label" for="motherName">Mother's Name</label>
            <input type="text" id="motherName" name="motherName" class="form-control" value="<%= studentData?.family?.mother?.name || '' %>" placeholder="Mother's full name">
          </div>
        </div>
        <div class="form-row" style="margin-top: 0.75rem;">
          <div class="form-group">
            <label class="form-label" for="fatherPhone">Father's Phone</label>
            <input type="tel" id="fatherPhone" name="fatherPhone" class="form-control" value="<%= studentData?.family?.father?.phone || '' %>" placeholder="Father contact number" pattern="[0-9]{10}" inputmode="numeric" maxlength="10">
          </div>
          <div class="form-group">
            <label class="form-label" for="motherPhone">Mother's Phone</label>
            <input type="tel" id="motherPhone" name="motherPhone" class="form-control" value="<%= studentData?.family?.mother?.phone || '' %>" placeholder="Mother contact number" pattern="[0-9]{10}" inputmode="numeric" maxlength="10">
          </div>
        </div>
        <div class="form-row" style="margin-top: 0.75rem;">
          <div class="form-group">
            <label class="form-label" for="guardianName">Guardian Name</label>
            <input type="text" id="guardianName" name="guardianName" class="form-control" value="<%= studentData?.family?.guardian?.name || '' %>" placeholder="Primary guardian name">
          </div>
          <div class="form-group">
            <label class="form-label" for="guardianRelation">Relationship</label>
            <input type="text" id="guardianRelation" name="guardianRelation" class="form-control" value="<%= studentData?.family?.guardian?.relation || '' %>" placeholder="e.g. Father, Mother, Uncle">
          </div>
          <div class="form-group">
            <label class="form-label" for="guardianPhone">Guardian Phone</label>
            <input type="tel" id="guardianPhone" name="guardianPhone" class="form-control" value="<%= studentData?.family?.guardian?.phone || '' %>" placeholder="Guardian contact number" pattern="[0-9]{10}" inputmode="numeric" maxlength="10">
          </div>
        </div>
      </div>

      <!-- Extended Profile Fields -->
      <div style="border-top: 1px dashed var(--border); margin-top: 1rem; padding-top: 1rem;">
        <div style="font-size: 0.75rem; color: var(--gold); text-transform: uppercase; font-weight: 700; margin-bottom: 0.75rem;">Extended Profile Information</div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="dob">Date of Birth</label>
            <input type="date" id="dob" name="dob" class="form-control" max="<%= new Date().toISOString().split('T')[0] %>" value="<%= inputDate(target?.dob) %>">
          </div>
          <div class="form-group">
            <label class="form-label" for="highestQualification">Highest Qualification</label>
            <input type="text" id="highestQualification" name="highestQualification" class="form-control" value="<%= studentData?.highestQualification || '' %>" placeholder="e.g. Higher Secondary, BCA Graduate">
          </div>
        </div>
        <div class="form-row" style="margin-top: 0.75rem;">
          <div class="form-group">
            <label class="form-label" for="referralSource">Referral / Lead Source</label>
            <input type="text" id="referralSource" name="referralSource" class="form-control" value="<%= studentData?.referralSource || '' %>" placeholder="e.g. Google Ads, Instagram, Walk-in">
          </div>
          <div class="form-group">
            <label class="form-label" for="socialHandle">Social Handle / Portfolio Link</label>
            <input type="text" id="socialHandle" name="socialHandle" class="form-control" value="<%= target?.socialHandle?.instagram || target?.socialHandle?.linkedin || '' %>" placeholder="e.g. portfolio URL or @username">
          </div>
        </div>
        <div class="form-row" style="margin-top: 0.75rem;">
          <div class="form-group" style="flex: 2;">
            <label class="form-label" for="address">Permanent Address</label>
            <input type="text" id="address" name="address" class="form-control" value="<%= isEdit ? target.address : '' %>" placeholder="Permanent home address">
          </div>
          <div class="form-group" style="flex: 1;">
            <label class="form-label" for="city">City</label>
            <input type="text" id="city" name="city" class="form-control" value="<%= isEdit ? target.city : '' %>" placeholder="e.g. New Delhi">
          </div>
        </div>
      </div>
    </div>

    <!-- TEACHER SPECIFIC FIELDS -->
    <div id="teacher-fields" style="display: none; border-top: 1px solid var(--border); padding-top: 1.25rem; margin-top: 1.25rem;">
      <div class="section-title">Teacher Specific Information</div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="teacherCourse">Primary Course</label>
          <select id="teacherCourse" name="course" class="form-control">
            <option value="">No course assigned</option>
            <% (courses || []).forEach(courseItem => { %>
              <option value="<%= courseItem._id %>" <%= String(teacherData?.courses?.[0] || '') === String(courseItem._id) ? 'selected' : '' %>><%= courseItem.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="qualification">Qualifications</label>
          <input type="text" id="qualification" name="qualification" class="form-control" value="<%= teacherData?.qualification || '' %>" placeholder="e.g. B.Voc in Film Editing">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="experienceYears">Experience (years)</label>
          <input type="number" id="experienceYears" name="experienceYears" class="form-control" min="0" max="60" value="<%= teacherData?.experienceYears || 0 %>">
        </div>
        <div class="form-group">
          <label class="form-label" for="joiningDate">Joining Date</label>
          <input type="date" id="joiningDate" name="joiningDate" class="form-control" value="<%= inputDate(teacherData?.joiningDate) %>">
        </div>
        <div class="form-group">
          <label class="form-label" for="salary">Monthly Salary</label>
          <input type="number" id="salary" name="salary" class="form-control" min="0" value="<%= teacherData?.salary || 0 %>">
        </div>
      </div>
    </div>

    <div class="divider"></div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary"><%= isEdit ? 'Update User' : 'Create User' %></button>
      <a href="<%= activeRole ? '/admin/' + activeRole + 's' : '/admin/dashboard' %>" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>

<script>
  const roleSelect = document.getElementById('role');
  const studentFields = document.getElementById('student-fields');
  const teacherFields = document.getElementById('teacher-fields');
  
  const courseInput = document.getElementById('course');
  const batchInput = document.getElementById('batch');
  const qualificationInput = document.getElementById('qualification');

  function setSectionEnabled(section, enabled) {
    section.querySelectorAll('input, select, textarea').forEach(control => {
      control.disabled = !enabled;
    });
  }

  function toggleRoleFields() {
    const role = roleSelect.value;
    if (role === 'student') {
      studentFields.style.display = 'block';
      teacherFields.style.display = 'none';
      setSectionEnabled(studentFields, true);
      setSectionEnabled(teacherFields, false);
      courseInput.setAttribute('required', 'required');
    } else if (role === 'teacher') {
      studentFields.style.display = 'none';
      teacherFields.style.display = 'block';
      setSectionEnabled(studentFields, false);
      setSectionEnabled(teacherFields, true);
      courseInput.removeAttribute('required');
    } else {
      studentFields.style.display = 'none';
      teacherFields.style.display = 'none';
      setSectionEnabled(studentFields, false);
      setSectionEnabled(teacherFields, false);
      courseInput.removeAttribute('required');
    }
  }

  roleSelect.addEventListener('change', toggleRoleFields);

  async function createTemporaryStaff(role) {
    const input = document.getElementById(role === 'teacher' ? 'newTeacherName' : 'newCounsellorName');
    const name = input.value.trim();
    if (!name) return window.showToast?.('Type the staff name first.', 'warning');

    try {
      const response = await fetch('/admin/users/temporary-staff', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, role })
      });
      const result = await response.json();
      if (!response.ok) throw new Error(result.error || 'Could not create temporary staff.');

      const select = document.getElementById(role);
      const option = new Option(`${result.name} (temporary)`, result.profileId, true, true);
      select.add(option);
      select.dispatchEvent(new Event('change', { bubbles: true }));
      input.value = '';

      const completeNow = await window.AppFeedback.confirm({
        title: 'Temporary profile saved',
        message: `${result.name} is assigned but cannot log in until the full ${role} account is completed.`,
        confirmLabel: 'Complete now'
      });
      if (completeNow) window.open(result.editUrl, '_blank', 'noopener');
    } catch (err) {
      window.showToast?.(err.message, 'error');
    }
  }
  
  // Call once on page load to initialize
  toggleRoleFields();
</script>
