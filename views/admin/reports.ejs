<%
  layout = 'main';
  title = 'Reports & Analytics';
  subtitle = 'Executive insights and operational analytics for cohorts, collections, conversion pipelines, and attendance';
  page = 'reports';
%>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<!-- Tabs Header -->
<div class="card" style="padding: 0.5rem; margin-bottom: 1.5rem; border-color: var(--border);">
  <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; width: 100%;">
    <a href="/admin/reports?tab=general" class="btn btn-sm <%= tab === 'general' ? 'btn-primary' : 'btn-ghost' %>">📊 General & Leads</a>
    <a href="/admin/reports?tab=revenue" class="btn btn-sm <%= tab === 'revenue' ? 'btn-primary' : 'btn-ghost' %>">💰 Revenue Trends</a>
    <a href="/admin/reports?tab=counsellors" class="btn btn-sm <%= tab === 'counsellors' ? 'btn-primary' : 'btn-ghost' %>">🎯 Counsellor KPIs</a>
    <a href="/admin/reports?tab=attendance" class="btn btn-sm <%= tab === 'attendance' ? 'btn-primary' : 'btn-ghost' %>">👥 Batch Attendance</a>
    <a href="/admin/reports?tab=batch_health" class="btn btn-sm <%= tab === 'batch_health' ? 'btn-primary' : 'btn-ghost' %>">🏥 Batch Health</a>
    <a href="/admin/reports?tab=funnel_velocity" class="btn btn-sm <%= tab === 'funnel_velocity' ? 'btn-primary' : 'btn-ghost' %>">⚡ Funnel Velocity</a>
    <a href="/admin/reports?tab=aging" class="btn btn-sm <%= tab === 'aging' ? 'btn-primary' : 'btn-ghost' %>">⏳ Fee Aging</a>
    <a href="/admin/reports?tab=at_risk" class="btn btn-sm <%= tab === 'at_risk' ? 'btn-primary' : 'btn-ghost' %>">🚨 At-Risk Students</a>
    <a href="/admin/reports?tab=teacher_load" class="btn btn-sm <%= tab === 'teacher_load' ? 'btn-primary' : 'btn-ghost' %>">👩‍🏫 Teacher Load</a>
    
    <a href="/admin/reports?tab=<%= tab %>&export=csv<%= batch ? '&batch=' + encodeURIComponent(batch) : '' %>" class="btn btn-sm btn-ghost" style="margin-left: auto; color: var(--gold); border: 1px solid var(--gold-border);">📥 Export CSV</a>
  </div>
</div>

<!-- ==================== TAB: GENERAL & LEADS ==================== -->
<% if (tab === 'general') { %>
  <!-- Financial Highlights -->
  <div class="stats-grid" style="margin-bottom: 1.5rem;">
    <div class="stat-card gold">
      <div class="stat-label">Total Fee Accounts</div>
      <div class="stat-value"><%= feeStats.count %></div>
      <div class="stat-sub">Registered student accounts</div>
    </div>
    <div class="stat-card green">
      <div class="stat-label">Total Collection</div>
      <div class="stat-value">₹<%= feeStats.totalRevenue.toLocaleString('en-IN') %></div>
      <div class="stat-sub">Net revenue logged</div>
    </div>
    <div class="stat-card red">
      <div class="stat-label">Total Outstandings</div>
      <div class="stat-value">₹<%= feeStats.totalDue.toLocaleString('en-IN') %></div>
      <div class="stat-sub">Accounts receivable due</div>
    </div>
  </div>

  <div class="grid-2">
    <!-- Leads Status Chart Card -->
    <div class="card">
      <div class="card-header">
        <div class="card-title">Leads Pipeline Status</div>
      </div>
      <div style="padding: 1rem; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 220px;">
        <canvas id="leadStatusChart" style="max-height: 200px; max-width: 100%;"></canvas>
      </div>
      <% 
        const statuses = ['new', 'contacted', 'interested', 'converted', 'lost'];
        let totalLeadsCount = 0;
        statuses.forEach(s => { totalLeadsCount += (leadsByStatus[s] || 0); });
      %>
      <div class="table-wrap" style="border-top: 1px solid var(--border);">
        <table>
          <thead>
            <tr>
              <th>Status</th>
              <th class="text-right">Queries Count</th>
              <th class="text-right">Ratio %</th>
            </tr>
          </thead>
          <tbody>
            <% statuses.forEach(s => { %>
              <% 
                const count = leadsByStatus[s] || 0;
                const ratio = totalLeadsCount > 0 ? Math.round((count / totalLeadsCount) * 100) : 0;
                const badgeClass = {
                  new: 'badge-orange',
                  contacted: 'badge-blue',
                  interested: 'badge-yellow',
                  converted: 'badge-green',
                  lost: 'badge-red'
                }[s] || 'badge-grey';
              %>
              <tr>
                <td><span class="badge <%= badgeClass %>"><%= s %></span></td>
                <td class="mono text-right fw-600"><%= count %></td>
                <td class="mono text-right"><%= ratio %>%</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Leads Traffic Channels Chart Card -->
    <div class="card">
      <div class="card-header">
        <div class="card-title">Leads Traffic Channels</div>
      </div>
      <div style="padding: 1rem; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 220px;">
        <canvas id="leadSourceChart" style="max-height: 200px; max-width: 100%;"></canvas>
      </div>
      <% const sources = Object.entries(leadsBySource).sort((a, b) => b[1] - a[1]); %>
      <% if (sources.length === 0) { %>
        <div class="empty-state">
          <p>No lead source details available.</p>
        </div>
      <% } else { %>
        <div class="table-wrap" style="border-top: 1px solid var(--border);">
          <table>
            <thead>
              <tr>
                <th>Channel</th>
                <th class="text-right">Volume</th>
              </tr>
            </thead>
            <tbody>
              <% sources.forEach(([src, count]) => { %>
                <tr>
                  <td><strong><%= src %></strong></td>
                  <td class="mono text-right text-gold fw-600"><%= count %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Cohorts Directory -->
  <div class="card" style="margin-top: 1.5rem;">
    <div class="card-header">
      <div class="card-title">Enrolled Students Cohort Directory</div>
    </div>
    <% if (students.length === 0) { %>
      <div class="empty-state">
        <p>No active student registrations found.</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Student Name</th>
              <th>Batch Name</th>
              <th>Course Program</th>
              <th>Enrollment Date</th>
            </tr>
          </thead>
          <tbody>
            <% students.forEach(s => { %>
              <tr>
                <td class="td-name"><%= s.name %></td>
                <td><%= s.batch || '—' %></td>
                <td><span class="badge badge-orange"><%= s.course %></span></td>
                <td class="mono text-sm">
                  <%= s.enrollmentDate ? new Date(s.enrollmentDate).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) : '—' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
<% } %>

<!-- ==================== TAB: REVENUE TRENDS ==================== -->
<% if (tab === 'revenue') { %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <div class="card-title">Revenue Target vs Actual Collections Chart</div>
      <p class="td-muted text-sm">Visual analysis comparing Monthly Target Invoice totals (expected) against Actual Payments collected (received).</p>
    </div>
    <div style="padding: 1.5rem; min-height: 320px;">
      <canvas id="revenueTrendsChart" style="max-height: 300px; width: 100%;"></canvas>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div class="card-title">Monthly Target vs Actual Collections Breakdown</div>
    </div>
    <% if (revenueData.length === 0) { %>
      <div class="empty-state" style="padding: 3rem 1rem;">
        <p>No billing or transaction records found to report.</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Month (YYYY-MM)</th>
              <th class="text-right">Target Collections (Invoice Net)</th>
              <th class="text-right">Actual Collections (Payments)</th>
              <th class="text-right">Collection Rate %</th>
            </tr>
          </thead>
          <tbody>
            <% revenueData.forEach(r => { %>
              <% 
                const rate = r.target > 0 ? Math.round((r.actual / r.target) * 100) : 0;
                let rateColor = 'var(--red)';
                if (rate >= 90) rateColor = 'var(--green)';
                else if (rate >= 50) rateColor = 'var(--gold)';
              %>
              <tr>
                <td><strong class="mono"><%= r.month %></strong></td>
                <td class="mono text-right fw-600">₹<%= r.target.toLocaleString('en-IN') %></td>
                <td class="mono text-right text-gold fw-600">₹<%= r.actual.toLocaleString('en-IN') %></td>
                <td class="mono text-right fw-700" style="color: <%= rateColor %>;"><%= rate %>%</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
<% } %>

<!-- ==================== TAB: COUNSELLOR PERFORMANCE ==================== -->
<% if (tab === 'counsellors') { %>
  <div class="grid-2" style="margin-bottom: 1.5rem;">
    <!-- Counsellor Conversion Volumes -->
    <div class="card">
      <div class="card-header">
        <div class="card-title">Counsellor Conversion Ratios</div>
      </div>
      <div style="padding: 1.25rem; min-height: 250px;">
        <canvas id="counsellorConversionsChart" style="max-height: 230px; width: 100%;"></canvas>
      </div>
    </div>

    <!-- Counsellor Speed -->
    <div class="card">
      <div class="card-header">
        <div class="card-title">Average Lead Conversion Time (Speed in Days)</div>
      </div>
      <div style="padding: 1.25rem; min-height: 250px;">
        <canvas id="counsellorSpeedChart" style="max-height: 230px; width: 100%;"></canvas>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <div class="card-title">Counsellor Performance Analytics</div>
      <p class="td-muted text-sm">Overview of team conversions, follow-ups logged, and conversion speed.</p>
    </div>
    <% if (counsellorPerformance.length === 0) { %>
      <div class="empty-state" style="padding: 3rem 1rem;">
        <p>No active counsellors found.</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Counsellor</th>
              <th class="text-right">Leads Assigned</th>
              <th class="text-right">Follow-ups Logged</th>
              <th class="text-right">Converted</th>
              <th class="text-right">Lost</th>
              <th class="text-right">Conversion Rate</th>
              <th class="text-right">Avg Conversion Days</th>
            </tr>
          </thead>
          <tbody>
            <% counsellorPerformance.forEach(c => { %>
              <tr>
                <td class="td-name">
                  <%= c.counsellor.name %>
                  <div class="td-muted text-xs"><%= c.counsellor.rollNumber %></div>
                </td>
                <td class="mono text-right"><%= c.total %></td>
                <td class="mono text-right text-gold"><%= c.followUps %></td>
                <td class="mono text-right text-green fw-600"><%= c.converted %></td>
                <td class="mono text-right text-red"><%= c.lost %></td>
                <td class="mono text-right fw-700 text-gold"><%= c.conversionRate %>%</td>
                <td class="mono text-right"><%= c.avgDays %> days</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
<% } %>

<!-- ==================== TAB: BATCH ATTENDANCE SUMMARY ==================== -->
<% if (tab === 'attendance') { %>
  <style>
  .calendar-container {
    margin-top: 1.5rem;
    margin-bottom: 2rem;
  }
  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .calendar-header-day {
    text-align: center;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--gold);
    padding: 0.5rem 0;
    text-transform: uppercase;
    background: rgba(212, 175, 55, 0.05);
    border-radius: 4px;
    border: 1px solid rgba(212, 175, 55, 0.15);
  }
  .calendar-day-card {
    min-height: 95px;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.5rem;
    background: rgba(255, 255, 255, 0.01);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
  }
  .calendar-day-card:hover {
    border-color: var(--gold-border);
    background: rgba(212, 175, 55, 0.05);
    transform: translateY(-2px);
  }
  .calendar-day-card.active {
    border-color: var(--gold);
    box-shadow: 0 0 12px rgba(212, 175, 55, 0.3);
    background: rgba(212, 175, 55, 0.08);
  }
  .calendar-day-card.holiday {
    background: rgba(239, 68, 68, 0.06);
    border-color: rgba(239, 68, 68, 0.2);
  }
  .calendar-day-card.empty {
    visibility: hidden;
    pointer-events: none;
  }
  .day-num-lbl {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }
  .day-pct-badge {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 4px;
    align-self: flex-end;
  }
  .pct-high {
    background: rgba(16, 185, 129, 0.15);
    color: var(--green);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }
  .pct-low {
    background: rgba(239, 68, 68, 0.15);
    color: var(--red);
    border: 1px solid rgba(239, 68, 68, 0.3);
  }
  .pct-none {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-muted);
    border: 1px solid var(--border);
  }
  .holiday-tag {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--red);
    background: rgba(239, 68, 68, 0.1);
    padding: 2px 4px;
    border-radius: 3px;
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
    max-width: 100%;
    margin-top: 0.25rem;
  }
  .student-matrix-table th {
    font-size: 0.75rem;
    padding: 0.5rem 0.25rem;
    text-align: center;
    min-width: 30px;
  }
  .student-matrix-table td {
    padding: 0.5rem 0.25rem;
    text-align: center;
    font-weight: 700;
    font-size: 0.8rem;
  }
  .cell-status-p {
    color: var(--green);
    background: rgba(16, 185, 129, 0.15);
    border-radius: 3px;
    padding: 2px;
    display: block;
  }
  .cell-status-a {
    color: var(--red);
    background: rgba(239, 68, 68, 0.15);
    border-radius: 3px;
    padding: 2px;
    display: block;
  }
  .cell-status-none {
    color: var(--text-muted);
    font-weight: 400;
  }
  </style>

  <!-- Filter Bar -->
  <div class="card" style="padding: 1rem 1.25rem; margin-bottom: 1.5rem;">
    <form method="GET" action="/admin/reports" class="filter-bar" style="margin:0; display: flex; gap: 1rem; flex-wrap: wrap;">
      <input type="hidden" name="tab" value="attendance">
      
      <div class="form-group" style="margin: 0; min-width: 200px; flex: 1;">
        <label class="form-label" style="margin-bottom: 0.25rem;">Select Batch</label>
        <select name="batch" class="form-control" style="padding: 0.45rem 0.75rem;">
          <option value="">Choose Batch (Show Academy Overall in Calendar)...</option>
          <% batches.forEach(b => { %>
            <option value="<%= b %>" <%= batch === b ? 'selected' : '' %>><%= b %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group" style="margin: 0; min-width: 150px;">
        <label class="form-label" style="margin-bottom: 0.25rem;">Select Month</label>
        <input type="month" name="month" class="form-control" style="padding: 0.45rem 0.75rem;" value="<%= selectedMonth %>" required>
      </div>

      <div style="display:flex; align-items:flex-end;">
        <button type="submit" class="btn btn-primary btn-sm" style="padding: 0.55rem 1.5rem;">Apply Filters</button>
      </div>
    </form>
  </div>

  <!-- Calendar Card -->
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
      <div>
        <div class="card-title">Attendance Calendar: <%= batch ? batch : 'Academy Overall' %></div>
        <p class="td-muted text-sm">Interactive monthly log. Percentage displays average student attendance rates per class session. Click any day block to view details.</p>
      </div>
      <div class="mono fw-600 text-gold" style="font-size: 1.1rem; text-transform: uppercase;">
        <%= new Date(selectedMonth + '-02').toLocaleDateString('en-IN', {month: 'long', year: 'numeric'}) %>
      </div>
    </div>
    <div style="padding: 1.25rem;">
      <div class="calendar-grid">
        <div class="calendar-header-day">Sun</div>
        <div class="calendar-header-day">Mon</div>
        <div class="calendar-header-day">Tue</div>
        <div class="calendar-header-day">Wed</div>
        <div class="calendar-header-day">Thu</div>
        <div class="calendar-header-day">Fri</div>
        <div class="calendar-header-day">Sat</div>

        <!-- Preceding Blank Days -->
        <% const firstDayOfWeek = calendarDays[0].dayOfWeek; %>
        <% for(let i = 0; i < firstDayOfWeek; i++) { %>
          <div class="calendar-day-card empty"></div>
        <% } %>

        <!-- Calendar Day Blocks -->
        <% calendarDays.forEach(day => { %>
          <div class="calendar-day-card <%= day.isHoliday ? 'holiday' : '' %>" 
               data-date="<%= day.dateStr %>"
               data-holiday="<%= day.isHoliday %>"
               data-holiday-name="<%= day.holidayName %>">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
              <span class="day-num-lbl"><%= day.dayNum %></span>
              <% if (day.attendancePct !== null) { %>
                <span class="day-pct-badge <%= day.attendancePct >= 75 ? 'pct-high' : 'pct-low' %>">
                  <%= day.attendancePct %>%
                </span>
              <% } else { %>
                <span class="day-pct-badge pct-none">—</span>
              <% } %>
            </div>
            <% if (day.isHoliday) { %>
              <div class="holiday-tag" title="Holiday: <%= day.holidayName %>">🎉 <%= day.holidayName %></div>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Row of Grid Matrix + Click Details -->
  <div class="grid-2" style="align-items: start; gap: 1.5rem; margin-bottom: 1.5rem;">
    <!-- Click Details Panel -->
    <div class="card" id="daily-attendance-detail">
      <div class="card-header">
        <div class="card-title" id="detail-date-header">Daily Attendance Log</div>
        <p class="td-muted text-sm">Roster audit detail for the selected calendar date.</p>
      </div>
      <div style="padding: 1rem;">
        <div id="detail-no-records" class="empty-state" style="padding: 3rem 1rem;">
          Select a marked date block on the calendar above to view student roster details.
        </div>
        <div class="table-wrap" id="detail-table-wrap" style="display: none;">
          <table>
            <thead>
              <tr>
                <th>Student</th>
                <th>Status</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody id="detail-table-body">
              <!-- Dynamically populated via JS -->
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Student Grid matrix -->
    <% if (batch) { %>
      <div class="card">
        <div class="card-header">
          <div class="card-title">Cohort Student Attendance Matrix: <%= batch %></div>
          <p class="td-muted text-sm">Monthly grid (skipping holidays). Showing Present/Late (<span class="text-green fw-700">P</span>), Absent (<span class="text-red fw-700">A</span>), or Not Marked (<span class="text-muted">—</span>).</p>
        </div>
        <% if (studentGrid.length === 0) { %>
          <div class="empty-state" style="padding: 3rem 1rem;">
            No student enrollments found in batch <%= batch %>.
          </div>
        <% } else { %>
          <div class="table-wrap" style="max-height: 450px; overflow: auto;">
            <table class="student-matrix-table">
              <thead>
                <tr>
                  <th style="text-align: left; position: sticky; left: 0; background: var(--card-bg); z-index: 2; min-width: 120px;">Student</th>
                  <% gridDates.forEach(dateStr => { %>
                    <th><%= Number(dateStr.slice(8)) %></th>
                  <% }) %>
                </tr>
              </thead>
              <tbody>
                <% studentGrid.forEach(row => { %>
                  <tr>
                    <td style="text-align: left; position: sticky; left: 0; background: var(--card-bg); z-index: 2; font-weight: 600;" class="td-name">
                      <%= row.name %>
                    </td>
                    <% gridDates.forEach(dateStr => { %>
                      <% 
                        const status = row.attendanceByDate[dateStr];
                      %>
                      <td>
                        <% if (status === 'present' || status === 'late') { %>
                          <span class="cell-status-p" title="<%= dateStr %>: <%= status.toUpperCase() %>">P</span>
                        <% } else if (status === 'absent') { %>
                          <span class="cell-status-a" title="<%= dateStr %>: ABSENT">A</span>
                        <% } else { %>
                          <span class="cell-status-none">—</span>
                        <% } %>
                      </td>
                    <% }) %>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="card">
        <div class="empty-state" style="padding: 4rem 1rem;">
          Select a batch from the filter dropdown to unlock student-level daily matrix grids.
        </div>
      </div>
    <% } %>
  </div>

  <!-- Attendance Rate Chart (only if batch is selected) -->
  <% if (batch && attendanceSummary && attendanceSummary.length > 0) { %>
    <div class="card">
      <div class="card-header">
        <div class="card-title">Batch Student Attendance Overview Comparison: <%= batch %></div>
        <p class="td-muted text-sm">Historical cohort overall attendance rate vs min 75% standard.</p>
      </div>
      <div style="padding: 1.5rem; min-height: 320px;">
        <canvas id="attendanceChart" style="max-height: 300px; width: 100%;"></canvas>
      </div>
    </div>
  <% } %>

  <!-- JSON Data Store for client-side calendar interactions -->
  <script id="monthly-attendance-data" type="application/json"><%- JSON.stringify(monthlyAttendanceRecords || []) %></script>
  
  <script>
  document.addEventListener('DOMContentLoaded', () => {
    const dayCards = document.querySelectorAll('.calendar-day-card:not(.empty)');
    const detailSection = document.getElementById('daily-attendance-detail');
    const detailDateHeader = document.getElementById('detail-date-header');
    const detailTableBody = document.getElementById('detail-table-body');
    const noRecordsMsg = document.getElementById('detail-no-records');
    const tableWrap = document.getElementById('detail-table-wrap');

    let attendanceRecords = [];
    try {
      const rawData = document.getElementById('monthly-attendance-data').textContent;
      attendanceRecords = JSON.parse(rawData);
    } catch(e) {
      console.error("Failed to parse attendance records:", e);
    }

    dayCards.forEach(card => {
      card.addEventListener('click', () => {
        dayCards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');

        const dateStr = card.getAttribute('data-date');
        const isHoliday = card.getAttribute('data-holiday') === 'true';
        const holidayName = card.getAttribute('data-holiday-name');

        const dateObj = new Date(dateStr);
        const formattedDate = dateObj.toLocaleDateString('en-IN', {
          weekday: 'short',
          day: 'numeric',
          month: 'short',
          year: 'numeric'
        });
        detailDateHeader.textContent = `Daily Log: ${formattedDate}` + (isHoliday ? ` (Holiday: ${holidayName})` : '');

        const filtered = attendanceRecords.filter(r => r.date === dateStr);

        if (filtered.length === 0) {
          tableWrap.style.display = 'none';
          noRecordsMsg.style.display = 'block';
          noRecordsMsg.textContent = isHoliday 
            ? `This day was a scheduled holiday (${holidayName}). No classes conducted.`
            : 'No attendance records logged for this calendar date.';
        } else {
          noRecordsMsg.style.display = 'none';
          tableWrap.style.display = 'block';
          detailTableBody.innerHTML = '';

          filtered.forEach(rec => {
            const studentName = rec.student?.name || 'Unknown Student';
            const status = rec.status.toUpperCase();
            const badgeClass = status === 'PRESENT' || status === 'LATE' ? 'badge-green' : 'badge-red';
            const note = rec.note || '—';

            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td class="td-name">${studentName}</td>
              <td><span class="badge ${badgeClass}">${status}</span></td>
              <td>${note}</td>
            `;
            detailTableBody.appendChild(tr);
          });
        }
      });
    });

    // Auto-select latest day card with marked attendance or first day card
    if (dayCards.length > 0) {
      let initialCard = null;
      // Try to find today
      const todayStr = new Date().toLocaleDateString('en-CA', {timeZone: 'Asia/Kolkata'});
      initialCard = Array.from(dayCards).find(c => c.getAttribute('data-date') === todayStr);

      if (!initialCard) {
        // Find latest day card with attendance rate badge
        initialCard = Array.from(dayCards).reverse().find(c => c.querySelector('.day-pct-badge:not(.pct-none)'));
      }
      if (!initialCard) {
        initialCard = dayCards[0];
      }
      if (initialCard) {
        initialCard.click();
      }
    }
  });
  </script>
<% } %>

