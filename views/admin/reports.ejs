<!-- ==================== CHART LOGIC SCRIPTS ==================== -->
<script>
window.runReportsReady(() => {
  // Parse reports data store
  let reportsData = { charts: {}, revenueData: [], counsellorPerformance: [], attendanceSummary: [], teacherLoad: [] };
  try {
    reportsData = JSON.parse(document.getElementById('reports-charts-data').value);
  } catch (err) {
    console.error("Failed to parse reports-charts-data:", err);
  }
  window.reportsData = reportsData;

  // Theme Helper for charts
  const getThemeColors = () => {
    const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
    return {
      textColor: isDark ? '#a3a3a3' : '#4b5563',
      gridColor: isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(0, 0, 0, 0.06)'
    };
  };

  const { textColor, gridColor } = getThemeColors();
  window.chartTextColor = textColor;
  window.chartGridColor = gridColor;

  Chart.defaults.color = textColor;
  Chart.defaults.font.family = 'Inter, sans-serif';
});
</script>

