<% if (tab === 'staff') { %>
<script>
window.runReportsReady(() => {
  const reportsData = window.reportsData;
  const gridColor = window.chartGridColor;
  const textColor = window.chartTextColor;

  // 1. Teachers Workload Chart
  const tLoad = reportsData.teacherLoad || [];
  const teacherChartEl = document.getElementById('teacherLoadChart');
  if (teacherChartEl && tLoad.length > 0) {
    new Chart(teacherChartEl.getContext('2d'), {
      type: 'bar',
      data: {
        labels: ['Classes Taught', 'Assignments Created', 'Submissions Graded', 'Attendance Sessions Marked', 'Curriculum Completion %'],
        datasets: tLoad.map((tl, index) => {
          const colors = [
            'rgba(59, 130, 246, 0.85)', // Blue
            'rgba(16, 185, 129, 0.85)', // Green
            'rgba(234, 179, 8, 0.85)',  // Yellow
            'rgba(249, 115, 22, 0.85)'   // Orange
          ];
          return {
            label: tl.teacher.name,
            data: [tl.classesConducted, tl.assignmentsCreated, tl.submissionsGraded, tl.attendanceSessionsMarked, tl.curriculumCompletion],
            backgroundColor: colors[index % colors.length],
            borderRadius: 4
          };
        })
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { color: textColor } } },
        scales: {
          x: { grid: { display: false }, ticks: { color: textColor } },
          y: { grid: { color: gridColor }, ticks: { color: textColor, precision: 0 } }
        }
      }
    });
  }

  // 2. Counsellor Conversions Chart
  const cPerf = reportsData.counsellorPerformance || [];
  const counsellorChartEl = document.getElementById('counsellorConversionsChart');
  if (counsellorChartEl && cPerf.length > 0) {
    const cNames = cPerf.map(c => c.counsellor.name);
    const cSpeeds = cPerf.map(c => c.avgDays);
    const cRates = cPerf.map(c => c.conversionRate);

    new Chart(counsellorChartEl.getContext('2d'), {
      type: 'bar',
      data: {
        labels: cNames,
        datasets: [
          {
            label: 'Conversion Rate %',
            data: cRates,
            backgroundColor: 'rgba(16, 185, 129, 0.8)', // Green
            borderRadius: 4,
            yAxisID: 'y'
          },
          {
            label: 'Avg Conversion (Days)',
            data: cSpeeds,
            backgroundColor: 'rgba(234, 179, 8, 0.8)', // Yellow
            borderRadius: 4,
            yAxisID: 'y1'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { color: textColor } } },
        scales: {
          x: { grid: { display: false }, ticks: { color: textColor } },
          y: { 
            type: 'linear',
            position: 'left',
            grid: { color: gridColor }, 
            ticks: { color: textColor, callback: function(value) { return value + '%'; } },
            title: { display: true, text: 'Conversion Rate', color: textColor }
          },
          y1: {
            type: 'linear',
            position: 'right',
            grid: { drawOnChartArea: false },
            ticks: { color: textColor, precision: 0 },
            title: { display: true, text: 'Avg Days to Convert', color: textColor }
          }
        }
      }
    });
  }
});
</script>
<% } %>
