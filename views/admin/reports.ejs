<% if (tab === 'financial') { %>
<script>
window.runReportsReady(() => {
  const reportsData = window.reportsData;
  const textColor = window.chartTextColor;
  const gridColor = window.chartGridColor;

  const rawRevenueData = reportsData.revenueData || [];
  let financialChart = null;

  function renderFinancialChart() {
    const period = document.getElementById('financialChartPeriod').value;

    // Filter by period
    let filteredData = [...rawRevenueData];
    if (period !== 'all') {
      const monthsCount = parseInt(period);
      filteredData = filteredData.slice(-monthsCount);
    }

    const months = filteredData.map(r => r.month);
    const datasets = [
      {
        label: 'Revenue Target',
        data: filteredData.map(r => r.target),
        type: 'bar',
        backgroundColor: 'rgba(59, 130, 246, 0.7)', // Blue
        borderRadius: 4,
        yAxisID: 'y'
      },
      {
        label: 'Actual Collections',
        data: filteredData.map(r => r.actual),
        type: 'line',
        borderColor: 'rgba(16, 185, 129, 1)', // Green
        backgroundColor: 'transparent',
        tension: 0.2,
        borderWidth: 3,
        pointBackgroundColor: 'rgba(16, 185, 129, 1)',
        yAxisID: 'y1'
      }
    ];

    const ctx = document.getElementById('revenueTrendsChart').getContext('2d');
    if (financialChart) {
      financialChart.destroy();
    }

    financialChart = new Chart(ctx, {
      data: {
        labels: months,
        datasets: datasets
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { color: textColor } } },
        scales: {
          x: { 
            grid: { display: false },
            ticks: { 
              color: textColor,
              maxRotation: 45,
              minRotation: 45,
              autoSkip: true,
              maxTicksLimit: 12
            }
          },
          y: { 
            type: 'linear',
            position: 'left',
            grid: { color: gridColor },
            ticks: {
              color: textColor,
              callback: function(value) { return '₹' + (value >= 1000 ? (value / 1000) + 'k' : value); }
            },
            title: {
              display: true,
              text: 'Target (₹)',
              color: textColor
            }
          },
          y1: { 
            type: 'linear',
            position: 'right',
            grid: { drawOnChartArea: false },
            ticks: {
              color: textColor,
              callback: function(value) { return '₹' + (value >= 1000 ? (value / 1000) + 'k' : value); }
            },
            title: {
              display: true,
              text: 'Actual Collections (₹)',
              color: textColor
            }
          }
        }
      }
    });
  }

  document.querySelectorAll('.btn-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const checkboxId = btn.getAttribute('data-id');
      const checkbox = document.getElementById(checkboxId);
      checkbox.checked = !checkbox.checked;
      
      if (checkbox.checked) {
        btn.classList.add('active');
        if (checkboxId === 'toggleTarget') {
          btn.style.background = 'rgba(212, 175, 55, 0.15)';
          btn.style.borderColor = 'rgba(212, 175, 55, 0.4)';
          btn.style.color = 'var(--gold-light)';
        } else if (checkboxId === 'toggleActual') {
          btn.style.background = 'rgba(16, 185, 129, 0.15)';
          btn.style.borderColor = 'rgba(16, 185, 129, 0.4)';
          btn.style.color = '#10b981';
        } else if (checkboxId === 'toggleExpenses') {
          btn.style.background = 'rgba(239, 68, 68, 0.15)';
          btn.style.borderColor = 'rgba(239, 68, 68, 0.4)';
          btn.style.color = '#ef4444';
        } else if (checkboxId === 'toggleNetProfit') {
          btn.style.background = 'rgba(59, 130, 246, 0.15)';
          btn.style.borderColor = 'rgba(59, 130, 246, 0.4)';
          btn.style.color = '#3b82f6';
        }
      } else {
        btn.classList.remove('active');
        btn.style.background = 'transparent';
        btn.style.borderColor = 'var(--border)';
        btn.style.color = 'var(--text-muted)';
      }
      
      renderFinancialChart();
    });
  });

  document.getElementById('financialChartPeriod').addEventListener('change', renderFinancialChart);

  renderFinancialChart();

  // Cumulative Revenue growth timeline
  const cumMonths = reportsData.charts?.cumulativeBilling?.months || [];
  const cumGrowth = reportsData.charts?.cumulativeBilling?.growth || [];

  new Chart(document.getElementById('cumulativeBillingChart').getContext('2d'), {
    type: 'line',
    data: {
      labels: cumMonths,
      datasets: [{
        label: 'Cumulative Billed (₹)',
        data: cumGrowth,
        borderColor: 'rgba(59, 130, 246, 1)', // Blue
        backgroundColor: 'rgba(59, 130, 246, 0.1)',
        fill: true,
        tension: 0.2,
        borderWidth: 3,
        pointBackgroundColor: 'rgba(59, 130, 246, 1)'
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false } },
        y: {
          grid: { color: gridColor },
          ticks: { callback: function(value) { return '₹' + (value / 1000) + 'k'; } }
        }
      }
    }
  });

  // Payment methods split horizontal bar
  const pmLabels = reportsData.charts?.paymentMethods?.labels || [];
  const pmValues = reportsData.charts?.paymentMethods?.values || [];

  new Chart(document.getElementById('paymentMethodsChart').getContext('2d'), {
    type: 'bar',
    data: {
      labels: pmLabels,
      datasets: [{
        label: 'Received Amount (₹)',
        data: pmValues,
        backgroundColor: 'rgba(16, 185, 129, 0.85)',
        borderRadius: 4
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { color: gridColor }, ticks: { callback: function(value) { return '₹' + (value / 1000) + 'k'; } } },
        y: { grid: { display: false } }
      }
    }
  });
});
</script>
<% } %>

