<!-- ==================== CHART LOGIC SCRIPTS ==================== -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  // Common visual config based on site light/dark mode
  const getThemeTextAndBorderColor = () => {
    const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
    return {
      textColor: isDark ? '#a3a3a3' : '#4b5563',
      gridColor: isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(0, 0, 0, 0.06)'
    };
  };

  const { textColor, gridColor } = getThemeTextAndBorderColor();

  // Chart.js Default Configs
  Chart.defaults.color = textColor;
  Chart.defaults.font.family = 'Inter, sans-serif';

  // 1. GENERAL TAB CHARTS
  <% if (tab === 'general') { %>
    // Lead Pipeline Status Doughnut
    const statusData = <%- JSON.stringify(leadsByStatus) %>;
    const statusLabels = ['new', 'contacted', 'interested', 'converted', 'lost'];
    const statusCounts = statusLabels.map(s => statusData[s] || 0);

    new Chart(document.getElementById('leadStatusChart').getContext('2d'), {
      type: 'doughnut',
      data: {
        labels: statusLabels.map(s => s.toUpperCase()),
        datasets: [{
          data: statusCounts,
          backgroundColor: [
            'rgba(249, 115, 22, 0.85)', // new (orange)
            'rgba(59, 130, 246, 0.85)',  // contacted (blue)
            'rgba(234, 179, 8, 0.85)',   // interested (yellow)
            'rgba(16, 185, 129, 0.85)',  // converted (green)
            'rgba(239, 68, 68, 0.85)'    // lost (red)
          ],
          borderColor: 'transparent',
          hoverOffset: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { boxWidth: 12, padding: 10 }
          }
        }
      }
    });

    // Lead Traffic Channels Horizontal Bar
    const sourceData = <%- JSON.stringify(leadsBySource) %>;
    const sourceLabels = Object.keys(sourceData);
    const sourceCounts = Object.values(sourceData);

    new Chart(document.getElementById('leadSourceChart').getContext('2d'), {
      type: 'bar',
      data: {
        labels: sourceLabels,
        datasets: [{
          label: 'Leads Count',
          data: sourceCounts,
          backgroundColor: 'rgba(212, 175, 55, 0.8)', // Gold
          borderColor: 'transparent',
          borderRadius: 4
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { color: gridColor }, ticks: { precision: 0 } },
          y: { grid: { display: false } }
        }
      }
    });
  <% } %>

  // 2. REVENUE TRENDS TAB CHARTS
  <% if (tab === 'revenue') { %>
    const revenueData = <%- JSON.stringify(revenueData) %>;
    const months = revenueData.map(r => r.month);
    const targets = revenueData.map(r => r.target);
    const collections = revenueData.map(r => r.actual);

    new Chart(document.getElementById('revenueTrendsChart').getContext('2d'), {
      type: 'bar',
      data: {
        labels: months,
        datasets: [
          {
            label: 'Actual Collections',
            data: collections,
            backgroundColor: 'rgba(16, 185, 129, 0.8)', // Green
            borderRadius: 4,
            order: 2
          },
          {
            label: 'Target Collections',
            data: targets,
            type: 'line',
            borderColor: 'rgba(212, 175, 55, 1)', // Gold
            borderWidth: 3,
            backgroundColor: 'transparent',
            tension: 0.2,
            pointBackgroundColor: 'rgba(212, 175, 55, 1)',
            order: 1
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom' }
        },
        scales: {
          x: { grid: { display: false } },
          y: { 
            grid: { color: gridColor },
            ticks: {
              callback: function(value) {
                return '₹' + (value >= 1000 ? (value / 1000) + 'k' : value);
              }
            }
          }
        }
      }
    });
  <% } %>

  // 3. COUNSELLOR PERFORMANCE TAB CHARTS
  <% if (tab === 'counsellors') { %>
    const cPerf = <%- JSON.stringify(counsellorPerformance) %>;
    const cNames = cPerf.map(c => c.counsellor.name);
    const cAssigned = cPerf.map(c => c.total);
    const cConverted = cPerf.map(c => c.converted);
    const cRates = cPerf.map(c => c.conversionRate);
    const cSpeeds = cPerf.map(c => c.avgDays);

    // Conversions Chart (Assigned vs Converted stacked or grouped)
    new Chart(document.getElementById('counsellorConversionsChart').getContext('2d'), {
      type: 'bar',
      data: {
        labels: cNames,
        datasets: [
          {
            label: 'Assigned Leads',
            data: cAssigned,
            backgroundColor: 'rgba(59, 130, 246, 0.35)', // Light Blue
            borderColor: 'rgba(59, 130, 246, 0.8)',
            borderWidth: 1,
            borderRadius: 4
          },
          {
            label: 'Converted Students',
            data: cConverted,
            backgroundColor: 'rgba(16, 185, 129, 0.8)', // Green
            borderRadius: 4
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } },
        scales: {
          x: { grid: { display: false } },
          y: { grid: { color: gridColor }, ticks: { precision: 0 } }
        }
      }
    });

    // Speed Chart (Bar representing speed in days)
    new Chart(document.getElementById('counsellorSpeedChart').getContext('2d'), {
      type: 'bar',
      data: {
        labels: cNames,
        datasets: [{
          label: 'Avg Conversion (Days)',
          data: cSpeeds,
          backgroundColor: 'rgba(234, 179, 8, 0.85)', // Yellow
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false } },
          y: { 
            grid: { color: gridColor }, 
            title: { display: true, text: 'Days' },
            ticks: { precision: 0 }
          }
        }
      }
    });
  <% } %>

  // 4. BATCH ATTENDANCE TAB CHARTS
  <% if (tab === 'attendance' && batch && attendanceSummary.length > 0) { %>
    const attData = <%- JSON.stringify(attendanceSummary) %>;
    const studentNames = attData.map(s => s.name);
    const attRates = attData.map(s => s.attendancePct);

    new Chart(document.getElementById('attendanceChart').getContext('2d'), {
      type: 'bar',
      data: {
        labels: studentNames,
        datasets: [{
          label: 'Attendance Rate %',
          data: attRates,
          backgroundColor: attRates.map(r => r < 75 ? 'rgba(239, 68, 68, 0.85)' : 'rgba(16, 185, 129, 0.85)'),
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          // Draw a custom red threshold line at 75%
          annotation: {
            annotations: {
              line1: {
                type: 'line',
                yMin: 75,
                yMax: 75,
                borderColor: 'red',
                borderWidth: 2,
                borderDash: [6, 6],
                label: {
                  content: 'Min 75% Requirement',
                  enabled: true,
                  position: 'end',
                  backgroundColor: 'rgba(239, 68, 68, 0.9)'
                }
              }
            }
          }
        },
        scales: {
          x: { grid: { display: false } },
          y: { 
            grid: { color: gridColor },
            min: 0,
            max: 100,
            ticks: {
              callback: function(value) { return value + '%'; }
            }
          }
        }
      }
    });
  <% } %>
});
</script>
