<%
  layout = 'main';
  title = `Convert Lead: ${lead.name}`;
  subtitle = 'Establish student portal account & fee ledger';
  page = 'leads';
%>

<!-- Page Action Header -->
<div style="display:flex; justify-content:flex-start; align-items:center; margin-bottom:1.25rem;">
  <a href="/counsellor/leads/<%= lead._id %>" class="btn btn-ghost btn-sm">&larr; Back to Lead Detail</a>
</div>

<div class="convert-container" style="max-width:680px; margin: 0 auto; padding: 0 10px;">
  <% if (typeof error !== 'undefined' && error && (Array.isArray(error) ? error.length > 0 : error)) { %>
    <div class="card" style="border-color:var(--red); background:rgba(239,68,68,0.05); margin-bottom:20px; padding:12px 16px; color:var(--red); font-size:13px; font-weight:500; border-left:4px solid var(--red);">
      ❌ <%= error %>
    </div>
  <% } %>

  <div class="card" style="border-color:rgba(34,197,94,0.25); background: linear-gradient(180deg, rgba(34,197,94,0.02) 0%, rgba(0,0,0,0) 100%); margin-bottom:20px; padding:16px 20px;">
    <div style="display:flex; gap:12px; align-items:center;">
      <div style="font-size:24px;">🎓</div>
      <div>
        <div style="font-size:14px; font-weight:600; color:var(--green);">Converting Lead to Student Profile</div>
        <div style="font-size:12px; color:var(--text-muted); margin-top:2px;">
          This will generate an active student account in the registry and initialize their financial record.
        </div>
      </div>
    </div>
  </div>

  <div class="card" style="padding: 24px;">
    <form action="/counsellor/leads/<%= lead._id %>/convert" method="POST">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

      <div class="form-row-responsive" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; margin-bottom: 1.25rem;">
        <div class="form-group" style="margin-bottom:0;">
          <label class="form-label" style="font-size: 10px;">Student Name *</label>
          <input type="text" name="name" class="form-control" value="<%= lead.name %>" required>
        </div>
        <div class="form-group" style="margin-bottom:0;">
          <label class="form-label" style="font-size: 10px;">Phone Contact *</label>
          <input type="tel" name="phone" class="form-control" value="<%= lead.phone %>" required>
        </div>
      </div>

      <div class="form-row-responsive" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; margin-bottom: 1.25rem;">
        <div class="form-group" style="margin-bottom:0;">
          <label class="form-label" style="font-size: 10px;">Portal Login Email *</label>
          <input type="email" name="email" class="form-control" value="<%= lead.email || '' %>" placeholder="student@email.com" required>
        </div>
        <div class="form-group" style="margin-bottom:0;">
          <label class="form-label" style="font-size: 10px;">Portal Password *</label>

          <input type="text" name="password" class="form-control" value="12345678" placeholder="Minimum 8 characters" required>
          <div class="form-hint">Student can reset this on first login. Default set to 12345678.</div>
        </div>
      </div>

      <div class="form-row-responsive" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; margin-bottom: 1.25rem;">
        <div class="form-group" style="margin-bottom:0;">
          <label class="form-label" style="font-size: 10px;">Selected Course *</label>
          <select id="course_select" name="course" class="form-control" required onchange="onCourseOrBatchChange(event)">
            <% ['Video Editing','Digital Marketing','Both'].forEach(c => { %>
              <option value="<%= c %>" <%= (lead.interestedCourse && lead.interestedCourse.name === c) ? 'selected' : '' %>><%= c %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group" style="margin-bottom:0;">
          <label class="form-label" style="font-size: 10px;">Assign Roster Batch *</label>
          <select id="batch_select" name="batch" class="form-control" required onchange="onCourseOrBatchChange(event)">
            <% if (batches && batches.length > 0) { %>
              <% batches.forEach(b => { %>
                <option value="<%= b.name %>" data-course="<%= b.course ? b.course.name : '' %>" data-teachers="<%= JSON.stringify((b.teacherProfileIds || []).map(String)) %>"><%= b.name %> (<%= b.course ? b.course.name : 'No Course' %>)</option>
              <% }); %>
            <% } %>
          </select>
        </div>
      </div>

      <div class="form-row-responsive" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; margin-bottom: 1.25rem;">
        <div class="form-group" style="margin-bottom:0;">
          <label class="form-label" style="font-size: 10px;">Assign Teacher</label>
          <select id="teacher_select" name="teacherId" class="form-control">
            <option value="">— No teacher assigned yet —</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t._id %>" data-user-id="<%= t.userId %>" data-courses="<%= JSON.stringify((t.courses || []).map(String)) %>"><%= t.name %></option>
            <% }); %>
          </select>
        </div>
      </div>

      <div class="form-row-responsive" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; margin-bottom: 1.25rem;">
        <div class="form-group" style="margin-bottom:0;">
          <label class="form-label" style="font-size: 10px;">Total Invoice Fees (₹) *</label>
          <input type="number" id="fees_total" name="fees_total" class="form-control" placeholder="30000" required min="0" oninput="suggestDownPayment()">
        </div>
        <div class="form-group" style="margin-bottom:0;">
          <label class="form-label" style="font-size: 10px;">Initial Down Payment (₹)</label>
          <input type="number" id="fees_paid" name="fees_paid" class="form-control" placeholder="0" value="0" min="0">
          <div class="form-hint" id="downpayment_hint">Minimum 50% downpayment required on conversion.</div>
        </div>
      </div>

      <div class="form-group" style="margin-bottom: 1.25rem;">
        <label class="form-label" style="font-size: 10px;">Registration/Enrollment Date</label>
        <input type="date" name="enrollmentDate" class="form-control"
          value="<%= new Date().toISOString().split('T')[0] %>">
      </div>

      <div style="display:flex; gap:10px; justify-content:flex-end; padding-top:12px; border-top:1px solid var(--border); margin-top:16px;">
        <a href="/counsellor/leads/<%= lead._id %>" class="btn btn-ghost">Cancel</a>
        <button type="submit" class="btn btn-success">Confirm & Enroll Student</button>
      </div>
    </form>
  </div>
</div>

<script>
  function onCourseOrBatchChange(e) {
    const courseSelect = document.getElementById('course_select');
    const batchSelect = document.getElementById('batch_select');
    const selectedCourse = courseSelect.value;

    // Auto-select batch matching selected course when course changes
    if (e && e.target === courseSelect) {
      let foundMatchingBatch = false;
      for (let option of batchSelect.options) {
        if (option.getAttribute('data-course') === selectedCourse) {
          batchSelect.value = option.value;
          foundMatchingBatch = true;
          break;
        }
      }
      if (!foundMatchingBatch) {
        batchSelect.value = '';
      }
    }

    // Hide batches that do not belong to the selected course
    for (let option of batchSelect.options) {
      if (option.value === '') continue;
      const batchCourse = option.getAttribute('data-course');
      if (batchCourse === selectedCourse) {
        option.style.display = 'block';
      } else {
        option.style.display = 'none';
      }
    }

    const teacherSelect = document.getElementById('teacher_select');
    const activeBatchOption = batchSelect.options[batchSelect.selectedIndex];

    let allowedTeacherIds = [];
    if (activeBatchOption && activeBatchOption.value !== '') {
      try {
        allowedTeacherIds = JSON.parse(activeBatchOption.getAttribute('data-teachers') || '[]');
      } catch(e) {}
    }

    let teacherSelected = false;
    for (let option of teacherSelect.options) {
      if (option.value === '') continue;

      if (allowedTeacherIds.length > 0) {
        if (allowedTeacherIds.includes(option.value)) {
          option.style.display = 'block';
          if (!teacherSelected) {
            teacherSelect.value = option.value;
            teacherSelected = true;
          }
        } else {
          option.style.display = 'none';
        }
      } else {
        option.style.display = 'block';
        if (!teacherSelected) {
          teacherSelect.value = option.value;
          teacherSelected = true;
        }
      }
    }

    if (!teacherSelected) {
      teacherSelect.value = '';
    }
  }

  function suggestDownPayment() {
    const totalInput = document.getElementById('fees_total');
    const paidInput = document.getElementById('fees_paid');
    const hint = document.getElementById('downpayment_hint');
    const total = Number(totalInput.value) || 0;

    if (total > 0) {
      const minDown = Math.ceil(total * 0.5);
      paidInput.value = minDown;
      hint.textContent = `Minimum 50% downpayment suggested: ₹${minDown.toLocaleString('en-IN')}`;
      hint.style.color = 'var(--green)';
    } else {
      paidInput.value = 0;
      hint.textContent = 'Minimum 50% downpayment required on conversion.';
      hint.style.color = 'var(--text-muted)';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const courseSelect = document.getElementById('course_select');
    const totalInput = document.getElementById('fees_total');

    if (courseSelect.value === 'Video Editing') {
      totalInput.value = 25000;
    } else if (courseSelect.value === 'Digital Marketing') {
      totalInput.value = 30000;
    } else {
      totalInput.value = 45000;
    }

    suggestDownPayment();
    onCourseOrBatchChange();
  });
</script>
