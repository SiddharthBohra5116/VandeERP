<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Phone</th>
        <th>Course</th>
        <th>Current Status</th>
        <th>Follow-up Date</th>
        <th>Last Note</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% leads.forEach(lead => { %>
        <%
          const statusBadge = {
            new: 'badge-orange',
            contacted: 'badge-blue',
            mentorship_scheduled: 'badge-blue',
            mentorship_attended: 'badge-yellow',
            follow_up: 'badge-yellow',
            joining_interested: 'badge-gold',
            admission_completed: 'badge-green',
            lost: 'badge-red'
          }[lead.status] || 'badge-grey';

          const lastNote = lead.followUpHistory.length > 0
            ? lead.followUpHistory[lead.followUpHistory.length - 1].note
            : null;
        %>
        <tr data-row-href="/counsellor/leads/<%= lead._id %>">
          <td><strong><%= lead.name %></strong></td>
          <td class="td-mono">
            <a href="tel:<%= lead.phone %>" style="color:var(--gold); font-weight:600;"><%= lead.phone %></a>
          </td>
          <td><span class="badge badge-orange"><%= lead.interestedCourse ? lead.interestedCourse.name : 'Undecided' %></span></td>
          <td><span class="badge <%= statusBadge %>"><%= lead.status %></span></td>
          <td class="td-mono" style="color:var(--red); font-weight:600;">
            <%= lead.nextFollowUpAt ? new Date(lead.nextFollowUpAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'2-digit'}) : '—' %>
          </td>
          <td class="td-muted text-sm" style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            <%= lastNote ? lastNote : '—' %>
          </td>
          <td>
            <a href="/counsellor/leads/<%= lead._id %>" class="btn btn-primary btn-xs">Follow Up</a>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<script>
  function initFollowupRowClicks() {
    document.querySelectorAll('[data-row-href]').forEach(row => {
      if (row.dataset.rowReady) return;
      const open = event => {
        if (event.target.closest('a, button, input, select, textarea, form, label')) return;
        if (window.AppSoftNav && typeof window.AppSoftNav.navigateTo === 'function') {
          window.AppSoftNav.navigateTo(row.dataset.rowHref);
        } else {
          window.location.href = row.dataset.rowHref;
        }
      };
      row.addEventListener('click', open);
      row.dataset.rowReady = 'true';
      row.style.cursor = 'pointer';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFollowupRowClicks);
  } else {
    initFollowupRowClicks();
  }

  document.addEventListener('softnav:load', initFollowupRowClicks);
</script>
