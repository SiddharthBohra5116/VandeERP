<%
  layout = 'main';
  title = 'Post Announcement';
  page = 'counsellor-announcements';
%>

<div class="card" style="max-width: 600px; margin: 0 auto;">
  <form action="/counsellor/announcements/create" method="POST">
    <div class="form-group">
      <label class="form-label" for="title">Title *</label>
      <input type="text" id="title" name="title" class="form-control" placeholder="e.g. Schedule Update / Document Submission Reminder" required>
    </div>

    <div class="form-group">
      <label class="form-label" for="content">Content *</label>
      <textarea id="content" name="content" class="form-control" style="min-height: 120px;" placeholder="Describe the announcement details..." required></textarea>
    </div>

    <div class="form-group">
      <label class="form-label">Target Audience</label>
      <input type="text" class="form-control" value="My Assigned Students" disabled>
      <div class="form-hint">Only students assigned to you as their counsellor will see this announcement on their dashboard.</div>
    </div>

    <div style="display:flex; gap:10px; justify-content:flex-end; padding-top:12px; border-top:1px solid var(--border); margin-top:20px;">
      <a href="/counsellor/announcements" class="btn btn-ghost btn-sm">Cancel</a>
      <button type="submit" class="btn btn-primary btn-sm">Post Announcement</button>
    </div>
  </form>
</div>
