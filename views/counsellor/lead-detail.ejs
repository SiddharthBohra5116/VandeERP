<%
  layout = 'main';
  title = lead.name;
  subtitle = `Lead File · ${lead.interestedCourse ? lead.interestedCourse.name : 'Undecided'}`;
  page = 'leads';
  const statusOptions = typeof leadStatuses !== 'undefined'
    ? leadStatuses
    : [
      { key: 'new', label: 'New', badgeClass: 'badge-orange' },
      { key: 'contacted', label: 'Contacted', badgeClass: 'badge-blue' },
      { key: 'mentorship_scheduled', label: 'Mentorship Scheduled', badgeClass: 'badge-blue' },
      { key: 'mentorship_attended', label: 'Mentorship Attended', badgeClass: 'badge-yellow' },
      { key: 'follow_up', label: 'Follow Up', badgeClass: 'badge-yellow' },
      { key: 'joining_interested', label: 'Ready For Admission', badgeClass: 'badge-gold' },
      { key: 'admission_completed', label: 'Admitted', badgeClass: 'badge-green' },
      { key: 'lost', label: 'Lost', badgeClass: 'badge-red' }
    ];
  const dynamicStatusLabels = statusOptions.reduce((map, status) => {
    map[status.key] = status.label;
    return map;
  }, {});
  const dynamicStatusBadges = statusOptions.reduce((map, status) => {
    map[status.key] = status.badgeClass || 'badge-grey';
    return map;
  }, {});
  const dynamicStatusClosed = statusOptions.reduce((map, status) => {
    map[status.key] = Boolean(status.isClosed);
    return map;
  }, {});
%>

<%
  const defaultStatusBadge = {
    new: 'badge-orange',
    contacted: 'badge-blue',
    mentorship_scheduled: 'badge-blue',
    mentorship_attended: 'badge-yellow',
    follow_up: 'badge-yellow',
    joining_interested: 'badge-gold',
    admission_completed: 'badge-green',
    lost: 'badge-red'
  }[lead.status] || 'badge-grey';
  const statusBadge = dynamicStatusBadges[lead.status] || defaultStatusBadge;
  const statusLabels = {
    new: 'New',
    contacted: 'Contacted',
    mentorship_scheduled: 'Mentorship scheduled',
    mentorship_attended: 'Mentorship attended',
    follow_up: 'Follow up',
    joining_interested: 'Ready for admission',
    admission_completed: 'Admitted',
    lost: 'Lost'
  };
  Object.assign(statusLabels, dynamicStatusLabels);
  const activityRecords = typeof leadActivities !== 'undefined' && Array.isArray(leadActivities) ? leadActivities : [];
  const timelineFeed = [{
    title: 'Lead created',
    status: 'new',
    actorName: 'System',
    actorRole: '',
    channel: lead.source || '',
    note: lead.notes || `Lead came from ${lead.source || 'manual entry'}.`,
    date: lead.createdAt
  }];
  activityRecords.forEach(item => {
    timelineFeed.push({
      title: item.title || 'Lead activity',
      status: item.newStatus || item.oldStatus || '',
      actorName: item.doneBy ? item.doneBy.name : 'System',
      actorRole: item.doneBy ? item.doneBy.role : '',
      channel: item.type === 'call' ? 'Call' : item.type === 'whatsapp' ? 'WhatsApp' : item.type,
      callOutcome: item.call?.outcome && item.call.outcome !== 'not-applicable' ? item.call.outcome : '',
      callDuration: item.call?.duration || '',
      nextFollowUpDate: item.followUp?.scheduledFor || '',
      note: item.note || item.whatsapp?.message || '',
      date: item.createdAt
    });
  });
  const activityMatchKeys = new Set(activityRecords.map(item => {
    const when = item.followUp?.completedAt || item.createdAt;
    const minuteBucket = when ? Math.floor(new Date(when).getTime() / 60000) : '';
    const actor = item.doneBy ? item.doneBy.name : 'System';
    const status = item.newStatus || item.oldStatus || '';
    const itemNote = String(item.note || item.whatsapp?.message || '').trim().toLowerCase();
    return `${minuteBucket}|${actor}|${status}|${itemNote}`;
  }));
  lead.followUpHistory.forEach((fu) => {
    const fuMinuteBucket = fu.doneAt ? Math.floor(new Date(fu.doneAt).getTime() / 60000) : '';
    const fuActor = fu.doneBy ? fu.doneBy.name : 'System';
    const fuNote = String(fu.note || '').trim().toLowerCase();
    const fuKey = `${fuMinuteBucket}|${fuActor}|${fu.status || ''}|${fuNote}`;
    if (activityMatchKeys.has(fuKey)) return;
    timelineFeed.push({
      title: fu.channel ? `${fu.channel} logged` : (fu.doneBy && fu.doneBy.role === 'admin' ? 'Admin instruction' : 'Follow-up logged'),
      status: fu.status || '',
      actorName: fu.doneBy ? fu.doneBy.name : 'System',
      actorRole: fu.doneBy ? fu.doneBy.role : '',
      channel: fu.channel || '',
      callOutcome: fu.callOutcome || '',
      callDuration: fu.callDuration || '',
      nextFollowUpDate: fu.nextFollowUpAt || '',
      note: fu.note || '',
      date: fu.doneAt
    });
  });
  const scheduledFollowUpDate = lead.nextFollowUpAt ? new Date(lead.nextFollowUpAt) : null;
  const closedLead = Boolean(dynamicStatusClosed[lead.status]);
  const hasCompletedScheduledFollowUp = scheduledFollowUpDate && activityRecords.some(item => {
    const completedAt = item.followUp?.completedAt ? new Date(item.followUp.completedAt) : null;
    return completedAt && completedAt >= scheduledFollowUpDate;
  });
  const todayStart = new Date();
  todayStart.setHours(0, 0, 0, 0);
  if (scheduledFollowUpDate && scheduledFollowUpDate < todayStart && !closedLead && !hasCompletedScheduledFollowUp) {
    timelineFeed.push({
      title: 'Follow-up missed',
      status: 'follow_up',
      actorName: lead.assignedTo?.user?.name || user.name || 'Counsellor',
      actorRole: 'counsellor',
      channel: 'scheduled',
      callOutcome: 'missed',
      callDuration: '',
      nextFollowUpDate: scheduledFollowUpDate,
      note: 'Scheduled follow-up date passed without a completed follow-up log.',
      date: scheduledFollowUpDate
    });
  }
  const seenTimeline = new Set();
  const cleanTimelineFeed = timelineFeed
    .filter(item => item.date)
    .sort((a, b) => new Date(a.date) - new Date(b.date))
    .filter(item => {
      const minuteBucket = Math.floor(new Date(item.date).getTime() / 60000);
      const identity = `${minuteBucket}|${item.actorName}|${item.status}|${item.channel}|${String(item.note || '').trim().toLowerCase().slice(0, 90)}`;
      if (seenTimeline.has(identity)) return false;
      seenTimeline.add(identity);
      return true;
    });
%>

<style>
  /* Modern Focus & Flow Layout Styles */
  .detail-layout {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 1.5rem;
    align-items: start;
    margin-top: 1rem;
  }

  .profile-header-card {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  .profile-avatar {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: var(--gold-dim);
    border: 1px solid var(--gold-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 800;
    color: var(--gold);
  }

  /* Timeline Horizontal Flow */
  .timeline-horizontal {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    padding: 1.5rem 0.5rem;
    overflow-x: auto;
  }

  .timeline-horizontal::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 20px;
    right: 20px;
    height: 2px;
    background: var(--border);
    transform: translateY(-16px);
    z-index: 1;
  }

  .timeline-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
    text-align: center;
    min-width: 80px;
  }

  .timeline-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    margin-bottom: 8px;
    transition: all 0.3s ease;
  }

  .timeline-node.active .timeline-icon {
    border-color: var(--gold);
    background: var(--gold-dim);
    color: var(--gold);
    box-shadow: 0 0 12px var(--gold-border);
  }

  .timeline-node-title {
    font-size: 10px;
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
    max-width: 90px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .timeline-node-date {
    font-size: 9px;
    color: var(--text-muted);
    font-family: var(--mono);
    margin-top: 2px;
  }

  /* Mini-connector dots matching screenshot */
  .timeline-connector-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border);
    position: absolute;
    top: 50%;
    transform: translateY(-19px);
    z-index: 1;
  }

  /* Form Layout Grid */
  .form-grid-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .form-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  /* Touch Targets & Button overrides */
  .btn-premium-action {
    background: #eab308;
    color: #000;
    font-weight: 700;
    padding: 12px 20px;
    border-radius: var(--radius);
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    box-shadow: 0 4px 12px rgba(234, 179, 8, 0.15);
  }

  .btn-premium-action:hover {
    background: #ca8a04;
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(234, 179, 8, 0.25);
  }

  .btn-premium-action:active {
    transform: translateY(0);
  }

  /* Handoff Ready Banner style */
  .handoff-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px;
    border-radius: var(--radius);
    background: var(--gold-dim);
    border: 1px solid var(--gold-border);
    color: var(--gold);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .lead-story { position:relative; display:grid; gap:.9rem; padding-left:1.55rem; }
  .lead-story::before { content:''; position:absolute; left:.52rem; top:.35rem; bottom:.35rem; width:2px; background:var(--border); }
  .lead-story-item { position:relative; display:grid; grid-template-columns:minmax(120px,150px) minmax(0,1fr); gap:1rem; padding:.9rem; border:1px solid var(--border); border-radius:8px; background:var(--bg-input); }
  .lead-story-item::before { content:''; position:absolute; left:-1.48rem; top:1.05rem; width:13px; height:13px; border-radius:50%; background:var(--gold); border:3px solid var(--bg-card); box-shadow:0 0 0 2px var(--gold-border); }
  .lead-story-time { color:var(--text); font-weight:900; font-size:.82rem; line-height:1.35; border:0; background:transparent; padding:0; text-align:left; cursor:pointer; font-family:inherit; }
  .lead-story-time:hover { color:var(--gold); }
  .lead-story-time span { display:block; color:var(--text-muted); font-size:.72rem; font-weight:750; margin-top:.15rem; }
  .lead-story-top { display:flex; align-items:center; gap:.45rem; flex-wrap:wrap; margin-bottom:.35rem; }
  .lead-story-action { font-size:.94rem; font-weight:900; }
  .lead-story-actor { color:var(--text-sub); font-size:.78rem; font-weight:750; margin-bottom:.45rem; }
  .lead-story-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:.6rem; margin:.65rem 0; }
  .lead-story-fact { padding:.55rem .65rem; border:1px solid var(--border); border-radius:8px; background:var(--bg-card); min-width:0; }
  .lead-story-fact b { display:block; color:var(--text-muted); font-size:.62rem; font-weight:900; text-transform:uppercase; letter-spacing:.04em; margin-bottom:.18rem; }
  .lead-story-fact span { display:block; color:var(--text); font-size:.78rem; font-weight:800; overflow-wrap:anywhere; }
  .lead-story-note { color:var(--text-sub); font-size:.88rem; line-height:1.55; overflow-wrap:anywhere; }

  /* Card and input custom responsiveness */
  .form-control {
    min-height: 40px;
  }

  /* Mobile-first Progressive Stacking */
  @media (max-width: 1024px) {
    .detail-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .form-row-2 {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .btn-premium-action, .btn {
      min-height: 48px;
    }

    /* Sticky footer submission on mobile */
    .mobile-sticky-footer {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--bg-card);
      border-top: 1px solid var(--border);
      padding: 12px 16px;
      z-index: 999;
      box-shadow: 0 -4px 16px rgba(0,0,0,0.15);
    }

    .mobile-sticky-footer .btn-premium-action {
      margin: 0;
    }

    /* Add padding to page bottom to prevent overlapping with sticky footer */
    .page-content {
      padding-bottom: 80px;
    }
  }
</style>

<!-- Page Action Header -->
<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
  <a href="/counsellor/leads" class="btn btn-ghost btn-sm" style="min-height:36px; display:inline-flex; align-items:center;">&larr; Back to Leads</a>
  <a href="/counsellor/leads/<%= lead._id %>/edit" class="btn btn-ghost btn-sm" style="min-height:36px; display:inline-flex; align-items:center;">Edit File</a>
</div>

<script>
  function toggleCounsellorHistory(detailId) {
    const detail = document.getElementById(detailId);
    if (!detail) return;
    detail.style.display = detail.style.display === 'none' || !detail.style.display ? 'grid' : 'none';
  }

  function lockFollowupSubmit(form) {
    if (form.dataset.submitting === 'true') return false;
    form.dataset.submitting = 'true';
    const button = form.querySelector('[type="submit"]');
    if (button) {
      button.disabled = true;
      button.textContent = 'Saving...';
    }
    return true;
  }
</script>

<div class="detail-layout">

  <!-- Left: Lead Info & Activity Timeline -->
  <div style="display:flex; flex-direction:column; gap:1.5rem;">

    <!-- Lead Profile Info Card -->
    <div class="card">
      <div class="profile-header-card">
        <div class="profile-avatar">
          <%= lead.name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2) %>
        </div>
        <div>
          <div style="font-size:20px; font-weight:700; color:var(--text);"><%= lead.name %></div>
          <div style="display:flex; gap:8px; align-items:center; margin-top:6px;">
            <span class="badge <%= statusBadge %>" style="text-transform: uppercase;"><%= statusLabels[lead.status] || lead.status.replace(/_/g, ' ') %></span>
            <span class="badge badge-orange" style="text-transform: uppercase;"><%= lead.interestedCourse ? lead.interestedCourse.name : 'Undecided' %></span>
          </div>
          <%
            const calls = lead.followUpHistory.filter(h => h.channel === 'Call');
          %>
          <div style="display:flex; align-items:center; gap:6px; margin-top:8px;">
            <span style="font-size:10px; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.05em;">Calls:</span>
            <div style="display:flex; gap:4px;">
              <% for (let i = 0; i < Math.max(3, calls.length); i++) { %>
                <%
                  const call = calls[i];
                  let dotColor = '#242424';
                  let dotBorder = '1px solid var(--border)';
                  let titleText = `Call ${i + 1}: No Attempt`;
                  if (call) {
                    titleText = `Call ${i + 1}: ${(call.callOutcome || 'answered').toUpperCase()} (${call.callDuration || 'no duration'}) - ${call.note}`;
                    if (call.callOutcome === 'answered') {
                      dotColor = 'var(--green)';
                    } else if (call.callOutcome === 'busy' || call.callOutcome === 'no-answer') {
                      dotColor = 'var(--red)';
                    } else {
                      dotColor = 'var(--orange)';
                    }
                    dotBorder = 'none';
                  }
                %>
                <span class="call-dot" title="<%= titleText %>" <%= `style="width:10px; height:10px; border-radius:50%; background:${dotColor}; border:${dotBorder}; display:inline-block; cursor:help;"` %>></span>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <hr class="divider">

      <div style="display:flex; flex-direction:column; gap:12px;">
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Phone</span>
          <a href="tel:<%= lead.phone %>" style="font-family:var(--mono); font-size:13px; color:var(--gold); font-weight:600;">
            <%= lead.phone %>
          </a>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Email</span>
          <span class="mono text-sm"><%= lead.email || '—' %></span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Source</span>
          <span class="text-sm"><%= lead.source %></span>
        </div>
        <% if (lead.referredBy) { %>
          <div>
            <span class="text-xs text-muted">Referred by</span>
            <span class="text-sm"><%= lead.referredBy %></span>
          </div>
        <% } %>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Course Interest</span>
          <span class="text-sm"><%= lead.interestedCourse ? lead.interestedCourse.name : 'Undecided' %></span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Follow-up Date</span>
         <% const isOverdue = lead.nextFollowUpAt && new Date(lead.nextFollowUpAt) < new Date() && lead.status !== 'admission_completed' && lead.status !== 'lost'; %>
          <span class="mono text-sm" <%= isOverdue ? 'style="color: var(--red);"' : 'style="color: var(--text);"' %>>
            <%= lead.nextFollowUpAt ? new Date(lead.nextFollowUpAt).toLocaleDateString('en-IN', {weekday:'short',day:'numeric',month:'short',year:'numeric'}) : '—' %>
            <% if (isOverdue) { %> ⚠️<% } %>
          </span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted text-sm">Added On</span>
          <span class="mono text-sm"><%= new Date(lead.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></span>
        </div>
      </div>

      <% if (lead.notes) { %>
        <hr class="divider">
        <div>
          <div class="form-label" style="margin-bottom:6px; font-size: 10px;">Inquiry Notes</div>
          <div style="font-size:13px; color:var(--text-sub); line-height:1.6; background:var(--bg-input); padding:10px 12px; border-radius:var(--radius); border: 1px solid var(--border);">
            <%= lead.notes %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="card">
      <div class="card-header" style="border-bottom:1px solid var(--border); padding-bottom:10px; margin-bottom:16px;">
        <div>
          <div class="card-title">Counsellor Work History</div>
          <div class="card-sub">Recent activity first &middot; <%= cleanTimelineFeed.length %> entries</div>
        </div>
      </div>

      <% if (cleanTimelineFeed.length === 0) { %>
        <div class="empty-state" style="padding:2rem 1rem;">
          <p>No work history recorded yet.</p>
        </div>
      <% } else { %>
        <div class="lead-story">
          <% cleanTimelineFeed.slice().sort((a, b) => new Date(b.date) - new Date(a.date)).forEach((item, index) => {
              const detailId = `counsellor-history-detail-${index}`;
              const defaultItemStatusClass = {
                new: 'badge-orange',
                contacted: 'badge-blue',
                mentorship_scheduled: 'badge-blue',
                mentorship_attended: 'badge-yellow',
                follow_up: 'badge-yellow',
                joining_interested: 'badge-gold',
                admission_completed: 'badge-green',
                lost: 'badge-red'
              }[item.status] || 'badge-grey';
              const itemStatusClass = dynamicStatusBadges[item.status] || defaultItemStatusClass;
          %>
            <div class="lead-story-item">
              <button type="button" class="lead-story-time" onclick="toggleCounsellorHistory('<%= detailId %>')">
                <%= new Date(item.date).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %>
                <span><%= new Date(item.date).toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'}) %></span>
              </button>
              <div>
                <div class="lead-story-top">
                  <span class="lead-story-action"><%= item.title %></span>
                  <% if (item.status) { %>
                    <span class="badge <%= itemStatusClass %>"><%= (statusLabels[item.status] || item.status).toString().replace(/_/g, ' ') %></span>
                  <% } %>
                </div>
                <div class="lead-story-actor">
                  <%= item.actorName || 'System' %><%= item.actorRole ? ` (${item.actorRole})` : '' %>
                </div>
                <div class="lead-story-note"><%= item.note || 'No note added.' %></div>
                <div id="<%= detailId %>" class="lead-story-grid" style="display:none;">
                  <div class="lead-story-fact"><b>Channel</b><span><%= item.channel || 'Not set' %></span></div>
                  <div class="lead-story-fact"><b>Result</b><span><%= [item.callOutcome, item.callDuration].filter(Boolean).join(' - ') || 'Not set' %></span></div>
                  <div class="lead-story-fact"><b>Next follow-up</b><span><%= item.nextFollowUpDate ? new Date(item.nextFollowUpDate).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) : 'Not set' %></span></div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Activity Timeline Card -->
    <div class="card" style="display:none;">
      <div class="card-header" style="border-bottom:1px solid var(--border); padding-bottom:10px; margin-bottom:16px;">
        <div>
          <div class="card-title">Lead Timeline</div>
          <div class="card-sub"><%= lead.followUpHistory.length %> entries logged</div>
        </div>
      </div>

      <% if (lead.followUpHistory.length === 0) { %>
        <div class="empty-state" style="padding: 2.5rem 1.5rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <p>No activity logs recorded yet.</p>
        </div>
      <% } else { %>
        <div class="timeline" style="padding-left:0.5rem;">
          <%
            const reversedHistory = lead.followUpHistory.slice().reverse();
            reversedHistory.forEach((fu) => {
              const originalIndex = lead.followUpHistory.findIndex(item => item === fu);
              const defaultFuBadge = {
                new: 'badge-orange',
                contacted: 'badge-blue',
                mentorship_scheduled: 'badge-blue',
                mentorship_attended: 'badge-yellow',
                follow_up: 'badge-yellow',
                joining_interested: 'badge-gold',
                admission_completed: 'badge-green',
                lost: 'badge-red'
              }[fu.status] || 'badge-grey';
              const fuBadge = dynamicStatusBadges[fu.status] || defaultFuBadge;
          %>
            <div class="timeline-item">
              <div class="timeline-dot <%= fu.doneBy && fu.doneBy.role === 'admin' ? 'active' : '' %>"></div>
              <div class="timeline-body" <%= fu.doneBy && fu.doneBy.role === 'admin' ? 'style="border-left: 2px solid var(--gold-border); padding-left: 10px;"' : '' %>>
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:2px; flex-wrap: wrap; gap:8px;">
                  <div style="display:flex; align-items:center; gap:8px; flex-wrap: wrap;">
                    <% if (fu.doneBy && fu.doneBy.role === 'admin') { %>
                      <div style="font-size:12px; font-weight:700; color:var(--gold); display:flex; align-items:center; gap:0.25rem;">
                        👑 Admin Instruction
                      </div>
                    <% } else { %>
                      <div style="font-size:12px; font-weight:600; color:var(--text);">
                        Status update &rarr; <span class="badge <%= fuBadge %>" style="font-size:9px; padding:1px 4px; text-transform: uppercase;"><%= fu.status %></span>
                      </div>
                    <% } %>

                    <% if (fu.channel) { %>
                      <span class="badge badge-grey" style="font-size:9px; padding:1px 4px; display:inline-flex; align-items:center; gap:3px;">
                        <% if (fu.channel === 'Call') { %>
                          📞 Call <%= fu.callAttemptNumber ? `#${fu.callAttemptNumber}` : '' %>
                          <% if (fu.callOutcome) { %>
                            (<%= fu.callOutcome %> <%= fu.callDuration ? `· ${fu.callDuration}` : '' %>)
                          <% } %>
                        <% } else if (fu.channel === 'WhatsApp') { %>
                          💬 WhatsApp
                        <% } else if (fu.channel === 'In-person') { %>
                          🚶 In-person
                        <% } %>
                      </span>
                    <% } %>
                  </div>

                  <% if (fu.doneBy && String(fu.doneBy._id || fu.doneBy) === String(user._id)) { %>
                    <button class="btn btn-ghost btn-xs" onclick="toggleEditTimeline('<%= originalIndex %>')" style="padding:2px 6px; font-size:10px;">Edit</button>
                  <% } %>
                </div>
                <div class="timeline-meta">
                  <%= fu.doneBy ? fu.doneBy.name : 'System' %> (<%= fu.doneBy ? fu.doneBy.role : 'admin' %>) &nbsp;·&nbsp;
                  <%= new Date(fu.doneAt).toLocaleDateString('en-IN', {weekday:'short',day:'numeric',month:'short'}) %> &nbsp;·&nbsp;
                  <%= new Date(fu.doneAt).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %>
                </div>

                <!-- Display Note -->
                <div id="note-display-<%= originalIndex %>" class="mt-1 text-sm" <%= fu.doneBy && fu.doneBy.role === 'admin' ? 'style="line-height:1.4; color:var(--text); font-style:italic;"' : 'style="line-height:1.4; color:var(--text-sub);"' %>>
                  <%= fu.note %>
                </div>

                <!-- Edit Note Form -->
                <div id="note-edit-<%= originalIndex %>" style="display:none; margin-top:8px;">
                  <form action="/counsellor/leads/<%= lead._id %>/followup/<%= originalIndex %>/edit" method="POST" style="margin:0;">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <div class="form-group" style="margin-bottom:6px;">
                      <textarea name="note" class="form-control" style="font-size:13px; padding:6px 10px; min-height:60px;" required maxlength="500"><%= fu.note %></textarea>
                    </div>
                    <div style="display:flex; gap:6px; justify-content:flex-end;">
                      <button type="button" class="btn btn-ghost btn-xs" onclick="toggleEditTimeline('<%= originalIndex %>')">Cancel</button>
                      <button type="submit" class="btn btn-primary btn-xs">Save</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          <% }); %>
        </div>

        <script>
          function toggleEditTimeline(index) {
            const displayDiv = document.getElementById(`note-display-${index}`);
            const editDiv = document.getElementById(`note-edit-${index}`);
            if (displayDiv.style.display === 'none') {
              displayDiv.style.display = 'block';
              editDiv.style.display = 'none';
            } else {
              displayDiv.style.display = 'none';
              editDiv.style.display = 'block';
            }
          }
        </script>
      <% } %>
    </div>
  </div>

  <!-- Right: Touchpoint Timeline, Log Follow-up & Actions -->
  <div style="display:flex; flex-direction:column; gap:1.5rem;">

    <!-- Touchpoint Timeline Card -->
    <div class="card" style="padding: 20px; display:none;">
      <div class="card-title" style="margin-bottom: 8px;">Touchpoint Timeline</div>
      <div class="timeline-horizontal">

        <!-- Generated Connector Lines & Small Intermediary Ticks -->
        <%
          const timelineEvents = [
            { title: 'Created', date: lead.createdAt, channel: lead.source || 'Walk-in' }
          ];
          lead.followUpHistory.forEach(fu => {
            timelineEvents.push({
              title: fu.status.toUpperCase().replace(/_/g, ' '),
              date: fu.doneAt,
              channel: fu.channel || 'Call'
            });
          });
          timelineEvents.sort((a, b) => new Date(a.date) - new Date(b.date));

          // Display up to 5 events or recent milestones to avoid rendering overload
          const renderEvents = timelineEvents.slice(-5);
        %>

        <% for (let i = 0; i < renderEvents.length; i++) { %>
          <% const event = renderEvents[i]; %>

          <div class="timeline-node active">
            <div class="timeline-icon">
              <% if (event.channel === 'WhatsApp') { %>
                💬
              <% } else if (event.channel === 'In-person') { %>
                🚶
              <% } else if (event.channel === 'Call') { %>
                📞
              <% } else { %>
                🌐
              <% } %>
            </div>
            <div class="timeline-node-title" title="<%= event.title %>">
              <%= event.title %>
            </div>
            <div class="timeline-node-date">
              <%= new Date(event.date).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %>
            </div>
          </div>

          <% if (i < renderEvents.length - 1) { %>
            <!-- Minor dot connector element matching design mockup -->
            <div class="timeline-connector-dot" style="left: <%= 20 + i * (100 / (renderEvents.length - 1)) + (100 / (renderEvents.length - 1)) / 2 %>%"></div>
          <% } %>
        <% } %>
      </div>
    </div>

    <!-- Quick Status Update Card (Log Follow-up) -->
    <div class="card">
      <div class="card-title" style="margin-bottom: 16px;">Log Follow-up & Update Status</div>
      <form action="/counsellor/leads/<%= lead._id %>/followup" method="POST" id="followupForm" data-no-soft-nav="true" onsubmit="return lockFollowupSubmit(this)">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

        <div class="form-grid-layout">
          <!-- Row 1: Status Selection & Follow-up Date -->
          <div class="form-row-2">
            <div class="form-group">
              <label class="form-label" style="font-size: 10px;">New Status</label>
              <select name="status" class="form-control" required>
                <% if (!statusOptions.length) { %>
                  <option value="<%= lead.status || 'new' %>">No statuses configured</option>
                <% } %>
                <% statusOptions.forEach(s => { %>
                  <option value="<%= s.key %>" <%= lead.status === s.key ? 'selected' : '' %>><%= s.label %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" style="font-size: 10px;">Next Follow-up Date</label>
              <input type="date" name="followUpDate" class="form-control"
                value="<%= lead.nextFollowUpAt ? new Date(lead.nextFollowUpAt).toISOString().split('T')[0] : '' %>">
            </div>
          </div>

          <!-- Row 2: Interaction Channel & Call Outcome (Conditional on left) -->
          <div class="form-row-2">
            <div class="form-group">
              <label class="form-label" style="font-size: 10px;">Interaction Channel</label>
              <select name="channel" id="channelSelect" class="form-control" required onchange="toggleCallFields()">
                <option value="Call" selected>Call</option>
                <option value="WhatsApp">WhatsApp</option>
                <option value="In-person">In-person</option>
              </select>
            </div>

            <div class="form-group" id="callOutcomeGroup">
              <label class="form-label" style="font-size: 10px;">Call Outcome</label>
              <select name="callOutcome" class="form-control">
                <option value="answered" selected>Answered</option>
                <option value="busy">Busy</option>
                <option value="voicemail">Voicemail</option>
                <option value="no-answer">No Answer</option>
                <option value="callback">Callback Requested</option>
              </select>
            </div>
          </div>

          <!-- Row 3: Call Duration & Interaction Notes -->
          <div class="form-row-2" id="row3Container">
            <div class="form-group" id="callDurationGroup">
              <label class="form-label" style="font-size: 10px;">Call Duration (e.g. 45s, 2m)</label>
              <input type="text" name="callDuration" class="form-control" placeholder="e.g. 1m 30s">
            </div>

            <div class="form-group" id="notesGroup" style="grid-column: span 1;">
              <label class="form-label" style="font-size: 10px;">Interaction Notes *</label>
              <textarea name="note" class="form-control" placeholder="What happened in this conversation?" required maxlength="500" style="min-height: 84px; resize: vertical;"></textarea>
            </div>
          </div>

          <!-- Save Button Container (Mobile-Optimized Action Target) -->
          <div class="form-group" id="submitButtonContainer" style="margin-top: 4px; margin-bottom: 0;">
            <button type="submit" class="btn-premium-action" data-submit-label="Save Update Log">Save Update Log</button>
          </div>
        </div>
      </form>
    </div>

    <script>
      function toggleCallFields() {
        const select = document.getElementById('channelSelect');
        const callOutcomeGroup = document.getElementById('callOutcomeGroup');
        const callDurationGroup = document.getElementById('callDurationGroup');
        const notesGroup = document.getElementById('notesGroup');
        const row3 = document.getElementById('row3Container');

        if (select.value === 'Call') {
          callOutcomeGroup.style.display = 'block';
          callDurationGroup.style.display = 'block';
          notesGroup.style.gridColumn = 'span 1';
        } else {
          callOutcomeGroup.style.display = 'none';
          callDurationGroup.style.display = 'none';
          notesGroup.style.gridColumn = 'span 2';
        }
      }

      // Auto-initialize responsive layout on load
      document.addEventListener('DOMContentLoaded', toggleCallFields);

      // Handle progressive sticky footer behavior on small screens
      document.addEventListener('DOMContentLoaded', () => {
        const checkSticky = () => {
          const container = document.getElementById('submitButtonContainer');
          const isMobile = window.innerWidth <= 768;
          if (isMobile) {
            container.classList.add('mobile-sticky-footer');
          } else {
            container.classList.remove('mobile-sticky-footer');
          }
        };

        window.addEventListener('resize', checkSticky);
        checkSticky();
      });
    </script>

    <!-- Handoff Action Cards (Ready to Convert / Convert to Student) -->
    <% if (lead.status !== 'admission_completed') { %>

      <!-- Handoff Banner -->
      <% if (lead.status === 'joining_interested') { %>
        <div class="handoff-banner">
          ✨ Ready to Convert (Flagged for Admin)
        </div>
      <% } else { %>
        <div class="card" style="border-color:rgba(146,120,224,0.25); background: linear-gradient(180deg, rgba(146,120,224,0.02) 0%, rgba(0,0,0,0) 100%);">
          <div class="card-title" style="color:var(--gold); margin-bottom:4px;">
            Ready to Convert Handoff
          </div>
          <div class="form-hint" style="margin-bottom:12px;">Flag this lead as ready to convert for Admin finalisation.</div>
          <form action="/counsellor/leads/<%= lead._id %>/ready" method="POST" style="margin:0;">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            <button type="submit" class="btn btn-primary btn-block btn-sm" style="min-height: 40px;">Mark as Ready to Convert</button>
          </form>
        </div>
      <% } %>

      <!-- Convert Card -->
      <div class="card" style="border-color:rgba(34,197,94,0.25); background: linear-gradient(180deg, rgba(34,197,94,0.02) 0%, rgba(0,0,0,0) 100%);">
        <div class="card-title" style="color:var(--green); margin-bottom:4px; display:flex; align-items:center; gap:0.4rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Convert to Student
        </div>
        <div class="form-hint" style="margin-bottom:12px;">Process this query to a registered student profile and ledger.</div>
        <a href="/counsellor/leads/<%= lead._id %>/convert" class="btn btn-success btn-block btn-sm" style="min-height: 40px; display: flex; align-items: center; justify-content: center;">
          Convert to Student Account
        </a>
      </div>

    <% } else { %>
      <div class="card" style="border-color:rgba(34,197,94,0.25); text-align:center; padding:20px;">
        <div style="font-size:24px; margin-bottom:6px;">✅</div>
        <div style="font-size:13px; color:var(--green); font-weight:600;">Admitted & Converted Student</div>
        <% if (lead.convertedStudent) { %>
          <div style="margin-top: 12px; font-size: 13px; color: var(--text-sub);">
             Roster account created.
          </div>
        <% } %>
      </div>
    <% } %>

  </div>

</div>
