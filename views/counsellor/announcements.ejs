<%
  layout = 'main';
  title = 'My Announcements';
  page = 'counsellor-announcements';
%>

<div class="card" style="padding: 1rem 1.25rem; margin-bottom: 1.25rem; display: flex; justify-content: flex-end;">
  <a href="/counsellor/announcements/create" class="btn btn-primary btn-sm">+ Post to Assigned Students</a>
</div>

<div class="card">
  <% if (announcements.length === 0) { %>
    <div class="empty-state" style="padding: 3rem 1.5rem; text-align: center;">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted); margin-bottom: 1rem;"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <p style="color: var(--text-muted);">No announcements posted yet. Click "Post to Assigned Students" to notify them.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Title & Content</th>
            <th>Target</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% announcements.forEach(a => { %>
            <tr>
              <td>
                <div style="font-weight: 600; color: var(--gold);"><%= a.title %></div>
                <div style="font-size: 0.8rem; color: var(--text); margin-top: 4px; max-width: 450px; word-wrap: break-word;"><%= a.content %></div>
                <div style="font-size: 0.72rem; color: var(--text-muted); margin-top: 4px;">Posted: <%= new Date(a.createdAt).toLocaleString('en-IN') %></div>
              </td>
              <td>
                <span class="badge badge-blue">👥 Assigned Students</span>
              </td>
              <td>
                <span class="badge <%= a.isActive ? 'badge-green' : 'badge-grey' %>">
                  <%= a.isActive ? 'Active' : 'Inactive' %>
                </span>
              </td>
              <td>
                <form action="/counsellor/announcements/<%= a._id %>/toggle" method="POST" style="margin: 0;">
                  <button type="submit" class="btn btn-ghost btn-xs">
                    <%= a.isActive ? 'Deactivate' : 'Activate' %>
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
