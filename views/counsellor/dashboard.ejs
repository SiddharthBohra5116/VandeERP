<%
  layout = 'main';
  title = 'Counsellor Dashboard';
  subtitle = 'Your CRM overview for today';
  page = 'dashboard';
%>

<!-- Greeting Header -->
<h2 id="dashboardGreeting" class="dashboard-greeting">Welcome back!</h2>

<!-- Stats Grid -->
<div class="stats-grid">
  <a href="/counsellor/leads" class="stat-card gold">
    <div class="stat-label">Total Leads</div>
    <div class="stat-value"><%= stats.total %></div>
    <div class="stat-sub">All time queries</div>
  </a>
  <a href="/counsellor/leads?status=new" class="stat-card orange">
    <div class="stat-label">New Today</div>
    <div class="stat-value"><%= stats.newToday %></div>
    <div class="stat-sub">Needs follow-up</div>
  </a>
  <a href="/counsellor/leads/followups" class="stat-card blue">
    <div class="stat-label">Follow-ups Due</div>
    <div class="stat-value"><%= stats.followupsDue %></div>
    <div class="stat-sub">Today & overdue</div>
  </a>
  <a href="/counsellor/admissions" class="stat-card green">
    <div class="stat-label">Converted</div>
    <div class="stat-value"><%= stats.converted %></div>
    <div class="stat-sub">Admitted students</div>
  </a>
  <a href="/counsellor/leads?status=lost" class="stat-card red">
    <div class="stat-label">Lost</div>
    <div class="stat-value"><%= stats.lost %></div>
    <div class="stat-sub">Inactive leads</div>
  </a>
</div>

<% if (stats && stats.followupsDue > 0) { %>
  <div class="card" id="followupNotificationPrompt" style="margin-top:1.25rem; display:none; border-color:var(--gold-border);">
    <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap;">
      <div>
        <div class="card-title">Follow-up Reminder Notifications</div>
        <div class="card-sub"><%= stats.followupsDue %> follow-up<%= stats.followupsDue === 1 ? '' : 's' %> due. Enable browser alerts so you do not miss callbacks.</div>
      </div>
      <button type="button" class="btn btn-primary btn-sm" id="enableFollowupNotificationsBtn">Enable Notifications</button>
    </div>
  </div>

  <script>
    (function() {
      const dueCount = <%= stats.followupsDue %>;
      if (!('Notification' in window) || dueCount <= 0) return;

      const todayKey = new Date().toISOString().slice(0, 10);
      const storageKey = 'followup-notified-' + todayKey;
      const prompt = document.getElementById('followupNotificationPrompt');
      const enableBtn = document.getElementById('enableFollowupNotificationsBtn');

      function showReminder() {
        if (localStorage.getItem(storageKey) === '1') return;
        new Notification('Follow-ups due today', {
          body: dueCount + ' lead follow-up' + (dueCount === 1 ? ' is' : 's are') + ' due or overdue.',
          tag: 'counsellor-followups'
        });
        localStorage.setItem(storageKey, '1');
      }

      if (Notification.permission === 'granted') {
        showReminder();
      } else if (Notification.permission === 'default' && prompt) {
        prompt.style.display = 'block';
      }

      if (enableBtn) {
        enableBtn.addEventListener('click', async () => {
          const permission = await Notification.requestPermission();
          if (permission === 'granted') {
            prompt.style.display = 'none';
            showReminder();
          }
        });
      }
    })();
  </script>
<% } %>

<!-- Admin Notifications / Alerts -->
<div class="card" style="margin-bottom: 1.5rem; border-color: var(--gold-border); background: linear-gradient(180deg, rgba(255,204,0,0.02) 0%, rgba(0,0,0,0) 100%);">
  <div class="card-header card-header--divided">
    <div class="card-title" style="color:var(--gold); font-size:0.75rem; letter-spacing:0.05em; display:flex; align-items:center; gap:0.4rem; text-transform: uppercase;">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      Admin Alerts & Notifications
    </div>
  </div>
  <% if (typeof messages === 'undefined' || !messages || messages.length === 0) { %>
    <div class="empty-state" style="padding: 1.5rem 1rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.2; margin-bottom:0.5rem;"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <p style="font-size:0.78rem;">No personal messages or notifications from the administrator.</p>
    </div>
  <% } else { %>
    <div style="display:flex; flex-direction:column; gap:0.6rem; padding: 0.25rem 0.5rem;">
      <% messages.forEach(msg => { %>
        <div style="background:var(--bg-input); padding:0.65rem 0.85rem; border-radius:var(--radius); border-left: 2px solid var(--gold); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); border-right: 1px solid var(--border);">
          <p style="font-size:0.85rem; color:var(--text); line-height:1.4; margin: 0;"><%= msg.content %></p>
          <% if (msg.isAnnouncement) { %>
            <div style="display:flex; align-items:center; gap:0.5rem; margin-top:0.45rem; flex-wrap:wrap;">
              <span class="badge <%= msg.isRead ? 'badge-grey' : 'badge-gold' %>"><%= msg.isRead ? 'Read' : 'Unread' %></span>
              <% if (!msg.isRead) { %>
                <form action="/auth/announcements/<%= msg._id %>/read" method="POST" style="margin:0;">
                  <button type="submit" class="btn btn-ghost btn-xs">Mark read</button>
                </form>
              <% } %>
            </div>
          <% } %>
          <div style="display:flex; justify-content:space-between; font-size:0.7rem; color:var(--text-muted); margin-top:0.35rem;">
            <span>From: <%= msg.sender ? msg.sender.name : 'Admin' %> (<%= msg.sender ? msg.sender.role : 'System' %>)</span>
            <span><%= new Date(msg.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %> · <%= new Date(msg.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<div class="grid-2">

  <!-- Pipeline Overview -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">Lead Pipeline breakdown</div>
      <a href="/counsellor/leads" class="btn btn-ghost btn-sm">View All &rarr;</a>
    </div>

    <% const pipelineStages = [
      { key: 'new',                  label: 'New',                badge: 'badge-orange' },
      { key: 'contacted',            label: 'Contacted',          badge: 'badge-blue' },
      { key: 'mentorship_scheduled', label: 'Mentorship Sched',   badge: 'badge-blue' },
      { key: 'joining_interested',   label: 'Joining Interested', badge: 'badge-gold' },
      { key: 'admission_completed',  label: 'Admitted',           badge: 'badge-green' },
      { key: 'lost',                 label: 'Lost',               badge: 'badge-red' },
    ]; %>

    <div style="display:flex; flex-direction:column; gap:1rem;">
      <% pipelineStages.forEach(s => { %>
        <% const count = stats.byStatus[s.key] || 0; %>
        <% const pct = stats.total > 0 ? Math.round((count / stats.total) * 100) : 0; %>
        <div>
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:5px;">
            <span class="badge <%= s.badge %>"><%= s.label %></span>
            <span class="mono text-sm text-muted" style="font-family:var(--font-body); font-size:12px;"><%= count %> <span style="color:var(--text-muted); font-size:11px;">(<%= pct %>%)</span></span>
          </div>
          <div class="progress-bar">
            <div class="progress-fill <%= s.key === 'new' ? 'orange' : s.key === 'contacted' ? 'blue' : s.key === 'interested' ? '' : s.key === 'converted' ? 'green' : 'red' %>"
                 style="width:<%= pct %>%"></div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- Today's Prioritized Task Queue -->
  <div class="card">
    <div class="card-header" style="border-bottom: 1px solid var(--border); padding-bottom:10px; margin-bottom:12px;">
      <div>
        <div class="card-title">Today's Task Queue</div>
        <div class="card-sub">Prioritized leads and student follow-ups</div>
      </div>
    </div>

    <!-- Tab Navigation -->
    <div style="display: flex; gap: 6px; border-bottom: 1px solid var(--border); padding-bottom: 8px; margin-bottom: 12px; overflow-x: auto; white-space: nowrap;">
      <button class="btn btn-xs btn-ghost active-tab-btn" onclick="switchTaskTab('overdue-tab')" id="overdue-tab-btn" style="display: inline-flex; align-items: center; gap: 4px; font-weight: 600; padding: 4px 8px; border-radius: var(--radius);">
        Overdue
        <span class="badge badge-red" style="font-size: 8px; padding: 1px 4px;"><%= overdueCallbacks.length %></span>
      </button>
      <button class="btn btn-xs btn-ghost" onclick="switchTaskTab('today-tab')" id="today-tab-btn" style="display: inline-flex; align-items: center; gap: 4px; font-weight: 600; padding: 4px 8px; border-radius: var(--radius);">
        Today
        <span class="badge badge-gold" style="font-size: 8px; padding: 1px 4px;"><%= todayCallbacks.length %></span>
      </button>
      <button class="btn btn-xs btn-ghost" onclick="switchTaskTab('fees-tab')" id="fees-tab-btn" style="display: inline-flex; align-items: center; gap: 4px; font-weight: 600; padding: 4px 8px; border-radius: var(--radius);">
        Fee Dues
        <span class="badge badge-orange" style="font-size: 8px; padding: 1px 4px;"><%= feeCallbacks.length %></span>
      </button>
    </div>

    <!-- Tab Content Blocks -->
    
    <!-- Overdue Tab -->
    <div id="overdue-tab" class="task-tab-content" style="display: block;">
      <% if (overdueCallbacks.length === 0) { %>
        <div class="empty-state" style="padding: 1.5rem 1rem;">
          <p style="font-size: 0.78rem; color: var(--text-muted);">🎉 Awesome! No overdue callbacks.</p>
        </div>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:0.5rem; max-height: 250px; overflow-y: auto;">
          <% overdueCallbacks.forEach(lead => { %>
            <div style="display:flex; align-items:center; justify-content:space-between; padding:8px; border:1px solid var(--border); border-radius:var(--radius); background:var(--bg-input);">
              <div style="flex: 1; min-width: 0; margin-right: 8px;">
                <div style="font-size:12px; font-weight:600; color:var(--text); text-overflow: ellipsis; overflow: hidden; white-space: nowrap;"><%= lead.name %></div>
                <div style="font-size:10px; color:var(--text-sub); margin-top:2px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                  📞 <%= lead.phone %> &nbsp;·&nbsp; <span style="color:var(--red); font-weight:600;"><%= new Date(lead.nextFollowUpAt).toLocaleDateString('en-IN') %></span>
                </div>
              </div>
              <a href="/counsellor/leads/<%= lead._id %>" class="btn btn-ghost btn-xs" style="flex-shrink: 0;">Open</a>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Scheduled Today Tab -->
    <div id="today-tab" class="task-tab-content" style="display: none;">
      <% if (todayCallbacks.length === 0) { %>
        <div class="empty-state" style="padding: 1.5rem 1rem;">
          <p style="font-size: 0.78rem; color: var(--text-muted);">No callbacks scheduled for today.</p>
        </div>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:0.5rem; max-height: 250px; overflow-y: auto;">
          <% todayCallbacks.forEach(lead => { %>
            <div style="display:flex; align-items:center; justify-content:space-between; padding:8px; border:1px solid var(--border); border-radius:var(--radius); background:var(--bg-input);">
              <div style="flex: 1; min-width: 0; margin-right: 8px;">
                <div style="font-size:12px; font-weight:600; color:var(--text); text-overflow: ellipsis; overflow: hidden; white-space: nowrap;"><%= lead.name %></div>
                <div style="font-size:10px; color:var(--text-sub); margin-top:2px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                  📞 <%= lead.phone %> &nbsp;·&nbsp; <span style="color:var(--gold); font-weight:600;"><%= lead.nextFollowUpAt ? new Date(lead.nextFollowUpAt).toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'}) : 'Today' %></span>
                </div>
              </div>
              <a href="/counsellor/leads/<%= lead._id %>" class="btn btn-ghost btn-xs" style="flex-shrink: 0;">Open</a>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- Student Fee Dues Tab -->
    <div id="fees-tab" class="task-tab-content" style="display: none;">
      <% if (feeCallbacks.length === 0) { %>
        <div class="empty-state" style="padding: 1.5rem 1rem;">
          <p style="font-size: 0.78rem; color: var(--text-muted);">🎉 All students are clear on fees!</p>
        </div>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:0.5rem; max-height: 250px; overflow-y: auto;">
          <% feeCallbacks.forEach(fee => { %>
            <div style="display:flex; align-items:center; justify-content:space-between; padding:8px; border:1px solid var(--border); border-radius:var(--radius); background:var(--bg-input);">
              <div style="flex: 1; min-width: 0; margin-right: 8px;">
                <div style="font-size:12px; font-weight:600; color:var(--text); text-overflow: ellipsis; overflow: hidden; white-space: nowrap;"><%= fee.student ? fee.student.name : 'Student' %></div>
                <div style="font-size:10px; color:var(--text-sub); margin-top:2px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                  📞 <%= fee.student ? fee.student.phone : '' %> &nbsp;·&nbsp; Due: <span style="color:var(--orange); font-weight:600;">₹<%= Math.max(0, fee.totalAmount - (fee.discount || 0) - fee.paidAmount) %></span>
                </div>
              </div>
              <span class="badge badge-orange" style="font-size: 9px; flex-shrink: 0;">Remind</span>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>

</div>

<script>
  function switchTaskTab(tabId) {
    document.querySelectorAll('.task-tab-content').forEach(el => el.style.display = 'none');
    document.getElementById(tabId).style.display = 'block';
    
    document.getElementById('overdue-tab-btn').classList.remove('active-tab-btn');
    document.getElementById('today-tab-btn').classList.remove('active-tab-btn');
    document.getElementById('fees-tab-btn').classList.remove('active-tab-btn');
    
    document.getElementById(tabId + '-btn').classList.add('active-tab-btn');
  }
</script>
<style>
  .active-tab-btn {
    background: var(--gold-dim) !important;
    border: 1px solid var(--gold-border) !important;
    color: var(--gold) !important;
  }
</style>

<!-- Recent Leads -->
<div class="card" style="margin-top:1.25rem;">
  <div class="card-header">
    <div class="card-title">Recent Leads</div>
    <a href="/counsellor/leads/new" class="btn btn-primary btn-sm">+ Add Lead</a>
  </div>

  <% if (recentLeads.length === 0) { %>
    <div class="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      <p>No leads yet. Start adding prospects.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Course</th>
            <th>Source</th>
            <th>Status</th>
            <th>Follow-up</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% recentLeads.forEach(lead => { %>
            <tr data-row-href="/counsellor/leads/<%= lead._id %>">
              <td><strong><%= lead.name %></strong></td>
              <td class="td-mono"><%= lead.phone %></td>
              <td><span class="badge badge-orange"><%= lead.interestedCourse ? lead.interestedCourse.name : 'Undecided' %></span></td>
              <td class="td-muted"><%= lead.source %></td>
              <td>
                <%
                  const statusBadge = {
                    new: 'badge-orange',
                    contacted: 'badge-blue',
                    mentorship_scheduled: 'badge-blue',
                    mentorship_attended: 'badge-yellow',
                    follow_up: 'badge-yellow',
                    joining_interested: 'badge-gold',
                    admission_completed: 'badge-green',
                    lost: 'badge-red'
                  }[lead.status] || 'badge-grey';
                %>
                <span class="badge <%= statusBadge %>"><%= lead.status %></span>
              </td>
              <td class="td-mono td-muted">
                <%= lead.nextFollowUpAt ? new Date(lead.nextFollowUpAt).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) : '—' %>
              </td>
              <td>
                <a href="/counsellor/leads/<%= lead._id %>" class="btn btn-ghost btn-xs">View</a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<!-- Lead Source Quality Analytics -->
<div class="card" style="margin-top:1.25rem;">
  <div class="card-header card-header--divided">
    <div>
      <div class="card-title">CRM Analytics: Lead Source Performance</div>
      <div class="card-sub">Conversion rates and velocity metrics per channel</div>
    </div>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Lead Source</th>
          <th>Total Leads</th>
          <th>Converted</th>
          <th>Conversion Rate</th>
          <th>Avg. Conversion Speed</th>
        </tr>
      </thead>
      <tbody>
        <% Object.entries(sourceStats).forEach(([source, data]) => { %>
          <tr>
            <td><strong><%= source %></strong></td>
            <td class="td-mono"><%= data.total %></td>
            <td class="td-mono"><%= data.converted %></td>
            <td>
              <div style="display:flex; align-items:center; gap:8px;">
                <span class="badge <%= data.convRate >= 50 ? 'badge-green' : data.convRate >= 20 ? 'badge-gold' : 'badge-orange' %>" style="min-width:40px; text-align:center;"><%= data.convRate %>%</span>
                <div class="progress-bar" style="width: 60px; height: 6px; margin: 0;">
                  <div class="progress-fill <%= data.convRate >= 50 ? 'green' : data.convRate >= 20 ? '' : 'orange' %>" style="width:<%= data.convRate %>%"></div>
                </div>
              </div>
            </td>
            <td class="td-muted td-mono">
              <% if (data.converted > 0) { %>
                <%= data.avgDays %> <%= data.avgDays === 1 ? 'day' : 'days' %>
              <% } else { %>
                —
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<script>
  function initDashboardRecentLeadRowClicks() {
    document.querySelectorAll('[data-row-href]').forEach(row => {
      if (row.dataset.rowReady) return;
      const open = event => {
        if (event.target.closest('a, button, input, select, textarea, form, label')) return;
        if (window.AppSoftNav && typeof window.AppSoftNav.navigateTo === 'function') {
          window.AppSoftNav.navigateTo(row.dataset.rowHref);
        } else {
          window.location.href = row.dataset.rowHref;
        }
      };
      row.addEventListener('click', open);
      row.dataset.rowReady = 'true';
      row.style.cursor = 'pointer';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDashboardRecentLeadRowClicks);
  } else {
    initDashboardRecentLeadRowClicks();
  }

  document.addEventListener('softnav:load', initDashboardRecentLeadRowClicks);
</script>

